{% extends 'base.html.twig' %}
{% block title %}Activar doble factor — Grova{% endblock %}

{% block stylesheets %}
<style>
    body { background:#0b1020; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:16px; }
    .card-auth { width:100%; max-width:480px; background:#111827; border:1px solid #1f2937; border-radius:12px; padding:40px 36px; }
    .logo-box { width:40px; height:40px; background:#2563eb; border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:700; color:#fff; font-size:1.1rem; }
    h1 { color:#f1f5f9; font-size:1.35rem; font-weight:700; margin:0; }
    .step { display:flex; gap:.75rem; margin-bottom:1.25rem; align-items:flex-start; }
    .step-num { flex-shrink:0; width:24px; height:24px; border-radius:50%; background:#2563eb; color:#fff; font-size:.78rem; font-weight:700; display:flex; align-items:center; justify-content:center; margin-top:1px; }
    .step-text { color:#cbd5e1; font-size:.88rem; line-height:1.55; }
    .qr-box { background:#fff; border-radius:12px; padding:12px; display:inline-block; margin:0 auto 1.5rem; display:flex; justify-content:center; }
    .secret-box { background:#0f172a; border:1px solid #1f2937; border-radius:8px; padding:10px 14px; font-family:monospace; font-size:.9rem; color:#93c5fd; letter-spacing:.12em; text-align:center; margin-bottom:1.5rem; word-break:break-all; }
    .form-label { color:#cbd5e1; font-size:.88rem; font-weight:600; margin-bottom:.4rem; }
    .form-control { background:#0f172a; border-color:#1f2937; border-radius:8px; color:#f1f5f9; font-size:1.4rem; letter-spacing:.3rem; text-align:center; }
    .form-control:focus { background:#0f172a; border-color:#2563eb; color:#f1f5f9; box-shadow:0 0 0 3px rgba(37,99,235,.2); }
    .btn-grova { background:#2563eb; border:none; border-radius:8px; font-weight:600; padding:.75rem; width:100%; color:#fff; transition:background .2s; }
    .btn-grova:hover { background:#1e40af; }
    .back-link { display:block; text-align:center; margin-top:20px; color:#93c5fd; font-size:.85rem; text-decoration:none; }
    .back-link:hover { text-decoration:underline; }
</style>
{% endblock %}

{% block body %}
<div class="card-auth">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="logo-box">G</div>
        <h1>Activar doble factor (2FA)</h1>
    </div>

    {% for msg in app.flashes('error') %}
    <div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#fca5a5;border-radius:8px;font-size:.88rem;padding:.75rem 1rem;margin-bottom:1rem;">
        <i class="bi bi-exclamation-triangle me-2"></i>{{ msg }}
    </div>
    {% endfor %}

    <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">Instala <strong style="color:#f1f5f9;">Google Authenticator</strong>, <strong style="color:#f1f5f9;">Authy</strong> o <strong style="color:#f1f5f9;">1Password</strong> en tu teléfono.</div>
    </div>

    <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">Escanea el código QR con la app.</div>
    </div>

    <div class="qr-box">
        <img src="{{ qr_data_uri }}" alt="QR Code 2FA" width="200" height="200">
    </div>

    <div class="step">
        <div class="step-num">3</div>
        <div class="step-text">Si no puedes escanear el QR, ingresa esta clave manualmente en tu app:</div>
    </div>

    <div class="secret-box">{{ secreto }}</div>

    <div class="step">
        <div class="step-num">4</div>
        <div class="step-text">Ingresa el código de 6 dígitos que muestra la app para confirmar que todo está bien.</div>
    </div>

    <form method="post" action="{{ path('2fa_activar') }}" autocomplete="off">
        <input type="hidden" name="_token" value="{{ csrf_token('2fa_activar') }}">

        <div class="mb-4">
            <label class="form-label" for="codigo">Código de verificación</label>
            <input type="text" id="codigo" name="codigo"
                   class="form-control"
                   placeholder="000000"
                   maxlength="6"
                   inputmode="numeric"
                   pattern="[0-9]{6}"
                   required autofocus>
        </div>

        <button type="submit" class="btn-grova">
            <i class="bi bi-shield-check me-2"></i>Activar doble factor
        </button>
    </form>

    <a href="{{ path('grova_profile') }}" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>Cancelar
    </a>
</div>
{% endblock %}
