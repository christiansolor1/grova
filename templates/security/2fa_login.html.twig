{% extends 'base.html.twig' %}
{% block title %}Verificación en dos pasos — Grova{% endblock %}

{% block stylesheets %}
<style>
    body { background:#0b1020; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:16px; }
    .card-auth { width:100%; max-width:440px; background:#111827; border:1px solid #1f2937; border-radius:12px; padding:40px 36px; }
    .logo-box { width:40px; height:40px; background:#2563eb; border-radius:8px; display:flex; align-items:center; justify-content:center; font-weight:700; color:#fff; font-size:1.1rem; }
    h1 { color:#f1f5f9; font-size:1.35rem; font-weight:700; margin:0; }
    .form-label { color:#cbd5e1; font-size:.88rem; font-weight:600; margin-bottom:.4rem; }
    .form-control { background:#0f172a; border-color:#1f2937; border-radius:8px; color:#f1f5f9; font-size:1.4rem; letter-spacing:.3rem; text-align:center; }
    .form-control:focus { background:#0f172a; border-color:#2563eb; color:#f1f5f9; box-shadow:0 0 0 3px rgba(37,99,235,.2); }
    .btn-grova { background:#2563eb; border:none; border-radius:8px; font-weight:600; padding:.75rem; width:100%; color:#fff; transition:background .2s; font-size:.95rem; }
    .btn-grova:hover { background:#1e40af; }
    .btn-bio { background:#0f172a; border:1px solid #1f2937; border-radius:8px; font-weight:600; padding:.75rem; width:100%; color:#f1f5f9; transition:all .2s; font-size:.95rem; cursor:pointer; }
    .btn-bio:hover { border-color:#2563eb; color:#93c5fd; }
    .divider { display:flex; align-items:center; gap:.75rem; margin:1.25rem 0; color:#374151; font-size:.8rem; }
    .divider::before, .divider::after { content:''; flex:1; border-top:1px solid #1f2937; }
    .alert-error { background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.3); color:#fca5a5; border-radius:8px; font-size:.88rem; padding:.75rem 1rem; margin-bottom:1rem; }
    .bio-status { font-size:.82rem; color:#64748b; text-align:center; margin-top:.5rem; min-height:1.2rem; }
    .back-link { display:block; text-align:center; margin-top:20px; color:#93c5fd; font-size:.85rem; text-decoration:none; }
    .back-link:hover { text-decoration:underline; }
    .shield-icon { font-size:2rem; color:#2563eb; }
</style>
{% endblock %}

{% block body %}
<div class="card-auth">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="logo-box">G</div>
        <h1>Verificación en dos pasos</h1>
    </div>

    <div class="text-center mb-3">
        <i class="bi bi-shield-lock-fill shield-icon"></i>
    </div>

    {% if authenticationError %}
    <div class="alert-error">
        <i class="bi bi-exclamation-triangle me-2"></i>Código incorrecto o expirado. Inténtalo de nuevo.
    </div>
    {% endif %}

    {% set mensajes = app.flashes('danger')|merge(app.flashes('error')) %}
    {% for message in mensajes %}
    <div class="alert-error" style="margin-bottom:1rem;">
        <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
    </div>
    {% endfor %}

    {# ── Biométrico (si está disponible) ── #}
    {% if tiene_biometrico %}
    <button type="button" class="btn-bio mb-2" id="btn-bio">
        <i class="bi bi-fingerprint me-2"></i>Usar huella / Face ID
    </button>
    <div class="bio-status" id="bio-status"></div>

    {# Form oculto que se envía con el token WebAuthn #}
    <form id="form-wa" method="post" action="{{ path('2fa_login_check') }}" style="display:none;">
        <input type="hidden" name="_auth_code" id="wa_code">
    </form>
    {% endif %}

    {# ── Divisor si hay ambas opciones ── #}
    {% if tiene_biometrico and tiene_totp %}
    <div class="divider">o ingresa el código</div>
    {% endif %}

    {# ── TOTP (si está disponible) ── #}
    {% if tiene_totp %}
    <form method="post" action="{{ path('2fa_login_check') }}" autocomplete="off">
        <div class="mb-4">
            <label class="form-label" for="_auth_code">
                Código de 6 dígitos <span style="color:#64748b;font-size:.8rem;">(Google Authenticator, Authy…)</span>
            </label>
            <input type="text" id="_auth_code" name="_auth_code"
                   class="form-control"
                   placeholder="000000"
                   maxlength="6"
                   inputmode="numeric"
                   pattern="[0-9]{6}"
                   required autofocus>
        </div>

        <button type="submit" class="btn-grova">
            <i class="bi bi-shield-check me-2"></i>Verificar código
        </button>
    </form>
    {% endif %}

    {# ── Divisor si hay PIN y otra opción ── #}
    {% if tiene_pin and (tiene_biometrico or tiene_totp) %}
    <div class="divider">o usa tu PIN</div>
    {% endif %}

    {# ── PIN (fallback) ── #}
    {% if tiene_pin %}
    <form method="post" action="{{ path('2fa_login_check') }}" autocomplete="off">
        <div class="mb-4">
            <label class="form-label" for="_auth_code_pin">
                <i class="bi bi-lock me-1"></i>PIN de seguridad
                <span style="color:#64748b;font-size:.8rem;">(4-8 dígitos)</span>
            </label>
            <input type="password" id="_auth_code_pin" name="_auth_code"
                   class="form-control"
                   placeholder="&bull;&bull;&bull;&bull;&bull;&bull;"
                   maxlength="8"
                   inputmode="numeric"
                   pattern="[0-9]{4,8}"
                   required
                   {% if not tiene_totp and not tiene_biometrico %}autofocus{% endif %}>
        </div>
        <button type="submit" class="btn-grova">
            <i class="bi bi-unlock me-2"></i>Ingresar con PIN
        </button>
    </form>
    {% endif %}

    {# ── Divisor si hay email y otra opción ── #}
    {% if tiene_email and (tiene_biometrico or tiene_totp or tiene_pin) %}
    <div class="divider">o código por email</div>
    {% endif %}

    {# ── Código por email (se envía automático al cargar) ── #}
    {% if tiene_email %}
    <div class="bio-status" id="email-status" style="color:#94a3b8;text-align:center;margin-bottom:.75rem;">
        Enviando código a tu email…
    </div>
    <form method="post" action="{{ path('2fa_login_check') }}" id="form-email" style="display:none;">
        <div class="mb-4">
            <label class="form-label" for="_auth_code_email">
                Código de 6 dígitos recibido por email
            </label>
            <input type="text" id="_auth_code_email" name="_auth_code"
                   class="form-control"
                   placeholder="000000"
                   maxlength="6"
                   inputmode="numeric"
                   pattern="[0-9]{6}"
                   autocomplete="one-time-code">
        </div>
    </form>
    {% endif %}

    {% if not tiene_biometrico and not tiene_totp and not tiene_pin and not tiene_email %}
    <p style="color:#fca5a5;font-size:.88rem;text-align:center;margin-top:.75rem;">
        No tienes ningún método de verificación configurado. Contacta al administrador.
    </p>
    {% endif %}

    <a href="{{ path('logout') }}" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>Volver al login
    </a>
</div>

{% if tiene_totp %}
<script>
    document.getElementById('_auth_code')?.addEventListener('input', function () {
        if (this.value.replace(/\D/g, '').length === 6) {
            this.closest('form').submit();
        }
    });
</script>
{% endif %}

{% if tiene_email %}
<script>
// Auto-enviar código al cargar la página
(function() {
    var status = document.getElementById('email-status');
    fetch('{{ path("2fa_enviar_codigo_email") }}', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                status.style.color = '#22c55e';
                status.textContent = 'Código enviado a tu email';
                document.getElementById('form-email').style.display = '';
                document.getElementById('_auth_code_email').focus();
            } else {
                throw new Error(data.error || 'Error');
            }
        })
        .catch(function() {
            status.style.color = '#fca5a5';
            status.textContent = 'No se pudo enviar el código. Recarga la página.';
        });
})();

// Auto-enviar al escribir 6 dígitos
document.getElementById('_auth_code_email')?.addEventListener('input', function () {
    if (this.value.replace(/\D/g, '').length === 6) {
        this.closest('form').submit();
    }
});
</script>
{% endif %}

{% if tiene_biometrico %}
<script>
function b64url(buf) {
    return btoa(String.fromCharCode(...new Uint8Array(buf)))
        .replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
}
function fromB64(s) {
    s = s.replace(/-/g,'+').replace(/_/g,'/');
    while (s.length % 4) s += '=';
    return Uint8Array.from(atob(s), c => c.charCodeAt(0));
}

const btnBio   = document.getElementById('btn-bio');
const bioStatus = document.getElementById('bio-status');
const formWa   = document.getElementById('form-wa');
const waCode   = document.getElementById('wa_code');

btnBio.addEventListener('click', async () => {
    btnBio.disabled = true;
    bioStatus.style.color = '#94a3b8';
    bioStatus.textContent = 'Iniciando…';

    try {
        const challengeRes = await fetch('{{ path("2fa_webauthn_challenge") }}');
        const args = await challengeRes.json();
        if (args.error) throw new Error(args.error);

        args.publicKey.challenge = fromB64(args.publicKey.challenge);
        args.publicKey.allowCredentials = (args.publicKey.allowCredentials || []).map(c => ({
            ...c, id: fromB64(c.id)
        }));

        bioStatus.textContent = 'Coloca tu dedo / activa Face ID…';
        const cred = await navigator.credentials.get({ publicKey: args.publicKey });

        const payload = {
            id:                b64url(cred.rawId),
            clientDataJSON:    b64url(cred.response.clientDataJSON),
            authenticatorData: b64url(cred.response.authenticatorData),
            signature:         b64url(cred.response.signature),
        };

        const verifyRes = await fetch('{{ path("2fa_webauthn_verify") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const verifyData = await verifyRes.json();

        if (!verifyData.token) throw new Error(verifyData.error || 'Error de verificación');

        bioStatus.style.color = '#22c55e';
        bioStatus.textContent = '¡Verificado!';
        waCode.value = verifyData.token;
        formWa.submit();

    } catch (e) {
        bioStatus.style.color = '#fca5a5';
        bioStatus.textContent = e.name === 'NotAllowedError' ? 'Cancelado' : (e.message || 'Error');
        btnBio.disabled = false;
    }
});
</script>
{% endif %}
{% endblock %}
