{% extends 'base.html.twig' %}

{% block title %}Grova – Instalación inicial{% endblock %}

{% block stylesheets %}
<style>
    body {
        background: #0b1020;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 16px;
    }
    .setup-wrapper { width: 100%; max-width: 640px; }
    .setup-card {
        background: #111827;
        border: 1px solid #1f2937;
        border-radius: 12px;
        overflow: hidden;
    }
    .setup-header {
        padding: 1.5rem 1.75rem 1rem;
        border-bottom: 1px solid #1f2937;
    }
    .setup-logo-box {
        width: 44px; height: 44px;
        background: #2563eb;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: #fff; font-size: 1.15rem;
    }
    .setup-title { color: #f1f5f9; font-weight: 700; font-size: 1.55rem; letter-spacing: -0.3px; }
    .setup-subtitle { color: #9ca3af; font-size: .92rem; margin-top: .15rem; }
    .setup-body { padding: 1.5rem 1.75rem 1.75rem; }
    .setup-section {
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #1f2937;
    }
    .setup-section:last-of-type { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .setup-section-title {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #6366f1;
        margin-bottom: 1rem;
    }
    .form-label { color: #cbd5e1; font-size: .88rem; font-weight: 600; margin-bottom: .4rem; }
    .form-control, .input-group-text {
        background: #0f172a;
        border-color: #1f2937;
        color: #f1f5f9;
        border-radius: 8px;
    }
    .form-control:focus {
        background: #0f172a;
        border-color: #2563eb;
        color: #f1f5f9;
        box-shadow: 0 0 0 3px rgba(37,99,235,.2);
    }
    .form-control::placeholder { color: #64748b; }
    .form-text { color: #64748b; font-size: .78rem; }
    .input-group-text { color: #64748b; }
    .is-invalid { border-color: #ef4444 !important; }
    .invalid-feedback { color: #fca5a5; font-size: .8rem; }
    .alert-install-error {
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.3);
        color: #fca5a5;
        border-radius: 8px;
        font-size: .85rem;
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 200px;
        overflow-y: auto;
    }
    .btn-grova {
        background: #2563eb;
        border: none;
        font-weight: 600;
        padding: .85rem;
        font-size: .98rem;
        border-radius: 8px;
        transition: background .2s;
    }
    .btn-grova:hover { background: #1d4ed8; }
    .btn-grova:disabled { background: #1e40af; opacity: .7; }
    .setup-steps { display: flex; gap: .5rem; margin-top: 1rem; }
    .setup-step { flex: 1; height: 3px; border-radius: 2px; background: #1f2937; }
    .setup-step.active { background: #2563eb; }
</style>
{% endblock %}

{% block body %}
{% set f = form|default({}) %}
<div class="setup-wrapper">
    <div class="setup-card shadow-lg">
        <div class="setup-header">
            <div class="d-flex align-items-center gap-3">
                <div class="setup-logo-box">G</div>
                <div>
                    <div class="setup-title">Instalar Grova</div>
                    <div class="setup-subtitle">Configura la base de datos y tu cuenta de administrador para empezar.</div>
                </div>
            </div>
            <div class="setup-steps" aria-hidden="true">
                <div class="setup-step active"></div>
                <div class="setup-step active"></div>
                <div class="setup-step active"></div>
            </div>
        </div>

        <div class="setup-body">
            {% if errors.install is defined %}
                <div class="alert alert-install-error mb-4 px-3 py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i>{{ errors.install }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_setup_install') }}" id="setup-form" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('grova_setup') }}">

                <div class="setup-section">
                    <div class="setup-section-title"><i class="bi bi-database me-1"></i> Base de datos</div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label for="db_host" class="form-label">Host</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-hdd-network"></i></span>
                                <input type="text" class="form-control{% if errors.db_host is defined %} is-invalid{% endif %}"
                                       id="db_host" name="db_host" value="{{ f.db_host|default('127.0.0.1') }}"
                                       placeholder="127.0.0.1" required>
                            </div>
                            {% if errors.db_host is defined %}<div class="invalid-feedback d-block">{{ errors.db_host }}</div>{% endif %}
                        </div>
                        <div class="col-md-4">
                            <label for="db_port" class="form-label">Puerto</label>
                            <input type="number" class="form-control" id="db_port" name="db_port"
                                   value="{{ f.db_port|default('3306') }}" min="1" max="65535">
                        </div>
                        <div class="col-12">
                            <label for="db_name" class="form-label">Nombre de la base de datos</label>
                            <input type="text" class="form-control{% if errors.db_name is defined %} is-invalid{% endif %}"
                                   id="db_name" name="db_name" value="{{ f.db_name|default('grova') }}"
                                   placeholder="grova" required pattern="[a-zA-Z0-9_]+">
                            <div class="form-text">Recomendado: <code>grova</code> (compatible con las migraciones del proyecto).</div>
                            {% if errors.db_name is defined %}<div class="invalid-feedback d-block">{{ errors.db_name }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label for="db_user" class="form-label">Usuario</label>
                            <input type="text" class="form-control{% if errors.db_user is defined %} is-invalid{% endif %}"
                                   id="db_user" name="db_user" value="{{ f.db_user|default('') }}"
                                   autocomplete="off" required>
                            {% if errors.db_user is defined %}<div class="invalid-feedback d-block">{{ errors.db_user }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label for="db_password" class="form-label">Contraseña</label>
                            <input type="password" class="form-control{% if errors.db_password is defined %} is-invalid{% endif %}"
                                   id="db_password" name="db_password" required
                                   autocomplete="new-password" placeholder="grova">
                            {% if errors.db_password is defined %}<div class="invalid-feedback d-block">{{ errors.db_password }}</div>{% endif %}
                        </div>
                    </div>
                </div>

                <div class="setup-section">
                    <div class="setup-section-title"><i class="bi bi-shield-lock me-1"></i> Superusuario</div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="admin_email" class="form-label">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control{% if errors.admin_email is defined %} is-invalid{% endif %}"
                                       id="admin_email" name="admin_email" value="{{ f.admin_email|default('') }}"
                                       placeholder="admin@tuempresa.com" required autocomplete="email">
                            </div>
                            {% if errors.admin_email is defined %}<div class="invalid-feedback d-block">{{ errors.admin_email }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label for="admin_password" class="form-label">Contraseña</label>
                            <input type="password" class="form-control{% if errors.admin_password is defined %} is-invalid{% endif %}"
                                   id="admin_password" name="admin_password" required minlength="8"
                                   autocomplete="new-password" placeholder="Mínimo 8 caracteres">
                            {% if errors.admin_password is defined %}<div class="invalid-feedback d-block">{{ errors.admin_password }}</div>{% endif %}
                        </div>
                        <div class="col-md-6">
                            <label for="admin_password_confirm" class="form-label">Confirmar contraseña</label>
                            <input type="password" class="form-control{% if errors.admin_password_confirm is defined %} is-invalid{% endif %}"
                                   id="admin_password_confirm" name="admin_password_confirm" required
                                   autocomplete="new-password">
                            {% if errors.admin_password_confirm is defined %}<div class="invalid-feedback d-block">{{ errors.admin_password_confirm }}</div>{% endif %}
                        </div>
                    </div>
                </div>

                <div class="setup-section">
                    <div class="setup-section-title"><i class="bi bi-building me-1"></i> Empresa / workspace</div>
                    <div class="mb-0">
                        <label for="workspace_name" class="form-label">Nombre</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-briefcase"></i></span>
                            <input type="text" class="form-control{% if errors.workspace_name is defined %} is-invalid{% endif %}"
                                   id="workspace_name" name="workspace_name" value="{{ f.workspace_name|default('') }}"
                                   placeholder="Mi Empresa S.A." required>
                        </div>
                        {% if errors.workspace_name is defined %}<div class="invalid-feedback d-block">{{ errors.workspace_name }}</div>{% endif %}
                    </div>
                </div>

                <button type="submit" class="btn btn-grova btn-primary w-100 mt-2" id="btn-install">
                    <span id="btn-text"><i class="bi bi-rocket-takeoff me-2"></i>Instalar Grova</span>
                    <span id="btn-spinner" class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('setup-form').addEventListener('submit', function () {
    const btn = document.getElementById('btn-install');
    const text = document.getElementById('btn-text');
    const spinner = document.getElementById('btn-spinner');
    btn.disabled = true;
    text.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Instalando… esto puede tardar un minuto';
    spinner.classList.remove('d-none');
});
</script>
{% endblock %}
