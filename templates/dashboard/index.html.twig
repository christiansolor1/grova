};

function slugifyMenuId(input) {
    return String(input || '')
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
}

function getCustomNavItems() {
    try {
        const parsed = JSON.parse(localStorage.getItem(CUSTOM_NAV_KEY) || '[]');
        if (!Array.isArray(parsed)) return [];
        return parsed
            .filter((item) => item && item.id && item.label)
            .map((item) => ({
                id: slugifyMenuId(item.id),
                label: String(item.label),
                icon: item.icon && IC[item.icon] ? item.icon : 'list',
                custom: true,
            }));
    } catch {
        return [];
    }
}

function saveCustomNavItems(items) {
    localStorage.setItem(CUSTOM_NAV_KEY, JSON.stringify(items));
}

function rebuildNavFromStorage() {
    const customItems = getCustomNavItems();
    NAV = [...NAV_BASE, ...customItems];
}

