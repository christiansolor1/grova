                <button type="button" class="btn btn-sm btn-success swal-demo-btn" data-swal-demo="async">Confirmacion async</button>
                <button type="button" class="btn btn-sm btn-outline-success swal-demo-btn" data-swal-demo="toast">Toast notificacion</button>
                <button type="button" class="btn btn-sm btn-outline-success swal-demo-btn" data-swal-demo="toastActions">Toast con acciones</button>
                <button type="button" class="btn btn-sm btn-outline-warning swal-demo-btn" data-swal-demo="timer">Auto close con timer</button>
                <button type="button" class="btn btn-sm btn-outline-warning swal-demo-btn" data-swal-demo="loader">Loader bloqueante</button>
