function toggleLangCombo(id, e) {
    e.stopPropagation();
    const combo = document.getElementById('lang-combo-' + id);
    const isOpen = combo.classList.contains('open');
    // close all combos first
    document.querySelectorAll('.lang-combo.open').forEach(el => el.classList.remove('open'));
    if (!isOpen) combo.classList.add('open');
}
