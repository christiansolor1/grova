    document.querySelectorAll('.lang-combo.open').forEach(el => el.classList.remove('open'));
});

// ── Helpers ───────────────────────────────────────────────────────────────
function isDescendant(node, id) {
    if (node.id === id) return true;
    for (const c of node.children || []) {
        if (c.id === id) return true;
        for (const g of c.children || []) {
            if (g.id === id) return true;
        }
    }
    return false;
}

function findNode(id) {
    for (const n of NAV) {
        if (n.id === id) return { node: n, l1: n, l2: null, l3: null };
        for (const c of n.children || []) {
            if (c.id === id) return { node: c, l1: n, l2: c, l3: null };
            for (const g of c.children || []) {
                if (g.id === id) return { node: g, l1: n, l2: c, l3: g };
            }
        }
    }
    return null;
}

function buildBreadcrumb(id) {
    const crumbs = [{ label: t('breadcrumb.home'), id: 'home', href: WORKSPACE_HOME_URL }];
    for (const n of NAV) {
        if (n.id === id) {
            crumbs.push({ label: n.label, id: n.id, href: n.href || null });
            return crumbs;
        }
        for (const c of n.children || []) {
            if (c.id === id) {
                crumbs.push({ label: n.label, id: n.id, href: n.href || null }, { label: c.label, id: c.id, href: c.href || null });
                return crumbs;
            }
            for (const g of c.children || []) {
                if (g.id === id) {
                    crumbs.push(
                        { label: n.label, id: n.id, href: n.href || null },
                        { label: c.label, id: c.id, href: c.href || null },
                        { label: g.label, id: g.id, href: g.href || null },
                    );
                    return crumbs;
                }
            }
        }
    }
    return crumbs;
}

// ── Render nav ────────────────────────────────────────────────────────────
function renderNav(query = '') {
    const navEl = document.getElementById('sidebar-nav');
    const q = query.toLowerCase();

    const filtered = NAV.filter(n => {
        if (!q) return true;
        return n.label.toLowerCase().includes(q)
            || (n.children || []).some(c => c.label.toLowerCase().includes(q)
                || (c.children || []).some(g => g.label.toLowerCase().includes(q)));
    });

    navEl.innerHTML = filtered.map(n => {
        const hasL2 = !!(n.children && n.children.length);
        const l1Active = isDescendant(n, activeId);
        const l1Open = exp1[n.id] || (q && hasL2);
        const isLeaf = !hasL2;

        let l2Html = '';
        if (hasL2 && l1Open) {
            l2Html = `<div class="nav-l2-wrap">` + n.children.map(c => {
                const hasL3 = !!(c.children && c.children.length);
                const l2Active = activeId === c.id || (c.children || []).some(g => g.id === activeId);
                const l2Open = exp2[c.id] || (q && hasL3);
                const isL2Leaf = !hasL3;
                const l2Cls = l2Active && isL2Leaf ? 'active-leaf' : l2Active ? 'active' : '';

                let l3Html = '';
                if (hasL3 && l2Open) {
                    l3Html = `<div class="nav-l3-wrap">` + c.children.map(g => {
                        const l3Cls = activeId === g.id ? 'active' : '';
                        if (g.href) {
                            return `<a class="nav-l3-btn ${l3Cls}" href="${g.href}">
                            <span class="nav-icon">${svg(IC[g.icon] || IC.check, 11)}</span>
                            <span>${g.label}</span>
                        </a>`;
                        }
                        return `<button type="button" class="nav-l3-btn ${l3Cls}" data-id="${g.id}">
                            <span class="nav-icon">${svg(IC[g.icon] || IC.check, 11)}</span>
                            <span>${g.label}</span>
                        </button>`;
                    }).join('') + `</div>`;
                }

                const l2TagOpen = (!hasL3 && c.href)
                    ? `<a class="nav-l2-btn ${l2Cls} ${l2Open && hasL3 ? 'open' : ''}" href="${c.href}">`
                    : `<button type="button" class="nav-l2-btn ${l2Cls} ${l2Open && hasL3 ? 'open' : ''}" data-id="${c.id}" data-has-l3="${hasL3}">`;
                const l2TagClose = (!hasL3 && c.href) ? `</a>` : `</button>`;

                return `<div>
                    ${l2TagOpen}
                        <span class="nav-icon">${svg(IC[c.icon] || IC.list, 13)}</span>
                        <span class="flex-1">${c.label}</span>
                        ${hasL3 ? `<span class="nav-chevron">${svg(IC.chevDown, 11)}</span>` : ''}
                    ${l2TagClose}
                    ${l3Html}
                </div>`;
            }).join('') + `</div>`;
        }

        const l1Cls = l1Active && isLeaf ? 'active-leaf' : l1Active ? 'active' : '';
        const l1TagOpen = (isLeaf && n.href)
            ? `<a class="nav-l1-btn ${l1Cls} ${l1Open ? 'open' : ''}" href="${n.href}" title="${n.label}">`
            : `<button type="button" class="nav-l1-btn ${l1Cls} ${l1Open ? 'open' : ''}" data-id="${n.id}" data-has-l2="${hasL2}" title="${n.label}">`;
        const l1TagClose = (isLeaf && n.href) ? `</a>` : `</button>`;
        return `<div class="nav-l1">
            ${l1TagOpen}
                <span class="nav-icon">${svg(IC[n.icon] || IC.dashboard, 15)}</span>
                <span class="nav-label">${n.label}</span>
                ${hasL2 ? `<span class="nav-chevron">${svg(IC.chevDown, 12)}</span>` : ''}
            ${l1TagClose}
            ${l2Html}
        </div>`;
    }).join('');

    // Bind clicks
    navEl.querySelectorAll('.nav-l1-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            const hasL2 = btn.dataset.hasL2 === 'true';
            if (!hasL2) {
                setActive(id);
            } else {
                exp1[id] = !exp1[id];
                localStorage.setItem('grova_exp1', JSON.stringify(exp1));
                renderNav(document.getElementById('nav-search').value);
            }
        });
    });
    navEl.querySelectorAll('.nav-l2-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            const hasL3 = btn.dataset.hasL3 === 'true';
            if (!hasL3) {
                setActive(id);
            } else {
                exp2[id] = !exp2[id];
                localStorage.setItem('grova_exp2', JSON.stringify(exp2));
                renderNav(document.getElementById('nav-search').value);
            }
        });
    });
    navEl.querySelectorAll('.nav-l3-btn').forEach(btn => {
        btn.addEventListener('click', () => setActive(btn.dataset.id));
    });
}

function setActive(id) {
    activeId = id;
    localStorage.setItem('grova_active', id);

    // auto-expand parents
    const found = findNode(id);
    if (found && found.l1) exp1[found.l1.id] = true;
    if (found && found.l2) exp2[found.l2.id] = true;
    localStorage.setItem('grova_exp1', JSON.stringify(exp1));
    localStorage.setItem('grova_exp2', JSON.stringify(exp2));

    renderNav(document.getElementById('nav-search').value);
    renderBreadcrumb();
    renderPageHeader(id);
    renderDynamicSections(id);
}

function renderBreadcrumb() {
    const crumbs = buildBreadcrumb(activeId);
    const el = document.getElementById('breadcrumb');
    el.innerHTML = crumbs.map((c, i) => {
        const isLast = i === crumbs.length - 1;
        const sep = i > 0 ? `<span class="sep">${svg(IC.slash, 11)}</span>` : '';
        if (i === 0) {
            return `${sep}<a href="${c.href}" class="breadcrumb-home" title="Inicio">${svg(IC.home, 13)}</a>`;
        }
        if (isLast) return `${sep}<span class="current">${c.label}</span>`;
        if (c.href) {
            return `${sep}<a href="${c.href}" class="breadcrumb-link">${c.label}</a>`;
        }
        return `${sep}<button type="button" onclick="setActive('${c.id}')">${c.label}</button>`;
    }).join('');
}

function renderPageHeader(id) {
    const found = findNode(id);
    const label = found ? found.node.label : t('dashboard.title');
    document.getElementById('page-title').textContent = label;
    document.getElementById('page-subtitle').textContent = id === 'dashboard'
        ? t('dashboard.subtitle') : label;
}

function renderDynamicSections(id) {
    const dynamicContainer = document.getElementById('menu-content-container');
    const dashboardStats = document.getElementById('dashboard-stats');
    const dashboardUsers = document.getElementById('dashboard-users-table');
    const dashboardFooter = document.getElementById('dashboard-footer');
    const swalTemplate = document.getElementById('swal-dev-template');
    const menuManagerTemplate = document.getElementById('menu-manager-template');

    const isDashboard = id === 'dashboard';
    const isSwalTemplate = id === 'ui-alerts-swal';
    const isMenuManager = id === 'menu-manager';
    const isFilterScaleDemo = ['filter-scale-lt8', 'filter-scale-9-20', 'filter-scale-20plus'].includes(id);
    const isUsersAccess = id.startsWith('users-');
    const isUiKit = id.startsWith('ui-');
    const found = findNode(id);

    if (dashboardStats) dashboardStats.style.display = isDashboard ? '' : 'none';
    if (dashboardUsers) dashboardUsers.style.display = 'none';
    if (dashboardFooter) dashboardFooter.style.display = '';
    if (!isDashboard) {
        const activeFiltersRow = document.getElementById('active-filters-row');
        if (activeFiltersRow) activeFiltersRow.classList.remove('show');
    }

    if (swalTemplate) {
        swalTemplate.style.display = isSwalTemplate ? 'block' : 'none';
    }
    if (menuManagerTemplate) {
        menuManagerTemplate.style.display = isMenuManager ? 'block' : 'none';
        if (isMenuManager) renderMenuManagerTable();
    }

    if (!dynamicContainer) return;

    if (isDashboard || isSwalTemplate || isMenuManager) {
        dynamicContainer.style.display = 'none';
        dynamicContainer.innerHTML = '';
        renderFilterPanelForView(id);
        return;
    }

    if (isFilterScaleDemo) {
        dynamicContainer.style.display = 'block';
        dynamicContainer.innerHTML = renderFilterScaleDemo(id, found ? found.node.label : id);
        initFilterDemoTable();
        renderFilterPanelForView(id);
        return;
    }

    if (isUsersAccess) {
        dynamicContainer.style.display = 'block';
        dynamicContainer.innerHTML = renderUsersAccessView(id, found ? found.node.label : id);
        renderFilterPanelForView(id);
        return;
    }

    if (isUiKit) {
        dynamicContainer.style.display = 'block';
        dynamicContainer.innerHTML = renderUiKitView(id, found ? found.node.label : id);
        dynamicContainer.querySelectorAll('.swal-demo-btn').forEach((btn) => {
            btn.addEventListener('click', () => runSwalDemo(btn.dataset.swalDemo));
        });
        renderFilterPanelForView(id);
        return;
    }

    dynamicContainer.style.display = 'block';
    dynamicContainer.innerHTML = `
        <div class="content-card">
            <div class="content-card-header">${found ? found.node.label : 'Seccion'}</div>
            <div class="content-card-body">
                <p style="margin:0 0 10px;font-size:13px;color:#64748b;">
                    Contenido del menu <strong>${found ? found.node.label : id}</strong>.
                </p>
                <div class="alert alert-secondary mb-0" role="alert" style="font-size:13px;">
                    ID tecnico: <code>${id}</code>. Aqui puedes colocar el contenido especifico de esta seccion.
                </div>
            </div>
        </div>
    `;
    renderFilterPanelForView(id);
}

