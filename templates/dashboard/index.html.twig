        </div>
    </section>

    <section id="menu-manager-template" class="content-card mt-4 menu-manager-template">
        <div class="content-card-header">
            Gestion de menus (solo DEV)
        </div>
        <div class="content-card-body">
            <p class="menu-manager-help mb-3">
                Crea y elimina items personalizados del sidebar. Estos items se guardan en tu navegador (localStorage).
            </p>

            <form id="menu-manager-form" class="row g-2 mb-3">
                <div class="col-md-4">
                    <label class="form-label" for="menu-item-label">Nombre del menu</label>
                    <input id="menu-item-label" class="form-control form-control-sm" type="text" placeholder="Ej: Reportes QA" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="menu-item-id">ID tecnico (opcional)</label>
                    <input id="menu-item-id" class="form-control form-control-sm" type="text" placeholder="ej_reportes_qa">
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="menu-item-icon">Icono (key IC)</label>
                    <input id="menu-item-icon" class="form-control form-control-sm" type="text" placeholder="list, chart, settings...">
                </div>
                <div class="col-12 d-flex justify-content-end">
                    <button type="submit" class="btn btn-sm btn-primary">Crear item</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0" id="menu-manager-table">
                    <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>ID</th>
                        <th>Icono</th>
                        <th style="width:120px;">Accion</th>
                    </tr>
                    </thead>
                    <tbody id="menu-manager-table-body"></tbody>
                </table>
            </div>
            <div id="menu-manager-result" class="swal-result mt-2">Sin cambios recientes.</div>
        </div>
    </section>
    {% endif %}

    <div id="filters-overlay" aria-hidden="true"></div>
    <button id="filters-toggle" type="button" title="Abrir filtros">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
        <span class="vertical-text">Filtros</span>
    </button>
    <aside id="filters-panel" aria-label="Panel de filtros">
