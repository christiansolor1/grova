            break;
        case 'toastActions': {
            const Toast = Swal.mixin({
                toast: true,
                position: 'bottom-end',
                showConfirmButton: true,
                showCancelButton: true,
                confirmButtonText: 'Ver',
                cancelButtonText: 'Cerrar',
                timer: 7000,
                timerProgressBar: true,
            });
            const response = await Toast.fire({
                icon: 'info',
                title: 'Tienes una notificacion pendiente'
            });
            if (response.isConfirmed) setSwalResult('Toast con acciones: Ver.');
            else if (response.dismiss) setSwalResult('Toast con acciones: Cerrado o expiro.');
            break;
        }
        case 'timer': {
            let timerInterval;
            await Swal.fire({
                title: 'Cerrando automaticamente...',
                html: 'Se cerrara en <b></b> ms.',
                timer: 2500,
                timerProgressBar: true,
                didOpen: () => {
                    Swal.showLoading();
                    const b = Swal.getHtmlContainer()?.querySelector('b');
                    timerInterval = setInterval(() => {
                        if (b) b.textContent = String(Swal.getTimerLeft());
                    }, 100);
                },
                willClose: () => clearInterval(timerInterval),
            });
            setSwalResult('Ejecutado: Auto close con timer.');
            break;
        }
        case 'loader':
            Swal.fire({
                title: 'Procesando...',
                html: 'No cierres esta ventana.',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => Swal.showLoading()
            });
            setTimeout(() => {
                Swal.close();
                setSwalResult('Loader bloqueante finalizado.');
            }, 1800);
            break;
        case 'position': {
            await Swal.fire({
                position: 'top-start',
                icon: 'success',
                title: 'Alerta en top-start',
                showConfirmButton: false,
                timer: 1800,
            });
            setSwalResult('Ejecutado: Posicion top-start.');
            break;
        }
        case 'customClass':
            await Swal.fire({
                title: 'Clases personalizadas',
                text: 'Este ejemplo aplica clases CSS en popup y boton.',
                icon: 'info',
                customClass: {
                    popup: 'border border-primary',
                    confirmButton: 'btn btn-primary',
                },
                buttonsStyling: false,
            });
            setSwalResult('Ejecutado: customClass + buttonsStyling false.');
            break;
        case 'image':
            await Swal.fire({
                title: 'Imagen en alerta',
                text: 'Puedes usar branding o ilustraciones.',
                imageUrl: 'https://sweetalert2.github.io/images/trees.png',
                imageWidth: 280,
                imageHeight: 140,
                imageAlt: 'Imagen de ejemplo',
            });
            setSwalResult('Ejecutado: Alerta con imagen.');
            break;
        default:
            setSwalResult('Demo no implementado.');
    }
}

// ── Sidebar toggle ─────────────────────────────────────────────────────────
function applySidebar() {
    const sidebar = document.getElementById('sidebar');
    if (sidebarCollapsed) {
        sidebar.classList.add('collapsed');
        document.body.classList.add('sidebar-collapsed');
    } else {
        sidebar.classList.remove('collapsed');
        document.body.classList.remove('sidebar-collapsed');
    }
}

document.getElementById('sidebar-toggle').addEventListener('click', () => {
    sidebarCollapsed = !sidebarCollapsed;
    localStorage.setItem('grova_sidebar', sidebarCollapsed ? '1' : '0');
    applySidebar();
});

// ── Theme ─────────────────────────────────────────────────────────────────
function applyTheme() {
    const dd = document.getElementById('theme-toggle-dropdown');
    if (darkMode) {
        document.body.classList.remove('light-mode');
        document.getElementById('icon-sun').style.display = 'block';
        document.getElementById('icon-moon').style.display = 'none';
        if (dd) dd.checked = true;
    } else {
        document.body.classList.add('light-mode');
        document.getElementById('icon-sun').style.display = 'none';
        document.getElementById('icon-moon').style.display = 'block';
        if (dd) dd.checked = false;
    }
}

document.getElementById('theme-toggle').addEventListener('click', () => {
    darkMode = !darkMode;
    setCookie('grova_theme', darkMode ? 'dark' : 'light', 365);
    applyTheme();
});

document.getElementById('theme-toggle-dropdown').addEventListener('change', (e) => {
    darkMode = e.target.checked;
    setCookie('grova_theme', darkMode ? 'dark' : 'light', 365);
    applyTheme();
});

// ── Profile dropdown ──────────────────────────────────────────────────────
const profileBtn = document.getElementById('profile-btn');
const profileDropdown = document.getElementById('profile-dropdown');
profileBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isVisible = profileDropdown.style.display === 'block';
    profileDropdown.style.display = isVisible ? 'none' : 'block';
});
document.addEventListener('click', () => { profileDropdown.style.display = 'none'; });

// ── Search filter ─────────────────────────────────────────────────────────
document.getElementById('nav-search').addEventListener('input', (e) => {
    renderNav(e.target.value);
});

// ── DataTable ─────────────────────────────────────────────────────────────
function initUsersTable() {
    const tableEl = document.getElementById('users-table');
    if (!tableEl || typeof DataTable === 'undefined') return;

    const dtLang = LOCALE === 'en'
        ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
        : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';

    try {
        usersDataTable = new DataTable(tableEl, {
            language: { url: dtLang },
            pageLength: 3,
            dom: 'Bfrtip',
            buttons: [
                { extend: 'copy', text: 'Copiar' },
                { extend: 'csv', text: 'CSV' },
                { extend: 'excel', text: 'Excel' },
                { extend: 'pdf', text: 'PDF' },
                { extend: 'print', text: 'Imprimir' },
                { extend: 'colvis', text: 'Columnas' },
                { extend: 'pageLength', text: 'Registros' }
            ],
            paging: true
        });
    } catch (e) {
        console.error('No se pudo inicializar DataTable:', e);
    }
}

function toggleFilters(forceOpen = null) {
    const shouldOpen = forceOpen === null
        ? !document.body.classList.contains('filters-open')
        : !!forceOpen;
    document.body.classList.toggle('filters-open', shouldOpen);
}

function initFilterPanel() {
    if (filterPanelInitialized) return;
    filterPanelInitialized = true;

    const toggleBtn = document.getElementById('filters-toggle');
    const closeBtn = document.getElementById('filters-close');
    const overlay = document.getElementById('filters-overlay');
    const applyBtn = document.getElementById('filters-apply');
    const resetBtn = document.getElementById('filters-reset');

    if (toggleBtn) toggleBtn.addEventListener('click', () => toggleFilters(true));
    if (closeBtn) closeBtn.addEventListener('click', () => toggleFilters(false));
    if (overlay) overlay.addEventListener('click', () => toggleFilters(false));

    if (applyBtn) {
        applyBtn.addEventListener('click', () => {
            const searchText = getCurrentFilterSummary().join(' ');
            const targetTable = resolveActiveDataTable();

            if (targetTable && typeof targetTable.search === 'function') {
                targetTable.search(searchText).draw();
            } else {
                const dtSearch = document.querySelector('.dt-search input');
                if (dtSearch) {
                    dtSearch.value = searchText;
                    dtSearch.dispatchEvent(new Event('input', { bubbles: true }));
                }
            }
            updateActiveFiltersBanner();
            toggleFilters(false);
        });
    }

    if (resetBtn) {
        resetBtn.addEventListener('click', () => {
            const targetTable = resolveActiveDataTable();
            document.querySelectorAll('[data-filter-input="1"]').forEach((el) => {
                if ('value' in el) {
                    if (el.tagName === 'SELECT') {
                        el.selectedIndex = 0;
                    } else {
                        el.value = '';
                    }
                }
            });
            if (targetTable && typeof targetTable.search === 'function') {
                targetTable.search('').draw();
            }
            updateActiveFiltersBanner();
        });
    }

    const activeFiltersText = document.getElementById('active-filters-text');
    const activeFiltersClear = document.getElementById('active-filters-clear');
    if (activeFiltersText) {
        activeFiltersText.addEventListener('click', () => toggleFilters(true));
    }
    if (activeFiltersClear) {
        activeFiltersClear.addEventListener('click', () => {
            if (resetBtn) resetBtn.click();
        });
    }
}

// ── Init ──────────────────────────────────────────────────────────────────
applySidebar();
applyTheme();
rebuildNavFromStorage();

if (!findNode(activeId)) {
    activeId = 'dashboard';
    localStorage.setItem('grova_active', activeId);
}

// auto-expand active item's parents on load
const foundInit = findNode(activeId);
if (foundInit && foundInit.l1) exp1[foundInit.l1.id] = true;
if (foundInit && foundInit.l2) exp2[foundInit.l2.id] = true;

renderNav();
renderBreadcrumb();
renderPageHeader(activeId);
renderDynamicSections(activeId);
initUsersTable();
initFilterPanel();
updateActiveFiltersBanner();

document.querySelectorAll('.swal-demo-btn').forEach((btn) => {
    btn.addEventListener('click', () => runSwalDemo(btn.dataset.swalDemo));
});

const menuManagerForm = document.getElementById('menu-manager-form');
if (menuManagerForm) {
    menuManagerForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const labelInput = document.getElementById('menu-item-label');
        const idInput = document.getElementById('menu-item-id');
        const iconInput = document.getElementById('menu-item-icon');

        const label = (labelInput?.value || '').trim();
        const requestedId = slugifyMenuId((idInput?.value || '').trim() || label);
        const icon = (iconInput?.value || '').trim();

        if (!label || !requestedId) {
            setMenuManagerResult('Debes indicar un nombre valido.');
            return;
        }

        const idAlreadyExists = NAV.some((item) => item.id === requestedId);
        if (idAlreadyExists) {
            setMenuManagerResult(`El ID ${requestedId} ya existe.`);
            return;
        }
        const customItems = getCustomNavItems();
        customItems.push({
            id: requestedId,
            label,
            icon: icon && IC[icon] ? icon : 'list',
        });
        saveCustomNavItems(customItems);
        rebuildNavFromStorage();
        renderNav(document.getElementById('nav-search').value);
        renderMenuManagerTable();
        setMenuManagerResult(`Item creado: ${label} (${requestedId})`);
        menuManagerForm.reset();
    });
}
</script>
{% endblock %}
