function getCurrentFilterSummary() {
    const parts = [];
    document.querySelectorAll('[data-filter-input="1"]').forEach((el) => {
        if (!('value' in el)) return;
        const raw = (el.value || '').trim();
        if (!raw) return;
        const label = el.dataset.label || el.id || 'Filtro';
        if (el.tagName === 'SELECT') {
            const selectedText = el.options && el.selectedIndex >= 0 ? el.options[el.selectedIndex].text : raw;
            const normalized = (selectedText || '').trim().toLowerCase();
            if (['todos', 'todas', '-seleccionar-', 'all'].includes(normalized)) return;
            parts.push(`${label}: ${selectedText}`);
        } else {
            parts.push(`${label}: ${raw}`);
        }
    });
    return parts;
}

function updateActiveFiltersBanner() {
    const row = document.getElementById('active-filters-row');
    const text = document.getElementById('active-filters-text');
    if (!row || !text) return;

    const parts = getCurrentFilterSummary();
    if (!parts.length) {
        row.classList.remove('show');
        text.textContent = '';
        return;
    }

    if (activeFilterMode === 'chips' && parts.length > 4) {
        const preview = parts.slice(0, 4).join(' ; ');
        text.textContent = ` ${preview} ; +${parts.length - 4} más`;
    } else if (activeFilterMode === 'compact' && parts.length > 3) {
        text.textContent = ` ${parts.slice(0, 3).join(' ; ')} ; +${parts.length - 3} más`;
    } else {
        text.textContent = ` ${parts.join(' ; ')}`;
    }
    row.classList.add('show');
}

function renderFilterPanelForView(viewId) {
    const body = document.getElementById('filters-body');
    if (!body) return;

    const schema = FILTER_SCHEMAS[viewId] || FILTER_SCHEMAS.default;
    activeFilterMode = schema.mode || 'compact';

    body.innerHTML = schema.sections.map((section) => `
        <div class="filter-section ${section.open ? 'open' : ''}">
            <button class="filter-section-btn" type="button">
                ${section.title}
                <span class="chev"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
            </button>
            <div class="filter-section-content">
                ${section.fields.map((field) => {
                    if (field.type === 'select') {
                        const options = (field.options || ['Todos', 'Opcion 1', 'Opcion 2']).map((opt) => `<option value="${opt}">${opt}</option>`).join('');
                        return `<label class="form-label">${field.label}</label>
                                <select id="${field.id}" data-filter-input="1" data-label="${field.label}" class="form-select form-select-sm mb-2">${options}</select>`;
                    }
                    return `<label class="form-label">${field.label}</label>
                            <input id="${field.id}" data-filter-input="1" data-label="${field.label}" class="form-control form-control-sm mb-2" type="${field.type}" placeholder="${field.placeholder || ''}">`;
                }).join('')}
            </div>
        </div>
    `).join('');

    body.querySelectorAll('.filter-section-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
            const section = btn.closest('.filter-section');
            if (section) section.classList.toggle('open');
        });
    });
}

function setMenuManagerResult(message) {
    const resultEl = document.getElementById('menu-manager-result');
