}

function renderMenuManagerTable() {
    const tableBody = document.getElementById('menu-manager-table-body');
    if (!tableBody) return;

    const items = getCustomNavItems();
    if (!items.length) {
        tableBody.innerHTML = '<tr><td colspan="4" class="text-muted">No hay items personalizados.</td></tr>';
        return;
    }

    tableBody.innerHTML = items.map((item) => `
        <tr>
            <td>${item.label}</td>
            <td><code>${item.id}</code></td>
            <td>${item.icon}</td>
            <td>
                <button type="button" class="btn btn-sm btn-outline-danger menu-item-delete-btn" data-menu-id="${item.id}">
                    Eliminar
                </button>
            </td>
        </tr>
    `).join('');

    tableBody.querySelectorAll('.menu-item-delete-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
            const targetId = btn.dataset.menuId;
            const nextItems = getCustomNavItems().filter((item) => item.id !== targetId);
            saveCustomNavItems(nextItems);
            rebuildNavFromStorage();
            renderNav(document.getElementById('nav-search').value);
            renderMenuManagerTable();
            setMenuManagerResult(`Item eliminado: ${targetId}`);
            if (activeId === targetId) setActive('menu-manager');
        });
    });
}

