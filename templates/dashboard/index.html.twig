function buildFilterFields(count, prefix = 'f') {
    return Array.from({ length: count }).map((_, idx) => ({
        id: `${prefix}-${idx + 1}`,
        label: `Filtro ${idx + 1}`,
        type: idx % 4 === 0 ? 'select' : 'text',
    }));
}

