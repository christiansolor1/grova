<!-- Navbar -->
<header id="navbar">
    {% if is_dev|default(false) %}
    <div class="navbar-dev-franja" aria-hidden="true"></div>
    <div class="dev-badge me-2">
        <span class="dev-dot"></span>
        DEV MODE
    </div>
    {% endif %}
    <button class="nav-btn" id="navbar-sidebar-toggle" title="{{ 'nav.expand'|trans }}" aria-label="{{ 'nav.expand'|trans }}">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <div class="navbar-search" id="navbar-search-wrap">
        <span class="search-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        </span>
        <input type="search" id="navbar-search-input" autocomplete="off" placeholder="{{ 'navbar.search_placeholder' | trans }}">
        <span class="navbar-search-kbd" aria-hidden="true">⌘K</span>
        <button type="button" class="navbar-search-clear" id="navbar-search-clear" title="{{ 'navbar.search_clear'|trans }}" aria-label="{{ 'navbar.search_clear'|trans }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
    </div>
    <div class="navbar-actions">
        <button class="nav-btn" id="theme-toggle" title="{{ 'navbar.theme_toggle' | trans }}">
            <svg id="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M12 3v1M12 20v1M4.22 4.22l.7.7M18.36 18.36l.7.7M3 12H4M20 12h1M4.22 19.78l.7-.7M18.36 5.64l.7-.7M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z"/></svg>
            <svg id="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        {% set _notif_count = unread_notifications_count() %}
        {% set _history_url = path('notifications_history', {_locale: app.request.locale}) %}
        <div id="notif-wrap" style="position:relative;">
            <button class="nav-btn" id="notif-btn" title="{{ 'navbar.notifications' | trans }}" aria-haspopup="true" aria-expanded="false">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span class="notif-dot" id="notif-dot" {% if _notif_count == 0 %}style="display:none"{% endif %}></span>
                <span id="notif-badge" style="
                    position:absolute; top:-4px; right:-4px;
                    background:#ef4444; color:#fff;
                    font-size:10px; font-weight:700; line-height:1;
                    min-width:16px; height:16px;
                    border-radius:8px; padding:0 4px;
                    display:{{ _notif_count > 0 ? 'flex' : 'none' }};
                    align-items:center; justify-content:center;
                    border:2px solid var(--navbar-bg, #0f172a);
                ">{{ _notif_count > 99 ? '99+' : _notif_count }}</span>
            </button>
            <div id="notif-dropdown" role="menu" style="
                display:none;
                position:absolute; top:calc(100% + 8px); right:-8px;
                width:340px;
                background:#1e293b; border:1px solid #334155;
                border-radius:12px;
                box-shadow:0 8px 32px rgba(0,0,0,.4);
                z-index:1000;
                overflow:hidden;
            ">
                {# Header #}
                <div style="padding:.75rem 1rem; border-bottom:1px solid #334155; display:flex; align-items:center; justify-content:space-between;">
                    <span style="font-size:13px; font-weight:700; color:#f1f5f9;">Notificaciones</span>
                    <div style="display:flex;gap:.75rem;align-items:center;">
                        <button id="notif-dismiss-all" style="font-size:11px;color:#64748b;background:none;border:none;cursor:pointer;padding:0;" title="Limpiar inbox">
                            <i class="bi bi-archive"></i> Limpiar
                        </button>
                        <button id="notif-mark-all" style="font-size:11px;color:#60a5fa;background:none;border:none;cursor:pointer;padding:0;">
                            Marcar leídas
                        </button>
                    </div>
                </div>
                {# Lista #}
                <div id="notif-list" style="max-height:380px; overflow-y:auto;"></div>
                {# Footer #}
                <div style="padding:.6rem 1rem; border-top:1px solid #334155; text-align:center;">
                    <a href="{{ _history_url }}" style="font-size:12px; color:#60a5fa; text-decoration:none;">
                        <i class="bi bi-clock-history me-1"></i>Ver historial completo
                    </a>
                </div>
            </div>
        </div>
        <button class="nav-btn" title="{{ 'navbar.help' | trans }}">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
        </button>
        <a href="http://grova.localhost/_profiler" target="_blank" rel="noopener" class="nav-btn grova-dev-profiler-extras" id="grova-nav-profiler" title="{{ 'navbar.profiler_open' | trans }}">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                <path d="M6 9l3 2.5L6 14"/>
                <path d="M12 15h5"/>
            </svg>
        </a>
        {% set flags = {'es': '🇪🇸', 'en': '🇺🇸'} %}
        {% set current_flag = flags[app.request.locale] ?? '🌐' %}
        <div class="nav-divider"></div>
        <div class="lang-combo" id="lang-combo-nav">
            <button class="lang-combo-trigger" onclick="toggleLangCombo('nav', event)" type="button">
                <span class="lc-flag">{{ current_flag }}</span>
                <span class="lc-code">{{ app.request.locale|upper }}</span>
                <svg class="lc-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="lang-combo-list">
                {% for locale, flag in flags %}
                    {% set locale_url = path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': locale})) %}
                    <a href="{{ locale_url }}" onclick="setCookie('grova_locale','{{ locale }}',365)" class="lang-combo-option {{ app.request.locale == locale ? 'active' : '' }}">
                        <span style="font-size:15px;">{{ flag }}</span>
                        <span>{{ locale|upper }}</span>
                        {% if app.request.locale == locale %}<svg class="lc-check" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>{% endif %}
                    </a>
                {% endfor %}
            </div>
        </div>
        <div class="nav-divider"></div>
        {% set nav_role = is_granted('ROLE_DEVELOPER') ? ('navbar.role.superadmin'|trans) : (is_granted('ROLE_ADMIN') ? ('navbar.role.admin'|trans) : ('navbar.role.user'|trans)) %}
        <div id="profile-wrap">
            <button class="profile-btn" id="profile-btn" type="button" aria-haspopup="menu" aria-expanded="false">
                <span class="profile-badge">{{ nav_role }}</span>
                <div class="profile-avatar">{{ app.user.username|first|upper }}</div>
                <span class="profile-name">{{ app.user.username }}</span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="profile-dropdown" id="profile-dropdown" role="menu" style="display:none;">
                <div class="profile-dropdown-header">
                    <span class="profile-badge" style="display:inline-block;margin-bottom:6px;">{{ nav_role }}</span>
                    <div class="name">{{ app.user.username }}</div>
                    <div class="email">{{ app.user.email }}</div>
                </div>
                <a href="{{ path('grova_profile', {'_locale': app.request.locale}) }}" class="profile-dropdown-item" style="text-decoration:none;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>
                    {{ 'navbar.profile' | trans }}
                </a>
                <button class="profile-dropdown-item">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    {{ 'navbar.settings' | trans }}
                </button>
                <div class="dev-switch-row dev-switch-row--theme" style="border-top:none;padding-top:0;">
                    <span class="dev-switch-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                        Modo noche
                    </span>
                    <label class="form-switch-dev" title="Alternar modo noche">
                        <input type="checkbox" id="theme-toggle-dropdown" {{ app.request.cookies.get('grova_theme') != 'light' ? 'checked' : '' }}>
                        <span class="slider"></span>
                    </label>
                </div>
                <div class="dev-switch-row dev-switch-row--dev" data-dev-targets="#dev-topbar,.dev-badge">
                    <span class="dev-switch-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg>
                        Modo desarrollo
                    </span>
                    <label class="form-switch-dev form-switch-dev--dev" title="Control visual de dev-topbar y dev-badge (solo interfaz)">
                        <input type="checkbox" id="dev-mode-toggle-ui" {{ is_dev ? 'checked' : '' }}>
                        <span class="slider"></span>
                    </label>
                </div>
                <a href="http://grova.localhost/_profiler" target="_blank" rel="noopener" class="profile-dropdown-item grova-dev-profiler-extras" id="grova-menu-profiler" style="text-decoration:none;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                        <path d="M6 9l3 2.5L6 14"/>
                        <path d="M12 15h5"/>
                    </svg>
                    {{ 'navbar.profiler' | trans }}
                </a>
                {% if is_granted('IS_IMPERSONATOR') %}
                <div class="profile-dropdown-divider"></div>
                <a href="{{ path('grova_page_dashboard', {_locale: app.request.locale, _switch_user: '_exit'}) }}"
                   class="profile-dropdown-item"
                   style="text-decoration:none; color:#f59e0b;">
                    <i class="bi bi-person-fill-x" style="font-size:15px;"></i>
                    {{ 'impersonate.exit'|trans }}
                </a>
                {% endif %}
                <div class="profile-dropdown-divider"></div>
                <a href="{{ path('logout', {'_locale': app.request.locale}) }}" class="profile-dropdown-item danger" style="text-decoration:none;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                    {{ 'navbar.logout' | trans }}
                </a>
            </div>
        </div>
    </div>
</header>
<script>
(function () {
    if (window.__grovaDevChromeInit) return;
    window.__grovaDevChromeInit = true;

    function getCookie(name) {
        return document.cookie.split('; ').reduce(function (acc, c) {
            var p = c.split('=');
            return p[0] === name ? decodeURIComponent(p[1] || '') : acc;
        }, null);
    }

    function setCookie(name, value, days) {
        var expires = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + expires + ';path=/;SameSite=Lax';
    }

    var devModeToggle = document.getElementById('dev-mode-toggle-ui');
    if (!devModeToggle) return;

    var isLocalHost = /(^localhost$|\.localhost$)/.test(window.location.hostname || '');
    var currentPath = window.location.pathname || '/';
    var normalizedPath = currentPath.replace(/^\/index_(dev|prod)\.php/, '') || '/';
    var query = window.location.search || '';
    var hash = window.location.hash || '';
    var devEntryUrl = '/index_dev.php' + normalizedPath + query + hash;
    var prodEntryUrl = '/index_prod.php' + normalizedPath + query + hash;
    var currentIsDevEntry = /^\/index_dev\.php/.test(currentPath);
    var currentIsProdEntry = /^\/index_prod\.php/.test(currentPath);

    var devChromeVisible = devModeToggle.checked;
    if (isLocalHost && currentIsDevEntry) devChromeVisible = true;
    if (isLocalHost && currentIsProdEntry) devChromeVisible = false;
    var saved = getCookie('grova_dev_chrome');
    if ((!isLocalHost || (!currentIsDevEntry && !currentIsProdEntry)) && saved !== null) {
        devChromeVisible = saved === '1';
    }

    function applyDevChrome() {
        document.body.classList.toggle('grova-dev-chrome-off', !devChromeVisible);
        var topbar = document.getElementById('dev-topbar');
        if (topbar) topbar.style.display = devChromeVisible ? '' : 'none';
        document.querySelectorAll('.dev-badge, .navbar-dev-franja').forEach(function (el) {
            el.style.display = devChromeVisible ? '' : 'none';
        });
        devModeToggle.checked = devChromeVisible;
        document.querySelectorAll('.grova-dev-profiler-extras').forEach(function (el) {
            el.style.display = devChromeVisible ? 'flex' : 'none';
        });
    }

    devModeToggle.addEventListener('change', function (e) {
        devChromeVisible = !!e.target.checked;
        setCookie('grova_dev_chrome', devChromeVisible ? '1' : '0', 365);
        if (isLocalHost) {
            window.location.href = devChromeVisible ? devEntryUrl : prodEntryUrl;
            return;
        }
        applyDevChrome();
    });

    applyDevChrome();
})();

(function () {
    var inp = document.getElementById('navbar-search-input');
    var wrap = document.getElementById('navbar-search-wrap');
    var btn = document.getElementById('navbar-search-clear');
    if (!inp || !wrap || !btn) return;
    if (window.__grovaNavbarSearchInit) return;
    window.__grovaNavbarSearchInit = true;
    function sync() {
        wrap.classList.toggle('has-value', (inp.value || '').length > 0);
    }
    inp.addEventListener('input', sync);
    btn.addEventListener('click', function () {
        inp.value = '';
        sync();
        inp.focus();
    });
    sync();
})();

(function () {
    var btn        = document.getElementById('notif-btn');
    var dropdown   = document.getElementById('notif-dropdown');
    var list       = document.getElementById('notif-list');
    var badge      = document.getElementById('notif-badge');
    var dot        = document.getElementById('notif-dot');
    var markAllBtn = document.getElementById('notif-mark-all');
    var dismissAllBtn = document.getElementById('notif-dismiss-all');
    if (!btn || !dropdown) return;
    if (window.__grovaNotifInit) return;
    window.__grovaNotifInit = true;

    var locale = document.documentElement.lang || 'es';
    var open   = false;

    var typeColors = { info: '#60a5fa', success: '#4ade80', warning: '#fbbf24', danger: '#f87171' };
    var typeBg     = { info: 'rgba(96,165,250,.12)', success: 'rgba(74,222,128,.12)', warning: 'rgba(251,191,36,.12)', danger: 'rgba(241,113,113,.12)' };

    function setBadge(count) {
        count = parseInt(count, 10) || 0;
        if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.style.display = 'flex';
            dot.style.display   = '';
        } else {
            badge.style.display = 'none';
            dot.style.display   = 'none';
        }
    }

    function timeAgo(iso) {
        var diff = Math.floor((Date.now() - new Date(iso)) / 1000);
        if (diff < 60)    return 'Justo ahora';
        if (diff < 3600)  return 'Hace ' + Math.floor(diff / 60) + ' min';
        if (diff < 86400) return 'Hace ' + Math.floor(diff / 3600) + ' h';
        return 'Hace ' + Math.floor(diff / 86400) + ' d';
    }

    function renderList(items) {
        if (!items.length) {
            list.innerHTML = '<div style="padding:2.5rem 1rem;text-align:center;">'
                + '<div style="font-size:28px;margin-bottom:.5rem;">🔔</div>'
                + '<div style="font-size:13px;color:#64748b;">Inbox vacío</div>'
                + '</div>';
            return;
        }

        // Agrupar por módulo
        var groups = {};
        var order  = [];
        items.forEach(function (n) {
            var key = n.module || 'sistema';
            if (!groups[key]) { groups[key] = []; order.push(key); }
            groups[key].push(n);
        });

        var html = '';
        order.forEach(function (mod) {
            html += '<div style="padding:.4rem 1rem .2rem;font-size:10px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid #1e293b;">'
                  + mod + '</div>';

            groups[mod].forEach(function (n) {
                var color  = typeColors[n.type] || typeColors.info;
                var bg     = typeBg[n.type]     || typeBg.info;
                var rowBg  = n.read ? 'transparent' : 'rgba(96,165,250,.04)';
                var weight = n.read ? '400' : '700';
                var iconHtml = n.icon
                    ? '<i class="' + n.icon + '" style="font-size:15px;"></i>'
                    : '<i class="bi bi-bell" style="font-size:15px;"></i>';

                html += '<div data-notif-id="' + n.id + '" style="display:flex;gap:.6rem;align-items:flex-start;padding:.65rem 1rem;border-bottom:1px solid #1e293b;background:' + rowBg + ';">'
                    // barra de color tipo
                    + '<div style="width:3px;border-radius:2px;background:' + color + ';align-self:stretch;flex-shrink:0;"></div>'
                    // icono
                    + '<div style="width:28px;height:28px;border-radius:7px;background:' + bg + ';color:' + color + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;">' + iconHtml + '</div>'
                    // contenido
                    + '<div style="flex:1;min-width:0;">';

                if (n.url) {
                    html += '<a href="' + n.url + '" style="font-size:12px;font-weight:' + weight + ';color:#f1f5f9;line-height:1.3;text-decoration:none;display:block;">' + n.title + '</a>';
                } else {
                    html += '<div style="font-size:12px;font-weight:' + weight + ';color:#f1f5f9;line-height:1.3;">' + n.title + '</div>';
                }

                html += '<div style="font-size:11px;color:#94a3b8;margin-top:2px;line-height:1.4;">' + n.body + '</div>'
                    + '<div style="font-size:10px;color:#475569;margin-top:3px;">' + timeAgo(n.createdAt) + '</div>'
                    + '</div>'
                    // botón X
                    + '<button class="notif-dismiss-btn" data-id="' + n.id + '" title="Descartar" style="background:none;border:none;cursor:pointer;color:#475569;padding:2px 4px;font-size:13px;line-height:1;flex-shrink:0;border-radius:4px;" onmouseover="this.style.color=\'#94a3b8\'" onmouseout="this.style.color=\'#475569\'">×</button>'
                    + '</div>';
            });
        });

        list.innerHTML = html;

        // Eventos en botones X
        list.querySelectorAll('.notif-dismiss-btn').forEach(function (xBtn) {
            xBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                var id  = xBtn.getAttribute('data-id');
                var row = list.querySelector('[data-notif-id="' + id + '"]');
                if (row) row.style.opacity = '.3';
                fetch('/' + locale + '/notifications/' + id + '/dismiss', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    setBadge(data.unread);
                    loadNotifications();
                });
            });
        });
    }

    function loadNotifications() {
        list.innerHTML = '<div style="padding:2rem;text-align:center;color:#64748b;font-size:13px;">Cargando...</div>';
        fetch('/' + locale + '/notifications', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) {
                var count = r.headers.get('X-Unread-Notifications');
                if (count !== null) setBadge(count);
                return r.json();
            })
            .then(function (data) { renderList(data.items || []); })
            .catch(function () {
                list.innerHTML = '<div style="padding:2rem;text-align:center;color:#ef4444;font-size:13px;">Error al cargar</div>';
            });
    }

    // Abrir/cerrar dropdown
    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        open = !open;
        dropdown.style.display = open ? 'block' : 'none';
        btn.setAttribute('aria-expanded', String(open));
        if (open) {
            loadNotifications();
            // Marcar como leídas al abrir
            fetch('/' + locale + '/notifications/read', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function () { setBadge(0); });
        }
    });

    // Marcar leídas
    markAllBtn.addEventListener('click', function (e) {
        e.preventDefault();
        fetch('/' + locale + '/notifications/read', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function () { setBadge(0); loadNotifications(); });
    });

    // Descartar todo
    dismissAllBtn.addEventListener('click', function (e) {
        e.preventDefault();
        fetch('/' + locale + '/notifications/dismiss-all', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function () { setBadge(0); loadNotifications(); });
    });

    // Cerrar al click fuera
    document.addEventListener('click', function (e) {
        if (open && !dropdown.contains(e.target) && e.target !== btn) {
            open = false;
            dropdown.style.display = 'none';
            btn.setAttribute('aria-expanded', 'false');
        }
    });

    // MERCURE: descomentar cuando el Hub esté corriendo
    // var mercureUrl = '/.well-known/mercure?topic=' + encodeURIComponent('/user/{{ app.user.id }}');
    // var es = new EventSource(mercureUrl, { withCredentials: true });
    // es.onmessage = function (e) {
    //     var data = JSON.parse(e.data);
    //     if (data.unread !== undefined) setBadge(data.unread);
    // };

    // Actualiza badge en cualquier fetch que devuelva el header
    var _origFetch = window.fetch;
    window.fetch = function () {
        return _origFetch.apply(this, arguments).then(function (r) {
            var count = r.headers.get('X-Unread-Notifications');
            if (count !== null) setBadge(count);
            return r;
        });
    };
})();
</script>
