{# Hermano de #main: franja solo en la columna de contenido; el bloque va dentro de .container (Bootstrap). #}
<div class="grova-app-footer-strip">
    <div class="container">
        <footer id="dashboard-footer" class="page-footer">
            <div class="page-footer-main">
                <div class="page-footer-info">
                    <div class="page-footer-title">{{ 'app.name' | trans }}</div>
                    <div class="page-footer-meta">Texto de relleno para descripcion del proyecto.</div>
                    <p>Contacto demo: +34 600 123 456</p>
                    <p>Email demo: soporte@grova.local</p>
                </div>
                <div class="page-footer-form">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label" for="footer-company">Empresa</label>
                            <input id="footer-company" type="text" class="form-control form-control-sm" placeholder="Nombre de empresa">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="footer-contact">Contacto</label>
                            <input id="footer-contact" type="text" class="form-control form-control-sm" placeholder="Persona de contacto">
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="footer-comments">Comentarios</label>
                            <input id="footer-comments" type="text" class="form-control form-control-sm" placeholder="Mensaje de prueba">
                        </div>
                        <div class="col-12 d-flex justify-content-between align-items-center pt-1">
                            <div class="page-footer-links">
                                <a href="#">Politica de privacidad</a>
                                <a href="#">Terminos</a>
                                <a href="#">Soporte</a>
                            </div>
                            <button type="button" class="btn btn-sm btn-primary">Enviar</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="page-footer-copy">
                &copy; {{ "now"|date("Y") }} {{ 'app.name' | trans }}. Todos los derechos reservados. ·
                v{{ build_info.display_version|default(build_info.version) }} ·
                {% if is_granted('ROLE_DEVELOPER') and build_info.commit_url %}
                    <a href="{{ build_info.commit_url }}" target="_blank" rel="noopener noreferrer">{{ build_info.git_sha }}</a>
                {% else %}
                    {{ build_info.git_sha }}
                {% endif %}
            </div>
        </footer>
    </div>
</div>
