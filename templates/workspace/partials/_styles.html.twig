{% include 'workspace/partials/_grova_datatables2_skin.css.twig' %}

/* ── Bootstrap table dark mode ── */
.table {
    --bs-table-bg: transparent;
    --bs-table-striped-bg: rgba(255,255,255,.03);
    --bs-table-hover-bg: rgba(37,99,235,.08);
    --bs-table-hover-color: inherit;
    --bs-table-border-color: #1e293b;
    --bs-table-color: #cbd5e1;
    --bs-table-striped-color: #cbd5e1;
}
.table thead th { color:#64748b; font-size:11px; text-transform:uppercase; letter-spacing:.05em; border-bottom-color:#1e293b !important; font-weight:600; }
.table tbody tr td { border-bottom-color:#1e293b; }
body.light-mode .table {
    --bs-table-bg: transparent;
    --bs-table-striped-bg: rgba(0,0,0,.02);
    --bs-table-hover-bg: rgba(37,99,235,.05);
    --bs-table-hover-color: inherit;
    --bs-table-border-color: #e2e8f0;
    --bs-table-color: #1e293b;
    --bs-table-striped-color: #1e293b;
}
body.light-mode .table thead th { color:#64748b; border-bottom-color:#e2e8f0 !important; }
body.light-mode .table tbody tr td { border-bottom-color:#e2e8f0; }

/* ── Minimal theme overrides ── */
body {
    background: var(--grova-night-canvas);
    color: #e5e7eb;
}
body.light-mode {
    background: #f8fafc;
    color: #111827;
}
body.light-mode .grova-app-column { background: #f1f5f9; }
#navbar {
    background: var(--grova-night-chrome);
    border-bottom-color: var(--sidebar-border);
}
body.light-mode #navbar {
    background: #ffffff;
    border-bottom-color: #e5e7eb;
}
#main {
    padding: 20px;
}
.grova-app-footer-strip {
    padding-bottom: 20px;
}
.stat-card,
.content-card,
.page-footer,
.page-footer-form {
    border-radius: 10px;
    box-shadow: none;
}
.stat-card,
.content-card,
.page-footer {
    background: #1e293b;
    border-color: #334155;
}
body.light-mode .stat-card,
body.light-mode .content-card,
body.light-mode .page-footer {
    background: #ffffff;
    border-color: #e5e7eb;
}
.page-header h1 {
    font-size: 20px;
}
.btn,
.form-control,
.nav-btn,
.profile-btn {
    border-radius: 8px !important;
}
.page-footer-form .form-control {
    background: #0f172a;
    border-color: #1f2937;
}
body.light-mode .page-footer-form .form-control {
    background: #ffffff;
    border-color: #d1d5db;
}

/* ── Responsive shell (sidebar off-canvas + navbar compact) ─────────────── */
#navbar-sidebar-toggle {
    display: none;
}
@media (max-width: 992px) {
    #navbar-sidebar-toggle {
        display: inline-flex;
        order: 1;
    }
    .dev-badge { order: 2; }
    .navbar-search { order: 3; }
    .navbar-actions { order: 4; }

    #sidebar {
        width: var(--sidebar-w);
        transform: translateX(-100%);
        box-shadow: none;
    }
    body.sidebar-mobile-open #sidebar {
        transform: translateX(0);
        box-shadow: 8px 0 28px rgba(0, 0, 0, 0.42);
    }
    /* En móvil no queremos modo colapsado mini fijo */
    #sidebar.collapsed {
        width: var(--sidebar-w);
    }

    #sidebar-toggle {
        display: none !important;
    }

    body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(2, 6, 23, 0.5);
        z-index: calc(var(--z-chrome) - 1);
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s ease;
    }
    body.sidebar-mobile-open::before {
        opacity: 1;
        pointer-events: auto;
    }

    #navbar {
        left: 0;
        padding: 0 10px;
        gap: 8px;
    }
    .grova-app-column,
    body.sidebar-collapsed .grova-app-column {
        margin-left: 0;
        width: 100%;
    }

    .navbar-search {
        max-width: none;
        min-width: 0;
    }
    .navbar-search input {
        font-size: 12px;
        padding: 6px 32px 6px 32px;
    }
    .navbar-search-kbd {
        display: none !important;
    }
    .profile-badge,
    .profile-name,
    .nav-divider,
    #grova-nav-profiler {
        display: none !important;
    }
    .profile-btn {
        padding-right: 4px;
    }
    .dev-badge {
        margin-right: 4px !important;
        margin-left: 2px !important;
        padding: 2px 8px;
        font-size: 9px;
        letter-spacing: .08em;
        flex-shrink: 0;
    }
    .lang-combo-trigger {
        padding: 4px 7px;
        gap: 4px;
        font-size: 11px;
    }
    .lang-combo-trigger .lc-flag { font-size: 13px; }
    .lang-combo-trigger .lc-code { font-size: 10px; }
    #main {
        padding: 16px;
    }
}

@media (max-width: 640px) {
    #navbar {
        padding: 0 8px;
        gap: 6px;
    }
    .navbar-search {
        /* Evita que el search “empuje” iconos a la derecha en emulación desktop */
        flex: 0 1 35%;
        min-width: 96px;
        max-width: 162px;
    }
    .navbar-search input {
        padding-left: 30px;
        padding-right: 28px;
        font-size: 12px;
    }
    .navbar-actions {
        margin-left: 0;
        flex-shrink: 0;
        gap: 2px;
    }
    .nav-btn {
        width: 30px;
        height: 30px;
    }
    /* Mantener visibles idioma y dev-mode en móvil; ocultamos acciones secundarias */
    .navbar-actions > .nav-btn:nth-child(2), /* notificaciones */
    .navbar-actions > .nav-btn:nth-child(3) { /* ayuda */
        display: none !important;
    }
    .dev-badge {
        padding: 2px 8px;
        font-size: 8.5px;
        margin-right: 2px !important;
        margin-left: 1px !important;
        max-width: 88px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .lang-combo {
        display: block;
    }
    .lang-combo-trigger {
        padding: 2px 6px;
    }
    .lang-combo-list {
        right: 0;
        left: auto;
    }
    .lang-combo-trigger .lc-code {
        display: none;
    }
    .profile-btn {
        gap: 2px;
        padding: 2px 3px 2px 2px !important;
    }
    .profile-btn > svg {
        display: none;
    }
    .profile-avatar {
        width: 26px;
        height: 26px;
        font-size: 10px;
    }
    #main {
        padding: 12px;
    }
}
@media (max-width: 430px) {
    .navbar-search {
        max-width: 142px;
    }
    .dev-badge {
        max-width: 76px;
    }
}

/* ── Empty states ── */
.grova-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1.5rem;
    gap: .75rem;
}
.grova-empty-icon {
    font-size: 2.5rem;
    color: #334155;
    line-height: 1;
}
.grova-empty-state-error .grova-empty-icon { color: #7f1d1d; }
.grova-empty-title {
    font-size: 15px;
    font-weight: 600;
    color: #94a3b8;
}
.grova-empty-desc {
    font-size: 13px;
    color: #64748b;
    max-width: 340px;
}
.grova-empty-actions { margin-top: .25rem; display: flex; gap: .5rem; flex-wrap: wrap; justify-content: center; }
.grova-empty-state-compact { padding: 1.5rem 1rem; }
.grova-empty-state-compact .grova-empty-icon { font-size: 1.75rem; }
.grova-empty-state-compact .grova-empty-title { font-size: 13px; }
.grova-empty-state-compact .grova-empty-desc { font-size: 12px; }
body.light-mode .grova-empty-icon { color: #cbd5e1; }
body.light-mode .grova-empty-title { color: #475569; }
body.light-mode .grova-empty-desc { color: #94a3b8; }

/* ── Page headers ── */
.grova-page-header {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
}
.grova-breadcrumb {
    display: flex;
    align-items: center;
    gap: .25rem;
    font-size: 11px;
    color: #64748b;
    flex-wrap: wrap;
}
.grova-breadcrumb a { color: #64748b; text-decoration: none; }
.grova-breadcrumb a:hover { color: #94a3b8; }
body.light-mode .grova-breadcrumb a { color: #94a3b8; }
body.light-mode .grova-breadcrumb a:hover { color: #475569; }
.grova-breadcrumb-sep { color: #334155; font-size: 10px; }
.grova-breadcrumb-active { color: #94a3b8; }
body.light-mode .grova-breadcrumb-active { color: #64748b; }
.grova-page-header-main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
}
.grova-page-title {
    font-size: 20px;
    font-weight: 700;
    color: #f1f5f9;
    margin: 0;
    line-height: 1.2;
}
body.light-mode .grova-page-title { color: #1e293b; }
.grova-page-subtitle {
    font-size: 13px;
    color: #64748b;
    margin: 2px 0 0;
}
.grova-page-header-actions {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
    flex-shrink: 0;
}
@media (max-width: 600px) {
    .grova-page-header-main { flex-direction: column; }
    .grova-page-header-actions { width: 100%; }
}

/* ── Profile ── */
.grova-profile-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #1e293b;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
}
body.light-mode .grova-profile-header { border-color: #e2e8f0; }
.grova-profile-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #1e3a5f;
    color: #60a5fa;
    font-size: 20px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: -.5px;
}
.grova-profile-name {
    font-size: 16px;
    font-weight: 700;
    color: #f1f5f9;
    margin: 0;
}
body.light-mode .grova-profile-name { color: #1e293b; }
.grova-profile-meta {
    font-size: 12px;
    color: #64748b;
    margin: 2px 0 0;
}
.grova-profile-info { display: flex; flex-direction: column; }

/* ── Detail list ── */
.grova-detail-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
}
.grova-detail-row {
    display: flex;
    align-items: baseline;
    gap: .75rem;
    padding: .5rem 0;
    border-bottom: 1px solid #1e293b;
    font-size: 13px;
}
.grova-detail-row:last-child { border-bottom: none; }
.grova-detail-row dt {
    min-width: 130px;
    font-weight: 500;
    color: #64748b;
    flex-shrink: 0;
}
.grova-detail-row dd {
    margin: 0;
    color: #e2e8f0;
    word-break: break-word;
}
body.light-mode .grova-detail-row { border-color: #e2e8f0; }
body.light-mode .grova-detail-row dt { color: #94a3b8; }
body.light-mode .grova-detail-row dd { color: #1e293b; }

/* ── Avatar upload zone ── */
.grova-avatar-upload-zone {
    border: 2px dashed #334155;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
