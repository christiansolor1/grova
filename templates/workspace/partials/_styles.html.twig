<link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.1.2/css/buttons.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.1.2/css/buttons.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/2.1.8/css/dataTables.bootstrap5.min.css">
<style>
/* ── Variables ── */
:root {
    /* Apilamiento: main (0) < filtros (110–120) < cromo sidebar/navbar/footer (400) < toggle hamb. (405) < tooltips (450) */
    --z-main: 0;
    --z-filters-overlay: 110;
    --z-filters-panel: 115;
    --z-filters-toggle: 120;
    --z-chrome: 400;
    --z-sidebar-toggle: 405;
    --z-nav-tooltip: 450;
    --z-modal-backdrop: 3000;
    --z-modal: 3010;
    --sidebar-w: 260px;
    --sidebar-w-collapsed: 64px;
    /* Noche: lienzo más profundo (--grova-night-canvas); cromo un peldaño más claro para que el menú siga leyéndose */
    --grova-night-canvas: #020617;
    --grova-night-chrome: #0f172a;
    --sidebar-bg: var(--grova-night-chrome);
    --sidebar-border: #334155;
    --nav-hover: #1e293b;
    --nav-active: #2563eb;
    --nav-active-bg: rgba(37,99,235,0.15);
    --text-muted: #6b7280;
    --text-dim: #9ca3af;
    --transition: all 0.28s ease;
}

/* ── Utilidades globales de modal (reusables en cualquier vista) ── */
[data-grova-modal-backdrop] {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal-backdrop);
}
[data-grova-modal-layer] {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
}
/* Bootstrap modal stack: siempre por encima del chrome (sidebar/navbar/footer). */
.modal {
    z-index: var(--z-modal) !important;
}
.modal-backdrop {
    z-index: var(--z-modal-backdrop) !important;
}
body.grova-modal-open {
    overflow: hidden;
}

/*
 * Modales estilo macOS (blur + “vidrio”): solo si el root lleva la clase grova-modal--macos.
 * El backdrop es hermano del .modal; body recibe grova-modal-macos-backdrop vía JS (show.bs.modal).
 * Sin la clase → aspecto Bootstrap estándar.
 */
body.grova-modal-macos-backdrop .modal-backdrop {
    --bs-backdrop-opacity: 1;
    background-color: rgba(2, 6, 23, 0.58) !important;
    backdrop-filter: blur(14px) saturate(1.12);
    -webkit-backdrop-filter: blur(14px) saturate(1.12);
    transition: opacity 0.28s cubic-bezier(0.16, 1, 0.3, 1);
}
body.light-mode.grova-modal-macos-backdrop .modal-backdrop {
    background-color: rgba(15, 23, 42, 0.46) !important;
}
@media (prefers-reduced-transparency: reduce) {
    body.grova-modal-macos-backdrop .modal-backdrop {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        background-color: rgba(2, 6, 23, 0.78) !important;
    }
    body.light-mode.grova-modal-macos-backdrop .modal-backdrop {
        background-color: rgba(15, 23, 42, 0.72) !important;
    }
}
@media (prefers-reduced-motion: reduce) {
    body.grova-modal-macos-backdrop .modal-backdrop {
        transition-duration: 0.01ms;
    }
}

.modal.grova-modal--macos .modal-content {
    border-radius: 12px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.05) inset,
        0 25px 50px -12px rgba(0, 0, 0, 0.55),
        0 0 1px rgba(0, 0, 0, 0.4);
    overflow: hidden;
}
body:not(.light-mode) .modal.grova-modal--macos .modal-content {
    background-color: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    color: #f1f5f9;
}
body.light-mode .modal.grova-modal--macos .modal-content {
    background-color: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: #1e293b;
    border-color: rgba(148, 163, 184, 0.35);
    box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.8) inset,
        0 25px 50px -12px rgba(15, 23, 42, 0.18),
        0 0 1px rgba(15, 23, 42, 0.08);
}
@media (prefers-reduced-transparency: reduce) {
    body:not(.light-mode) .modal.grova-modal--macos .modal-content,
    body.light-mode .modal.grova-modal--macos .modal-content {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
    }
    body:not(.light-mode) .modal.grova-modal--macos .modal-content {
        background-color: #0f172a;
    }
    body.light-mode .modal.grova-modal--macos .modal-content {
        background-color: #fff;
    }
}

.modal.grova-modal--macos .modal-header {
    border-bottom-color: rgba(148, 163, 184, 0.18);
}
.modal.grova-modal--macos .modal-footer {
    border-top-color: rgba(148, 163, 184, 0.18);
}
body.light-mode .modal.grova-modal--macos .modal-header,
body.light-mode .modal.grova-modal--macos .modal-footer {
    border-color: rgba(226, 232, 240, 0.95);
}

@media (prefers-reduced-motion: no-preference) {
    .modal.grova-modal--macos.fade .modal-dialog {
        transform: translateY(10px) scale(0.988);
        transition: transform 0.24s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .modal.grova-modal--macos.show .modal-dialog {
        transform: translateY(0) scale(1);
    }
    .modal.grova-modal--macos.fade .modal-dialog.modal-dialog-centered {
        transform: translateY(8px) scale(0.988);
    }
    .modal.grova-modal--macos.show .modal-dialog.modal-dialog-centered {
        transform: translateY(0) scale(1);
    }
}

[data-theme="light"] {
    --sidebar-bg: #111827;
    --sidebar-border: #1f2937;
    --nav-hover: #1f2937;
}

/* ── Reset / Base ── */
*, *::before, *::after { box-sizing: border-box; }
body { margin: 0; font-family: 'Inter', system-ui, sans-serif; background: var(--grova-night-canvas); color: #f1f5f9; overflow: hidden; }
body.light-mode { background: #f1f5f9; color: #1e293b; }
html {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
}
html::-webkit-scrollbar { width: 8px; }
html::-webkit-scrollbar-track { background: transparent; }
html::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 999px;
}
html:hover {
    scrollbar-color: #475569 transparent;
}
html:hover::-webkit-scrollbar-thumb {
    background: #475569;
}
html:hover::-webkit-scrollbar-thumb:hover {
    background: #64748b;
}

/* ── Sidebar ── */
#sidebar {
    position: fixed; top: 0; left: 0; height: 100vh; z-index: var(--z-chrome);
    width: var(--sidebar-w);
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border);
    /* Crítico con body.light-mode: el body usa color oscuro; sin esto, .menu-ui (inherit) queda ilegible */
    color: #d1d5db;
    display: flex; flex-direction: column;
    transition: var(--transition);
    overflow: hidden;
}
body.light-mode #sidebar { color: #d1d5db; }
#sidebar.collapsed { width: var(--sidebar-w-collapsed); }

/* Sidebar Header */
.sidebar-header {
    position: relative;
    height: 56px; display: flex; align-items: center; gap: 10px;
    padding: 0 12px;
    padding-right: 44px;
    border-bottom: 1px solid var(--sidebar-border);
    flex-shrink: 0;
}
.sidebar-logo {
    width: 28px; height: 28px; border-radius: 6px;
    background: #2563eb; display: flex; align-items: center; justify-content: center;
    font-weight: 700; color: #fff; font-size: 12px; flex-shrink: 0;
}
.sidebar-title {
    color: #fff; font-weight: 600; font-size: 14px; letter-spacing: .5px;
    white-space: nowrap; opacity: 1; transition: opacity .2s;
}
#sidebar.collapsed .sidebar-title { display: none; }
#sidebar.collapsed .sidebar-header {
    height: 48px;
    padding: 0 6px;
    padding-right: 6px;
    justify-content: center;
    align-items: center;
}
#sidebar.collapsed .sidebar-logo { display: none; }

/* Sidebar Search */
.sidebar-search {
    padding: 10px 10px;
    border-bottom: 1px solid var(--sidebar-border);
    flex-shrink: 0;
    transition: var(--transition);
}
#sidebar.collapsed .sidebar-search { display: none; }
.ws-server-nav .nav-l1.ws-nav-l1.ws-nav-filter-hidden { display: none !important; }
.sidebar-search .input-wrap {
    position: relative;
}
.sidebar-search input {
    width: 100%; background: var(--grova-night-canvas); border: 1px solid rgba(148, 163, 184, 0.32); border-radius: 6px;
    color: #f1f5f9; font-size: 12px; padding: 6px 32px 6px 30px; outline: none;
    box-sizing: border-box;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.18);
}
.sidebar-search input::placeholder { color: #94a3b8; }
.sidebar-search input:focus { border-color: rgba(59, 130, 246, 0.6); }
.sidebar-search .search-icon {
    position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; pointer-events: none;
}
.sidebar-search-clear {
    position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
    width: 22px; height: 22px; border: none; border-radius: 4px;
    background: transparent; color: #6b7280; cursor: pointer;
    display: none; align-items: center; justify-content: center;
    padding: 0; line-height: 0;
}
.sidebar-search .input-wrap.has-value .sidebar-search-clear { display: flex; }
.sidebar-search-clear:hover { background: rgba(15, 23, 42, 0.85); color: #f1f5f9; }

/* Sidebar Nav: sin padding horizontal (fondos a ancho completo); jerarquía por padding izq. */
#sidebar-nav {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 8px 0;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    --nav-indent-l1: 14px;
    --nav-indent-l2: 32px;
    --nav-indent-l3: 54px;
}
#sidebar-nav::-webkit-scrollbar { width: 6px; }
#sidebar-nav::-webkit-scrollbar-track { background: transparent; }
#sidebar-nav::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 999px;
}
#sidebar:hover #sidebar-nav,
#sidebar:focus-within #sidebar-nav,
body.sidebar-mobile-open #sidebar-nav {
    scrollbar-color: #475569 transparent;
}
#sidebar:hover #sidebar-nav::-webkit-scrollbar-thumb,
#sidebar:focus-within #sidebar-nav::-webkit-scrollbar-thumb,
body.sidebar-mobile-open #sidebar-nav::-webkit-scrollbar-thumb {
    background: #475569;
}
#sidebar:hover #sidebar-nav::-webkit-scrollbar-thumb:hover,
#sidebar:focus-within #sidebar-nav::-webkit-scrollbar-thumb:hover,
body.sidebar-mobile-open #sidebar-nav::-webkit-scrollbar-thumb:hover {
    background: #64748b;
}

/* L1 */
.nav-l1 { margin-bottom: 0; }
.nav-l1-btn {
    width: 100%; display: flex; align-items: center; gap: 10px;
    padding: 10px 12px 10px var(--nav-indent-l1, 14px); border-radius: 0; border: none;
    background: transparent; color: #cbd5e1;
    font-size: 13px; font-weight: 600; text-align: left; cursor: pointer;
    transition: background .15s, color .15s;
    white-space: normal;
}
a.nav-l1-btn, a.nav-l2-btn, a.nav-l3-btn {
    text-decoration: none;
    box-sizing: border-box;
}
.nav-l1-btn:hover { background: var(--nav-hover); color: #e5e7eb; }
.nav-l1-btn.active { background: var(--nav-hover); color: #fff; }
.nav-l1-btn.active-leaf { background: #2563eb; color: #fff; }
.nav-l1-btn .nav-icon { flex-shrink: 0; color: #94a3b8; }
.nav-l1-btn.active .nav-icon,
.nav-l1-btn.active-leaf .nav-icon { color: #93c5fd; }
.nav-l1-btn .nav-label {
    flex: 1;
    line-height: 1.25;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
}
.nav-l1-btn .nav-chevron { flex-shrink: 0; color: #94a3b8; transition: transform .2s; }
.nav-l1-btn.open .nav-chevron { transform: rotate(180deg); }
.menu-status-badge {
    margin-left: 6px; flex-shrink: 0;
    display: inline-flex; align-items: center;
    font-size: 9px; font-weight: 700; letter-spacing: .02em;
    color: #f59e0b; background: rgba(245,158,11,.14);
    border: 1px solid rgba(245,158,11,.45); border-radius: 999px; padding: 1px 6px;
}
body.light-mode .menu-status-badge {
    color: #b45309; background: #fef3c7; border-color: #f59e0b;
}

/* ── Menu: Premium / UI Style (controlado por variables) ── */
.menu-ui {
    --menu-bg: transparent;
    /* inherit tomaba #1e293b del body en light-mode; fallback explícito al sidebar */
    --menu-text: #e2e8f0;
    --menu-border: transparent;
    --menu-hover-bg: var(--nav-hover);
    --menu-hover-text: #e5e7eb;
    background: var(--menu-bg);
    color: var(--menu-text);
    border: none;
}
.menu-ui:hover {
    background: var(--menu-hover-bg);
    color: var(--menu-hover-text);
}
.nav-l1-btn.menu-ui,
.nav-l2-btn.menu-ui,
.nav-l3-btn.menu-ui {
    background: var(--menu-bg) !important;
    color: var(--menu-text) !important;
    /* Minimalista: sin caja/borde por ítem; premium sigue con tinte vía --menu-bg */
    border: none !important;
    box-shadow: none;
}
.nav-l1-btn.menu-ui:hover,
.nav-l2-btn.menu-ui:hover,
.nav-l3-btn.menu-ui:hover {
    background: var(--menu-hover-bg) !important;
    color: var(--menu-hover-text) !important;
}
/* Activo: solo fondo / color (sin anillos ni bordes apilados) */
.nav-l1-btn.menu-ui.active,
.nav-l1-btn.menu-ui.active-leaf,
.nav-l2-btn.menu-ui.active,
.nav-l2-btn.menu-ui.active-leaf,
.nav-l3-btn.menu-ui.active,
.nav-l3-btn.menu-ui.active-leaf {
    box-shadow: none;
    filter: none;
}
.nav-l1-btn.menu-ui.active-leaf { --menu-text: #fff; --menu-hover-text: #f1f5f9; }
.nav-l2-btn.menu-ui.active,
.nav-l2-btn.menu-ui.active-leaf,
.nav-l3-btn.menu-ui.active { --menu-text: #e0f2fe; --menu-hover-text: #f0f9ff; }
/* L1 enlace hoja: acento sólido (solo <a>, no <summary>) */
#sidebar-nav a.nav-l1-btn.menu-ui.active-leaf {
    background: #1d4ed8 !important;
    color: #f8fafc !important;
}
/* Premium L1: conservar tinte */
#sidebar-nav a.nav-l1-btn.menu-ui.active-leaf[style*='--menu-bg'] {
    background: var(--menu-bg) !important;
    color: var(--menu-text) !important;
    box-shadow: none;
}
#sidebar-nav .nav-l2-btn.menu-ui.active,
#sidebar-nav .nav-l2-btn.menu-ui.active-leaf,
#sidebar-nav .nav-l3-btn.menu-ui.active:not(.nav-active-current) {
    background: rgba(37, 99, 235, 0.12) !important;
    border-radius: 0;
}
/* Antecesentes de la ruta (ancho completo, sin sombras / líneas) */
#sidebar-nav summary.nav-l1-btn.nav-on-trail,
#sidebar-nav summary.nav-l2-btn.nav-on-trail,
#sidebar-nav a.nav-l1-btn.menu-ui.nav-on-trail:not(.active-leaf),
#sidebar-nav a.nav-l2-btn.menu-ui.nav-on-trail:not(.active-leaf) {
    color: #e0f2fe !important;
    --menu-text: #e0f2fe;
    --menu-hover-text: #f8fafc;
    background: rgba(37, 99, 235, 0.12) !important;
    --menu-bg: rgba(37, 99, 235, 0.12);
    font-weight: 500;
    border-radius: 0;
    box-shadow: none;
}
#sidebar-nav summary.nav-on-trail .nav-chevron,
#sidebar-nav a.nav-on-trail .nav-chevron { color: #93c5fd; }
#sidebar-nav summary.nav-on-trail.menu-ui[style*='--menu-bg'],
#sidebar-nav a.nav-on-trail.menu-ui[style*='--menu-bg'] {
    background: var(--menu-bg) !important;
    color: var(--menu-text) !important;
    box-shadow: none;
}
/* L3: vista actual */
#sidebar-nav .nav-l3-btn.menu-ui.active.nav-active-current {
    background: rgba(30, 58, 138, 0.85) !important;
    color: #f8fafc !important;
    --menu-text: #f8fafc !important;
    font-weight: 600;
    border-radius: 0;
    box-shadow: none;
}
.menu-ui .nav-icon { color: currentColor; opacity: .9; }
.menu-premium-badge {
    margin-left: 6px; flex-shrink: 0;
    display: inline-flex; align-items: center;
    font-size: 9px; font-weight: 800; letter-spacing: .03em;
    color: #422006; background: rgba(254, 243, 199, 0.95);
    border: none;
    border-radius: 999px; padding: 2px 7px;
}

/* Collapsed icon-only */
#sidebar.collapsed .nav-l1-btn {
    justify-content: center; padding: 10px 4px;
    min-height: 44px;
}
#sidebar.collapsed .nav-label,
#sidebar.collapsed .nav-chevron { display: none; }

/* Colapsado: un solo L1 con flyout; submenú ancho y desplazado a la derecha */
#sidebar.collapsed .ws-server-nav .nav-l2-wrap {
    margin-left: 0;
    margin-top: 4px;
    padding-left: 0;
    border-left: none;
}
#sidebar.collapsed .ws-server-nav .nav-l3-wrap {
    margin-left: 0;
    margin-top: 4px;
    padding-left: 0;
    border: none;
}
#sidebar.collapsed .nav-l1.ws-nav-l1 > .ws-details[open] > .ws-sub {
    position: fixed;
    z-index: 1;
    left: var(--sidebar-w-collapsed);
    min-width: 220px;
    max-width: min(300px, calc(100vw - var(--sidebar-w-collapsed) - 12px));
    max-height: min(70vh, 520px);
    overflow-y: auto;
    overflow-x: hidden;
    margin: 0 !important;
    padding: 10px 10px 12px !important;
    border: 1px solid var(--sidebar-border);
    border-left: none;
    border-radius: 0 10px 10px 0;
    background: var(--sidebar-bg);
    box-shadow: 6px 6px 28px rgba(0, 0, 0, 0.45);
    -webkit-overflow-scrolling: touch;
    --nav-indent-l1: 12px;
    --nav-indent-l2: 22px;
    --nav-indent-l3: 36px;
}

/* L2 / L3: ancho completo; jerarquía solo con padding de fila (no líneas) */
.nav-l2-wrap { margin: 0; padding: 0; border: none; }
.nav-l2-btn {
    width: 100%; display: flex; align-items: center; gap: 8px;
    padding: 8px 12px 8px var(--nav-indent-l2, 32px); border-radius: 0; border: none;
    background: transparent; color: #cbd5e1;
    font-size: 12px; font-weight: 500; text-align: left; cursor: pointer;
    transition: background .15s, color .15s;
    white-space: normal;
}
.nav-l2-btn .flex-1 {
    min-width: 0;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1.2;
}
.nav-l2-btn:hover { background: var(--nav-hover); color: #f1f5f9; }
.nav-l2-btn.active { background: rgba(37,99,235,.1); color: #60a5fa; font-weight: 500; }
.nav-l2-btn.active-leaf { background: rgba(37,99,235,.15); color: #60a5fa; font-weight: 500; }
.nav-l2-btn .nav-icon { flex-shrink: 0; color: #94a3b8; }
.nav-l2-btn.active .nav-icon,
.nav-l2-btn.active-leaf .nav-icon { color: #3b82f6; }
.nav-l2-btn .nav-chevron { flex-shrink: 0; color: #94a3b8; transition: transform .2s; }
.nav-l2-btn.open .nav-chevron { transform: rotate(180deg); }

.nav-l3-wrap { margin: 0; padding: 0; border: none; }
.nav-l3-btn {
    width: 100%; display: flex; align-items: center; gap: 7px;
    padding: 7px 12px 7px var(--nav-indent-l3, 54px); border-radius: 0; border: none;
    background: transparent; color: #94a3b8;
    font-size: 11px; font-weight: 400; text-align: left; cursor: pointer;
    transition: color .15s;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
}
.nav-l3-btn:hover { color: #e2e8f0; }
.nav-l3-btn.active { color: #93c5fd; font-weight: 600; }
a.nav-l3-btn { text-decoration: none; color: inherit; box-sizing: border-box; }
a.nav-l3-btn:hover { color: #e2e8f0; }
a.nav-l3-btn.active { color: #93c5fd; font-weight: 600; }
.nav-l3-btn .nav-icon { flex-shrink: 0; color: #94a3b8; }
.nav-l3-btn.active .nav-icon { color: #3b82f6; }
/* <details> del menú server-side (sustituye .open en el demo JS) */
.ws-server-nav details[open] > summary .nav-chevron { transform: rotate(180deg); }
.ws-server-nav summary.nav-l1-btn,
.ws-server-nav summary.nav-l2-btn { list-style: none; }

/* Sidebar Bottom */
.sidebar-bottom {
    border-top: 1px solid var(--sidebar-border);
    padding: 10px 8px;
    flex-shrink: 0;
}
.sidebar-user {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 8px; border-radius: 7px; cursor: pointer;
    transition: background .15s;
    text-decoration: none;
}
.sidebar-user:hover { background: var(--nav-hover); }
.sidebar-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: #2563eb; display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 11px; font-weight: 700; flex-shrink: 0;
}
.sidebar-user-info { flex: 1; min-width: 0; }
.sidebar-user-name { color: #fff; font-size: 12px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sidebar-user-email { color: #94a3b8; font-size: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
#sidebar.collapsed .sidebar-user-info,
#sidebar.collapsed .sidebar-logout-icon { display: none; }
#sidebar.collapsed .sidebar-user { justify-content: center; }

/* Tooltip for collapsed state */
/* Tooltips de nav colapsada: encima de navbar (400) y del panel de filtros */
.nav-tooltip {
    position: fixed; z-index: var(--z-nav-tooltip); pointer-events: none;
    background: #1f2937; color: #fff; font-size: 12px;
    padding: 5px 10px; border-radius: 6px;
    border: 1px solid #374151; white-space: nowrap;
    box-shadow: 0 4px 12px rgba(0,0,0,.4);
    display: none;
}

/* ── Toggle menú: anclado a la cabecera del sidebar (no sobre el navbar) ── */
#sidebar-toggle {
    position: absolute;
    z-index: 5;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    border-radius: 7px;
    border: 1px solid rgba(148, 163, 184, 0.25);
    background: rgba(15, 23, 42, 0.65);
    color: #cbd5e1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .15s, color .15s, border-color .15s, box-shadow .15s, transform .2s ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
}
#sidebar-toggle:hover {
    background: rgba(30, 41, 59, 0.95);
    color: #f1f5f9;
    border-color: rgba(148, 163, 184, 0.45);
}
#sidebar-toggle:focus-visible { outline: 2px solid #2563eb; outline-offset: 2px; }
#sidebar.collapsed #sidebar-toggle {
    left: 50%;
    right: auto;
    transform: translate(-50%, -50%);
}
#sidebar.collapsed #sidebar-toggle:hover {
    transform: translate(-50%, -50%);
}

/* Franja dev dentro del navbar (visible aunque el body no tenga la barra global) */
.navbar-dev-franja {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(90deg, #f59e0b, #ef4444, #f59e0b);
    background-size: 200% 100%;
    animation: devBar 2s linear infinite;
}
body.grova-dev-chrome-off .navbar-dev-franja { display: none; }

/* ── Navbar (por encima del contenedor y del cajón de filtros) ── */
#navbar {
    position: fixed; top: 0; right: 0; height: 56px; z-index: var(--z-chrome);
    left: var(--sidebar-w);
    background: var(--grova-night-chrome); border-bottom: 1px solid var(--sidebar-border);
    display: flex; align-items: center; padding: 0 16px; gap: 10px;
    transition: left .28s ease;
}
body.sidebar-collapsed #navbar { left: var(--sidebar-w-collapsed); }
body.light-mode #navbar { background: #fff; border-bottom-color: #e2e8f0; }

.navbar-search {
    flex: 1 1 520px;
    max-width: min(620px, 52vw);
    min-width: 220px;
    position: relative;
}
.navbar-search input {
    width: 100%; background: var(--grova-night-canvas); border: 1px solid #334155;
    border-radius: 7px; color: #e2e8f0; font-size: 13px;
    padding: 7px 36px 7px 36px; outline: none;
    box-sizing: border-box;
}
.navbar-search input:focus { border-color: #2563eb; }
.navbar-search input::placeholder { color: #475569; }
.navbar-search .search-icon {
    position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: #475569;
}
.navbar-search-kbd {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    font-size: 10px; font-weight: 600; letter-spacing: .02em;
    color: #64748b; border: 1px solid #334155; border-radius: 4px;
    padding: 2px 6px; line-height: 1; pointer-events: none;
    background: rgba(15, 23, 42, 0.45);
}
.navbar-search-clear {
    position: absolute; right: 5px; top: 50%; transform: translateY(-50%);
    width: 26px; height: 26px; border: none; border-radius: 5px;
    background: transparent; color: #64748b; cursor: pointer;
    display: none; align-items: center; justify-content: center;
    padding: 0; line-height: 0;
}
.navbar-search.has-value .navbar-search-clear { display: flex; }
.navbar-search.has-value .navbar-search-kbd,
.navbar-search input:focus + .navbar-search-kbd { display: none; }
.navbar-search-clear:hover { background: #334155; color: #e2e8f0; }
body.light-mode .navbar-search-clear:hover { background: #e2e8f0; color: #334155; }
body.light-mode .navbar-search input { background: #f8fafc; border-color: #e2e8f0; color: #1e293b; }
body.light-mode .navbar-search input::placeholder { color: #94a3b8; }
body.light-mode .navbar-search-kbd { border-color: #dbe3ee; color: #94a3b8; background: #fff; }

.navbar-actions { margin-left: auto; display: flex; align-items: center; gap: 4px; }
.nav-btn {
    width: 34px; height: 34px; border-radius: 7px; border: none;
    background: transparent; color: #64748b; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s, color .15s; position: relative;
}
.nav-btn:hover { background: #334155; color: #e2e8f0; }
body.light-mode .nav-btn:hover { background: #f1f5f9; color: #334155; }
a.nav-btn { text-decoration: none; color: inherit; }

.nav-divider { width: 1px; height: 24px; background: #334155; margin: 0 4px; }
body.light-mode .nav-divider { background: #e2e8f0; }

.notif-dot {
    position: absolute; top: 6px; right: 6px; width: 8px; height: 8px;
    background: #ef4444; border-radius: 50%; border: 2px solid #1e293b;
}
body.light-mode .notif-dot { border-color: #fff; }

/* Profile dropdown */
.profile-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 8px 4px 4px; border-radius: 7px; border: none;
    background: transparent; cursor: pointer; transition: background .15s;
}
.profile-btn:hover { background: #334155; }
body.light-mode .profile-btn:hover { background: #f1f5f9; }
.profile-badge {
    font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px;
    border: 1px solid #3b82f6; color: #60a5fa; background: rgba(37,99,235,.15);
}
body.light-mode .profile-badge { border-color: #93c5fd; color: #2563eb; background: #eff6ff; }
.profile-name { font-size: 13px; font-weight: 500; color: #e2e8f0; }
body.light-mode .profile-name { color: #1e293b; }
.profile-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: #2563eb; display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 11px; font-weight: 700;
}

.profile-dropdown {
    position: absolute; top: calc(100% + 6px); right: 0;
    width: 220px; background: #1e293b; border: 1px solid #334155;
    border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,.4);
    z-index: 200; overflow: hidden;
}
body.light-mode .profile-dropdown { background: #fff; border-color: #e2e8f0; }
.profile-dropdown-header {
    padding: 14px 16px; border-bottom: 1px solid #334155;
}
body.light-mode .profile-dropdown-header { border-bottom-color: #e2e8f0; }
.profile-dropdown-header .name { font-size: 13px; font-weight: 500; color: #e2e8f0; }
body.light-mode .profile-dropdown-header .name { color: #1e293b; }
.profile-dropdown-header .email { font-size: 11px; color: #64748b; }
.profile-dropdown-item {
    width: 100%; display: flex; align-items: center; gap: 10px;
    padding: 10px 16px; background: transparent; border: none;
    color: #94a3b8; font-size: 13px; cursor: pointer; text-align: left;
    transition: background .15s, color .15s;
}
.profile-dropdown-item:hover { background: #0f172a; color: #e2e8f0; }
body.light-mode .profile-dropdown-item:hover { background: #f8fafc; color: #1e293b; }
.profile-dropdown-item.danger { color: #ef4444; }
.profile-dropdown-item.danger:hover { background: #fef2f2; color: #dc2626; }
.profile-dropdown-divider { height: 1px; background: #334155; margin: 4px 0; }
body.light-mode .profile-dropdown-divider { background: #e2e8f0; }
#profile-wrap { position: relative; }

/* ── Dev mode badge ── */
.dev-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    color: #fff; font-size: 10px; font-weight: 700;
    padding: 3px 10px; border-radius: 20px;
    text-transform: uppercase; letter-spacing: 1px;
    box-shadow: 0 0 10px rgba(245,158,11,.5);
    animation: devPulse 2s ease-in-out infinite;
    white-space: nowrap;
}
.dev-badge .dev-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #fff;
    animation: devBlink 1s ease-in-out infinite;
}
@keyframes devPulse {
    0%, 100% { box-shadow: 0 0 8px rgba(245,158,11,.4); }
    50%       { box-shadow: 0 0 18px rgba(245,158,11,.8); }
}
@keyframes devBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: .3; }
}

/* ── Dev top bar (por encima del cromo 400 para que sea visible) ── */
#dev-topbar {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: calc(var(--z-chrome) + 15);
    height: 3px;
    pointer-events: none;
    background: linear-gradient(90deg, #f59e0b, #ef4444, #f59e0b);
    background-size: 200% 100%;
    animation: devBar 2s linear infinite;
}
@keyframes devBar {
    0%   { background-position: 0% 0; }
    100% { background-position: 200% 0; }
}

/* Franja Grova en el borde superior de la Web Debug Toolbar (misma animación que #dev-topbar). */
.sf-toolbar .sf-toolbarreset::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 3px;
    z-index: 5;
    background: linear-gradient(90deg, #f59e0b, #ef4444, #f59e0b);
    background-size: 200% 100%;
    animation: devBar 2s linear infinite;
    pointer-events: none;
}
body.grova-dev-chrome-off .sf-toolbar .sf-toolbarreset::before {
    display: none;
}

/* ── Dev switch en dropdown ── */
.dev-switch-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    border-top: 1px solid #334155;
}
body.light-mode .dev-switch-row { border-top-color: #e2e8f0; }

/* ── Language combo ── */
.lang-combo { position: relative; }
.lang-combo-trigger {
    display: flex; align-items: center; gap: 6px;
    padding: 5px 10px; border-radius: 7px; border: 1px solid #334155;
    background: #0f172a; color: #94a3b8;
    font-size: 12px; font-weight: 500; cursor: pointer;
    transition: border-color .15s, color .15s; white-space: nowrap;
}
.lang-combo-trigger:hover { border-color: #475569; color: #e2e8f0; }
.lang-combo-trigger .lc-flag { font-size: 15px; line-height: 1; }
.lang-combo-trigger .lc-code { font-size: 11px; letter-spacing: .4px; }
.lang-combo-trigger .lc-chevron { color: #475569; transition: transform .2s; }
.lang-combo.open .lc-chevron { transform: rotate(180deg); }
body.light-mode .lang-combo-trigger { background: #f8fafc; border-color: #e2e8f0; color: #64748b; }
body.light-mode .lang-combo-trigger:hover { border-color: #94a3b8; color: #1e293b; }

.lang-combo-list {
    position: absolute; top: calc(100% + 6px); right: 0;
    min-width: 130px; background: #1e293b; border: 1px solid #334155;
    border-radius: 8px; box-shadow: 0 8px 20px rgba(0,0,0,.4);
    z-index: 300; overflow: hidden;
    display: none;
}
.lang-combo.open .lang-combo-list { display: block; }
body.light-mode .lang-combo-list { background: #fff; border-color: #e2e8f0; box-shadow: 0 8px 20px rgba(0,0,0,.1); }

.lang-combo-option {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 12px; text-decoration: none;
    font-size: 12px; font-weight: 500; color: #94a3b8;
    transition: background .12s, color .12s; cursor: pointer;
    border: none; background: transparent; width: 100%; text-align: left;
}
.lang-combo-option:hover { background: #0f172a; color: #e2e8f0; }
.lang-combo-option.active { color: #60a5fa; }
.lang-combo-option .lc-check { margin-left: auto; color: #3b82f6; }
body.light-mode .lang-combo-option { color: #64748b; }
body.light-mode .lang-combo-option:hover { background: #f8fafc; color: #1e293b; }
body.light-mode .lang-combo-option.active { color: #2563eb; }
body.light-mode .lang-combo-option .lc-check { color: #2563eb; }

/* Inline combo (inside profile dropdown) */
.lang-combo-inline .lang-combo-trigger {
    width: 100%; background: transparent; border-color: #334155;
    color: #94a3b8; padding: 7px 12px;
}
.lang-combo-inline .lang-combo-trigger:hover { background: #0f172a; color: #e2e8f0; }
.lang-combo-inline .lang-combo-list {
    position: static; box-shadow: none;
    border: 1px solid #334155; border-radius: 6px;
    margin: 4px 0 2px; background: #0f172a;
}
body.light-mode .lang-combo-inline .lang-combo-trigger { background: transparent; border-color: #e2e8f0; }
body.light-mode .lang-combo-inline .lang-combo-trigger:hover { background: #f8fafc; }
body.light-mode .lang-combo-inline .lang-combo-list { background: #f8fafc; border-color: #e2e8f0; }
/* Tema: verde “on” típico; dev: mantiene ámbar (form-switch-dev--dev) */
.dev-switch-label {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 600;
}
.dev-switch-row--theme .dev-switch-label { color: #22c55e; }
.dev-switch-row--theme .dev-switch-label svg { color: #22c55e; }
.dev-switch-row--dev .dev-switch-label { color: #f59e0b; }
.dev-switch-row--dev .dev-switch-label svg { color: #f59e0b; }

.form-switch-dev { position: relative; display: inline-block; width: 36px; height: 20px; }
.form-switch-dev input { opacity: 0; width: 0; height: 0; }
.form-switch-dev .slider {
    position: absolute; cursor: pointer; inset: 0;
    background: #334155; border-radius: 20px; transition: .3s;
    border: 1px solid transparent;
}
.form-switch-dev .slider:before {
    content: ''; position: absolute;
    width: 14px; height: 14px; border-radius: 50%;
    left: 3px; bottom: 2px; background: #64748b;
    transition: .3s;
}
.form-switch-dev input:checked + .slider { background: rgba(34,197,94,.22); border: 1px solid #22c55e; }
.form-switch-dev input:checked + .slider:before { transform: translateX(16px); background: #22c55e; }
.form-switch-dev--dev input:checked + .slider { background: rgba(245,158,11,.3); border: 1px solid #f59e0b; }
.form-switch-dev--dev input:checked + .slider:before { background: #f59e0b; }

/* Columna principal (contenido + pie): desplazada bajo navbar fijo; flex para pie al final sin solaparse */
.grova-app-column {
    box-sizing: border-box;
    margin-left: var(--sidebar-w);
    margin-top: 56px;
    height: calc(100vh - 56px);
    width: calc(100% - var(--sidebar-w));
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: margin-left .28s ease, width .28s ease;
    background: var(--grova-night-canvas);
}
.grova-app-column::-webkit-scrollbar { width: 8px; }
.grova-app-column::-webkit-scrollbar-track { background: transparent; }
.grova-app-column::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 999px;
}
.grova-app-column:hover {
    scrollbar-color: #475569 transparent;
}
.grova-app-column:hover::-webkit-scrollbar-thumb {
    background: #475569;
}
.grova-app-column:hover::-webkit-scrollbar-thumb:hover {
    background: #64748b;
}
body.sidebar-collapsed .grova-app-column {
    margin-left: var(--sidebar-w-collapsed);
    width: calc(100% - var(--sidebar-w-collapsed));
}

/* ── Main content (z-index bajo: debajo de filtros y del cromo) ── */
#main {
    position: relative;
    z-index: var(--z-main);
    flex: 1 1 auto;
    padding: 24px;
    box-sizing: border-box;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
}
#main::-webkit-scrollbar { width: 8px; }
#main::-webkit-scrollbar-track { background: transparent; }
#main::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 999px;
}
#main:hover {
    scrollbar-color: #475569 transparent;
}
#main:hover::-webkit-scrollbar-thumb {
    background: #475569;
}
#main:hover::-webkit-scrollbar-thumb:hover {
    background: #64748b;
}
body.light-mode #main { background: #f1f5f9; color: #1e293b; }

/* Pie: dentro de .grova-app-column; sin z-index de cromo (evita que flote sobre #main) */
.grova-app-footer-strip {
    position: relative;
    z-index: auto;
    flex-shrink: 0;
    box-sizing: border-box;
    width: 100%;
    margin-top: 24px;
    padding: 0 0 24px;
}

/* ── Breadcrumb ── */
.grova-breadcrumb {
    display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap;
    margin-bottom: 20px; padding: 6px 12px;
    border: 1px solid #334155; border-radius: 10px;
    background: rgba(15, 23, 42, 0.45);
}
.grova-breadcrumb-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(30, 41, 59, 0.75);
    color: #93c5fd;
    text-decoration: none;
    flex-shrink: 0;
    transition: background .15s, color .15s, border-color .15s;
}
.grova-breadcrumb-back:hover {
    color: #e2e8f0;
    background: rgba(51, 65, 85, 0.85);
    border-color: rgba(148, 163, 184, 0.55);
}
.grova-breadcrumb-back i { font-size: 14px; line-height: 1; }
body.light-mode .grova-breadcrumb-back {
    border-color: #dbe3ee;
    background: #f8fafc;
    color: #2563eb;
}
body.light-mode .grova-breadcrumb-back:hover {
    background: #eff6ff;
    color: #1d4ed8;
    border-color: #93c5fd;
}
.grova-breadcrumb a, .grova-breadcrumb button {
    background: none; border: none; padding: 0; cursor: pointer;
    font-size: 12px; color: #cbd5e1; transition: color .15s; text-decoration: none;
}
.grova-breadcrumb a:hover, .grova-breadcrumb button:hover { color: #93c5fd; }
.grova-breadcrumb .breadcrumb-home {
    display: inline-flex; align-items: center; gap: 6px;
}
.grova-breadcrumb .breadcrumb-home-icon {
    width: 18px; height: 18px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(30, 41, 59, 0.7);
    color: #93c5fd; font-size: 10px; line-height: 1;
}
.grova-breadcrumb .current { font-size: 12px; color: #e2e8f0; font-weight: 600; }
.grova-breadcrumb .sep { color: #64748b; font-size: 11px; }
body.light-mode .grova-breadcrumb {
    background: #fff; border-color: #e2e8f0;
}
body.light-mode .grova-breadcrumb a,
body.light-mode .grova-breadcrumb button { color: #64748b; }
body.light-mode .grova-breadcrumb a:hover,
body.light-mode .grova-breadcrumb button:hover { color: #2563eb; }
body.light-mode .grova-breadcrumb .current { color: #1e293b; }
body.light-mode .grova-breadcrumb .sep { color: #94a3b8; }
body.light-mode .grova-breadcrumb .breadcrumb-home-icon {
    border-color: #dbe3ee; background: #f8fafc; color: #2563eb;
}

/* ── Page Header ── */
.page-header { margin-bottom: 24px; }
.page-header h1 { font-size: 22px; font-weight: 700; color: #f1f5f9; margin: 0 0 4px; }
body.light-mode .page-header h1 { color: #1e293b; }
.page-header p { font-size: 13px; color: #64748b; margin: 0; }
body:not(.light-mode) #page-subtitle.text-muted { color: #94a3b8 !important; }

/* ── Stat cards ── */
.stat-card {
    background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px;
}
body.light-mode .stat-card { background: #fff; border-color: #e2e8f0; }
.stat-card .stat-label { font-size: 11px; color: #64748b; font-weight: 500; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px; }
.stat-card .stat-value { font-size: 26px; font-weight: 700; color: #f1f5f9; line-height: 1; margin-bottom: 6px; }
body.light-mode .stat-card .stat-value { color: #1e293b; }
.stat-card .stat-change { font-size: 11px; color: #22c55e; }
.stat-card .stat-change.down { color: #ef4444; }

/* ── Content card ── */
.content-card {
    background: #1e293b; border: 1px solid #334155; border-radius: 12px;
}
body.light-mode .content-card { background: #fff; border-color: #e2e8f0; }
.content-card-header {
    padding: 16px 20px; border-bottom: 1px solid #334155;
    font-size: 14px; font-weight: 600; color: #f1f5f9;
    display: flex; align-items: center; justify-content: space-between;
}
body.light-mode .content-card-header { border-bottom-color: #e2e8f0; color: #1e293b; }
.content-card-body { padding: 20px; }
.swal-template { display: none; }
.menu-manager-template { display: none; }
.swal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px;
}
.swal-result {
    margin-top: 12px;
    font-size: 12px;
    color: #94a3b8;
}
body.light-mode .swal-result { color: #475569; }

/* Campos de filtro dentro de modales Swal (misma piel que #filters-panel) */
.swal2-html-container .grova-swal-filter-fields {
    --grova-filter-label: #94a3b8;
    --grova-filter-input-bg: #0b1220;
    --grova-filter-input-border: #334155;
    --grova-filter-input-text: #e2e8f0;
    --grova-filter-input-placeholder: #64748b;
    --grova-filter-focus-border: #3b82f6;
