/* Resumen de filtros activos (patrón global bajo título de página) */
.active-filters-row {
    display: none;
    margin-bottom: 14px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #334155;
    background: rgba(15, 23, 42, 0.65);
}
body.light-mode .active-filters-row {
    border-color: #e2e8f0;
    background: #f8fafc;
}
.active-filters-row.show { display: block; }
.active-filters-label {
    font-size: 11px;
    color: #f87171;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-right: 6px;
}
body.light-mode .active-filters-label { color: #dc2626; }
.active-filters-text {
    cursor: pointer;
    color: #fb7185;
