body.light-mode .filter-demo-item label { color: #64748b; }
body.light-mode .filter-demo-item input,
body.light-mode .filter-demo-item select {
    border-color: #dbe3ee;
    background: #fff;
    color: #1e293b;
}
body.light-mode .filter-demo-chip {
    border-color: #dbe3ee;
