}
body.grova-filters-select2-open:not(.light-mode) .select2-dropdown .select2-search--dropdown .select2-search__field {
    background-color: #0b1220 !important;
    border: 1px solid #334155 !important;
    color: #e2e8f0 !important;
}
body.grova-filters-select2-open.light-mode .select2-dropdown,
body.grova-filters-select2-open.light-mode .select2-dropdown.grova-filter-select2-dropdown {
    background-color: #ffffff !important;
    border-color: #dbe3ee !important;
