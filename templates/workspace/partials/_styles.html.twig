    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    cursor: pointer;
    vertical-align: middle;
    transition: background 0.15s ease, transform 0.1s ease;
}
.active-filters-clear:hover {
    background: #dc2626;
}
.filter-demo-grid {
