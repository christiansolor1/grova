/* ── Panel lateral de filtros (sobre #main; bajo cromo sidebar/navbar/footer) ── */
#filters-toggle {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: var(--z-filters-toggle);
    width: 36px;
    padding: 10px 4px;
    border: 1px solid #334155;
    border-right: none;
    border-radius: 12px 0 0 12px;
    background: #111827;
    color: #94a3b8;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: right .28s ease, background .15s, color .15s;
}
#filters-toggle:hover { background: #1f2937; color: #e2e8f0; }
#filters-toggle .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
}
body.filters-open #filters-toggle { right: 340px; }

#filters-overlay {
    position: fixed;
    inset: 0;
    background: rgba(2, 6, 23, 0.45);
    z-index: var(--z-filters-overlay);
    opacity: 0;
    pointer-events: none;
    transition: opacity .25s ease;
}
body.filters-open #filters-overlay {
    opacity: 1;
    pointer-events: auto;
}

#filters-panel {
    position: fixed;
    top: 56px;
    right: 0;
    width: 340px;
    height: calc(100vh - 56px);
    z-index: var(--z-filters-panel);
    transform: translateX(100%);
    transition: transform .28s ease;
    border-left: 1px solid #334155;
    background: #0f172a;
    display: flex;
    flex-direction: column;
}
body.filters-open #filters-panel { transform: translateX(0); }
body.filters-open.filters-panel-wide #filters-toggle { right: 520px; }
body.filters-panel-wide #filters-panel { width: 520px; }
body.light-mode #filters-toggle {
    background: #fff;
    border-color: #dbe3ee;
    color: #64748b;
}
body.light-mode #filters-toggle:hover { background: #f8fafc; color: #1e293b; }
body.light-mode #filters-panel {
    background: #fff;
    border-left-color: #e2e8f0;
}

.filters-head {
    flex-shrink: 0;
    padding: 14px 16px;
    border-bottom: 1px solid #334155;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
