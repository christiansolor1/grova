/* Ocultar el <select> nativo cuando Select2 ya está activo */
#filters-panel select.grova-select2.select2-hidden-accessible {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
}

#filters-panel .filter-section-btn:focus-visible,
#filters-panel .filters-close:focus-visible,
#filters-toggle:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
}

body.light-mode #filters-panel:hover .filters-body,
body.light-mode #filters-panel:focus-within .filters-body {
    scrollbar-color: #cbd5e1 transparent;
}
body.light-mode #filters-panel:hover .filters-body::-webkit-scrollbar-thumb,
body.light-mode #filters-panel:focus-within .filters-body::-webkit-scrollbar-thumb {
    background: #cbd5e1;
}

.filter-section-content.filter-grid-two {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 8px 10px;
}
.filter-section.open .filter-section-content.filter-grid-two {
    display: grid;
}
.filter-grid-two .filter-field { margin-bottom: 0; }
@media (max-width: 860px) {
    body.filters-panel-wide #filters-panel {
