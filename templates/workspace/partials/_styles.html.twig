body.grova-filters-select2-open.light-mode .select2-dropdown .select2-results__option {
    color: #1e293b !important;
}
body.grova-filters-select2-open.light-mode .select2-dropdown .select2-results__option--highlighted,
body.grova-filters-select2-open.light-mode .select2-dropdown .select2-results__option--highlighted.select2-results__option--selectable {
    background-color: #eff6ff !important;
