{# Cajón fijo a la derecha: pestaña + panel (estilos en _styles.html.twig). #}
<div id="filters-overlay" aria-hidden="true"></div>
<button id="filters-toggle" type="button" title="{{ 'filters.open'|trans }}">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
    <span class="vertical-text">{{ 'filters.title'|trans }}</span>
</button>
<aside id="filters-panel" aria-label="{{ 'filters.panel'|trans }}">
    <div class="filters-head">
        <div class="filters-head-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
            {{ 'filters.title'|trans }}
        </div>
        <button id="filters-close" class="filters-close" type="button" title="{{ 'filters.close'|trans }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
    </div>
    <div id="filters-body" class="filters-body"></div>
    <div class="filters-foot">
        <button id="filters-apply" class="btn btn-sm btn-primary" type="button">{{ 'filters.apply'|trans }}</button>
        <button id="filters-reset" class="btn btn-sm btn-outline-secondary" type="button">{{ 'filters.reset'|trans }}</button>
    </div>
</aside>
