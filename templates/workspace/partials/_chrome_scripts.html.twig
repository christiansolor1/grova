<script>
(function () {
    window.GrovaUi = window.GrovaUi || {};
    window.GrovaUi.portalToBody = function (el) {
        if (!el || !el.parentNode) return el;
        if (el.parentNode !== document.body) {
            document.body.appendChild(el);
        }
        return el;
    };
    window.GrovaUi.portalAllToBody = function (selector) {
        document.querySelectorAll(selector).forEach(function (el) {
            window.GrovaUi.portalToBody(el);
        });
    };

    function getCookie(name) {
        return document.cookie.split('; ').reduce(function (acc, c) {
            var p = c.split('=');
            return p[0] === name ? decodeURIComponent(p[1] || '') : acc;
        }, null);
    }
    function setCookie(name, value, days) {
        var expires = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + expires + ';path=/;SameSite=Lax';
    }
    window.setCookie = setCookie;
    window.toggleLangCombo = function (id, e) {
        e.stopPropagation();
        var combo = document.getElementById('lang-combo-' + id);
        if (!combo) return;
        var isOpen = combo.classList.contains('open');
        document.querySelectorAll('.lang-combo.open').forEach(function (el) { el.classList.remove('open'); });
        if (!isOpen) combo.classList.add('open');
    };
    var sidebarCollapsed = localStorage.getItem('grova_sidebar') === '1';
    var darkMode = getCookie('grova_theme') !== 'light';
    var sidebarMobileOpen = false;

    function isMobileSidebarMode() {
        return window.matchMedia('(max-width: 992px)').matches;
    }

    function updateSidebarToggleUi() {
        var st = document.getElementById('sidebar-toggle');
        if (!st) return;
        st.setAttribute('aria-expanded', (!sidebarCollapsed).toString());
        st.setAttribute('aria-label', sidebarCollapsed
            ? (st.getAttribute('data-title-expand') || '')
            : (st.getAttribute('data-title-collapse') || ''));
        st.title = st.getAttribute('aria-label') || '';
    }

    function syncCollapsedFlyouts() {
        var side = document.getElementById('sidebar');
        if (!side) return;
        if (!side.classList.contains('collapsed')) {
            side.querySelectorAll('.nav-l1.ws-nav-l1 > .ws-details > .ws-sub').forEach(function (sub) {
                sub.style.removeProperty('top');
                sub.style.removeProperty('max-height');
            });
            return;
        }
        side.querySelectorAll('.nav-l1.ws-nav-l1 > .ws-details[open] > .ws-sub').forEach(function (sub) {
            var det = sub.parentElement;
            var sm = det && det.querySelector(':scope > summary');
            if (!sm) return;
            var r = sm.getBoundingClientRect();
            var top = Math.max(8, r.top);
            var maxH = Math.max(120, window.innerHeight - top - 12);
            sub.style.top = top + 'px';
            sub.style.maxHeight = maxH + 'px';
        });
    }

    function applySidebar() {
        var sidebar = document.getElementById('sidebar');
        if (!sidebar) return;
        if (isMobileSidebarMode()) {
            sidebar.classList.remove('collapsed');
            document.body.classList.remove('sidebar-collapsed');
            document.body.classList.toggle('sidebar-mobile-open', !!sidebarMobileOpen);
            updateSidebarToggleUi();
            return;
        }
        document.body.classList.remove('sidebar-mobile-open');
        sidebarMobileOpen = false;
        if (sidebarCollapsed) {
            sidebar.classList.add('collapsed');
            document.body.classList.add('sidebar-collapsed');
        } else {
            sidebar.classList.remove('collapsed');
            document.body.classList.remove('sidebar-collapsed');
        }
        updateSidebarToggleUi();
        syncCollapsedFlyouts();
    }
    function applyTheme() {
        var dd = document.getElementById('theme-toggle-dropdown');
        if (darkMode) {
            document.body.classList.remove('light-mode');
            document.body.setAttribute('data-bs-theme', 'dark');
            var sun = document.getElementById('icon-sun');
            var moon = document.getElementById('icon-moon');
            if (sun) sun.style.display = 'block';
            if (moon) moon.style.display = 'none';
            if (dd) dd.checked = true;
        } else {
            document.body.classList.add('light-mode');
            document.body.setAttribute('data-bs-theme', 'light');
            var sun2 = document.getElementById('icon-sun');
            var moon2 = document.getElementById('icon-moon');
            if (sun2) sun2.style.display = 'none';
            if (moon2) moon2.style.display = 'block';
            if (dd) dd.checked = false;
        }
    }

    var st = document.getElementById('sidebar-toggle');
    if (st) {
        st.addEventListener('click', function () {
            if (isMobileSidebarMode()) return;
            sidebarCollapsed = !sidebarCollapsed;
            localStorage.setItem('grova_sidebar', sidebarCollapsed ? '1' : '0');
            applySidebar();
        });
    }
    var navSt = document.getElementById('navbar-sidebar-toggle');
    if (navSt) {
        navSt.addEventListener('click', function (e) {
            if (!isMobileSidebarMode()) return;
            e.preventDefault();
            e.stopPropagation();
            sidebarMobileOpen = !sidebarMobileOpen;
            applySidebar();
        });
    }
    var tt = document.getElementById('theme-toggle');
    if (tt) {
        tt.addEventListener('click', function () {
            darkMode = !darkMode;
            setCookie('grova_theme', darkMode ? 'dark' : 'light', 365);
            applyTheme();
        });
    }
    var ttd = document.getElementById('theme-toggle-dropdown');
    if (ttd) {
        ttd.addEventListener('change', function (e) {
            darkMode = e.target.checked;
            setCookie('grova_theme', darkMode ? 'dark' : 'light', 365);
            applyTheme();
        });
    }
    var profileBtn = document.getElementById('profile-btn');
    var profileDropdown = document.getElementById('profile-dropdown');
    function setProfileDropdownOpen(open) {
        if (!profileDropdown) return;
        profileDropdown.style.display = open ? 'block' : 'none';
        if (profileBtn) {
            profileBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
    }
    if (profileBtn && profileDropdown) {
        profileBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var vis = profileDropdown.style.display === 'block';
            setProfileDropdownOpen(!vis);
        });
        profileDropdown.addEventListener('click', function (e) {
            e.stopPropagation();
        });
    }
    document.addEventListener('click', function (e) {
        document.querySelectorAll('.lang-combo.open').forEach(function (el) { el.classList.remove('open'); });
        var pd = document.getElementById('profile-dropdown');
        if (pd) setProfileDropdownOpen(false);
        if (isMobileSidebarMode() && document.body.classList.contains('sidebar-mobile-open') && e.target && !e.target.closest('#sidebar') && !e.target.closest('#navbar-sidebar-toggle')) {
            sidebarMobileOpen = false;
            applySidebar();
        }
        if (document.body.classList.contains('sidebar-collapsed') && e.target && !e.target.closest('#sidebar')) {
            closeCollapsedL1Flyouts();
        }
    });

    function closeCollapsedL1Flyouts() {
        var nav0 = document.getElementById('sidebar-nav');
        if (!nav0) return;
        nav0.querySelectorAll('.nav-l1.ws-nav-l1 > .ws-details[open]').forEach(function (d) {
            d.open = false;
        });
        nav0.querySelectorAll('.ws-sub details[open]').forEach(function (d) {
            d.open = false;
        });
        syncCollapsedFlyouts();
    }

    applySidebar();
    applyTheme();
    if (window.GrovaUi && typeof window.GrovaUi.portalAllToBody === 'function') {
        window.GrovaUi.portalAllToBody('[data-grova-portal="body"]');
    }

    /* Mismo “camino” abierto/activo que el demo: abrir <details> que contienen la hoja activa. */
    var nav = document.getElementById('sidebar-nav');
    if (nav) {
        var current = nav.querySelector('a.nav-l1-btn.active-leaf, a.nav-l2-btn.active-leaf, a.nav-l3-btn.active');
        if (current) {
            for (var el = current; el; el = el.parentElement) {
                if (el.tagName === 'DETAILS') {
                    el.open = true;
                    var sm2 = el.querySelector(':scope > summary');
                    if (sm2) sm2.classList.add('active');
                }
            }
        }
        syncCollapsedFlyouts();
    }

    function rebindSidebarAfterAjaxUpdate() {
        var nav2 = document.getElementById('sidebar-nav');
        if (!nav2) return;
        // Abrir la ruta activa si existe.
        var current2 = nav2.querySelector('a.nav-l1-btn.active-leaf, a.nav-l2-btn.active-leaf, a.nav-l3-btn.active');
        if (current2) {
            for (var el2 = current2; el2; el2 = el2.parentElement) {
                if (el2.tagName === 'DETAILS') {
                    el2.open = true;
                    var sm3 = el2.querySelector(':scope > summary');
                    if (sm3) sm3.classList.add('active');
                }
            }
        }
        syncCollapsedFlyouts();
    }

    document.addEventListener('grova:sidebar-updated', function () {
        rebindSidebarAfterAjaxUpdate();
    });

    /* Sidebar colapsado: tooltips con data-nav-tip + flyout L1 */
    var navTip = document.getElementById('nav-tooltip');
    var navTipHideTimer = null;
    function hideNavTip() {
        if (navTipHideTimer) clearTimeout(navTipHideTimer);
        navTipHideTimer = setTimeout(function () {
            if (navTip) navTip.style.display = 'none';
        }, 80);
    }
    if (nav && navTip) {
        nav.addEventListener('mouseover', function (e) {
            if (!document.getElementById('sidebar').classList.contains('collapsed')) {
                if (navTip) navTip.style.display = 'none';
                return;
            }
            var h = e.target && e.target.closest ? e.target.closest('[data-nav-tip]') : null;
            if (!h || !nav.contains(h)) return;
            var msg = h.getAttribute('data-nav-tip');
            if (!msg) return;
            if (navTipHideTimer) clearTimeout(navTipHideTimer);
            navTip.textContent = msg;
            navTip.style.display = 'block';
            var rect = h.getBoundingClientRect();
            var nx = Math.min(window.innerWidth - 220, rect.right + 8);
            var ny = Math.max(8, rect.top);
            navTip.style.left = nx + 'px';
            navTip.style.top = ny + 'px';
        });
        nav.addEventListener('mouseout', function (e) {
            var to = e.relatedTarget;
            if (to && nav.contains(to)) return;
            hideNavTip();
        });
    }

    document.addEventListener('keydown', function (e) {
        var key = (e.key || '').toLowerCase();
        var target = e.target;
        var tag = target && target.tagName ? target.tagName.toLowerCase() : '';
        var typing = tag === 'input' || tag === 'textarea' || (target && target.isContentEditable);

        /* Atajo global de búsqueda: Cmd/Ctrl + K */
        if ((e.metaKey || e.ctrlKey) && key === 'k') {
            var navSearch = document.getElementById('navbar-search-input');
            if (navSearch) {
                e.preventDefault();
                navSearch.focus();
                if (typeof navSearch.select === 'function') navSearch.select();
            }
            return;
        }

        if (key !== 'escape') return;
        if (typing) return;

        document.querySelectorAll('.lang-combo.open').forEach(function (el) { el.classList.remove('open'); });
        setProfileDropdownOpen(false);
        if (document.body.classList.contains('sidebar-collapsed')) {
            closeCollapsedL1Flyouts();
        }
        if (isMobileSidebarMode() && document.body.classList.contains('sidebar-mobile-open')) {
            sidebarMobileOpen = false;
            applySidebar();
        }
        if (navTip) navTip.style.display = 'none';
    });

    if (nav) {
        nav.addEventListener('toggle', function (e) {
            var t = e.target;
            if (!t || t.tagName !== 'DETAILS') return;
            if (t.parentElement && t.parentElement.classList.contains('ws-nav-l1')
                && document.body.classList.contains('sidebar-collapsed') && t.open) {
                document.querySelectorAll('.nav-l1.ws-nav-l1 > .ws-details[open]').forEach(function (d) {
                    if (d !== t) d.open = false;
                });
            }
            syncCollapsedFlyouts();
        }, true);

        /* Clic en enlace del flyout (submenú fijo): cerrar <details> al navegar */
        nav.addEventListener('click', function (e) {
            if (!document.body.classList.contains('sidebar-collapsed')) return;
            var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
            if (!a || !nav.contains(a)) return;
            if (!a.closest('.ws-sub')) return;
            if (!a.classList.contains('nav-l1-btn') && !a.classList.contains('nav-l2-btn') && !a.classList.contains('nav-l3-btn')) return;
            var href = (a.getAttribute('href') || '').trim();
            if (!href || href === '#') return;
            closeCollapsedL1Flyouts();
            if (isMobileSidebarMode() && document.body.classList.contains('sidebar-mobile-open')) {
                sidebarMobileOpen = false;
                applySidebar();
            }
        }, true);
    }

    window.addEventListener('resize', function () {
        if (!isMobileSidebarMode()) {
            sidebarMobileOpen = false;
        }
        applySidebar();
    });

    var navSearchWs = document.getElementById('nav-search-workspace');
    var navSearchWsWrap = document.getElementById('nav-search-workspace-wrap');
    var navSearchWsClear = document.getElementById('nav-search-workspace-clear');
    function syncNavSearchWsClear() {
        if (navSearchWsWrap && navSearchWs) {
            navSearchWsWrap.classList.toggle('has-value', (navSearchWs.value || '').length > 0);
        }
    }
    if (nav && navSearchWs) {
        navSearchWs.addEventListener('input', function () {
            syncNavSearchWsClear();
            var q = (navSearchWs.value || '').trim().toLowerCase();
            nav.querySelectorAll(':scope > .nav-l1.ws-nav-l1').forEach(function (root) {
                if (!q) {
                    root.classList.remove('ws-nav-filter-hidden');
                    return;
                }
                var hay = (root.textContent || '').toLowerCase().replace(/\s+/g, ' ');
                if (hay.indexOf(q) !== -1) {
                    root.classList.remove('ws-nav-filter-hidden');
                } else {
                    root.classList.add('ws-nav-filter-hidden');
                }
            });
            syncCollapsedFlyouts();
        });
        if (navSearchWsClear) {
            navSearchWsClear.addEventListener('click', function () {
                navSearchWs.value = '';
                navSearchWs.dispatchEvent(new Event('input', { bubbles: true }));
                navSearchWs.focus();
            });
        }
        syncNavSearchWsClear();
    }

    window.addEventListener('resize', function () { syncCollapsedFlyouts(); });
})();
</script>
<script>
/**
 * Modal portal fix — causa raíz:
 * #main tiene position:relative + z-index:0 → crea stacking context propio.
 * Cualquier .modal dentro queda atrapado en ese contexto (z-index 0 en el raíz),
 * por debajo del navbar (z-index 400 en el raíz), sin importar su z-index interno.
 * Fix: mover cada .modal a <body> antes de mostrarlo (contexto raíz),
 * donde z-index:3010 funciona correctamente.
 * El .modal-backdrop ya lo inserta Bootstrap directamente en <body>, por eso ese sí funcionaba.
 */
(function () {
    document.addEventListener('show.bs.modal', function (e) {
        var modal = e.target;
        if (modal && modal.parentElement !== document.body) {
            document.body.appendChild(modal);
        }
        if (modal && modal.classList && modal.classList.contains('grova-modal--macos')) {
            document.body.classList.add('grova-modal-macos-backdrop');
        }
    });
    document.addEventListener('hidden.bs.modal', function (e) {
        var modal = e.target;
        if (modal && modal.classList && modal.classList.contains('grova-modal--macos')) {
            if (!document.querySelector('.modal.grova-modal--macos.show')) {
                document.body.classList.remove('grova-modal-macos-backdrop');
            }
        }
    });
}());
</script>
<script src="{{ asset('js/workspace-filter-panel.js') }}"></script>
