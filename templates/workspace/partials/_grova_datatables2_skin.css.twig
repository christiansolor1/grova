/* ── Doble scroll: arriba thead · centro tabla · abajo leyenda/paginación ── */
.dt-container,
.work-invoice-dt-scroll-wrap,
[data-grova-dual-scroll] {
    min-width: 0;
    max-width: 100%;
}
.work-invoice-dt-scroll-wrap,
[data-grova-dual-scroll] {
    overflow-x: hidden;
}
.dt-container .dt-layout-row.dt-layout-table {
    overflow-x: hidden;
    overflow-y: visible;
    min-width: 0;
    max-width: 100%;
}
.dt-container .dt-layout-row.dt-layout-table .dt-layout-cell,
.dt-container .dt-layout-row.dt-layout-table .dt-layout-full {
    padding-left: 0;
    padding-right: 0;
    min-width: 0;
    max-width: 100%;
    width: 100%;
}
/* Barras de scroll alineadas al ancho útil de la tabla (sin desbordar el card) */
.dt-container .grova-dt-scroll-top,
.dt-container .grova-dt-scroll-foot {
    box-sizing: border-box;
    max-width: 100%;
}
.dt-container .grova-dt-scroll-top {
    overflow-x: auto;
    overflow-y: hidden;
    height: 14px;
    margin: 0 0 0.2rem;
    scrollbar-width: thin;
    scrollbar-color: #475569 transparent;
}
.dt-container .grova-dt-scroll-top::-webkit-scrollbar {
    height: 8px;
}
.dt-container .grova-dt-scroll-top::-webkit-scrollbar-thumb {
    background: #475569;
    border-radius: 4px;
}
body.light-mode .dt-container .grova-dt-scroll-top,
body.light-mode .dt-container .grova-dt-scroll-foot {
    scrollbar-color: #94a3b8 transparent;
}
body.light-mode .dt-container .grova-dt-scroll-top::-webkit-scrollbar-thumb,
body.light-mode .dt-container .grova-dt-scroll-foot::-webkit-scrollbar-thumb {
    background: #94a3b8;
}
.dt-container .grova-dt-scroll-top.is-hidden {
    display: none !important;
}
.dt-container .grova-dt-scroll-top-inner {
    height: 1px;
}
/* Tabla — scroll real (barra oculta; rueda en la tabla; top + foot visibles) */
.dt-container .grova-dt-scroll-body {
    overflow-x: auto;
    overflow-y: visible;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
}
.dt-container .grova-dt-scroll-body::-webkit-scrollbar {
    display: none;
    height: 0;
}
/* Barra inferior — al final del shell, antes del pie DT */
.dt-container .grova-dt-scroll-shell > .grova-dt-scroll-foot,
.dt-container > .grova-dt-scroll-foot {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    height: 14px;
    margin: 0.15rem 0 0;
    padding: 0;
    flex-shrink: 0;
    order: 2;
    scrollbar-width: thin;
    scrollbar-color: #475569 transparent;
}
.dt-container .grova-dt-scroll-shell > .row.dt-layout-table,
.dt-container .grova-dt-scroll-shell > .dt-layout-table {
    order: 1;
}
/* Ocultar barra si quedó dentro de la celda por error */
.dt-container .dt-layout-full > .grova-dt-scroll-foot,
.dt-container .dt-layout-cell > .grova-dt-scroll-foot {
    display: none !important;
}
.dt-container .grova-dt-scroll-foot.is-hidden {
    display: none !important;
}
.dt-container .grova-dt-scroll-foot-inner {
    height: 1px;
}
.dt-container .grova-dt-scroll-foot::-webkit-scrollbar {
    height: 8px;
}
.dt-container .grova-dt-scroll-foot::-webkit-scrollbar-thumb {
    background: #475569;
    border-radius: 4px;
}
/* Legacy work (antes de init DT) */
.work-invoice-dt-scroll-wrap,
.grova-dt-dual-scroll-wrap {
    position: relative;
    width: 100%;
}
.work-invoice-table-wrap,
.grova-dt-scroll-bottom {
    overflow-x: auto;
}

/* Responsive: toolbar y pie apilados con aire simétrico */
@media (max-width: 767.98px) {
    .dt-container {
        --grova-dt-inset: 0.75rem;
    }
    .dt-container .dt-layout-row:not(.dt-layout-table) {
        flex-direction: column;
        align-items: stretch !important;
    }
    .dt-container .dt-layout-row:last-child {
        flex-direction: column;
        align-items: stretch !important;
    }
    .dt-container .dt-layout-start,
    .dt-container .dt-layout-end {
        width: 100%;
        max-width: 100%;
        justify-content: flex-start !important;
    }
    .dt-container .dt-search {
        width: 100%;
    }
    .dt-container .dt-search .form-control {
        max-width: 100%;
        width: 100%;
    }
    .dt-container .dt-paging .pagination {
        justify-content: center;
    }
}
@media (max-width: 575.98px) {
    .dt-container .dt-paging .page-link {
        padding: 0.3rem 0.45rem;
        font-size: 11px;
    }
}
