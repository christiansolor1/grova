{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});

var demoDrawer = document.getElementById('demo-drawer');
var demoBackdrop = document.getElementById('demo-drawer-backdrop');
function openDemoDrawer() { demoDrawer.classList.add('open'); demoBackdrop.classList.add('open'); }
function closeDemoDrawer() { demoDrawer.classList.remove('open'); demoBackdrop.classList.remove('open'); }
document.getElementById('btn-demo-drawer').addEventListener('click', openDemoDrawer);
document.getElementById('btn-close-demo-drawer').addEventListener('click', closeDemoDrawer);
document.getElementById('btn-close-demo-drawer-2').addEventListener('click', closeDemoDrawer);
demoBackdrop.addEventListener('click', closeDemoDrawer);
</script>
{% endblock %}
