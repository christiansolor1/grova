{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Páginas de error{% endblock %}
{% block app_page_subtitle %}Errores HTTP más comunes. Copia el bloque y colócalo en templates/bundles/TwigBundle/Exception/errorXXX.html.twig.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 2.5rem 1.5rem; background: #0f172a; display: flex; justify-content: center; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; white-space: pre; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }

/* Preview local */
.err-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    width: 100%;
    max-width: 480px;
}
.err-code {
    font-size: 80px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -.04em;
    color: #1e3a5f;
}
.err-code-403 { color: #7c1d1d; }
.err-code-404 { color: #1e3a5f; }
.err-code-500 { color: #3b1f00; }
.err-code-503 { color: #1a2e1a; }
.err-title { font-size: 20px; font-weight: 700; color: #e2e8f0; }
.err-desc  { font-size: 14px; color: #64748b; max-width: 360px; }
.err-actions { display: flex; gap: .5rem; flex-wrap: wrap; justify-content: center; margin-top: .25rem; }
body.light-mode .err-title { color: #1e293b; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Páginas de error</div>
    <div class="content-card-body">

        <p class="mb-4" style="font-size:13px;color:#64748b;">
            En Symfony, cada plantilla de error va en
            <code>templates/bundles/TwigBundle/Exception/</code>.
            Crea <code>error403.html.twig</code>, <code>error404.html.twig</code>, etc.
            extendiendo tu layout base.
        </p>

        {# ── 403 Forbidden ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="err-preview">
                    <div class="err-code err-code-403">403</div>
                    <div class="err-title">Sin permisos</div>
                    <div class="err-desc">No tienes autorización para acceder a esta sección. Contacta al administrador si crees que es un error.</div>
                    <div class="err-actions">
                        <a href="#" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
                        <a href="#" class="btn btn-primary btn-sm"><i class="bi bi-house me-1"></i>Ir al inicio</a>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — error403.html.twig</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-403">Copiar</button>
                </div>
                <pre id="code-403">{% verbatim %}{# templates/bundles/TwigBundle/Exception/error403.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}
<div class="grova-error-page">
    <div class="grova-error-code">403</div>
    <h1 class="grova-error-title">Sin permisos</h1>
    <p class="grova-error-desc">
        No tienes autorización para acceder a esta sección.
        Contacta al administrador si crees que es un error.
    </p>
    <div class="grova-error-actions">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <a href="{{ path('grova_page_dashboard') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-house me-1"></i>Ir al inicio
        </a>
    </div>
</div>
{% endblock %}{% endverbatim %}</pre>
            </div>
        </div>

        {# ── 404 Not Found ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="err-preview">
                    <div class="err-code err-code-404">404</div>
                    <div class="err-title">Página no encontrada</div>
                    <div class="err-desc">La URL que buscas no existe o fue movida. Verifica la dirección o regresa al inicio.</div>
                    <div class="err-actions">
                        <a href="#" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
