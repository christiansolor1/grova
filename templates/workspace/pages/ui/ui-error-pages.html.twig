{% extends 'base.html.twig' %}

{% block body %}
<div class="grova-error-page">
    <div class="grova-error-code">{{ status_code }}</div>
    <h1 class="grova-error-title">{{ status_text }}</h1>
    <p class="grova-error-desc">
        {% if status_code == 403 %}
            No tienes permisos para acceder a esta sección.
        {% elseif status_code == 404 %}
            La página que buscas no existe o fue movida.
        {% elseif status_code >= 500 %}
            Ocurrió un error interno. Inténtalo de nuevo en unos minutos.
        {% else %}
            Ocurrió un error inesperado.
        {% endif %}
    </p>
    <div class="grova-error-actions">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <a href="{{ path('grova_page_dashboard') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-house me-1"></i>Ir al inicio
        </a>
    </div>
</div>
