{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}{{ 'Botones' | trans }}{% endblock %}
{% block app_page_subtitle %}{{ 'Catálogo de botones base. Copia el código y úsalo en cualquier vista.' | trans }}{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Botones principales</div>
    <div class="content-card-body">

        {# ── Botones tamaño sm ── #}
        <div class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-primary btn-sm">Primary</button>
                <button type="button" class="btn btn-secondary btn-sm">Secondary</button>
                <button type="button" class="btn btn-success btn-sm">Success</button>
                <button type="button" class="btn btn-danger btn-sm">Danger</button>
                <button type="button" class="btn btn-warning btn-sm">Warning</button>
                <button type="button" class="btn btn-info btn-sm">Info</button>
                <button type="button" class="btn btn-dark btn-sm">Dark</button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-btn-solid">Copiar</button>
                </div>
                <pre id="code-btn-solid">{% verbatim %}<button type="button" class="btn btn-primary btn-sm">Primary</button>
<button type="button" class="btn btn-secondary btn-sm">Secondary</button>
<button type="button" class="btn btn-success btn-sm">Success</button>
<button type="button" class="btn btn-danger btn-sm">Danger</button>
<button type="button" class="btn btn-warning btn-sm">Warning</button>
<button type="button" class="btn btn-info btn-sm">Info</button>
<button type="button" class="btn btn-dark btn-sm">Dark</button>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Botones outline ── #}
        <div class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm">Primary</button>
                <button type="button" class="btn btn-outline-secondary btn-sm">Secondary</button>
                <button type="button" class="btn btn-outline-success btn-sm">Success</button>
                <button type="button" class="btn btn-outline-danger btn-sm">Danger</button>
                <button type="button" class="btn btn-outline-warning btn-sm">Warning</button>
                <button type="button" class="btn btn-outline-dark btn-sm">Dark</button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Outline</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-btn-outline">Copiar</button>
                </div>
                <pre id="code-btn-outline">{% verbatim %}<button type="button" class="btn btn-outline-primary btn-sm">Primary</button>
<button type="button" class="btn btn-outline-secondary btn-sm">Secondary</button>
<button type="button" class="btn btn-outline-success btn-sm">Success</button>
<button type="button" class="btn btn-outline-danger btn-sm">Danger</button>
<button type="button" class="btn btn-outline-warning btn-sm">Warning</button>
<button type="button" class="btn btn-outline-dark btn-sm">Dark</button>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Botones con icono ── #}
        <div class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>Nuevo</button>
                <button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil me-1"></i>Editar</button>
                <button type="button" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-download me-1"></i>Exportar</button>
                <button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i></button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Con icono</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-btn-icon">Copiar</button>
                </div>
                <pre id="code-btn-icon">{% verbatim %}<button type="button" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>Nuevo</button>
<button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil me-1"></i>Editar</button>
<button type="button" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
<button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-download me-1"></i>Exportar</button>
<button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i></button>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Tamaños ── #}
        <div class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap align-items-center gap-2">
                <button type="button" class="btn btn-primary btn-lg">Large</button>
                <button type="button" class="btn btn-primary">Normal</button>
                <button type="button" class="btn btn-primary btn-sm">Small</button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Tamaños</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-btn-sizes">Copiar</button>
                </div>
                <pre id="code-btn-sizes">{% verbatim %}<button type="button" class="btn btn-primary btn-lg">Large</button>
<button type="button" class="btn btn-primary">Normal</button>
<button type="button" class="btn btn-primary btn-sm">Small</button>{% endverbatim %}</pre>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});
</script>
{% endblock %}
