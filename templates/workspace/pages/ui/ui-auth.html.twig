{% extends 'workspace/app_layout.html.twig' %}
{% block page_title %}Autenticación{% endblock %}
{% block app_page_subtitle %}Formularios de login, reset de contraseña, 2FA y banners de sesión.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border:1px solid #1e293b; border-radius:10px; overflow:hidden; margin-bottom:1.5rem; }
.ui-component-preview { padding:2rem 1.5rem; background:#0f172a; display:flex; justify-content:center; }
.ui-component-code { background:#020617; border-top:1px solid #1e293b; }
.ui-component-code-header { display:flex; align-items:center; justify-content:space-between; padding:.5rem 1rem; border-bottom:1px solid #1e293b; }
.ui-component-code-label { font-size:11px; color:#64748b; text-transform:uppercase; letter-spacing:.5px; }
.ui-component-code pre { margin:0; padding:1rem; font-size:12px; color:#94a3b8; overflow-x:auto; white-space:pre; }
.btn-copy-code { font-size:11px; padding:2px 10px; }
body.light-mode .ui-component { border-color:#dbe3ee; }
body.light-mode .ui-component-preview { background:#f8fafc; }
body.light-mode .ui-component-code { background:#f1f5f9; border-color:#dbe3ee; }
body.light-mode .ui-component-code-header { border-color:#dbe3ee; }
body.light-mode .ui-component-code pre { color:#475569; }
.auth-box { background:#1e293b; border:1px solid #334155; border-radius:12px; padding:2rem; width:100%; max-width:380px; }
body.light-mode .auth-box { background:#fff; border-color:#e2e8f0; }
.auth-logo { font-size:22px; font-weight:800; color:#f1f5f9; letter-spacing:-.02em; margin-bottom:1.5rem; text-align:center; }
body.light-mode .auth-logo { color:#1e293b; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Autenticación</div>
    <div class="content-card-body">

        {# ── Login ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="auth-box">
                    <div class="auth-logo">grova</div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control form-control-sm" placeholder="usuario@empresa.com">
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label">Contraseña</label>
                            <a href="#" style="font-size:12px;color:#60a5fa;">¿Olvidaste tu contraseña?</a>
                        </div>
                        <input type="password" class="form-control form-control-sm" placeholder="••••••••">
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="remember-demo">
                        <label class="form-check-label" for="remember-demo" style="font-size:13px;">Recordarme</label>
                    </div>
                    <button class="btn btn-primary btn-sm w-100">Iniciar sesión</button>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — login.html.twig</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-login">Copiar</button>
                </div>
                <pre id="code-login">{% verbatim %}{% extends 'base.html.twig' %}
{% block body %}
<div class="grova-auth-wrap">
    <div class="grova-auth-box">
        <div class="grova-auth-logo">grova</div>
        <form method="post" action="{{ path('app_login') }}" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            {% if error %}
                <div class="alert alert-danger alert-sm mb-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="_username" class="form-control form-control-sm"
                       value="{{ last_username }}" autocomplete="email" required autofocus>
            </div>
            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label class="form-label">Contraseña</label>
                    <a href="{{ path('app_forgot_password') }}" style="font-size:12px;">¿Olvidaste tu contraseña?</a>
                </div>
                <input type="password" name="_password" class="form-control form-control-sm"
                       autocomplete="current-password" required>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="_remember_me" id="remember_me">
                <label class="form-check-label" for="remember_me">Recordarme</label>
            </div>
            <button type="submit" class="btn btn-primary btn-sm w-100">Iniciar sesión</button>
        </form>
    </div>
</div>
{% endblock %}{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Reset de contraseña ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="auth-box">
                    <div class="auth-logo" style="font-size:16px;margin-bottom:1rem;">Recuperar contraseña</div>
                    <p style="font-size:13px;color:#64748b;margin-bottom:1.25rem;text-align:center;">
                        Ingresa tu email y te enviaremos un enlace para restablecer tu contraseña.
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control form-control-sm" placeholder="usuario@empresa.com">
                    </div>
                    <button class="btn btn-primary btn-sm w-100 mb-2">Enviar enlace</button>
                    <a href="#" class="btn btn-outline-secondary btn-sm w-100">Volver al login</a>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — forgot_password.html.twig</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-forgot">Copiar</button>
                </div>
                <pre id="code-forgot">{% verbatim %}<div class="grova-auth-box">
    <h1 class="grova-auth-logo" style="font-size:16px;">Recuperar contraseña</h1>
    <p style="font-size:13px;color:#64748b;text-align:center;">
        Ingresa tu email y te enviaremos un enlace para restablecer tu contraseña.
    </p>
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control form-control-sm" required autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100 mb-2">Enviar enlace</button>
        <a href="{{ path('app_login') }}" class="btn btn-outline-secondary btn-sm w-100">Volver al login</a>
    </form>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── 2FA ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="auth-box" style="text-align:center;">
                    <div style="font-size:2rem;margin-bottom:.5rem;">🔐</div>
                    <div style="font-size:15px;font-weight:700;color:#e2e8f0;margin-bottom:.5rem;">Verificación en dos pasos</div>
                    <p style="font-size:13px;color:#64748b;margin-bottom:1.25rem;">
                        Ingresa el código de 6 dígitos enviado a tu app de autenticación.
                    </p>
                    <div class="mb-3">
                        <input type="text" class="form-control form-control-sm text-center" placeholder="000000"
                               maxlength="6" style="letter-spacing:.5em;font-size:18px;font-weight:700;">
                    </div>
                    <button class="btn btn-primary btn-sm w-100">Verificar</button>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — 2fa.html.twig</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-2fa">Copiar</button>
                </div>
                <pre id="code-2fa">{% verbatim %}<div class="grova-auth-box" style="text-align:center;">
    <div style="font-size:2rem;">🔐</div>
    <h1 style="font-size:15px;font-weight:700;">Verificación en dos pasos</h1>
    <p style="font-size:13px;color:#64748b;">
        Ingresa el código de 6 dígitos de tu app de autenticación.
    </p>
    <form method="post">
        <div class="mb-3">
            <input type="text" name="code" class="form-control form-control-sm text-center"
                   placeholder="000000" maxlength="6" inputmode="numeric"
                   style="letter-spacing:.5em;font-size:18px;font-weight:700;" autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100">Verificar</button>
    </form>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Banner sesión expirada ── #}
        <div class="ui-component">
            <div class="ui-component-preview" style="flex-direction:column;gap:.75rem;">
                <div class="alert alert-warning d-flex align-items-center gap-2 mb-0 w-100" style="max-width:540px;">
                    <i class="bi bi-clock-history flex-shrink-0"></i>
                    <span style="font-size:13px;">Tu sesión expiró por inactividad. <a href="#" class="alert-link">Inicia sesión de nuevo</a> para continuar.</span>
                </div>
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-0 w-100" style="max-width:540px;">
                    <i class="bi bi-shield-x flex-shrink-0"></i>
                    <span style="font-size:13px;">Token inválido o expirado. <a href="#" class="alert-link">Vuelve a iniciar sesión</a>.</span>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Banners de sesión / token</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-session-banner">Copiar</button>
                </div>
                <pre id="code-session-banner">{% verbatim %}{# Sesión expirada por inactividad #}
<div class="alert alert-warning d-flex align-items-center gap-2">
    <i class="bi bi-clock-history flex-shrink-0"></i>
    <span>Tu sesión expiró por inactividad.
        <a href="{{ path('app_login') }}" class="alert-link">Inicia sesión de nuevo</a>.
    </span>
</div>

{# Token inválido / JWT expirado #}
<div class="alert alert-danger d-flex align-items-center gap-2">
    <i class="bi bi-shield-x flex-shrink-0"></i>
    <span>Token inválido o expirado.
        <a href="{{ path('app_login') }}" class="alert-link">Vuelve a iniciar sesión</a>.
    </span>
</div>{% endverbatim %}</pre>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function(btn){
    btn.addEventListener('click',function(){
        var t=document.getElementById(btn.getAttribute('data-copy-target'));
        if(!t)return;
        navigator.clipboard.writeText(t.textContent.trim()).then(function(){
            var o=btn.textContent; btn.textContent='Copiado';
            setTimeout(function(){btn.textContent=o;},1200);
        });
    });
});
</script>
{% endblock %}
