            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">JS — Cargar / recargar filas tras <code>fetch</code></span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-dt-fetch">Copiar</button>
                </div>
                <pre id="code-dt-fetch">const dt = new DataTable('#mi-tabla', {
  processing: true,
  data: [],
  columns: [
    { data: 'cliente', title: 'Cliente' },
    { data: 'estado', title: 'Estado' },
    { data: 'sync', title: 'Última sync' },
  ],
});

async function cargarDesdeApi() {
  dt.processing(true);
  try {
    const res = await fetch('/api/listado');
    const filas = await res.json();
    dt.clear().rows.add(filas).draw();
  } finally {
    dt.processing(false);
  }
}</pre>
            </div>
