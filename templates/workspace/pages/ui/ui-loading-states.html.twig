{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Cargas y esperas{% endblock %}
{% block app_page_subtitle %}Catálogo de patrones de espera: CRUD, formularios, alertas, toasts Bootstrap, SweetAlert2, modales, offcanvas, tablas DataTables y overlays. Reutiliza el snippet que encaje en cada pantalla.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; white-space: pre-wrap; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }

.ui-load-toc { font-size: 13px; columns: 2; gap: 1.5rem; max-width: 48rem; }
@media (max-width: 640px) { .ui-load-toc { columns: 1; } }
.ui-load-toc a { color: #38bdf8; text-decoration: none; }
.ui-load-toc a:hover { text-decoration: underline; }
body.light-mode .ui-load-toc a { color: #0369a1; }

.ui-load-overlay-wrap { position: relative; min-height: 140px; border-radius: 8px; border: 1px dashed #334155; padding: 1rem; }
body.light-mode .ui-load-overlay-wrap { border-color: #cbd5e1; }
.ui-load-overlay {
  display: none;
  position: absolute;
  inset: 0;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: .5rem;
  background: rgba(15, 23, 42, 0.72);
  border-radius: 8px;
  z-index: 2;
}
body.light-mode .ui-load-overlay { background: rgba(248, 250, 252, 0.88); }
.ui-load-overlay.is-active { display: flex; }
.ui-load-overlay .text { font-size: 12px; color: #e2e8f0; }
body.light-mode .ui-load-overlay .text { color: #475569; }

.ui-fullpage-load {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 1080;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: .75rem;
  background: rgba(2, 6, 23, 0.78);
  backdrop-filter: blur(2px);
}
body.light-mode .ui-fullpage-load { background: rgba(248, 250, 252, 0.92); }
.ui-fullpage-load.is-active { display: flex; }
.ui-fullpage-load .text { font-size: 14px; color: #e2e8f0; }
body.light-mode .ui-fullpage-load .text { color: #334155; }

#modal-loading-demo .modal-body--loading { min-height: 120px; display: flex; align-items: center; justify-content: center; }

.ui-skeleton-card { border-radius: 8px; border: 1px solid #334155; padding: 1rem; max-width: 320px; }
body.light-mode .ui-skeleton-card { border-color: #e2e8f0; }

#offcanvas-loading-demo .offcanvas-body--loading { min-height: 160px; display: flex; align-items: center; justify-content: center; }

.swal-load-grid { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
#swal-dev-result { font-size: 12px; color: #94a3b8; margin-top: .75rem; min-height: 1.25rem; }
body.light-mode #swal-dev-result { color: #64748b; }
</style>
{% endblock %}

{% block app_main %}
{# Contenedor de toasts (mismo patrón que ui-toasts) #}
<div id="grova-toast-container" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999;" aria-live="polite" aria-atomic="false"></div>

<div class="content-card">
    <div class="content-card-header">Cargas y esperas</div>
    <div class="content-card-body">

        <p class="text-muted small mb-2" style="max-width:52rem;">
            Deshabilita el control que dispara la acción, muestra <code>spinner-border spinner-border-sm</code> o un overlay, y restaura el estado en <code>fetch().finally()</code> o al terminar el submit.
            Para más variantes de Swal genéricas, la página
            <a href="{{ path('grova_page_ui_alerts_swal', {_locale: app.request.locale}) }}">Alertas SweetAlert2</a>
            y para toasts detallados,
            <a href="{{ path('grova_page_ui_toasts', {_locale: app.request.locale}) }}">Toasts</a>.
        </p>
        <nav class="ui-load-toc mb-4 text-muted" aria-label="Índice de secciones">
            <ul class="mb-0 ps-3">
                <li><a href="#sec-crud">Botones CRUD ocupados</a></li>
                <li><a href="#sec-form">Formulario enviando</a></li>
                <li><a href="#sec-spinners">Spinners</a></li>
                <li><a href="#sec-inline-alert">Alerta inline con estado</a></li>
                <li><a href="#sec-progress">Barra de progreso</a></li>
                <li><a href="#sec-skeleton">Placeholders / skeleton</a></li>
                <li><a href="#sec-overlay">Overlay en tarjeta</a></li>
                <li><a href="#sec-fullpage">Overlay pantalla completa</a></li>
                <li><a href="#sec-modal">Modal con carga</a></li>
                <li><a href="#sec-offcanvas">Offcanvas con carga</a></li>
                <li><a href="#sec-toast">Toasts Bootstrap (<code>gToast</code>)</a></li>
                <li><a href="#sec-alerts-bs">Alertas Bootstrap estáticas</a></li>
                <li><a href="#sec-swal">SweetAlert2 — carga y bloqueo</a></li>
                <li><a href="#sec-datatables">DataTables <code>processing</code></a></li>
                <li><a href="#sec-datatables-fetch">DataTable: carga de datos (simula API)</a></li>
            </ul>
        </nav>

        {# ── CRUD: botones con estado “ocupado” ── #}
        <section id="sec-crud" class="ui-component">
            <div class="ui-component-preview">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <button type="button" class="btn btn-primary btn-sm js-ui-busy-btn" data-label="Crear">
                        <i class="bi bi-plus-lg me-1"></i>Crear
                    </button>
                    <button type="button" class="btn btn-success btn-sm js-ui-busy-btn" data-label="Guardar">
                        <i class="bi bi-check2 me-1"></i>Guardar
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm js-ui-busy-btn" data-label="Actualizar">
                        <i class="bi bi-arrow-repeat me-1"></i>Actualizar
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm js-ui-busy-btn" data-label="Eliminar">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </div>
                <p class="small text-muted mt-3 mb-0">Simula ~1,2&nbsp;s de red; el botón muestra spinner y queda deshabilitado.</p>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">JS — Botón ocupado (CRUD)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-busy-btn">Copiar</button>
                </div>
                <pre id="code-busy-btn">btn.disabled = true;
btn.innerHTML = '&lt;span class="spinner-border spinner-border-sm me-1"&gt;&lt;/span&gt;Guardando…';
// … await fetch …
btn.disabled = false;
btn.innerHTML = originalHtml;</pre>
            </div>
        </section>

        {# ── Formulario: fieldset + submit ── #}
        <section id="sec-form" class="ui-component">
            <div class="ui-component-preview">
                <form id="demo-form-busy" class="small" style="max-width:22rem;">
                    <fieldset id="demo-form-busy-fieldset" class="border-0 p-0 m-0">
                        <div class="mb-2">
                            <label class="form-label mb-0">Nota</label>
                            <input type="text" class="form-control form-control-sm" name="demo_note" value="Texto de prueba" autocomplete="off">
                        </div>
                    </fieldset>
                    <button type="submit" class="btn btn-primary btn-sm" id="demo-form-busy-submit">
                        <i class="bi bi-send me-1"></i>Enviar formulario
                    </button>
                </form>
                <p class="small text-muted mt-3 mb-0">Patrón típico: <code>fieldset.disabled = true</code> y spinner en el submit mientras dura el POST.</p>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">JS — Formulario bloqueado</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-form-busy">Copiar</button>
                </div>
                <pre id="code-form-busy">form.addEventListener('submit', async (e) => {
  e.preventDefault();
  fieldset.disabled = true;
  submitBtn.disabled = true;
  submitBtn.innerHTML = '&lt;span class="spinner-border spinner-border-sm me-1"&gt;&lt;/span&gt;Enviando…';
  try { await fetch(url, { method: 'POST', body: new FormData(form) }); }
  finally {
    fieldset.disabled = false;
    submitBtn.disabled = false;
    submitBtn.innerHTML = originalHtml;
  }
});</pre>
            </div>
        </section>

        {# ── Spinners Bootstrap ── #}
        <section id="sec-spinners" class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap align-items-center gap-4">
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando…</span></div>
                    <div class="small text-muted mt-1">border</div>
                </div>
                <div class="text-center">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                    <div class="small text-muted mt-1">sm</div>
                </div>
                <div class="text-center">
                    <div class="spinner-grow text-info" role="status"></div>
                    <div class="small text-muted mt-1">grow</div>
                </div>
                <div>
                    <button type="button" class="btn btn-outline-light btn-sm" id="btn-link-busy-demo">
                        <span class="spinner-border spinner-border-sm me-1 d-none" id="btn-link-busy-spin" role="status"></span>
                        <span id="btn-link-busy-label">Enlace estilo botón</span>
                    </button>
                    <div class="small text-muted mt-2 mb-0">Spinner dentro de un <code>btn-outline-*</code> sin cambiar el tamaño del botón.</div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Spinners</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-spinners">Copiar</button>
                </div>
                <pre id="code-spinners">&lt;span class="spinner-border spinner-border-sm text-primary" role="status"&gt;&lt;/span&gt;
&lt;span class="visually-hidden"&gt;Cargando…&lt;/span&gt;</pre>
            </div>
        </section>

        {# ── Alerta inline que cambia con el flujo ── #}
        <section id="sec-inline-alert" class="ui-component">
            <div class="ui-component-preview">
                <div id="inline-alert-slot" class="mb-2" style="min-height:3rem;"></div>
                <button type="button" class="btn btn-outline-primary btn-sm" id="btn-inline-alert-demo">Simular guardado (2&nbsp;s)</button>
                <p class="small text-muted mt-2 mb-0">Sustituye el contenido del contenedor: aviso con spinner → éxito (o error).</p>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Alerta + spinner</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-inline-alert">Copiar</button>
                </div>
                <pre id="code-inline-alert">&lt;div class="alert alert-info py-2 mb-0 d-flex align-items-center gap-2" role="status"&gt;
  &lt;span class="spinner-border spinner-border-sm"&gt;&lt;/span&gt;
  &lt;span&gt;Guardando cambios…&lt;/span&gt;
&lt;/div&gt;</pre>
            </div>
        </section>

        {# ── Barra de progreso (indeterminada / animada) ── #}
        <section id="sec-progress" class="ui-component">
            <div class="ui-component-preview">
                <div class="mb-2" id="progress-wrap" style="display:none; max-width:22rem;">
                    <div class="small text-muted mb-1">Generando informe…</div>
                    <div class="progress" role="progressbar" style="height: 8px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width: 100%;"></div>
                    </div>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-progress-demo">Mostrar barra 2&nbsp;s</button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Progreso indeterminado</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-progress">Copiar</button>
                </div>
                <pre id="code-progress">&lt;div class="progress" style="height:8px;"&gt;
  &lt;div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width:100%"&gt;&lt;/div&gt;
&lt;/div&gt;</pre>
            </div>
        </section>

        {# ── Skeleton / placeholders ── #}
        <section id="sec-skeleton" class="ui-component">
            <div class="ui-component-preview">
                <div class="placeholder-glow ui-skeleton-card">
                    <div class="d-flex gap-2 mb-3">
                        <span class="placeholder col-2 rounded-circle" style="width:40px;height:40px;"></span>
                        <div class="flex-grow-1">
                            <span class="placeholder col-7 mb-2"></span>
                            <span class="placeholder col-4"></span>
                        </div>
                    </div>
                    <span class="placeholder col-12 mb-2"></span>
                    <span class="placeholder col-10 mb-2"></span>
                    <span class="placeholder col-8"></span>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm ms-2 align-self-start" id="btn-skeleton-toggle">Alternar contenido real</button>
                <div id="skeleton-real-content" class="d-none small mt-2 text-muted" style="max-width:22rem;">Contenido cargado: sustituye el bloque <code>placeholder-glow</code> por datos reales.</div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Bootstrap placeholder</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-skeleton">Copiar</button>
                </div>
                <pre id="code-skeleton">&lt;div class="placeholder-glow"&gt;
  &lt;span class="placeholder col-12"&gt;&lt;/span&gt;
  &lt;span class="placeholder col-8"&gt;&lt;/span&gt;
&lt;/div&gt;</pre>
            </div>
        </section>

        {# ── Overlay en tarjeta ── #}
        <section id="sec-overlay" class="ui-component">
            <div class="ui-component-preview">
                <div class="ui-load-overlay-wrap" id="ui-overlay-card">
                    <div class="ui-load-overlay" id="ui-overlay-layer" aria-hidden="true">
                        <div class="spinner-border text-light" role="status"></div>
                        <span class="text">Cargando datos…</span>
                    </div>
                    <p class="mb-2 fw-semibold">Contenido de la tarjeta</p>
                    <p class="small text-muted mb-3">El overlay cubre solo esta zona (paneles, resúmenes, gráficos).</p>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-ui-overlay-demo">Simular carga (1,5&nbsp;s)</button>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML + JS — Overlay local</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-overlay">Copiar</button>
                </div>
                <pre id="code-overlay">&lt;div class="position-relative"&gt;
  &lt;div class="mi-overlay" style="display:none; position:absolute; inset:0; …"&gt;…spinner…&lt;/div&gt;
  …contenido…
&lt;/div&gt;</pre>
            </div>
        </section>

        {# ── Overlay pantalla completa ── #}
        <section id="sec-fullpage" class="ui-component">
            <div class="ui-component-preview">
                <button type="button" class="btn btn-outline-warning btn-sm" id="btn-fullpage-load">Simular bloqueo de pantalla (1,2&nbsp;s)</button>
                <p class="small text-muted mt-2 mb-0">Útil antes de un redirect o una operación larga; usa <code>z-index</code> por encima del contenido y por debajo de modales si aplica.</p>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">CSS — Overlay fijo</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-fullpage">Copiar</button>
                </div>
                <pre id="code-fullpage">.overlay {
  position: fixed; inset: 0; z-index: 1080;
  display: flex; align-items: center; justify-content: center;
  background: rgba(2,6,23,.78);
}</pre>
            </div>
        </section>

        {# ── Modal con contenido que “llega” después ── #}
        <section id="sec-modal" class="ui-component">
            <div class="ui-component-preview">
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-loading-demo">
                    Abrir modal (carga simulada)
                </button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Bootstrap — eventos shown.bs.modal</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-modal-load">Copiar</button>
                </div>
                <pre id="code-modal-load">modalEl.addEventListener('shown.bs.modal', () => {
  body.innerHTML = '&lt;div class="spinner-border"&gt;…&lt;/div&gt;';
  fetch('/api/…').then(() => { body.innerHTML = formHtml; });
});</pre>
            </div>
        </section>

        {# ── Offcanvas ── #}
        <section id="sec-offcanvas" class="ui-component">
            <div class="ui-component-preview">
                <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="offcanvas" data-bs-target="#offcanvas-loading-demo">
                    Abrir panel lateral (carga simulada)
                </button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Bootstrap — show.bs.offcanvas</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-offcanvas">Copiar</button>
                </div>
                <pre id="code-offcanvas">offcanvasEl.addEventListener('show.bs.offcanvas', () => {
  body.classList.add('offcanvas-body--loading');
  body.innerHTML = '&lt;div class="spinner-border"&gt;&lt;/div&gt;';
});
offcanvasEl.addEventListener('shown.bs.offcanvas', () => {
  setTimeout(() => { body.innerHTML = formularioHtml; }, 600);
});</pre>
            </div>
        </section>

        {# ── Toasts Bootstrap (gToast) ── #}
        <section id="sec-toast" class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap gap-2 align-items-center">
                <button type="button" class="btn btn-sm btn-outline-info" id="btn-toast-flow">Flujo: info → éxito (simula CRUD)</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" id="btn-toast-loading-msg">Toast con HTML (spinner en texto)</button>
                <button type="button" class="btn btn-sm btn-outline-warning" id="btn-toast-warn-persist">Advertencia persistente (error de red)</button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">JS — gToast (Bootstrap Toast)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-toast-flow">Copiar</button>
                </div>
                <pre id="code-toast-flow">gToast('Sincronizando con el servidor…', 'info');
// … await fetch …
gToast('Cambios guardados.', 'success');</pre>
            </div>
        </section>

        {# ── Alertas Bootstrap (bloque superior de página) ── #}
        <section id="sec-alerts-bs" class="ui-component">
            <div class="ui-component-preview d-flex flex-column gap-2">
                <div class="alert alert-warning py-2 mb-0 d-flex align-items-center gap-2" role="status">
                    <span class="spinner-border spinner-border-sm text-warning" role="status"></span>
                    <span>La operación está en curso; no cierres esta pestaña.</span>
                </div>
                <div class="alert alert-secondary py-2 mb-0" role="status">
                    <i class="bi bi-hourglass-split me-2"></i>Cola de trabajos: posición <strong>3</strong> — tiempo estimado 2&nbsp;min.
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Alertas de espera</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-alerts-wait">Copiar</button>
                </div>
                <pre id="code-alerts-wait">{% verbatim %}<div class="alert alert-warning py-2 d-flex align-items-center gap-2" role="status">
  <span class="spinner-border spinner-border-sm text-warning"></span>
  <span>Procesando…</span>
</div>{% endverbatim %}</pre>
            </div>
        </section>

        {# ── SweetAlert2: varias cargas ── #}
        <section id="sec-swal" class="ui-component">
            <div class="ui-component-preview">
                <p class="small text-muted mb-2">Atajos locales (misma API global <code>Swal</code> que el resto del workspace):</p>
                <div class="swal-load-grid mb-3">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-swal-loading">showLoading simple</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-swal-loading-html">HTML + bloqueo</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-swal-update-steps">Título en pasos (<code>Swal.update</code>)</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-swal-preconfirm">Confirmar con <code>preConfirm</code> async</button>
                </div>
                <p class="small text-muted mb-2">Demos compartidos con <code>workspace-swal-demos.js</code> (loader bloqueante, timer con loading, confirmación async con <code>showLoaderOnConfirm</code>, toast Swal con barra):</p>
                <div class="swal-load-grid">
                    <button type="button" class="btn btn-sm btn-outline-primary swal-load-demo-btn" data-swal-demo="loader">Loader bloqueante</button>
                    <button type="button" class="btn btn-sm btn-outline-primary swal-load-demo-btn" data-swal-demo="timer">Timer + loading en título</button>
