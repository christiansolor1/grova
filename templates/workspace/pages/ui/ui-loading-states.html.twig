                <pre id="code-dt">new DataTable('#mi-tabla', {
  processing: true,
  data: filas,
  columns: [{ data: 'id' }, …],
});
DataTable.get('#mi-tabla').processing(true); // o la instancia devuelta por new DataTable(…)</pre>
