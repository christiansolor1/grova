{% block app_page_scripts %}
<script src="{{ asset('js/workspace-swal-demos.js') }}"></script>
<script>
/* gToast — mismo comportamiento que ui-toasts (Bootstrap Toast) */
function gToast(message, type, options) {
    options = options || {};
    var delay = options.persistent ? 0 : (options.delay || 4000);
    var icons  = { success: 'bi-check-circle-fill', error: 'bi-x-circle-fill', warning: 'bi-exclamation-triangle-fill', info: 'bi-info-circle-fill' };
    var colors = { success: 'text-success', error: 'text-danger', warning: 'text-warning', info: 'text-info' };
    var icon  = icons[type]  || icons.info;
    var color = colors[type] || colors.info;
    var actionHtml = '';
    if (options.action && options.action.label) {
        actionHtml = '<button type="button" class="btn btn-link btn-sm p-0 ms-2 grova-toast-action" style="font-size:12px;">'
            + options.action.label + '</button>';
    }
    var el = document.createElement('div');
    el.className = 'toast align-items-center border-0 show';
    el.setAttribute('role', 'alert');
    el.setAttribute('aria-live', 'assertive');
    el.innerHTML =
        '<div class="d-flex">' +
        '<div class="toast-body d-flex align-items-center gap-2">' +
        '<i class="bi ' + icon + ' ' + color + '"></i>' +
        '<span style="font-size:13px;">' + message + '</span>' +
        actionHtml +
        '</div>' +
        '<button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>' +
        '</div>';
    if (options.action && options.action.callback) {
        el.querySelector('.grova-toast-action').addEventListener('click', function () {
            options.action.callback();
            bootstrap.Toast.getOrCreateInstance(el).hide();
        });
    }
    var container = document.getElementById('grova-toast-container');
    if (!container) {
        container = document.createElement('div');
        container.id = 'grova-toast-container';
        container.className = 'toast-container position-fixed top-0 end-0 p-3';
        container.style.zIndex = '9999';
        document.body.appendChild(container);
    }
    container.appendChild(el);
    var bsToast = new bootstrap.Toast(el, { autohide: !options.persistent, delay: delay });
    bsToast.show();
    el.addEventListener('hidden.bs.toast', function () { el.remove(); });
}

document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});

(function () {
    var busyMs = 1200;
    document.querySelectorAll('.js-ui-busy-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (btn.disabled) return;
            var label = btn.getAttribute('data-label') || 'Acción';
            var original = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>' + label + '…';
            setTimeout(function () {
                btn.disabled = false;
                btn.innerHTML = original;
            }, busyMs);
        });
    });

    var form = document.getElementById('demo-form-busy');
    var fieldset = document.getElementById('demo-form-busy-fieldset');
    var submitBtn = document.getElementById('demo-form-busy-submit');
    if (form && fieldset && submitBtn) {
        var submitOriginal = submitBtn.innerHTML;
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            fieldset.disabled = true;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Enviando…';
            setTimeout(function () {
                fieldset.disabled = false;
                submitBtn.disabled = false;
                submitBtn.innerHTML = submitOriginal;
                if (typeof gToast === 'function') {
                    gToast('Formulario recibido (demo).', 'success');
                }
            }, 1400);
        });
    }

    var linkSpin = document.getElementById('btn-link-busy-spin');
    var linkLabel = document.getElementById('btn-link-busy-label');
    var linkBtn = document.getElementById('btn-link-busy-demo');
    if (linkBtn && linkSpin && linkLabel) {
        var linkOrig = linkLabel.textContent;
        linkBtn.addEventListener('click', function () {
            if (linkBtn.getAttribute('aria-busy') === 'true') return;
            linkBtn.setAttribute('aria-busy', 'true');
            linkBtn.disabled = true;
            linkSpin.classList.remove('d-none');
            linkLabel.textContent = 'Cargando…';
            setTimeout(function () {
                linkSpin.classList.add('d-none');
                linkLabel.textContent = linkOrig;
                linkBtn.disabled = false;
                linkBtn.removeAttribute('aria-busy');
            }, 1100);
        });
    }

    var alertSlot = document.getElementById('inline-alert-slot');
    document.getElementById('btn-inline-alert-demo')?.addEventListener('click', function () {
        if (!alertSlot) return;
        alertSlot.innerHTML = '<div class="alert alert-info py-2 mb-0 d-flex align-items-center gap-2" role="status">' +
            '<span class="spinner-border spinner-border-sm" role="status"></span>' +
            '<span>Guardando cambios…</span></div>';
        setTimeout(function () {
            alertSlot.innerHTML = '<div class="alert alert-success py-2 mb-0" role="status"><i class="bi bi-check-circle me-2"></i>Listo.</div>';
        }, 2000);
    });

    document.getElementById('btn-progress-demo')?.addEventListener('click', function () {
        var w = document.getElementById('progress-wrap');
        if (!w) return;
        w.style.display = 'block';
        setTimeout(function () { w.style.display = 'none'; }, 2000);
    });

    var skBtn = document.getElementById('btn-skeleton-toggle');
    var skCard = document.querySelector('.ui-skeleton-card');
    var skReal = document.getElementById('skeleton-real-content');
    if (skBtn && skCard && skReal) {
        skBtn.addEventListener('click', function () {
            var showing = !skCard.classList.contains('d-none');
            if (showing) {
                skCard.classList.add('d-none');
                skReal.classList.remove('d-none');
                skBtn.textContent = 'Mostrar skeleton';
            } else {
                skCard.classList.remove('d-none');
                skReal.classList.add('d-none');
                skBtn.textContent = 'Alternar contenido real';
            }
        });
    }

    var overlay = document.getElementById('ui-overlay-layer');
    var btnOv = document.getElementById('btn-ui-overlay-demo');
    if (overlay && btnOv) {
        btnOv.addEventListener('click', function () {
            overlay.classList.add('is-active');
            overlay.setAttribute('aria-hidden', 'false');
            setTimeout(function () {
                overlay.classList.remove('is-active');
                overlay.setAttribute('aria-hidden', 'true');
            }, 1500);
        });
    }

    var fullEl = document.getElementById('ui-fullpage-overlay');
    document.getElementById('btn-fullpage-load')?.addEventListener('click', function () {
        if (!fullEl) return;
        fullEl.classList.add('is-active');
        fullEl.setAttribute('aria-hidden', 'false');
        setTimeout(function () {
            fullEl.classList.remove('is-active');
            fullEl.setAttribute('aria-hidden', 'true');
        }, 1200);
    });

    var modalEl = document.getElementById('modal-loading-demo');
    var modalBody = document.getElementById('modal-loading-demo-body');
    var modalFooter = document.getElementById('modal-loading-demo-footer');
    if (modalEl && modalBody) {
        modalEl.addEventListener('show.bs.modal', function () {
            modalBody.classList.add('modal-body--loading');
            modalBody.classList.remove('py-3');
            modalBody.innerHTML = '<div class="spinner-border text-primary" role="status"></div>';
            if (modalFooter) modalFooter.classList.add('d-none');
        });
        modalEl.addEventListener('shown.bs.modal', function () {
            setTimeout(function () {
                modalBody.classList.remove('modal-body--loading');
                modalBody.classList.add('py-3');
                modalBody.innerHTML = '<p class="mb-0 small">Aquí iría el detalle cargado por <code>fetch</code> o el fragmento Twig.</p>';
                if (modalFooter) modalFooter.classList.remove('d-none');
            }, 900);
        });
    }

    var ocEl = document.getElementById('offcanvas-loading-demo');
    var ocBody = document.getElementById('offcanvas-loading-demo-body');
    if (ocEl && ocBody) {
        ocEl.addEventListener('show.bs.offcanvas', function () {
            ocBody.classList.add('offcanvas-body--loading');
            ocBody.innerHTML = '<div class="spinner-border text-light" role="status"></div>';
        });
        ocEl.addEventListener('shown.bs.offcanvas', function () {
            setTimeout(function () {
                ocBody.classList.remove('offcanvas-body--loading');
                ocBody.innerHTML = '<p class="small mb-2">Contenido del panel cargado.</p>' +
                    '<div class="mb-2"><label class="form-label small mb-0">Desde</label><input type="date" class="form-control form-control-sm"></div>' +
                    '<div class="mb-2"><label class="form-label small mb-0">Hasta</label><input type="date" class="form-control form-control-sm"></div>' +
                    '<button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="offcanvas">Aplicar</button>';
            }, 700);
        });
    }

    document.getElementById('btn-toast-flow')?.addEventListener('click', function () {
        gToast('Guardando en el servidor…', 'info', { delay: 2500 });
        setTimeout(function () {
            gToast('Operación completada.', 'success');
        }, 1600);
    });
    document.getElementById('btn-toast-loading-msg')?.addEventListener('click', function () {
        gToast('<span class="spinner-border spinner-border-sm me-1 align-middle" role="status"></span>Importando filas…', 'info', { delay: 3500 });
    });
    document.getElementById('btn-toast-warn-persist')?.addEventListener('click', function () {
        gToast('Sin conexión. Los cambios no se enviaron.', 'warning', { persistent: true });
    });

    document.querySelectorAll('.swal-load-demo-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var t = btn.getAttribute('data-swal-demo');
            if (typeof runSwalDemo === 'function') {
                runSwalDemo(t);
            }
        });
    });

    document.getElementById('btn-swal-loading')?.addEventListener('click', async function () {
        if (typeof window.Swal === 'undefined' || typeof window.Swal.fire !== 'function') return;
        window.Swal.fire({
            title: 'Guardando…',
            allowOutsideClick: false,
            showConfirmButton: false,
            didOpen: function () { window.Swal.showLoading(); }
        });
        await new Promise(function (r) { setTimeout(r, 1400); });
        window.Swal.close();
    });

    document.getElementById('btn-swal-loading-html')?.addEventListener('click', async function () {
        if (typeof window.Swal === 'undefined') return;
        window.Swal.fire({
            title: 'Exportando',
            html: 'Generando archivo…<br><small class="text-muted">No cierres esta ventana.</small>',
            allowOutsideClick: false,
            allowEscapeKey: false,
            showConfirmButton: false,
            didOpen: function () { window.Swal.showLoading(); }
        });
        await new Promise(function (r) { setTimeout(r, 1600); });
        window.Swal.close();
    });

    document.getElementById('btn-swal-update-steps')?.addEventListener('click', async function () {
        if (typeof window.Swal === 'undefined') return;
        window.Swal.fire({
            title: 'Paso 1 de 3',
            allowOutsideClick: false,
            showConfirmButton: false,
            didOpen: function () { window.Swal.showLoading(); }
        });
        await new Promise(function (r) { setTimeout(r, 500); });
        window.Swal.update({ title: 'Paso 2 de 3 — validando' });
        await new Promise(function (r) { setTimeout(r, 500); });
        window.Swal.update({ title: 'Paso 3 — finalizando' });
        await new Promise(function (r) { setTimeout(r, 500); });
        window.Swal.hideLoading();
        window.Swal.update({
            title: 'Hecho',
            html: 'Puedes cerrar o continuar.',
            showConfirmButton: true,
            confirmButtonText: 'Entendido'
        });
    });

    document.getElementById('btn-swal-preconfirm')?.addEventListener('click', async function () {
        if (typeof window.Swal === 'undefined') return;
        var res = await window.Swal.fire({
            title: '¿Eliminar ítem?',
            text: 'Se llama al API y el botón muestra loader.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            showLoaderOnConfirm: true,
            preConfirm: function () {
                return new Promise(function (resolve) {
                    setTimeout(function () { resolve({ ok: true }); }, 1200);
                });
            },
            allowOutsideClick: function () { return !window.Swal.isLoading(); }
        });
        if (res.isConfirmed && typeof gToast === 'function') {
            gToast('Eliminado (demo).', 'success');
        }
    });

    var dtEl = document.getElementById('dt-loading-demo');
    var dtFetchEl = document.getElementById('dt-fetch-demo');
    var locale = {{ app.request.locale|json_encode|raw }};
    var dtLang = locale === 'en'
        ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
        : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';

    if (dtEl && typeof DataTable !== 'undefined') {
        var rows = [
            { id: 1, concepto: 'Suscripción', importe: '19,99' },
            { id: 2, concepto: 'Dominio', importe: '12,00' },
            { id: 3, concepto: 'API IA', importe: '48,50' }
        ];
        var dt;
        try {
            dt = new DataTable(dtEl, {
                processing: true,
                data: rows,
                columns: [
                    { data: 'id', title: 'Id' },
                    { data: 'concepto', title: 'Concepto' },
                    { data: 'importe', title: 'Importe' }
                ],
                ordering: true,
                paging: false,
                searching: false,
                info: false,
                language: { url: dtLang }
            });
        } catch (e) {
            console.error(e);
            dt = null;
        }
        document.getElementById('btn-dt-processing')?.addEventListener('click', function () {
            if (!dt || typeof dt.processing !== 'function') return;
            dt.processing(true);
            setTimeout(function () {
                dt.processing(false);
                dt.draw();
            }, 1500);
        });
    }

    if (dtFetchEl && typeof DataTable !== 'undefined') {
        var dtFetch;
        var dtFetchBusy = false;
        var dtFetchSeq = 0;
        try {
            dtFetch = new DataTable(dtFetchEl, {
                processing: true,
                data: [],
                columns: [
                    { data: 'cliente', title: 'Cliente' },
                    { data: 'estado', title: 'Estado' },
                    { data: 'sync', title: 'Última sync' }
                ],
                ordering: true,
                paging: false,
                searching: false,
                info: false,
                language: { url: dtLang }
            });
        } catch (e2) {
            console.error(e2);
            dtFetch = null;
        }
        if (dtFetch && typeof dtFetch.processing === 'function') {
            dtFetch.processing(false);
        }
        function simulateFetchFilas() {
            return new Promise(function (resolve) {
                setTimeout(function () {
                    dtFetchSeq += 1;
                    var stamp = new Date().toISOString().slice(0, 16).replace('T', ' ');
                    resolve([
                        { cliente: 'Acme SL', estado: 'Activo', sync: stamp + ' · req #' + dtFetchSeq },
                        { cliente: 'Nova Labs', estado: 'Activo', sync: stamp },
                        { cliente: 'Grova Hosting', estado: 'Suspendido', sync: '—' },
                        { cliente: 'Taller Jordi', estado: 'Activo', sync: stamp }
                    ]);
                }, 1600);
            });
        }
        async function ejecutarCargaFetch() {
            if (!dtFetch || dtFetchBusy) return;
            dtFetchBusy = true;
            dtFetch.processing(true);
            try {
                var filas = await simulateFetchFilas();
                dtFetch.clear().rows.add(filas).draw();
            } catch (err) {
                console.error(err);
                if (typeof gToast === 'function') {
                    gToast('Error al cargar (demo).', 'error');
                }
            } finally {
                if (dtFetch && typeof dtFetch.processing === 'function') {
                    dtFetch.processing(false);
                }
                dtFetchBusy = false;
            }
        }
        document.getElementById('btn-dt-fetch-load')?.addEventListener('click', ejecutarCargaFetch);
        document.getElementById('btn-dt-fetch-reload')?.addEventListener('click', ejecutarCargaFetch);
        document.getElementById('btn-dt-fetch-clear')?.addEventListener('click', function () {
            if (!dtFetch || dtFetchBusy) return;
            dtFetch.clear().draw();
        });
    }
})();
</script>
{% endblock %}
