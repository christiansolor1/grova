                    <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-dt-fetch-reload">Recargar (mantiene indicador)</button>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btn-dt-fetch-clear">Vaciar tabla</button>
                </div>
                <div class="table-responsive rounded border border-secondary border-opacity-25" style="max-width:100%;">
                    <table id="dt-fetch-demo" class="table table-sm table-hover w-100 mb-0" style="color:inherit;">
                        <thead>
                            <tr><th>Cliente</th><th>Estado</th><th>Última sync</th></tr>
                        </thead>
