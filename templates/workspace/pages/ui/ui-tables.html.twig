        {# ── Nota API antigua (jQuery) ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="alert alert-secondary mb-0 py-2" style="font-size:13px;">
                    <i class="bi bi-info-circle me-2"></i>CSS global + piel Grova. <code>GrovaDataTable.init</code>: sin <code>buttons</code> → ninguno; <code>buttons: 'full'</code> → todos; <code>buttons: ['excel','pdf']</code> → manual; <code>buttons: 'export'</code> → preset.
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('grova-ui-tables-dt-demo');
    if (!el || typeof DataTable === 'undefined') return;
    var locale = {{ app.request.locale|json_encode|raw }};
    var langUrl = locale === 'en'
        ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
        : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';
    try {
        var initDt = (window.GrovaDataTable && window.GrovaDataTable.init) ? window.GrovaDataTable.init : function (t, o) { return new DataTable(t, o); };
        initDt(el, {
            language: { url: langUrl },
            pageLength: 5,
            order: [[0, 'asc']],
            buttons: ['copy', 'excel', 'colvis'],
            layout: {
                topStart: { pageLength: { menu: [5, 10, 25, -1] } },
                topEnd: { search: { placeholder: {{ (app.request.locale == 'en' ? 'Search…' : 'Buscar…')|json_encode|raw }} } }
            }
        });
    } catch (e) {
        console.error(e);
    }
});
</script>
<script>
document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});
</script>
{% endblock %}
