                </div>
                <pre id="code-datatable-init">{% verbatim %}<!-- En Grova workspace, app_layout ya carga dataTables + integración Bootstrap antes de app_page_scripts. -->
<script>
document.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('mi-tabla');
    if (!el || typeof DataTable === 'undefined') return;
    var locale = document.documentElement.lang || 'es';
    var langUrl = locale.indexOf('en') === 0
        ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
        : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';
    new DataTable(el, {
        language: { url: langUrl },
        pageLength: 10,
        layout: {
            topStart: { pageLength: { menu: [5, 10, 25, 50, -1] } },
            topEnd: { search: { placeholder: 'Buscar…' } }
        }
    });
});
</script>{% endverbatim %}</pre>
            </div>
