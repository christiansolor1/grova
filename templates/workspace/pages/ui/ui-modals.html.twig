{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Modales{% endblock %}
{% block app_page_subtitle %}Modales para formularios, confirmaciones y detalles. Copia el código y úsalo en cualquier vista.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Modales</div>
    <div class="content-card-body">

        {# ── Modal de formulario ── #}
        <div class="ui-component">
            <div class="ui-component-preview d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-form-demo">
                    <i class="bi bi-plus me-1"></i>Modal formulario
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#modal-confirm-demo">
                    <i class="bi bi-trash me-1"></i>Modal confirmación
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-detail-demo">
                    <i class="bi bi-eye me-1"></i>Modal detalle
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-lg-demo">
                    Modal grande
                </button>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Trigger</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-modal-trigger">Copiar</button>
                </div>
                <pre id="code-modal-trigger">{% verbatim %}<button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#mi-modal">
    <i class="bi bi-plus me-1"></i>Abrir modal
</button>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Código modal formulario ── #}
        <div class="ui-component">
            <div class="ui-component-code" style="border-top:0;">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Modal formulario</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-modal-form">Copiar</button>
                </div>
                <pre id="code-modal-form">{% verbatim %}<div class="modal fade" id="mi-modal" tabindex="-1" aria-labelledby="mi-modal-label" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mi-modal-label">Nuevo registro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="mi-form">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control form-control-sm" name="nombre" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Estado</label>
                            <select class="form-select form-select-sm" name="estado">
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" form="mi-form" class="btn btn-primary btn-sm">Guardar</button>
            </div>
        </div>
    </div>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Código modal confirmación ── #}
        <div class="ui-component">
            <div class="ui-component-code" style="border-top:0;">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Modal confirmación (eliminar)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-modal-confirm">Copiar</button>
                </div>
                <pre id="code-modal-confirm">{% verbatim %}<div class="modal fade" id="modal-eliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Eliminar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-1">
                <p class="mb-0" style="font-size:14px;">¿Estás seguro de que deseas eliminar este registro? Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger btn-sm" id="btn-confirm-delete">Eliminar</button>
            </div>
        </div>
    </div>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Código modal detalle / solo lectura ── #}
        <div class="ui-component">
            <div class="ui-component-code" style="border-top:0;">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Modal detalle (solo lectura)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-modal-detail">Copiar</button>
                </div>
                <pre id="code-modal-detail">{% verbatim %}<div class="modal fade" id="modal-detalle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalle del registro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">Christian Solórzano</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">christian@grova.com</dd>
                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8"><span class="badge bg-success">Activo</span></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary btn-sm">Editar</button>
            </div>
        </div>
    </div>
</div>{% endverbatim %}</pre>
            </div>
        </div>

    </div>
</div>

{# ── Modales de demo (no copiar esto, solo para preview) ── #}
<div class="modal fade" id="modal-form-demo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo registro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Ingresa el nombre">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Estado</label>
                        <select class="grova-select2" data-placeholder="Seleccionar estado..." data-dropdown-parent="#modal-form-demo">
                            <option value=""></option>
                            <option value="activo">Activo</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Asignar a</label>
                        <select class="grova-select2" data-placeholder="Buscar usuario..." data-allow-clear="true" data-dropdown-parent="#modal-form-demo">
                            <option value=""></option>
                            <option value="1">Christian Solórzano</option>
                            <option value="2">Jordi Construcción</option>
                            <option value="3">Alcides Bufete</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary btn-sm">Guardar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-confirm-demo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Eliminar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-1">
                <p class="mb-0" style="font-size:14px;">¿Estás seguro? Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger btn-sm" data-bs-dismiss="modal">Eliminar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-detail-demo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalle del registro</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">Christian Solórzano</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">christian@grova.com</dd>
                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8"><span class="badge bg-success">Activo</span></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary btn-sm">Editar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-lg-demo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Modal grande (xl)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted" style="font-size:13px;">Usa <code>modal-sm</code>, <code>modal-lg</code>, <code>modal-xl</code> para controlar el tamaño.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});
</script>
{% endblock %}
