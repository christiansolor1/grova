{% extends 'workspace/app_layout.html.twig' %}
{% block page_title %}Admin / Super-admin{% endblock %}
{% block app_page_subtitle %}Patrones para gestión de tenants, planes, MRR e impersonation. Solo disponible para super-admin.{% endblock %}

{% block page_styles %}
<style>
.ui-component{border:1px solid #1e293b;border-radius:10px;overflow:hidden;margin-bottom:1.5rem;}
.ui-component-preview{padding:1.5rem;background:#0f172a;overflow-x:auto;}
.ui-component-code{background:#020617;border-top:1px solid #1e293b;}
.ui-component-code-header{display:flex;align-items:center;justify-content:space-between;padding:.5rem 1rem;border-bottom:1px solid #1e293b;}
.ui-component-code-label{font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;}
.ui-component-code pre{margin:0;padding:1rem;font-size:12px;color:#94a3b8;overflow-x:auto;white-space:pre;}
.btn-copy-code{font-size:11px;padding:2px 10px;}
body.light-mode .ui-component{border-color:#dbe3ee;}
body.light-mode .ui-component-preview{background:#f8fafc;}
body.light-mode .ui-component-code{background:#f1f5f9;border-color:#dbe3ee;}
body.light-mode .ui-component-code-header{border-color:#dbe3ee;}
body.light-mode .ui-component-code pre{color:#475569;}
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Admin / Super-admin</div>
    <div class="content-card-body">

        {# ── Impersonation banner ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div style="width:100%;background:#7c2d12;border:1px solid #9a3412;border-radius:8px;padding:.6rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:.5rem;font-size:13px;color:#fed7aa;">
                        <i class="bi bi-eye-fill"></i>
                        <span>Estás viendo el sistema como <strong>jordi@construccion.com</strong> (grova_jordi)</span>
                    </div>
                    <a href="#" class="btn btn-sm" style="background:#9a3412;color:#fed7aa;border:1px solid #c2410c;font-size:12px;">
                        <i class="bi bi-x-circle me-1"></i>Salir de vista
                    </a>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Banner de impersonation</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-impersonate">Copiar</button>
                </div>
                <pre id="code-impersonate">{% verbatim %}{% if is_granted('IS_IMPERSONATOR') %}
<div class="grova-impersonate-banner">
    <div class="grova-impersonate-msg">
        <i class="bi bi-eye-fill"></i>
        Estás viendo como <strong>{{ app.user.email }}</strong>
        ({{ app.user.tenantSlug }})
    </div>
    <a href="{{ path('app_dashboard') }}?_switch_user=_exit" class="btn btn-sm grova-impersonate-exit">
        <i class="bi bi-x-circle me-1"></i>Salir de vista
    </a>
</div>
{% endif %}{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Lista de tenants ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <table class="table table-sm mb-0" style="min-width:560px;">
                    <thead>
                        <tr>
                            <th style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;">Tenant</th>
                            <th style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;">Plan</th>
                            <th style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;">MRR</th>
                            <th style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;">Estado</th>
                            <th style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in [
                            {n:'Bufete Alcides',   slug:'grova_alcides',  plan:'Pro',   mrr:'$49',  estado:'activo'},
                            {n:'Jordi Construcción',slug:'grova_jordi',   plan:'Pro',   mrr:'$49',  estado:'activo'},
                            {n:'Christian',        slug:'grova_christian',plan:'Free',  mrr:'$0',   estado:'cortesía'},
                            {n:'Pesca Grupo',      slug:'grova_pesca',    plan:'Free',  mrr:'$0',   estado:'cortesía'},
                        ] %}
                        <tr>
                            <td>
                                <div style="font-size:13px;font-weight:500;color:#e2e8f0;">{{ t.n }}</div>
                                <div style="font-size:11px;color:#475569;"><code>{{ t.slug }}</code></div>
                            </td>
                            <td style="font-size:13px;">{{ t.plan }}</td>
                            <td style="font-size:13px;font-weight:600;color:{{ t.mrr == '$0' ? '#64748b' : '#22c55e' }};">{{ t.mrr }}</td>
                            <td>
                                <span class="badge {{ t.estado == 'activo' ? 'bg-success' : 'bg-secondary' }}">{{ t.estado }}</span>
                            </td>
                            <td>
                                <div style="display:flex;gap:.35rem;">
                                    <button class="btn btn-outline-secondary btn-sm" style="font-size:11px;padding:2px 8px;"><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-outline-warning btn-sm" style="font-size:11px;padding:2px 8px;"><i class="bi bi-person-fill-gear"></i></button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Lista de tenants</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-tenants">Copiar</button>
                </div>
                <pre id="code-tenants">{% verbatim %}<table class="table table-sm">
    <thead>
        <tr>
            <th>Tenant</th><th>Plan</th><th>MRR</th><th>Estado</th><th></th>
        </tr>
    </thead>
    <tbody>
        {% for tenant in tenants %}
        <tr>
            <td>
                <div style="font-size:13px;font-weight:500;">{{ tenant.nombre }}</div>
                <div style="font-size:11px;color:#64748b;"><code>{{ tenant.slug }}</code></div>
            </td>
            <td>{{ tenant.suscripcion.plan.nombre }}</td>
            <td style="font-weight:600;">$ {{ tenant.suscripcion.plan.precio }}</td>
            <td><span class="badge bg-{{ tenant.activo ? 'success' : 'secondary' }}">
                {{ tenant.activo ? 'Activo' : 'Inactivo' }}
            </span></td>
            <td>
                <a href="{{ path('grova_admin_tenant_show', {id: tenant.id}) }}"
                   class="btn btn-outline-secondary btn-sm"><i class="bi bi-eye"></i></a>
                <a href="{{ path('app_login') }}?_switch_user={{ tenant.adminEmail }}"
                   class="btn btn-outline-warning btn-sm"><i class="bi bi-person-fill-gear"></i></a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Ficha de tenant ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div style="max-width:440px;width:100%;background:#111827;border:1px solid #1e293b;border-radius:10px;padding:1rem;">
                    <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;">
                        <div class="grova-profile-avatar" style="width:40px;height:40px;font-size:16px;background:#1e3a5f;">JC</div>
                        <div>
                            <div style="font-size:14px;font-weight:700;color:#e2e8f0;">Jordi Construcción</div>
                            <div style="font-size:11px;color:#64748b;"><code>grova_jordi</code></div>
                        </div>
                        <span class="badge bg-success ms-auto">Activo</span>
                    </div>
                    <dl class="grova-detail-list mb-0">
                        <div class="grova-detail-row"><dt>Plan</dt><dd>Pro · $49/mes</dd></div>
                        <div class="grova-detail-row"><dt>Vencimiento</dt><dd>01/07/2026</dd></div>
                        <div class="grova-detail-row"><dt>DB</dt><dd><code>grova_jordi</code></dd></div>
                        <div class="grova-detail-row"><dt>Admin</dt><dd>jordi@construccion.com</dd></div>
                        <div class="grova-detail-row"><dt>Módulos</dt><dd>Construcción, Facturación, RRHH</dd></div>
                    </dl>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Ficha de tenant</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-tenant-card">Copiar</button>
                </div>
                <pre id="code-tenant-card">{% verbatim %}<div class="grova-tenant-card">
    <div class="grova-tenant-card-header">
        <div class="grova-profile-avatar">{{ tenant.initials }}</div>
        <div>
            <div style="font-size:14px;font-weight:700;">{{ tenant.nombre }}</div>
            <div style="font-size:11px;color:#64748b;"><code>{{ tenant.slug }}</code></div>
        </div>
        <span class="badge bg-{{ tenant.activo ? 'success' : 'secondary' }} ms-auto">
            {{ tenant.activo ? 'Activo' : 'Inactivo' }}
        </span>
    </div>
    <dl class="grova-detail-list">
        <div class="grova-detail-row"><dt>Plan</dt><dd>{{ tenant.plan.nombre }}</dd></div>
        <div class="grova-detail-row"><dt>DB</dt><dd><code>{{ tenant.db_name }}</code></dd></div>
        <div class="grova-detail-row"><dt>Admin</dt><dd>{{ tenant.adminEmail }}</dd></div>
        <div class="grova-detail-row">
            <dt>Módulos</dt>
            <dd>{{ tenant.modulosActivos|join(', ') }}</dd>
        </div>
    </dl>
</div>{% endverbatim %}</pre>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function(btn){
    btn.addEventListener('click',function(){
        var t=document.getElementById(btn.getAttribute('data-copy-target'));
        if(!t)return;
        navigator.clipboard.writeText(t.textContent.trim()).then(function(){
            var o=btn.textContent;btn.textContent='Copiado';
            setTimeout(function(){btn.textContent=o;},1200);
        });
    });
});
</script>
{% endblock %}
