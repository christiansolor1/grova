{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Cards y contenedores{% endblock %}
{% block app_page_subtitle %}Cards, listas, timelines y contenedores para sistemas transaccionales. Copia el código y úsalo en cualquier vista.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
.grova-timeline { list-style: none; padding: 0; margin: 0; position: relative; }
.grova-timeline::before { content: ''; position: absolute; left: 16px; top: 0; bottom: 0; width: 2px; background: #1e293b; }
.grova-timeline li { display: flex; gap: 1rem; padding: .75rem 0; position: relative; }
.grova-timeline .tl-dot { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 13px; z-index: 1; }
.grova-timeline .tl-body { flex: 1; }
.grova-timeline .tl-title { font-size: 13px; font-weight: 600; }
.grova-timeline .tl-meta { font-size: 11px; color: #64748b; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }
body.light-mode .grova-timeline::before { background: #dbe3ee; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Cards y contenedores</div>
    <div class="content-card-body">

        {# ── Content card (estándar de grova) ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="content-card">
                            <div class="content-card-header">Card básica</div>
                            <div class="content-card-body">
                                <p style="font-size:13px; margin:0;">Contenido de la card. Úsala para agrupar información relacionada.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="content-card">
                            <div class="content-card-header d-flex justify-content-between align-items-center">
                                Card con acción
                                <button type="button" class="btn btn-outline-secondary btn-sm" style="font-size:11px;padding:2px 8px;"><i class="bi bi-gear"></i></button>
                            </div>
                            <div class="content-card-body">
                                <p style="font-size:13px; margin:0;">Card con botón de acción en el header.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="content-card">
                            <div class="content-card-header">Card con footer</div>
                            <div class="content-card-body">
                                <p style="font-size:13px; margin:0;">Card con footer para acciones secundarias.</p>
                            </div>
                            <div class="content-card-body" style="border-top:1px solid #1e293b; padding-top:.75rem;">
                                <button type="button" class="btn btn-primary btn-sm me-1">Guardar</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm">Cancelar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Content card</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-content-card">Copiar</button>
                </div>
                <pre id="code-content-card">{% verbatim %}{# Card básica #}
<div class="content-card">
    <div class="content-card-header">Título</div>
    <div class="content-card-body">
        Contenido aquí.
    </div>
</div>

{# Card con acción en header #}
<div class="content-card">
    <div class="content-card-header d-flex justify-content-between align-items-center">
        Título
        <button type="button" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i></button>
    </div>
    <div class="content-card-body">Contenido.</div>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Lista de items con acción ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="content-card">
