{% extends 'workspace/app_layout.html.twig' %}
{% block page_title %}Permisos y roles{% endblock %}
{% block app_page_subtitle %}Matriz de permisos, asignación de roles y acceso denegado inline.{% endblock %}

{% block page_styles %}
<style>
.ui-component{border:1px solid #1e293b;border-radius:10px;overflow:hidden;margin-bottom:1.5rem;}
.ui-component-preview{padding:1.5rem;background:#0f172a;overflow-x:auto;}
.ui-component-code{background:#020617;border-top:1px solid #1e293b;}
.ui-component-code-header{display:flex;align-items:center;justify-content:space-between;padding:.5rem 1rem;border-bottom:1px solid #1e293b;}
.ui-component-code-label{font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.5px;}
.ui-component-code pre{margin:0;padding:1rem;font-size:12px;color:#94a3b8;overflow-x:auto;white-space:pre;}
.btn-copy-code{font-size:11px;padding:2px 10px;}
body.light-mode .ui-component{border-color:#dbe3ee;}
body.light-mode .ui-component-preview{background:#f8fafc;}
body.light-mode .ui-component-code{background:#f1f5f9;border-color:#dbe3ee;}
body.light-mode .ui-component-code-header{border-color:#dbe3ee;}
body.light-mode .ui-component-code pre{color:#475569;}
/* Matriz */
.perm-table th,.perm-table td{padding:8px 12px;font-size:13px;white-space:nowrap;}
.perm-table th{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.04em;color:#64748b;}
.perm-table td:first-child{font-weight:500;color:#e2e8f0;}
body.light-mode .perm-table td:first-child{color:#1e293b;}
.perm-check{display:flex;align-items:center;justify-content:center;}
.perm-yes{color:#22c55e;font-size:16px;}
.perm-no{color:#334155;font-size:16px;}
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Permisos y roles</div>
    <div class="content-card-body">

        {# ── Matriz de permisos ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <table class="table table-sm perm-table mb-0">
                    <thead>
                        <tr>
                            <th>Recurso</th>
                            <th class="text-center">Ver</th>
                            <th class="text-center">Crear</th>
                            <th class="text-center">Editar</th>
                            <th class="text-center">Eliminar</th>
                            <th class="text-center">Exportar</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set recursos = [
                            {n:'Usuarios',       v:true,  c:false, e:false, d:false, x:false},
                            {n:'Contactos',      v:true,  c:true,  e:true,  d:false, x:true},
                            {n:'Facturas',       v:true,  c:true,  e:true,  d:false, x:true},
                            {n:'Configuración',  v:false, c:false, e:false, d:false, x:false},
                            {n:'Reportes',       v:true,  c:false, e:false, d:false, x:true},
                        ] %}
                        {% for r in recursos %}
                        <tr>
                            <td>{{ r.n }}</td>
                            {% for key in ['v','c','e','d','x'] %}
                            <td class="text-center">
                                {% if attribute(r, key) %}
                                    <i class="bi bi-check-circle-fill perm-yes"></i>
                                {% else %}
                                    <i class="bi bi-dash-circle perm-no"></i>
                                {% endif %}
                            </td>
                            {% endfor %}
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Matriz de permisos</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-matrix">Copiar</button>
                </div>
                <pre id="code-matrix">{% verbatim %}<table class="table table-sm perm-table">
    <thead>
        <tr>
            <th>Recurso</th>
            <th class="text-center">Ver</th>
            <th class="text-center">Crear</th>
            <th class="text-center">Editar</th>
            <th class="text-center">Eliminar</th>
            <th class="text-center">Exportar</th>
        </tr>
    </thead>
    <tbody>
        {% for recurso in recursos %}
        <tr>
            <td>{{ recurso.nombre }}</td>
            {% for accion in ['ver','crear','editar','eliminar','exportar'] %}
            <td class="text-center">
                {% if recurso.permisos[accion] is defined and recurso.permisos[accion] %}
                    <i class="bi bi-check-circle-fill text-success"></i>
                {% else %}
                    <i class="bi bi-dash-circle text-secondary"></i>
                {% endif %}
            </td>
            {% endfor %}
        </tr>
        {% endfor %}
    </tbody>
</table>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Asignación de rol ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div style="max-width:400px;width:100%;">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="grova-profile-avatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;">CS</div>
                        <div>
                            <div style="font-size:13px;font-weight:600;color:#e2e8f0;">Christian Solórzano</div>
                            <div style="font-size:11px;color:#64748b;">christian@grova.com</div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rol asignado</label>
                        <select class="grova-select2 form-select form-select-sm" data-placeholder="Seleccionar rol...">
                            <option value=""></option>
                            <option selected value="admin">Administrador</option>
                            <option value="editor">Editor</option>
                            <option value="viewer">Visor</option>
                        </select>
                    </div>
                    <button class="btn btn-primary btn-sm">Guardar rol</button>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Asignación de rol</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-role">Copiar</button>
                </div>
                <pre id="code-role">{% verbatim %}<form method="post" action="{{ path('grova_user_assign_role', {id: user.id}) }}">
    <div class="mb-3">
        <label class="form-label">Rol asignado</label>
        <select name="role" class="grova-select2 form-select form-select-sm" data-placeholder="Seleccionar rol...">
            <option value=""></option>
            {% for role in roles_disponibles %}
                <option value="{{ role.key }}" {{ user.role == role.key ? 'selected' : '' }}>
                    {{ role.label }}
                </option>
            {% endfor %}
        </select>
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Guardar rol</button>
</form>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Acceso denegado inline ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-access-denied">
                    <i class="bi bi-shield-lock" style="font-size:2rem;color:#475569;"></i>
                    <div style="font-size:14px;font-weight:600;color:#94a3b8;">Acceso restringido</div>
                    <div style="font-size:13px;color:#64748b;">No tienes permisos para ver esta sección. Contacta al administrador.</div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig — Acceso denegado inline</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-denied">Copiar</button>
                </div>
                <pre id="code-denied">{% verbatim %}{% if is_granted('ROLE_ADMIN') %}
    {# contenido protegido #}
{% else %}
    <div class="grova-access-denied">
        <i class="bi bi-shield-lock" style="font-size:2rem;color:#475569;"></i>
        <div style="font-size:14px;font-weight:600;">Acceso restringido</div>
        <div style="font-size:13px;color:#64748b;">No tienes permisos para ver esta sección.</div>
    </div>
{% endif %}{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Chips de permisos ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
                    <span class="badge rounded-pill bg-success bg-opacity-20 text-success" style="font-size:12px;padding:4px 10px;border:1px solid #16a34a40;"><i class="bi bi-eye me-1"></i>Ver</span>
                    <span class="badge rounded-pill bg-primary bg-opacity-20 text-primary" style="font-size:12px;padding:4px 10px;border:1px solid #2563eb40;"><i class="bi bi-plus me-1"></i>Crear</span>
                    <span class="badge rounded-pill bg-warning bg-opacity-20 text-warning" style="font-size:12px;padding:4px 10px;border:1px solid #d9770640;"><i class="bi bi-pencil me-1"></i>Editar</span>
                    <span class="badge rounded-pill bg-secondary bg-opacity-20 text-secondary" style="font-size:12px;padding:4px 10px;border:1px solid #47556940;"><i class="bi bi-x me-1"></i>Sin eliminar</span>
                    <span class="badge rounded-pill bg-info bg-opacity-20 text-info" style="font-size:12px;padding:4px 10px;border:1px solid #0284c740;"><i class="bi bi-download me-1"></i>Exportar</span>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Chips de permisos activos</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-chips">Copiar</button>
                </div>
                <pre id="code-chips">{% verbatim %}{% for permiso in user.permisos %}
<span class="badge rounded-pill {{ permiso.activo ? 'bg-success bg-opacity-20 text-success' : 'bg-secondary bg-opacity-20 text-secondary' }}"
      style="font-size:12px;padding:4px 10px;">
    <i class="bi {{ permiso.icon }} me-1"></i>{{ permiso.label }}
</span>
{% endfor %}{% endverbatim %}</pre>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function(btn){
    btn.addEventListener('click',function(){
        var t=document.getElementById(btn.getAttribute('data-copy-target'));
        if(!t)return;
        navigator.clipboard.writeText(t.textContent.trim()).then(function(){
            var o=btn.textContent;btn.textContent='Copiado';
            setTimeout(function(){btn.textContent=o;},1200);
        });
    });
});
</script>
{% endblock %}
