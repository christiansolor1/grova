{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}{{ 'Iconos BI/FA' | trans }}{% endblock %}
{% block app_page_subtitle %}{{ 'Referencia rápida para copiar clases de Bootstrap Icons y Font Awesome.' | trans }}{% endblock %}

{% block page_styles %}
<style>
.icons-search-wrap { position: relative; }
.icons-search-wrap input {
    height: 34px; border: 1px solid #334155; border-radius: 9px;
    background: #0f172a; color: #e5e7eb; padding: 7px 34px 7px 30px; font-size: 13px;
}
.icons-search-wrap input::placeholder { color: #64748b; }
.icons-search-wrap input:focus { border-color: #2563eb; outline: none; box-shadow: none; }
.icons-search-wrap .search-icon {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: #64748b; display: inline-flex; align-items: center;
}
.icons-search-clear {
    position: absolute; right: 6px; top: 50%; transform: translateY(-50%);
    width: 22px; height: 22px; border: 0; border-radius: 6px; display: none;
    align-items: center; justify-content: center; background: #111827; color: #9ca3af;
}
.icons-search-wrap.has-value .icons-search-clear { display: inline-flex; }
.icons-search-clear:hover { background: #1f2937; color: #e5e7eb; }
body.light-mode .icons-search-wrap input { background: #fff; color: #0f172a; border-color: #dbe3ee; }
body.light-mode .icons-search-wrap input::placeholder { color: #94a3b8; }
body.light-mode .icons-search-clear { background: #f1f5f9; color: #64748b; }
body.light-mode .icons-search-clear:hover { background: #e2e8f0; color: #334155; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">{{ 'Catálogo de íconos' | trans }}</div>
    <div class="content-card-body">
        <p class="text-muted mb-3" style="font-size:13px;">
            Busca un ícono y copia su clase en un clic. Soporta <code>Bootstrap Icons</code> y <code>Font Awesome</code>.
        </p>

        <div class="row g-2 mb-3">
            <div class="col-md-7">
                <div class="icons-search-wrap" id="icons-search-wrap">
                    <span class="search-icon" aria-hidden="true">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
                    </span>
                    <input id="icons-search" type="search" class="form-control form-control-sm" placeholder="Buscar ícono... ejemplo: user, chart, shield, house">
                    <button id="icons-search-clear" type="button" class="icons-search-clear" aria-label="{{ 'Buscar' | trans }}" title="{{ 'Buscar' | trans }}">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>
            <div class="col-md-3">
                <select id="icons-set" class="form-select form-select-sm">
                    <option value="all">{{ 'Todas las librerías' | trans }}</option>
                    <option value="bi">{{ 'Solo Bootstrap Icons' | trans }}</option>
                    <option value="fa">{{ 'Solo Font Awesome' | trans }}</option>
                </select>
            </div>
            <div class="col-md-2">
                <select id="icons-limit" class="form-select form-select-sm">
                    <option value="50">50</option>
                    <option value="100" selected>100</option>
                    <option value="200">200</option>
                    <option value="300">300</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                    <option value="all">{{ 'Ver todos' | trans }}</option>
                </select>
            </div>
        </div>

        <div id="icons-feedback" class="small text-muted mb-2">{{ 'Cargando catálogos...' | trans }}</div>
        <div id="icons-counts" class="small text-muted mb-2"></div>
        <div id="icons-grid" class="row g-2"></div>
    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
(function () {
    var searchEl = document.getElementById('icons-search');
    var clearSearchEl = document.getElementById('icons-search-clear');
    var searchWrapEl = document.getElementById('icons-search-wrap');
    var setEl = document.getElementById('icons-set');
    var limitEl = document.getElementById('icons-limit');
    var gridEl = document.getElementById('icons-grid');
    var feedbackEl = document.getElementById('icons-feedback');
    var countsEl = document.getElementById('icons-counts');
    if (!searchEl || !clearSearchEl || !searchWrapEl || !setEl || !limitEl || !gridEl || !feedbackEl || !countsEl) return;

    var allIcons = [];

    function esc(s) {
        return String(s || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    function normalized(text) {
        if (window.GrovaIconLib && typeof window.GrovaIconLib.normalizeText === 'function') {
            return window.GrovaIconLib.normalizeText(text);
        }
        return String(text || '').toLowerCase().trim();
    }

    function renderCard(icon) {
        var badge = icon.set === 'fa'
            ? '<span class="badge text-bg-warning">FA</span>'
            : '<span class="badge text-bg-primary">BI</span>';
        return '' +
            '<div class="col-sm-6 col-lg-4 col-xl-3">' +
                '<div class="border rounded p-2 h-100 d-flex flex-column gap-2">' +
                    '<div class="d-flex align-items-center justify-content-between">' +
                        '<div class="d-flex align-items-center gap-2">' +
                            '<i class="' + esc(icon.className) + '" style="font-size:18px;"></i>' +
                            '<strong style="font-size:12px;">' + esc(icon.shortName) + '</strong>' +
                        '</div>' +
                        badge +
                    '</div>' +
                    '<code style="font-size:11px;word-break:break-all;">' + esc(icon.className) + '</code>' +
                    '<button type="button" class="btn btn-sm btn-outline-secondary js-copy-icon mt-auto" data-copy="' + esc(icon.className) + '">Copiar clase</button>' +
                '</div>' +
            '</div>';
    }

    function renderList() {
        var term = normalized(searchEl.value);
        var setFilter = setEl.value;
        var isAll = limitEl.value === 'all';
        var limit = isAll ? 100000 : (parseInt(limitEl.value, 10) || 100);
        var visible = window.GrovaIconLib && typeof window.GrovaIconLib.filterIcons === 'function'
            ? window.GrovaIconLib.filterIcons(allIcons, term, setFilter, limit)
            : allIcons.slice(0, limit);
        var totalMatching = window.GrovaIconLib && typeof window.GrovaIconLib.filterIcons === 'function'
            ? window.GrovaIconLib.filterIcons(allIcons, term, setFilter, 100000).length
            : allIcons.length;
        var totalLoaded = allIcons.length;
        var totalBi = allIcons.filter(function (i) { return i.set === 'bi'; }).length;
        var totalFa = allIcons.filter(function (i) { return i.set === 'fa'; }).length;
        feedbackEl.textContent = 'Mostrando ' + visible.length + ' de ' + totalMatching + ' coincidencias' + (isAll ? ' (Ver todos)' : '') + '.';
        countsEl.textContent = 'Total cargado: ' + totalLoaded + ' iconos (BI: ' + totalBi + ', FA: ' + totalFa + ').';
        gridEl.innerHTML = visible.map(renderCard).join('') || '<div class="col-12"><div class="alert alert-secondary mb-0">Sin resultados para tu búsqueda.</div></div>';
        searchWrapEl.classList.toggle('has-value', searchEl.value.trim() !== '');
    }

    function attachCopyEvents() {
        gridEl.addEventListener('click', function (e) {
            var btn = e.target.closest('.js-copy-icon');
            if (!btn) return;
            var text = btn.getAttribute('data-copy') || '';
            if (!text) return;
            navigator.clipboard.writeText(text).then(function () {
                var old = btn.textContent;
                btn.textContent = 'Copiado';
                setTimeout(function () { btn.textContent = old; }, 900);
            });
        });
    }

    function loadIcons() {
        if (!window.GrovaIconLib || typeof window.GrovaIconLib.loadAllIcons !== 'function') {
            feedbackEl.textContent = 'No se encontro libreria de iconos compartida.';
            return;
        }
        window.GrovaIconLib.loadAllIcons().then(function (result) {
            allIcons = (result || []).map(function (it) {
                return {
                    set: it.set,
                    shortName: it.shortName || it.value,
                    className: it.className || it.value
                };
            });
            if (allIcons.length === 0) {
                feedbackEl.textContent = 'No se pudieron cargar catálogos. Revisa conexión a internet.';
                gridEl.innerHTML = '<div class="col-12"><div class="alert alert-warning mb-0">No fue posible cargar Bootstrap Icons / Font Awesome.</div></div>';
                return;
            }
            allIcons.sort(function (a, b) { return a.shortName.localeCompare(b.shortName); });
            renderList();
        });
    }

    searchEl.addEventListener('input', renderList);
    clearSearchEl.addEventListener('click', function () {
        searchEl.value = '';
        searchEl.focus();
        renderList();
    });
    setEl.addEventListener('change', renderList);
    limitEl.addEventListener('change', renderList);
    attachCopyEvents();
    loadIcons();
})();
</script>
{% endblock %}
