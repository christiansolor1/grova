{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Empty states{% endblock %}
{% block app_page_subtitle %}Pantallas vacías para listas sin datos, búsquedas sin resultados y errores. Copia y pega dentro de cualquier tabla o contenedor.{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 2rem 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; white-space: pre; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Empty states</div>
    <div class="content-card-body">

        {# ── Básico ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-empty-state">
                    <div class="grova-empty-icon"><i class="bi bi-inbox"></i></div>
                    <div class="grova-empty-title">Sin registros</div>
                    <div class="grova-empty-desc">Aún no hay datos en esta sección. Comienza creando el primer registro.</div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Empty state básico</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-basic">Copiar</button>
                </div>
                <pre id="code-empty-basic"><div class="grova-empty-state">
    <div class="grova-empty-icon"><i class="bi bi-inbox"></i></div>
    <div class="grova-empty-title">Sin registros</div>
    <div class="grova-empty-desc">Aún no hay datos en esta sección.</div>
</div></pre>
            </div>
        </div>

        {# ── Con botón CTA ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-empty-state">
                    <div class="grova-empty-icon"><i class="bi bi-people"></i></div>
                    <div class="grova-empty-title">No hay usuarios</div>
                    <div class="grova-empty-desc">Invita a tu equipo para comenzar a colaborar en el sistema.</div>
                    <div class="grova-empty-actions">
                        <button type="button" class="btn btn-primary btn-sm">
                            <i class="bi bi-person-plus me-1"></i>Invitar usuario
                        </button>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Empty state con CTA</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-cta">Copiar</button>
                </div>
                <pre id="code-empty-cta"><div class="grova-empty-state">
    <div class="grova-empty-icon"><i class="bi bi-people"></i></div>
    <div class="grova-empty-title">No hay usuarios</div>
    <div class="grova-empty-desc">Invita a tu equipo para comenzar a colaborar.</div>
    <div class="grova-empty-actions">
        <button type="button" class="btn btn-primary btn-sm"
                data-bs-toggle="modal" data-bs-target="#modal-invite">
            <i class="bi bi-person-plus me-1"></i>Invitar usuario
        </button>
    </div>
</div></pre>
            </div>
        </div>

        {# ── Sin resultados de búsqueda ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-empty-state">
                    <div class="grova-empty-icon"><i class="bi bi-search"></i></div>
                    <div class="grova-empty-title">Sin resultados</div>
                    <div class="grova-empty-desc">No encontramos registros para <strong>"christian"</strong>. Intenta con otro término o limpia los filtros.</div>
                    <div class="grova-empty-actions">
                        <button type="button" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x-circle me-1"></i>Limpiar filtros
                        </button>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Sin resultados de búsqueda</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-search">Copiar</button>
                </div>
                <pre id="code-empty-search">{% verbatim %}<div class="grova-empty-state">
    <div class="grova-empty-icon"><i class="bi bi-search"></i></div>
    <div class="grova-empty-title">Sin resultados</div>
    <div class="grova-empty-desc">
        No encontramos registros para <strong>"{{ query }}"</strong>.
        Intenta con otro término o limpia los filtros.
    </div>
    <div class="grova-empty-actions">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-clear-search">
            <i class="bi bi-x-circle me-1"></i>Limpiar filtros
        </button>
    </div>
</div>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Error ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-empty-state grova-empty-state-error">
                    <div class="grova-empty-icon"><i class="bi bi-exclamation-triangle"></i></div>
                    <div class="grova-empty-title">Error al cargar</div>
                    <div class="grova-empty-desc">No pudimos obtener los datos. Verifica tu conexión o intenta de nuevo.</div>
                    <div class="grova-empty-actions">
                        <button type="button" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-arrow-clockwise me-1"></i>Reintentar
                        </button>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Empty state de error</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-error">Copiar</button>
                </div>
                <pre id="code-empty-error"><div class="grova-empty-state grova-empty-state-error">
    <div class="grova-empty-icon"><i class="bi bi-exclamation-triangle"></i></div>
    <div class="grova-empty-title">Error al cargar</div>
    <div class="grova-empty-desc">No pudimos obtener los datos. Intenta de nuevo.</div>
    <div class="grova-empty-actions">
        <button type="button" class="btn btn-outline-danger btn-sm" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise me-1"></i>Reintentar
        </button>
    </div>
</div></pre>
            </div>
        </div>

        {# ── Compacto (dentro de card o panel) ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div style="max-width:340px; background:#1e293b; border:1px solid #334155; border-radius:10px; padding:1rem;">
                    <div style="font-size:13px; font-weight:600; color:#e2e8f0; margin-bottom:.75rem;">Actividad reciente</div>
                    <div class="grova-empty-state grova-empty-state-compact">
                        <div class="grova-empty-icon"><i class="bi bi-clock-history"></i></div>
                        <div class="grova-empty-title">Sin actividad</div>
                        <div class="grova-empty-desc">Las acciones del equipo aparecerán aquí.</div>
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">HTML — Empty state compacto (dentro de card)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-compact">Copiar</button>
                </div>
                <pre id="code-empty-compact"><div class="grova-empty-state grova-empty-state-compact">
    <div class="grova-empty-icon"><i class="bi bi-clock-history"></i></div>
    <div class="grova-empty-title">Sin actividad</div>
    <div class="grova-empty-desc">Las acciones del equipo aparecerán aquí.</div>
</div></pre>
            </div>
        </div>

        {# ── En tabla DataTables ── #}
        <div class="ui-component">
            <div class="ui-component-code" style="border-top:0;">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">JS — DataTables: reemplazar mensaje vacío nativo</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-empty-dt">Copiar</button>
                </div>
                <pre id="code-empty-dt">// En la config de DataTables, usar language.emptyTable
var table = new DataTable('#mi-tabla', {
    language: {
        emptyTable:
            '&lt;div class="grova-empty-state grova-empty-state-compact py-3"&gt;' +
            '  &lt;div class="grova-empty-icon"&gt;&lt;i class="bi bi-inbox"&gt;&lt;/i&gt;&lt;/div&gt;' +
            '  &lt;div class="grova-empty-title"&gt;Sin registros&lt;/div&gt;' +
            '  &lt;div class="grova-empty-desc"&gt;No hay datos que mostrar.&lt;/div&gt;' +
            '&lt;/div&gt;',
        zeroRecords:
            '&lt;div class="grova-empty-state grova-empty-state-compact py-3"&gt;' +
            '  &lt;div class="grova-empty-icon"&gt;&lt;i class="bi bi-search"&gt;&lt;/i&gt;&lt;/div&gt;' +
            '  &lt;div class="grova-empty-title"&gt;Sin resultados&lt;/div&gt;' +
            '  &lt;div class="grova-empty-desc"&gt;Ningún registro coincide con la búsqueda.&lt;/div&gt;' +
            '&lt;/div&gt;',
    },
});</pre>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
document.querySelectorAll('.btn-copy-code').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var target = document.getElementById(btn.getAttribute('data-copy-target'));
        if (!target) return;
        navigator.clipboard.writeText(target.textContent.trim()).then(function () {
            var old = btn.textContent;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = old; }, 1200);
        });
    });
});
</script>
{% endblock %}
