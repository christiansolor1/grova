                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-select2">Copiar</button>
                </div>
                <pre id="code-select2">{% verbatim %}{# Solo agrega la clase grova-select2 — se inicializa solo, sin JS adicional #}

{# Simple #}
<select class="grova-select2" data-placeholder="Seleccionar...">
