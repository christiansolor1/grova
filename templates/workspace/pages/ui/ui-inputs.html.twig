{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}{{ 'Inputs y formularios' | trans }}{% endblock %}
{% block app_page_subtitle %}{{ 'Catálogo de campos de formulario. Copia el código y úsalo en cualquier vista.' | trans }}{% endblock %}

{% block page_styles %}
<style>
.ui-component { border: 1px solid #1e293b; border-radius: 10px; overflow: hidden; margin-bottom: 1.5rem; }
.ui-component-preview { padding: 1.5rem; background: #0f172a; }
.ui-component-code { background: #020617; border-top: 1px solid #1e293b; }
.ui-component-code-header { display: flex; align-items: center; justify-content: space-between; padding: .5rem 1rem; border-bottom: 1px solid #1e293b; }
.ui-component-code-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
.ui-component-code pre { margin: 0; padding: 1rem; font-size: 12px; color: #94a3b8; overflow-x: auto; }
.btn-copy-code { font-size: 11px; padding: 2px 10px; }
body.light-mode .ui-component { border-color: #dbe3ee; }
body.light-mode .ui-component-preview { background: #f8fafc; }
body.light-mode .ui-component-code { background: #f1f5f9; border-color: #dbe3ee; }
body.light-mode .ui-component-code-header { border-color: #dbe3ee; }
body.light-mode .ui-component-code pre { color: #475569; }
/* Dual Listbox */
.grova-dual-listbox { display: flex; gap: 1rem; align-items: flex-start; }
.grova-dlb-col { flex: 1; display: flex; flex-direction: column; gap: .4rem; }
.grova-dlb-label { font-size: 11px; text-transform: uppercase; letter-spacing: .5px; color: #64748b; font-weight: 600; }
.grova-dlb-list { width: 100%; height: 220px; border: 1px solid #334155; border-radius: 8px; background: #0f172a; color: #f1f5f9; font-size: 13px; padding: .25rem 0; overflow-y: auto; }
.grova-dlb-list option { padding: .4rem .75rem; cursor: pointer; }
.grova-dlb-list option:checked { background: #2563eb; color: #fff; }
.grova-dlb-list option:hover { background: #1e293b; }
.grova-dlb-actions { display: flex; flex-direction: column; gap: .4rem; justify-content: center; padding-top: 1.6rem; }
.grova-dlb-btn { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; padding: 0; }
body.light-mode .grova-dlb-list { background: #fff; border-color: #dbe3ee; color: #0f172a; }
body.light-mode .grova-dlb-list option:hover { background: #f1f5f9; }
body.light-mode .grova-dlb-list option:checked { background: #2563eb; color: #fff; }
/* Select2 overrides */
.select2-container--default .select2-selection--single,
.select2-container--default .select2-selection--multiple { background: #0f172a; border: 1px solid #334155; border-radius: 6px; color: #f1f5f9; min-height: 31px; }
.select2-container--default .select2-selection--single .select2-selection__rendered { color: #f1f5f9; line-height: 29px; padding-left: 8px; }
.select2-container--default .select2-selection--single .select2-selection__arrow { height: 29px; }
.select2-dropdown { background: #0f172a; border: 1px solid #334155; }
.select2-container--default .select2-results__option { color: #f1f5f9; font-size: 13px; }
.select2-container--default .select2-results__option--highlighted { background: #2563eb; }
.select2-search--dropdown .select2-search__field { background: #1e293b; border: 1px solid #334155; color: #f1f5f9; border-radius: 4px; }
.select2-container--default .select2-selection--multiple .select2-selection__choice { background: #2563eb; border: none; color: #fff; font-size: 12px; }
.select2-container--default .select2-selection--multiple .select2-selection__choice__remove { color: #fff; margin-right: 4px; }
body.light-mode .select2-container--default .select2-selection--single,
body.light-mode .select2-container--default .select2-selection--multiple { background: #fff; border-color: #dbe3ee; }
body.light-mode .select2-container--default .select2-selection--single .select2-selection__rendered { color: #0f172a; }
body.light-mode .select2-dropdown { background: #fff; border-color: #dbe3ee; }
body.light-mode .select2-container--default .select2-results__option { color: #0f172a; }
body.light-mode .select2-search--dropdown .select2-search__field { background: #f8fafc; border-color: #dbe3ee; color: #0f172a; }
</style>
{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">Inputs y formularios</div>
    <div class="content-card-body">

        {# ── Inputs básicos ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Texto</label>
                        <input type="text" class="form-control form-control-sm" placeholder="Nombre">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control form-control-sm" placeholder="correo@dominio.com">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Contraseña</label>
                        <input type="password" class="form-control form-control-sm" placeholder="••••••••">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Número</label>
                        <input type="number" class="form-control form-control-sm" placeholder="0">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control form-control-sm">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Teléfono</label>
                        <input type="tel" class="form-control form-control-sm" placeholder="+506 0000-0000">
                    </div>
                </div>
            </div>
            <div class="ui-component-code">
                <div class="ui-component-code-header">
                    <span class="ui-component-code-label">Twig / HTML — Inputs básicos</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm btn-copy-code" data-copy-target="code-inputs-basic">Copiar</button>
                </div>
                <pre id="code-inputs-basic">{% verbatim %}<div class="col-md-4">
    <label class="form-label">Texto</label>
    <input type="text" class="form-control form-control-sm" placeholder="Nombre">
</div>
<div class="col-md-4">
    <label class="form-label">Email</label>
