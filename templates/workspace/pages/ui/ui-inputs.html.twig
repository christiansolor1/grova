        <button type="button" class="btn btn-primary btn-sm grova-dlb-btn" data-dlb-action="move-all-right"><i class="bi bi-chevron-double-right"></i></button>
        <button type="button" class="btn btn-outline-secondary btn-sm grova-dlb-btn" data-dlb-action="move-left"><i class="bi bi-chevron-left"></i></button>
        <button type="button" class="btn btn-outline-secondary btn-sm grova-dlb-btn" data-dlb-action="move-all-left"><i class="bi bi-chevron-double-left"></i></button>
