</script>{% endverbatim %}</pre>
            </div>
        </div>

        {# ── Dual Listbox ── #}
        <div class="ui-component">
            <div class="ui-component-preview">
                <div class="grova-dual-listbox" id="demo-dual-listbox">
                    <div class="grova-dlb-col">
