{# JS — inicializar (se incluye automáticamente via grova-dual-listbox.js) #}
{# Al guardar el form, recoger los valores del lado derecho: #}
<script>
document.getElementById('mi-form').addEventListener('submit', function () {
    var selected = Array.from(document.getElementById('dlb-right').options).map(o => o.value);
    document.getElementById('mi-input-hidden').value = selected.join(',');
});
</script>{% endverbatim %}</pre>
            </div>
