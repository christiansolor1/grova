<script>
(function () {
    var tableEl = document.getElementById('users-table');
    if (!tableEl || typeof DataTable === 'undefined') return;
    var locale = {{ app.request.locale | json_encode | raw }};
    var dtLang = locale === 'en'
        ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
        : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';
    try {
        var initDt = (window.GrovaDataTable && window.GrovaDataTable.init) ? window.GrovaDataTable.init : function (el, o) { return new DataTable(el, o); };
        initDt(tableEl, {
            language: { url: dtLang },
            pageLength: 5,
            buttons: 'full',
        });
    } catch (e) {
        console.error(e);
    }
})();
</script>
