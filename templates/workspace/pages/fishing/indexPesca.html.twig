{% extends 'workspace/app_layout.html.twig' %}
{% block page_title %}Pesca{% endblock %}
{% block app_page_subtitle %}Fincas, señuelos, salidas y gastos del grupo{% endblock %}

{% block page_styles %}
<style>
.fish-card { background:#111827; border:1px solid #1e293b; border-radius:12px; padding:1.25rem; height:100%; }
body.light-mode .fish-card { background:#fff; border-color:#e2e8f0; }
.fish-card-title { font-size:11px; color:#64748b; text-transform:uppercase; letter-spacing:.06em; margin-bottom:.75rem; }
.finca-chip { display:inline-flex; align-items:center; gap:.4rem; background:#1e3a5f; color:#93c5fd; border:1px solid #1d4ed844; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; text-decoration:none; }
.finca-chip:hover { background:#1d4ed8; color:#fff; }
body.light-mode .finca-chip { background:#eff6ff; color:#1d4ed8; border-color:#bfdbfe; }
.lure-img { width:50px; height:50px; object-fit:cover; border-radius:8px; border:1px solid #1e293b; }
.lure-placeholder { width:50px; height:50px; border-radius:8px; background:#1e293b; display:flex; align-items:center; justify-content:center; color:#475569; font-size:18px; }
.tag-funciona { background:#16a34a22; color:#4ade80; border:1px solid #16a34a44; font-size:10px; padding:1px 7px; border-radius:10px; }
.tag-no-funciona { background:#dc262622; color:#f87171; border:1px solid #dc262644; font-size:10px; padding:1px 7px; border-radius:10px; }
</style>
{% endblock %}

{% block app_main %}

<div class="row g-3 mb-4">

    {# ── Fincas ── #}
    <div class="col-md-4">
        <div class="fish-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="fish-card-title mb-0">Fincas ({{ fincas|length }})</div>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modal-nueva-finca">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
            {% if fincas|length > 0 %}
            <div class="d-flex flex-wrap gap-2">
                {% for finca in fincas %}
                <a href="{{ path('grova_fishing_finca_show', {id: finca.id, _locale: app.request.locale}) }}" class="finca-chip">
                    <i class="bi bi-geo-alt-fill"></i> {{ finca.nombre }}
                </a>
                {% endfor %}
            </div>
            {% else %}
            <div style="font-size:12px;color:#475569;text-align:center;padding:1rem;">Sin fincas registradas</div>
            {% endif %}
        </div>
    </div>

    {# ── Stats rápidos ── #}
    <div class="col-md-8">
        <div class="row g-3 h-100">
            <div class="col-sm-4">
                <div class="fish-card text-center">
                    <div class="fish-card-title">Salidas</div>
                    <div style="font-size:32px;font-weight:800;color:#6366f1;">{{ trips|length }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="fish-card text-center">
                    <div class="fish-card-title">Señuelos</div>
                    <div style="font-size:32px;font-weight:800;color:#22c55e;">{{ lures|length }}</div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="fish-card text-center">
                    <div class="fish-card-title">Fincas</div>
                    <div style="font-size:32px;font-weight:800;color:#f59e0b;">{{ fincas|length }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">

    {# ── Últimas salidas ── #}
    <div class="col-lg-7">
        <div class="content-card">
            <div class="content-card-header">
                Últimas salidas
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modal-nueva-salida">
                    <i class="bi bi-plus-lg me-1"></i>Nueva salida
                </button>
            </div>
            <div class="content-card-body p-0">
                {% if trips|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="color:inherit;">
                        <thead>
                            <tr>
                                <th style="width:100px;">Fecha</th>
                                <th>Finca</th>
                                <th style="width:80px;">Miembros</th>
                                <th style="width:100px;">Total</th>
                                <th style="width:100px;">Por persona</th>
                                <th style="width:50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for trip in trips %}
                            <tr>
                                <td style="font-size:12px;color:#64748b;">{{ trip.fecha|date('d/m/Y') }}</td>
                                <td style="font-weight:600;">{{ trip.finca.nombre }}</td>
                                <td style="text-align:center;">{{ trip.memberCount }}</td>
                                <td style="color:#f59e0b;font-weight:600;">${{ trip.totalGastos|number_format(2) }}</td>
                                <td style="color:#6366f1;font-weight:600;">${{ trip.gastoPorMiembro|number_format(2) }}</td>
                                <td>
                                    <a href="{{ path('grova_fishing_trip_show', {id: trip.id, _locale: app.request.locale}) }}"
                                       class="btn btn-outline-secondary btn-sm" style="padding:2px 7px;font-size:11px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="grova-empty-state">
                    <div class="grova-empty-icon"><i class="bi bi-water"></i></div>
                    <div class="grova-empty-title">Sin salidas registradas</div>
                    <div class="grova-empty-desc">Registra tu primera salida de pesca.</div>
                    <div class="grova-empty-actions">
                        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-nueva-salida">
                            <i class="bi bi-plus-lg me-1"></i>Nueva salida
                        </button>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Señuelos ── #}
    <div class="col-lg-5">
        <div class="content-card">
            <div class="content-card-header">
                Señuelos
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modal-nuevo-señuelo">
                    <i class="bi bi-plus-lg me-1"></i>Agregar
                </button>
            </div>
            <div class="content-card-body p-0">
                {% if lures|length > 0 %}
                <ul class="list-group list-group-flush">
                    {% for lure in lures %}
                    <li class="list-group-item d-flex align-items-center gap-3" style="background:transparent;border-color:#1e293b;">
                        {% if lure.foto %}
                        <img src="{{ lure.fotoUrl }}" class="lure-img" alt="{{ lure.nombre }}">
                        {% else %}
                        <div class="lure-placeholder"><i class="bi bi-fish"></i></div>
                        {% endif %}
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:600;font-size:13px;">{{ lure.nombre }}</div>
                            <div style="font-size:11px;color:#64748b;">
                                {% if lure.marca %}{{ lure.marca }}{% endif %}
                                {% if lure.color %} · {{ lure.color }}{% endif %}
                                {% if lure.tipo %} · {{ lure.tipo }}{% endif %}
                            </div>
                            {% if lure.propietario %}
                            <div style="font-size:11px;color:#6366f1;">{{ lure.propietario }}</div>
                            {% endif %}
                        </div>
                        {% if lure.precio %}
                        <div style="font-size:12px;font-weight:600;color:#f59e0b;">${{ lure.precioFloat|number_format(2) }}</div>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div style="padding:1.5rem;text-align:center;font-size:12px;color:#475569;">Sin señuelos registrados</div>
                {% endif %}
            </div>
        </div>
    </div>

</div>

{# ── Modal: Nueva finca ── #}
<div class="modal fade" id="modal-nueva-finca" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="{{ path('grova_fishing_finca_create', {_locale: app.request.locale}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('fishing_finca') }}">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva finca</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control form-control-sm" name="nombre" required maxlength="100">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Latitud GPS</label>
                            <input type="number" step="0.0000001" class="form-control form-control-sm" name="latitud" placeholder="13.1234567">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Longitud GPS</label>
                            <input type="number" step="0.0000001" class="form-control form-control-sm" name="longitud" placeholder="-87.2345678">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descripción</label>
                            <textarea class="form-control form-control-sm" name="descripcion" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-sm">Crear finca</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Modal: Nueva salida ── #}
<div class="modal fade" id="modal-nueva-salida" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="{{ path('grova_fishing_trip_create', {_locale: app.request.locale}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('fishing_trip') }}">
                <div class="modal-header">
                    <h5 class="modal-title">Nueva salida de pesca</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="form-label">Finca</label>
                            <select class="form-select form-select-sm" name="finca_id" required>
                                <option value="">Selecciona...</option>
                                {% for finca in fincas %}
                                <option value="{{ finca.id }}">{{ finca.nombre }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Fecha</label>
                            <input type="date" class="form-control form-control-sm" name="fecha" value="{{ 'now'|date('Y-m-d') }}" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <textarea class="form-control form-control-sm" name="notas" rows="2" placeholder="Opcional"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-sm">Crear salida</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Modal: Nuevo señuelo ── #}
<div class="modal fade" id="modal-nuevo-señuelo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form method="post" action="{{ path('grova_fishing_lure_create', {_locale: app.request.locale}) }}" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('fishing_lure') }}">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo señuelo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="form-label">Nombre *</label>
                            <input type="text" class="form-control form-control-sm" name="nombre" required maxlength="100">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Marca</label>
                            <input type="text" class="form-control form-control-sm" name="marca" maxlength="100">
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Color</label>
                            <input type="text" class="form-control form-control-sm" name="color" maxlength="50">
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Tipo</label>
                            <select class="form-select form-select-sm" name="tipo">
                                <option value="">— Tipo —</option>
                                <option>Cuchara</option>
                                <option>Popper</option>
                                <option>Jig</option>
                                <option>Señuelo blando</option>
                                <option>Minnow</option>
                                <option>Crankbait</option>
                                <option>Spinner</option>
                                <option>Otro</option>
                            </select>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Precio</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" class="form-control" name="precio" min="0">
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Tienda / Dónde se compró</label>
                            <input type="text" class="form-control form-control-sm" name="tienda" maxlength="150">
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Propietario</label>
                            <input type="text" class="form-control form-control-sm" name="propietario" maxlength="100" placeholder="Nombre de quien lo tiene">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Foto</label>
                            <input type="file" class="form-control form-control-sm" name="foto" accept="image/*">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notas</label>
                            <textarea class="form-control form-control-sm" name="notas" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary btn-sm">Guardar señuelo</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}
