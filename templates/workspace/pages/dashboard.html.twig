{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block app_page_subtitle %}
    {% if tenant %}Bienvenido, {{ app.user.nombre ?? app.user.username }} · {{ tenant.nombre }}{% else %}Bienvenido al sistema{% endif %}
{% endblock %}

{% block page_styles %}
<style>
.dash-section-title {
    font-size: 11px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: .75rem;
}
.dash-top-col {
    display: flex;
    flex-direction: column;
    min-height: 0;
}
.dash-tenant-card,
.dash-plan-card {
    background: #111827;
    border-radius: 12px;
    padding: 1.25rem;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 168px;
}
.dash-tenant-card {
    border: 1px solid #1e293b;
}
.dash-plan-card {
    border: 1px solid #1e3a5f;
}
body.light-mode .dash-tenant-card { background: #fff; border-color: #e2e8f0; }
body.light-mode .dash-plan-card { background: #fff; border-color: #bfdbfe; }

.dash-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .75rem;
}
.dash-card-head-main {
    display: flex;
    align-items: center;
    gap: .75rem;
    min-width: 0;
    flex: 1;
}
.dash-card-title {
    font-size: 16px;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1.25;
}
body.light-mode .dash-card-title { color: #1e293b; }
.dash-card-meta {
    font-size: 12px;
    color: #64748b;
    margin-top: 2px;
}
.dash-card-meta code {
    font-size: 11px;
}
.dash-card-foot {
    margin-top: auto;
}
.dash-tenant-card .grova-detail-list {
    width: 100%;
    min-width: 0;
}
.dash-tenant-card .grova-detail-row dt {
    min-width: 72px;
}

.dash-plan-name { font-size: 22px; font-weight: 800; color: #60a5fa; line-height: 1.2; }
.dash-plan-price { font-size: 13px; color: #64748b; margin-top: 2px; }
.dash-plan-expiry { font-size: 12px; color: #64748b; margin-top: .5rem; }
.dash-plan-badges {
    display: flex;
    flex-wrap: wrap;
    gap: .3rem;
}

.dash-module-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: .5rem;
}
.dash-module-chip {
    display: flex;
    align-items: center;
    gap: .4rem;
    min-height: 40px;
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    padding: .5rem .75rem;
    font-size: 12px;
    color: #94a3b8;
    font-weight: 500;
}
body.light-mode .dash-module-chip { background: #f8fafc; border-color: #e2e8f0; color: #475569; }
.dash-module-chip i { color: #60a5fa; font-size: 14px; flex-shrink: 0; }

.dash-stat-col { display: flex; }
.dash-stat-col .stat-card {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
}
.dash-stat-col .stat-value {
    min-height: 32px;
    display: flex;
    align-items: center;
}
.dash-stat-col .stat-value--md { font-size: 18px; }
.dash-stat-col .stat-value--sm { font-size: 16px; }
.dash-stat-col .stat-value--xs { font-size: 14px; }
.dash-stat-col .stat-change {
    color: #64748b;
    margin-top: auto;
    line-height: 1.35;
}

.dash-no-tenant {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 1rem;
    text-align: center;
    color: #64748b;
}
.dash-no-tenant i { font-size: 3rem; color: #334155; }
</style>
{% endblock %}

{% block app_main %}

{% if tenant %}
{# ── Fila superior: tarjeta tenant + tarjeta plan ── #}
<div class="row g-3 mb-4 align-items-stretch">

    {# Tarjeta del tenant #}
    <div class="col-lg-6 dash-top-col">
        <div class="dash-section-title">Tu espacio</div>
        <div class="dash-tenant-card">
            <div class="dash-card-head">
                <div class="dash-card-head-main">
                    <div class="grova-profile-avatar" style="width:48px;height:48px;font-size:18px;flex-shrink:0;">
                        {{ tenant.initials }}
                    </div>
                    <div style="min-width:0;">
                        <div class="dash-card-title">{{ tenant.nombre }}</div>
                        <div class="dash-card-meta"><code>{{ tenant.slug }}</code></div>
                    </div>
                </div>
                <span class="badge {{ tenant.isActivo ? 'bg-success' : 'bg-secondary' }}">
                    {{ tenant.estado|capitalize }}
                </span>
            </div>
            <div class="dash-card-foot grova-detail-list">
                <div class="grova-detail-row">
                    <dt>BD</dt>
                    <dd><code>{{ tenant.dbName }}</code></dd>
                </div>
                <div class="grova-detail-row">
                    <dt>Desde</dt>
                    <dd>{{ tenant.createdAt|date('d/m/Y') }}</dd>
                </div>
            </div>
        </div>
    </div>

    {# Tarjeta del plan #}
    <div class="col-lg-6 dash-top-col">
        <div class="dash-section-title">Plan activo</div>
        {% if suscripcion %}
        <div class="dash-plan-card">
            <div class="dash-card-head">
                <div style="min-width:0;">
                    <div class="dash-plan-name">{{ suscripcion.plan.nombre }}</div>
                    <div class="dash-plan-price">
                        {% if suscripcion.plan.precioMensual == '0.00' %}
                            Cortesía — $0/mes
                        {% else %}
                            ${{ suscripcion.plan.precioMensual }}/mes
                        {% endif %}
                    </div>
                    <div class="dash-plan-expiry">
                        <i class="bi bi-calendar3 me-1"></i>
                        Vence el {{ suscripcion.fechaVencimiento|date('d/m/Y') }}
                    </div>
                </div>
                <span class="badge {{ suscripcion.isActiva ? 'bg-success' : 'bg-danger' }}">
                    {{ suscripcion.estado|capitalize }}
                </span>
            </div>
            <div class="dash-card-foot dash-plan-badges">
                {% for modulo in suscripcion.plan.modulos|slice(0,4) %}
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25" style="font-size:11px;">{{ modulo }}</span>
                {% endfor %}
                {% if suscripcion.plan.modulos|length > 4 %}
                    <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size:11px;">+{{ suscripcion.plan.modulos|length - 4 }} más</span>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="dash-plan-card" style="border-color:#dc2626;">
            <div class="dash-card-head">
                <div style="color:#f87171;font-size:13px;">
                    <i class="bi bi-exclamation-triangle me-1"></i>Sin suscripción activa
                </div>
            </div>
        </div>
        {% endif %}
    </div>

</div>

{# ── Módulos activos ── #}
<div class="content-card mb-4">
    <div class="content-card-header">
        Módulos activos
        <span class="badge bg-primary ms-2">{{ modulos_activos|length }}</span>
    </div>
    <div class="content-card-body">
        {% if modulos_activos|length > 0 %}
        <div class="dash-module-grid">
            {% set modulo_icons = {
                'wallet':      'bi-wallet2',
                'work':        'bi-briefcase',
                'agenda':      'bi-calendar-check',
                'habitos':     'bi-activity',
                'pesca':       'bi-water',
                'facturacion': 'bi-receipt',
                'legal':       'bi-building',
                'construccion':'bi-hammer',
                'pos':         'bi-shop',
                'restaurante': 'bi-cup-straw',
                'clinica':     'bi-heart-pulse',
                'financiera':  'bi-bank',
                'inventario':  'bi-boxes',
                'rrhh':        'bi-people',
            } %}
            {% set modulo_labels = {
                'wallet':      'Wallet',
                'work':        'Work',
                'agenda':      'Agenda',
                'habitos':     'Hábitos',
                'pesca':       'Pesca',
                'facturacion': 'Facturación',
                'legal':       'Legal',
                'construccion':'Construcción',
                'pos':         'POS',
                'restaurante': 'Restaurante',
                'clinica':     'Clínica',
                'financiera':  'Financiera',
                'inventario':  'Inventario',
                'rrhh':        'RRHH',
            } %}
            {% for key in modulos_activos %}
            <div class="dash-module-chip">
                <i class="{{ modulo_icons[key] ?? 'bi-box' }}"></i>
                {{ modulo_labels[key] ?? key|capitalize }}
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="grova-empty-state grova-empty-state-compact">
            <div class="grova-empty-icon"><i class="bi bi-box"></i></div>
            <div class="grova-empty-title">Sin módulos activos</div>
            <div class="grova-empty-desc">Activa módulos desde Configuración → Módulos activos.</div>
        </div>
        {% endif %}
    </div>
</div>

{# ── Stats del usuario ── #}
<div class="row g-3 align-items-stretch">
    <div class="col-sm-6 col-xl-3 dash-stat-col">
        <div class="stat-card">
            <div class="stat-label">Módulos activos</div>
            <div class="stat-value">{{ modulos_activos|length }}</div>
            <div class="stat-change">de {{ suscripcion ? suscripcion.plan.modulos|length : 0 }} disponibles</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3 dash-stat-col">
        <div class="stat-card">
            <div class="stat-label">Plan</div>
            <div class="stat-value stat-value--md">{{ suscripcion ? suscripcion.plan.nombre : '—' }}</div>
            <div class="stat-change">
                {% if suscripcion %}
                    vence {{ suscripcion.fechaVencimiento|date('d/m/Y') }}
                {% else %}
                    sin suscripción
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3 dash-stat-col">
        <div class="stat-card">
            <div class="stat-label">Rol</div>
            <div class="stat-value stat-value--sm">
                {% if is_granted('ROLE_DEVELOPER') %}Super-admin
                {% elseif is_granted('ROLE_ADMIN') %}Admin
                {% else %}Usuario{% endif %}
            </div>
            <div class="stat-change">{{ app.user.email }}</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3 dash-stat-col">
        <div class="stat-card">
            <div class="stat-label">Tenant</div>
            <div class="stat-value stat-value--xs" style="word-break:break-all;">{{ tenant.slug }}</div>
            <div class="stat-change">
                <span class="badge {{ tenant.isActivo ? 'bg-success' : 'bg-secondary' }}" style="font-size:10px;">{{ tenant.estado }}</span>
            </div>
        </div>
    </div>
</div>

{% else %}
{# ── Sin tenant asignado (super-admin puro) ── #}
<div class="content-card">
    <div class="content-card-body">
        <div class="dash-no-tenant">
            <i class="bi bi-buildings"></i>
            <div>
                <div style="font-size:16px;font-weight:600;color:#94a3b8;margin-bottom:.25rem;">Vista de sistema</div>
                <div style="font-size:13px;">Este usuario no tiene un tenant asignado. Estás en modo super-admin.</div>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# ── Panel de impersonate — solo visible para ROLE_DEVELOPER cuando no está impersonando ── #}
{% if switch_users is defined and switch_users|length > 0 %}
<div class="content-card mt-4" style="border-color:#7c3aed33;">
    <div class="content-card-header" style="color:#a78bfa; font-size:12px;">
        <i class="bi bi-incognito me-2"></i>Entrar como otro usuario
        <span style="font-size:10px; color:#64748b; margin-left:.5rem; font-weight:400;">
            <i class="bi bi-shield-lock me-1"></i>Solo visible para ti · queda en el log
        </span>
    </div>
    <div class="content-card-body" style="padding:.25rem 0;">
        <table style="width:100%; border-collapse:collapse;">
            {% for u in switch_users %}
            <tr style="border-bottom:1px solid #1e293b22;">
                <td style="padding:.5rem 1rem; width:36px;">
                    <div style="
                        width:30px; height:30px; border-radius:50%;
                        background:#1e293b; border:1px solid #334155;
                        display:flex; align-items:center; justify-content:center;
                        font-size:12px; font-weight:700; color:#94a3b8;
                    ">{{ u.userIdentifier|first|upper }}</div>
                </td>
                <td style="padding:.5rem 0;">
                    <div style="font-size:13px; font-weight:600; color:#f1f5f9; line-height:1.2;">
                        {{ u.nombreCompleto ?: u.userIdentifier }}
                    </div>
                    <div style="font-size:11px; color:#64748b;">{{ u.email }}</div>
                </td>
                <td style="padding:.5rem 1rem; text-align:right;">
                    <a href="{{ path('grova_page_dashboard', {_locale: app.request.locale, _switch_user: u.username}) }}"
                       class="btn btn-xs"
                       title="Entrar como {{ u.username }}"
                       style="background:#7c3aed22; color:#a78bfa; border:1px solid #7c3aed44; padding:3px 9px; border-radius:6px; font-size:11px; text-decoration:none; display:inline-flex; align-items:center; gap:.3rem;">
                        <i class="bi bi-person-fill-lock" style="font-size:13px;"></i>
                        Entrar
                    </a>
                </td>
            </tr>
            {% endfor %}
        </table>
    </div>
</div>
{% endif %}

{% endblock %}

{% block app_page_scripts %}
{% include 'workspace/pages/dashboard_scripts.html.twig' %}
{% endblock %}
