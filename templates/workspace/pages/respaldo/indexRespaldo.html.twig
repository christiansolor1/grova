{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}{{ 'respaldo.page_title'|trans({}, 'messages') }}{% endblock %}

{% block app_main %}
<div class="content-card">
    <div class="content-card-header">{{ 'respaldo.page_title'|trans({}, 'messages') }}</div>
    <div class="content-card-body">
        <p class="text-muted mb-4">
            {{ 'respaldo.description'|trans({}, 'messages') }}
        </p>

        <div class="row gy-4">
            {% for modulo in modulos %}
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">{{ modulo.etiqueta }}</h5>

                        <div class="mt-auto d-flex gap-2">
                            <a href="{{ path('grova_respaldo_exportar', {modulo: modulo.nombreModulo, _locale: 'es'}) }}"
                               class="btn btn-outline-primary btn-sm flex-fill">
                                <i class="bi-download"></i>
                                {{ 'respaldo.exportar'|trans({}, 'messages') }}
                            </a>

                            <button type="button"
                                    class="btn btn-outline-warning btn-sm flex-fill"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#import-{{ modulo.nombreModulo }}"
                                    aria-expanded="false"
                                    aria-controls="import-{{ modulo.nombreModulo }}">
                                <i class="bi-upload"></i>
                                {{ 'respaldo.importar'|trans({}, 'messages') }}
                            </button>
                        </div>

                        <div class="collapse mt-3" id="import-{{ modulo.nombreModulo }}">
                            <form action="{{ path('grova_respaldo_importar', {modulo: modulo.nombreModulo, _locale: 'es'}) }}"
                                  method="post"
                                  enctype="multipart/form-data">
                                <input type="hidden" name="_token" value="{{ csrf_token('respaldo_importar_' ~ modulo.nombreModulo) }}">

                                <div class="mb-2">
                                    <label for="zip-{{ modulo.nombreModulo }}" class="form-label form-label-sm">
                                        {{ 'respaldo.select_zip'|trans({}, 'messages') }}
                                    </label>
                                    <input type="file"
                                           id="zip-{{ modulo.nombreModulo }}"
                                           name="respaldo_zip"
                                           accept=".zip"
                                           class="form-control form-control-sm"
                                           required>
                                </div>

                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                    <i class="bi-upload"></i>
                                    {{ 'respaldo.restaurar'|trans({}, 'messages') }}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12">
                <div class="alert alert-info mb-0">
                    {{ 'respaldo.no_modulos'|trans({}, 'messages') }}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
