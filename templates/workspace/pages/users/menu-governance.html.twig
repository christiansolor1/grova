{% extends 'workspace/app_layout.html.twig' %}
{% block main_attributes %} class="menu-governance-page" data-grova-filter-schema="users-menu-governance"{% endblock %}

{% block app_filters_row %}{% include 'workspace/partials/_filters_active_row.html.twig' %}{% endblock %}
{% block app_filters_drawer %}{% include 'workspace/partials/_filters_drawer.html.twig' %}{% endblock %}

{% block page_title %}{{ 'Gestión de menú' | trans }}{% endblock %}
{% block app_page_subtitle %}{{ 'Gobierno de jerarquía y visibilidad del menú (UI de referencia, sin CRUD).' | trans }}{% endblock %}
{% block page_styles %}
<link rel="stylesheet" href="{{ asset('css/menu-builder.css') }}">
<style>
.menu-governance-page .sidebar-snapshot { min-width: 0; width: 100%; max-width: 100%; }
.menu-governance-page .snapshot-row.sibling { opacity: .96; }
.menu-governance-page .snapshot-row { cursor: default; }
.menu-info-wrap { position: relative; display: inline-flex; margin-left: 6px; }
.menu-info-btn {
    width: 18px; height: 18px; border-radius: 999px; border: 1px solid #64748b;
    background: transparent; color: #64748b; font-size: 11px; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center; cursor: pointer;
    line-height: 1; padding: 0;
}
.menu-info-pop {
    position: absolute; top: 24px; right: 0; width: 260px; z-index: 20;
    background: #111827; color: #cbd5e1; border: 1px solid #334155; border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,.35); padding: 10px 12px; font-size: 12px; display: none;
}
.menu-info-wrap.open .menu-info-pop { display: block; }
.menu-preview-pop { width: 320px; }
.menu-preview-pop .sidebar-mini-preview { margin-top: 4px; }
body.light-mode .menu-info-pop { background: #fff; color: #334155; border-color: #e2e8f0; box-shadow: 0 8px 24px rgba(15,23,42,.12); }
.mini-item.l2 { margin-left: 14px; }
.mini-item.l3 { margin-left: 28px; }
.icon-opt-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%; }
.icon-opt-left { display: inline-flex; align-items: center; gap: 8px; min-width: 0; }
.icon-opt-left i { width: 16px; text-align: center; }
.icon-opt-class { font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 280px; }
.icon-opt-badge {
    display: inline-flex; align-items: center; justify-content: center; min-width: 28px;
    font-size: 10px; font-weight: 700; border-radius: 999px; padding: 1px 7px; border: 1px solid transparent;
}
.icon-opt-badge.bi { color: #60a5fa; background: rgba(37,99,235,.16); border-color: rgba(37,99,235,.45); }
.icon-opt-badge.fa { color: #f59e0b; background: rgba(245,158,11,.16); border-color: rgba(245,158,11,.45); }
body.light-mode .icon-opt-badge.bi { color: #1d4ed8; background: #dbeafe; border-color: #93c5fd; }
body.light-mode .icon-opt-badge.fa { color: #b45309; background: #fef3c7; border-color: #f59e0b; }
.menu-governance-toolbar {
    border: 1px solid #334155; border-radius: 10px; padding: 10px 12px;
    background: #111827; margin-bottom: 12px;
}
.menu-governance-toolbar .toolbar-note { font-size: 12px; color: #94a3b8; }
.menu-governance-toolbar .toolbar-actions { display: inline-flex; gap: 8px; }
.btn-governance-primary {
    display: inline-flex; align-items: center; gap: 6px;
}
.menu-panel-subtitle { font-size: 12px; color: #94a3b8; margin: 6px 0 0; }
.menu-table-shell table tbody tr:hover td { background: rgba(59,130,246,.06); }
.editor-shell {
    border: 1px dashed #334155; border-radius: 10px; padding: 10px; background: rgba(15,23,42,.4);
}
.menu-type-badge {
    display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 999px;
    font-size: 11px; font-weight: 700; border: 1px solid transparent;
}
.menu-type-badge.principal { background: rgba(16,185,129,.18); color: #a7f3d0; border-color: rgba(16,185,129,.38); }
.menu-type-badge.submenu { background: rgba(59,130,246,.18); color: #bfdbfe; border-color: rgba(59,130,246,.38); }
.menu-type-badge.subopcion { background: rgba(168,85,247,.18); color: #e9d5ff; border-color: rgba(168,85,247,.38); }
.menu-color-dot {
    width: 10px; height: 10px; border-radius: 999px; display: inline-block; border: 1px solid rgba(148,163,184,.45);
}
.menu-color-dot.principal { background: #10b981; }
.menu-color-dot.submenu { background: #3b82f6; }
.menu-color-dot.subopcion { background: #a855f7; }
body.light-mode .menu-type-badge.principal { background: #d1fae5; color: #065f46; border-color: rgba(52,211,153,.5); }
body.light-mode .menu-type-badge.submenu { background: #dbeafe; color: #1e40af; border-color: rgba(96,165,250,.5); }
body.light-mode .menu-type-badge.subopcion { background: #f3e8ff; color: #6b21a8; border-color: rgba(192,132,252,.5); }
body.light-mode .menu-governance-toolbar { background: #fff; border-color: #e2e8f0; }
body.light-mode .menu-governance-toolbar .toolbar-note { color: #64748b; }
body.light-mode .menu-panel-subtitle { color: #64748b; }
body.light-mode .editor-shell { background: #f8fafc; border-color: #dbe3ee; }
</style>
{% endblock %}

{% block app_main %}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} mb-3" role="alert">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="content-card mb-3">
    <div class="content-card-header">{{ 'Reglas recomendadas' | trans }}</div>
    <div class="content-card-body">
        <div class="alert alert-info mb-0" role="alert" style="font-size:13px;">
            Estructura recomendada: <strong>id + parent_id</strong> para jerarquía, y <strong>menu_key</strong> para lógica funcional.
            Visibilidad lateral controlada por <code>show_in_sidebar</code>.
        </div>
    </div>
</div>

<div class="menu-governance-toolbar d-flex align-items-center justify-content-between">
    <div class="toolbar-note">Gestiona el árbol del menú con flujo de listado y formulario.</div>
    <div class="toolbar-actions">
        <button type="button" id="menu-open-create" class="btn btn-sm btn-primary btn-governance-primary">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            {{ 'Nuevo ítem' | trans }}
        </button>
        <button type="button" id="menu-back-to-list" class="btn btn-sm btn-outline-secondary" style="display:none;">{{ 'Volver al listado' | trans }}</button>
    </div>
</div>

<div id="menu-governance-layout" class="row g-3">
    <div id="menu-list-panel" class="col-xl-12">
        <div class="content-card h-100">
            <div class="content-card-header">
                Árbol actual
                <div class="menu-panel-subtitle">Vista operativa de niveles, estado y visibilidad.</div>
            </div>
            <div class="content-card-body">
                <div class="table-responsive menu-table-shell">
                    <table id="users-table" class="table table-sm align-middle mb-0" style="color:inherit;">
                        <thead>
                        <tr>
                            <th>{{ 'Editar' | trans }}</th>
                            <th>{{ 'Nivel' | trans }}</th>
                            <th>{{ 'Tipo' | trans }}</th>
                            <th>{{ 'Color' | trans }}</th>
                            <th>{{ 'Menu key' | trans }}</th>
                            <th>{{ 'Label' | trans }}</th>
                            <th>{{ 'Sidebar' | trans }}</th>
                            <th>{{ 'Estado' | trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for l1 in menu_tree %}
                            <tr>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-secondary js-edit-row" data-level="principal" data-key="{{ l1.id }}" data-label="{{ l1.label }}" data-icon="{{ l1.icon|default('bi-list') }}" data-status="{{ l1.status|default('hecho') }}">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                                <td>L1</td>
                                <td><span class="menu-type-badge principal">{{ 'Menú principal' | trans }}</span></td>
                                <td><span class="menu-color-dot principal" title="{{ 'Menú principal' | trans }}"></span></td>
                                <td><code>{{ l1.id }}</code></td>
                                <td>{{ l1.label }}</td>
                                <td data-sidebar="{{ l1.showInSidebar|default(true) ? 'visible' : 'oculto' }}"><span class="badge {{ l1.showInSidebar|default(true) ? 'bg-success' : 'bg-secondary' }}">{{ l1.showInSidebar|default(true) ? ('Visible'|trans) : ('Oculto'|trans) }}</span></td>
                                <td data-status="{{ l1.status|default('hecho') }}"><span class="badge {{ l1.status|default('hecho') == 'pendiente' ? 'bg-warning text-dark' : 'bg-success' }}">{{ l1.status|default('hecho')|capitalize }}</span></td>
                            </tr>
                            {% for l2 in l1.children|default([]) %}
                                <tr>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-secondary js-edit-row" data-level="submenu" data-key="{{ l2.id }}" data-label="{{ l2.label }}" data-icon="{{ l2.icon|default('bi-list') }}" data-status="{{ l2.status|default('hecho') }}" data-parent-key="{{ l1.id }}">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </td>
                                    <td>L2</td>
                                    <td><span class="menu-type-badge submenu">{{ 'Submenú' | trans }}</span></td>
                                    <td><span class="menu-color-dot submenu" title="{{ 'Submenú' | trans }}"></span></td>
                                    <td><code>{{ l2.id }}</code></td>
                                    <td>&mdash; {{ l2.label }}</td>
                                    <td data-sidebar="{{ l2.showInSidebar|default(true) ? 'visible' : 'oculto' }}"><span class="badge {{ l2.showInSidebar|default(true) ? 'bg-success' : 'bg-secondary' }}">{{ l2.showInSidebar|default(true) ? ('Visible'|trans) : ('Oculto'|trans) }}</span></td>
                                    <td data-status="{{ l2.status|default('hecho') }}"><span class="badge {{ l2.status|default('hecho') == 'pendiente' ? 'bg-warning text-dark' : 'bg-success' }}">{{ l2.status|default('hecho')|capitalize }}</span></td>
                                </tr>
                                {% for l3 in l2.children|default([]) %}
                                    <tr>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-secondary js-edit-row" data-level="subopcion" data-key="{{ l3.id }}" data-label="{{ l3.label }}" data-icon="{{ l3.icon|default('bi-list') }}" data-status="{{ l3.status|default('hecho') }}" data-parent-key="{{ l2.id }}" data-principal-key="{{ l1.id }}">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </td>
                                        <td>L3</td>
                                        <td><span class="menu-type-badge subopcion">{{ 'Subopción' | trans }}</span></td>
                                        <td><span class="menu-color-dot subopcion" title="{{ 'Subopción' | trans }}"></span></td>
                                        <td><code>{{ l3.id }}</code></td>
                                        <td>&mdash; &mdash; {{ l3.label }}</td>
                                        <td data-sidebar="{{ l3.showInSidebar|default(true) ? 'visible' : 'oculto' }}"><span class="badge {{ l3.showInSidebar|default(true) ? 'bg-success' : 'bg-secondary' }}">{{ l3.showInSidebar|default(true) ? ('Visible'|trans) : ('Oculto'|trans) }}</span></td>
                                        <td data-status="{{ l3.status|default('hecho') }}"><span class="badge {{ l3.status|default('hecho') == 'pendiente' ? 'bg-warning text-dark' : 'bg-success' }}">{{ l3.status|default('hecho')|capitalize }}</span></td>
                                    </tr>
                                {% endfor %}
                            {% endfor %}
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div id="menu-editor-panel" class="col-xl-12" style="display:none;">
        <div class="content-card h-100">
            <div class="content-card-header">
                {{ 'Editor de ítems' | trans }}
                <div class="menu-panel-subtitle">Configura jerarquía, estado e ícono antes de guardar.</div>
            </div>
            <div class="content-card-body">
                <div class="editor-shell">
                <form id="menu-governance-form-demo" method="post" action="{{ path('grova_page_users_menu_governance_save', {_locale: app.request.locale}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('menu_governance_save') }}">
                    <div class="mb-2">
                        <label class="form-label">¿Qué quieres crear?</label>
                        <select id="demo-create-mode" name="create_mode" class="form-select form-select-sm js-select2">
                            <option value="single" selected>Solo 1 ítem de menú</option>
                            <option value="bundle">Menú completo (principal + submenú + subopción)</option>
                        </select>
                    </div>

                    <div id="single-create-fields">
                    <div class="mb-2">
                        <label class="form-label">Path</label>
                        <input id="demo-menu-key" name="single_path" type="text" class="form-control form-control-sm" placeholder="gestion-menu" value="gestion-menu">
                        <div class="small text-muted mt-1">Identificador técnico único (URL/route key).</div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Label menú</label>
                        <input id="demo-menu-label" name="single_label" type="text" class="form-control form-control-sm" placeholder="Gestión de menú" value="Gestión de menú">
                        <div class="small text-muted mt-1">Nombre que verá el usuario en el sidebar.</div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Ícono (Bootstrap Icons o Font Awesome)</label>
                        <div class="d-flex align-items-center gap-2">
                            <select id="demo-menu-icon" name="single_icon" class="form-select form-select-sm js-select2" style="width:100%;"></select>
                            <span class="icon-live-preview" id="demo-menu-icon-preview"><i class="bi bi-list"></i></span>
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label">Tipo de elemento</label>
                            <select id="demo-item-type" name="single_item_type" class="form-select form-select-sm js-select2">
                                <option value="principal">Menú principal</option>
                                <option value="submenu" selected>Submenú</option>
                                <option value="subopcion">Subopción</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Orden</label>
                            <input type="number" name="single_sort_order" class="form-control form-control-sm" value="23">
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Elemento padre</label>
                        <label id="demo-parent-principal-label" class="form-label small text-muted mb-1" style="display:none;">1) Menú principal</label>
                        <select id="demo-parent-principal" class="form-select form-select-sm js-select2" style="display:none;"></select>
                        <label id="demo-parent-submenu-label" class="form-label small text-muted mt-2 mb-1" style="display:none;">2) Submenú</label>
                        <select id="demo-parent-key" name="single_parent_key" class="form-select form-select-sm js-select2"></select>
                        <div id="demo-parent-help" class="small text-muted mt-1"></div>
                    </div>
                    <div class="mb-2 d-flex align-items-center justify-content-between border rounded p-2">
                        <label class="form-label mb-0">Mostrar en sidebar</label>
                        <input id="single-show-in-sidebar" name="single_show_in_sidebar" class="form-check-input" type="checkbox" checked>
                    </div>
                    <div class="mb-3 d-flex align-items-center justify-content-between border rounded p-2">
                        <label class="form-label mb-0">Solo desarrollo</label>
                        <input name="single_dev_only" class="form-check-input" type="checkbox">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Estado del item</label>
                        <select id="single-status" name="single_status" class="form-select form-select-sm js-select2">
                            <option value="pendiente" selected>Pendiente (en construcción)</option>
                            <option value="hecho">Hecho (listo)</option>
                        </select>
                    </div>
                    <div class="mb-3 border rounded p-2" style="border-color:#334155 !important;">
                        <div class="small text-muted mb-2 d-flex align-items-center">
                            Vista previa en sidebar
                            <span class="menu-info-wrap" id="menu-info-wrap">
                                <button type="button" class="menu-info-btn" id="menu-info-btn" title="Cómo funciona">i</button>
                                <div class="menu-info-pop" id="menu-info-pop">
                                    Elige tipo y ubicación. Esta maqueta te muestra cómo quedaría el nuevo elemento
                                    dentro del menú lateral antes de guardarlo.
                                </div>
                            </span>
                            <span class="menu-info-wrap" id="menu-preview-wrap">
                                <button type="button" class="menu-info-btn" id="menu-preview-btn" title="Ver previsualización" aria-label="Ver previsualización">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                                <div class="menu-info-pop menu-preview-pop" id="menu-preview-pop"></div>
                            </span>
                        </div>
                        <div id="menu-level-meta" class="small text-muted mb-1"></div>
                        <div id="menu-level-chip" class="badge bg-primary mb-2">Nuevo item: Submenú</div>
                        <div id="menu-hierarchy-preview"></div>
                    </div>
                    </div>

                    <div id="bundle-create-fields" style="display:none;">
                        <div class="alert alert-secondary" role="alert" style="font-size:13px;">
                            Este modo crea una estructura completa partiendo desde el nivel que elijas.
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Estructura a crear</label>
                            <select id="bundle-kind" name="bundle_kind" class="form-select form-select-sm js-select2">
                                <option value="full" selected>Principal + Submenú + Subopción</option>
                                <option value="submenu">Submenú + Subopción (bajo principal existente)</option>
                                <option value="subopcion">Solo Subopción (bajo submenú existente)</option>
                            </select>
                        </div>

                        <div id="bundle-parent-principal-wrap" class="mb-2" style="display:none;">
                            <label class="form-label">Menú principal padre</label>
                            <select id="bundle-parent-principal" name="bundle_parent_principal" class="form-select form-select-sm js-select2">
                                <option value="">Selecciona menú principal...</option>
                                {% for l1 in menu_tree %}
                                    <option value="{{ l1.id }}">{{ l1.label }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div id="bundle-parent-principal-suboption-wrap" class="mb-2" style="display:none;">
                            <label class="form-label">1) Menú principal padre</label>
                            <select id="bundle-parent-principal-suboption" name="bundle_parent_principal_suboption" class="form-select form-select-sm js-select2">
                                <option value="">Selecciona menú principal...</option>
                                {% for l1 in menu_tree %}
                                    <option value="{{ l1.id }}">{{ l1.label }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div id="bundle-parent-submenu-wrap" class="mb-2" style="display:none;">
                            <label class="form-label">2) Submenú padre</label>
                            <select id="bundle-parent-submenu" name="bundle_parent_submenu" class="form-select form-select-sm js-select2">
                                <option value="">Selecciona submenú...</option>
                            </select>
                        </div>
                        <div id="bundle-principal-row" class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label">Path menú principal</label>
                                <input name="bundle_principal_path" type="text" class="form-control form-control-sm" placeholder="ventas">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Label menú principal</label>
                                <input name="bundle_principal_label" type="text" class="form-control form-control-sm" placeholder="Ventas">
                            </div>
                        </div>
                        <div id="bundle-submenu-row" class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label">Path submenú</label>
                                <input name="bundle_submenu_path" type="text" class="form-control form-control-sm" placeholder="ventas-reportes">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Label submenú</label>
                                <input name="bundle_submenu_label" type="text" class="form-control form-control-sm" placeholder="Reportes">
                            </div>
                        </div>
                        <div id="bundle-suboption-row" class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label">Path subopción</label>
                                <input name="bundle_suboption_path" type="text" class="form-control form-control-sm" placeholder="ventas-reportes-diario">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Label subopción</label>
                                <input name="bundle_suboption_label" type="text" class="form-control form-control-sm" placeholder="Reporte diario">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Orden base</label>
                            <input name="bundle_base_sort_order" type="number" class="form-control form-control-sm" value="80">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Estado de la estructura</label>
                            <select id="bundle-status" name="bundle_status" class="form-select form-select-sm js-select2">
                                <option value="pendiente" selected>Pendiente (en construcción)</option>
                                <option value="hecho">Hecho (listo)</option>
                            </select>
                        </div>
                        <div class="mb-3 border rounded p-2" style="border-color:#334155 !important;">
                            <div class="small text-muted mb-2">Vista previa en sidebar (modo estructura)</div>
                            <div id="bundle-level-meta" class="small text-muted mb-1"></div>
                            <div id="bundle-level-chip" class="badge bg-primary mb-2">Estructura</div>
                            <div id="bundle-hierarchy-preview"></div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" id="menu-form-cancel-btn" class="btn btn-sm btn-outline-secondary">Cancelar</button>
                        <button type="submit" class="btn btn-sm btn-primary">Guardar</button>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block app_page_scripts %}
<script>
(function () {
    var modeEl = document.getElementById('demo-create-mode');
    var singleFieldsEl = document.getElementById('single-create-fields');
    var bundleFieldsEl = document.getElementById('bundle-create-fields');
    var keyEl = document.getElementById('demo-menu-key');
    var labelEl = document.getElementById('demo-menu-label');
    var iconEl = document.getElementById('demo-menu-icon');
    var iconPreviewEl = document.getElementById('demo-menu-icon-preview');
    var typeEl = document.getElementById('demo-item-type');
    var parentEl = document.getElementById('demo-parent-key');
    var parentPrincipalEl = document.getElementById('demo-parent-principal');
    var parentPrincipalLabelEl = document.getElementById('demo-parent-principal-label');
    var parentSubmenuLabelEl = document.getElementById('demo-parent-submenu-label');
