    }

    function validateBeforeSubmit() {
        clearValidationState();
        var mode = getSelectValue(modeEl) || 'single';
        var errors = [];
        if (mode === 'single') {
            var itemType = getSelectValue(typeEl) || 'principal';
            var key = (keyEl.value || '').trim();
            var label = (labelEl.value || '').trim();
            var icon = (iconEl.value || '').trim();
            var parent = (getSelectValue(parentEl) || '').trim();
            var principal = (getSelectValue(parentPrincipalEl) || '').trim();
            var sortOrder = (singleSortOrderEl && singleSortOrderEl.value ? singleSortOrderEl.value : '').trim();

            if (!key) {
                errors.push('El campo Path es obligatorio.');
                markInvalid(keyEl);
            } else if (!isValidPath(key)) {
                errors.push('Path solo permite minúsculas, números y guiones (ej: gestion-menu).');
                markInvalid(keyEl);
            }
            if (!label) {
                errors.push('El campo Label menú es obligatorio.');
                markInvalid(labelEl);
            }
            if (!icon) {
                errors.push('Debes seleccionar un ícono.');
                markInvalid(iconEl);
            }
            if (sortOrder === '' || isNaN(Number(sortOrder))) {
                errors.push('Orden debe ser numérico.');
                markInvalid(singleSortOrderEl);
            }
            if (itemType === 'submenu' && !parent) {
                errors.push('Selecciona el menú principal padre del submenú.');
                markInvalid(parentEl);
            }
            if (itemType === 'subopcion' && !principal) {
                errors.push('Selecciona el menú principal padre.');
                markInvalid(parentPrincipalEl);
            }
            if (itemType === 'subopcion' && !parent) {
                errors.push('Selecciona el submenú padre.');
                markInvalid(parentEl);
            }
        } else {
            var kind = getSelectValue(bundleKindEl) || 'full';
            var principalPath = (bundlePrincipalPathEl.value || '').trim();
            var principalLabel = (bundlePrincipalLabelEl.value || '').trim();
            var submenuPath = (bundleSubmenuPathEl.value || '').trim();
            var submenuLabel = (bundleSubmenuLabelEl.value || '').trim();
            var suboptionPath = (bundleSuboptionPathEl.value || '').trim();
