            var bundleSubmenu = (getSelectValue(bundleParentSubmenuEl) || '').trim();
            var bundleBaseSort = (bundleBaseSortOrderEl && bundleBaseSortOrderEl.value ? bundleBaseSortOrderEl.value : '').trim();

            if (kind === 'full') {
                if (!principalPath) {
                    errors.push('Path menú principal es obligatorio.');
                    markInvalid(bundlePrincipalPathEl);
                } else if (!isValidPath(principalPath)) {
                    errors.push('Path menú principal tiene formato inválido.');
                    markInvalid(bundlePrincipalPathEl);
                }
                if (!principalLabel) {
                    errors.push('Label menú principal es obligatorio.');
                    markInvalid(bundlePrincipalLabelEl);
                }
            }
            if (kind === 'submenu' && !bundlePrincipal) {
                errors.push('Selecciona el menú principal padre.');
                markInvalid(bundleParentPrincipalEl);
            }
            if (kind === 'subopcion') {
                if (!bundlePrincipalForSub) {
                    errors.push('Selecciona el menú principal padre.');
                    markInvalid(bundleParentPrincipalSuboptionEl);
                }
                if (!bundleSubmenu) {
                    errors.push('Selecciona el submenú padre.');
                    markInvalid(bundleParentSubmenuEl);
                }
            }
            if (kind === 'full' || kind === 'submenu') {
                if (!submenuPath) {
                    errors.push('Path submenú es obligatorio.');
                    markInvalid(bundleSubmenuPathEl);
                } else if (!isValidPath(submenuPath)) {
                    errors.push('Path submenú tiene formato inválido.');
                    markInvalid(bundleSubmenuPathEl);
                }
                if (!submenuLabel) {
                    errors.push('Label submenú es obligatorio.');
                    markInvalid(bundleSubmenuLabelEl);
                }
            }
            if (!suboptionPath) {
                errors.push('Path subopción es obligatorio.');
                markInvalid(bundleSuboptionPathEl);
            } else if (!isValidPath(suboptionPath)) {
                errors.push('Path subopción tiene formato inválido.');
                markInvalid(bundleSuboptionPathEl);
            }
            if (!suboptionLabel) {
