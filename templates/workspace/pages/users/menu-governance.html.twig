        var base = String(iconValue || '').replace(/^bi-/, '');
        return [base, base.replace(/-/g, ' ')];
    }

    function iconMatcher(params, data) {
        if (!params.term || !params.term.trim()) {
            return data;
        }
        var term = normalizeText(params.term);
        var text = normalizeText(data.text || '');
        var tags = normalizeText((data.element && data.element.getAttribute('data-tags')) || '');

        if (text.indexOf(term) > -1 || tags.indexOf(term) > -1) {
            return data;
        }
        return null;
    }

