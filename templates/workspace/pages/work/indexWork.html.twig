{% endblock %}

{% block app_main %}
{% set work_swal_flashes = [] %}
{% for type, msgs in app.flashes %}
    {% for m in msgs %}
        {% set work_swal_flashes = work_swal_flashes|merge([{ type: type, message: m }]) %}
    {% endfor %}
{% endfor %}

{% if client is null %}
<div class="alert alert-warning">
    {{ 'work.no_client_warning'|trans({}, 'work') }}
    <a href="{{ path('grova_work_clients', {_locale: app.request.locale}) }}" class="alert-link">{{ 'work.no_client_link'|trans({}, 'work') }}</a>
</div>
{% else %}
{% import _self as wf %}

{# ── Cliente activo ── #}
<div class="content-card mb-4">
    <div class="content-card-header">
        <span><i class="bi bi-building me-2"></i>{{ 'work.client_active'|trans({}, 'work') }}</span>
        <div class="d-flex gap-2">
            <a href="{{ path('grova_work_clients', {_locale: app.request.locale}) }}" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-people me-1"></i>{{ 'work.client_manage'|trans({}, 'work') }}
            </a>
            <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modal-edit-client">
                <i class="bi bi-pencil me-1"></i>{{ 'work.client_edit'|trans({}, 'work') }}
            </button>
        </div>
    </div>
    <div class="content-card-body">
        <div class="row g-3">
            <div class="col-sm-4">
                <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.06em;">{{ 'work.client_company'|trans({}, 'work') }}</div>
                <div style="font-weight:700;font-size:15px;">{{ client.nombre }}</div>
                <div style="font-size:12px;color:#64748b;margin-top:2px;">{{ client.emailsFactura }}</div>
            </div>
            <div class="col-sm-2">
                <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.06em;">{{ 'work.client_base_salary'|trans({}, 'work') }}</div>
                <div style="font-weight:700;font-size:15px;">€{{ client.salarioBaseFloat|number_format(2, '.', ',') }}</div>
                {{ wf.work_fx_eur_sub(client.salarioBaseFloat, salary_fx_rates) }}
                {% if salary_fx_hint is defined and salary_fx_hint %}
                <div class="small text-muted mt-1" style="font-size:10px;line-height:1.3;">{{ salary_fx_hint }}</div>
                {% endif %}
            </div>
            <div class="col-sm-2">
                <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.06em;">{{ 'work.client_bonus_day'|trans({}, 'work') }}</div>
                <div style="font-weight:700;font-size:15px;color:#22c55e;">€{{ client.bonusDiaFloat|number_format(2) }}</div>
                <div style="font-size:11px;color:#64748b;">{{ 'work.client_before'|trans({'%time%': client.horaLimiteBonus}, 'work') }}</div>
                {{ wf.work_fx_eur_sub(client.bonusDiaFloat, salary_fx_rates) }}
            </div>
            <div class="col-sm-4">
                <div style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.06em;">{{ 'work.client_bank_data'|trans({}, 'work') }}</div>
                {% if client.bancNombre %}
                <div style="font-size:12px;">{{ client.bancNombre }} · {{ client.bancSwift }}</div>
                <div style="font-size:12px;color:#64748b;">{{ client.bancCuenta }} · {{ client.bancTitular }}</div>
                {% else %}
                <div style="font-size:12px;color:#475569;">{{ 'work.client_no_bank'|trans({}, 'work') }}</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ── Tasas de cambio ── #}
{% if rates is defined %}
<div class="rates-bar" style="margin-bottom:1rem;padding:.6rem .85rem;border-radius:8px;font-size:11px;">
    <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
        <span class="work-rates-kicker">
            <i class="bi bi-bank me-1"></i>{{ 'work.rates_title'|trans({'%date%': rates.fecha}, 'work') }}
        </span>
        {% for name, bank in rates.banks %}
        {% set isBestEur = name == rates.best_eur %}
        {% set isBestUsd = name == rates.best_usd %}
        <div class="rate-bank-item {{ (isBestEur or isBestUsd) ? 'best' : '' }}">
            <span style="font-weight:700;color:{{ (isBestEur or isBestUsd) ? '#4ade80' : '#64748b' }};">
                {{ name }}
                {% if isBestEur or isBestUsd %}<i class="bi bi-star-fill ms-1" style="font-size:9px;"></i>{% endif %}
            </span>
            <span style="color:#475569;">·</span>
            <span style="color:#94a3b8;">
                USD <strong style="color:{{ isBestUsd ? '#4ade80' : '#64748b' }};">{{ bank.usd }}</strong>/<span style="color:#475569;">{{ bank.usd_venta }}</span>
            </span>
            {% if bank.eur > 0 %}
            <span style="color:#475569;">·</span>
            <span style="color:#94a3b8;">
                EUR <strong style="color:{{ isBestEur ? '#4ade80' : '#64748b' }};">{{ bank.eur }}</strong>/<span style="color:#475569;">{{ bank.eur_venta }}</span>
            </span>
            {% endif %}
        </div>
        {% endfor %}
        {% if rates.best_eur and rates.best_usd %}
        <span class="work-rates-best-summary">
            <span class="text-nowrap"><i class="bi bi-star-fill me-1"></i>{{ 'work.rates_best'|trans({'%bank%': rates.best_eur}, 'work') }}</span>
            <span class="text-nowrap"><i class="bi bi-star-fill me-1"></i>{{ 'work.rates_best_usd'|trans({'%bank%': rates.best_usd}, 'work') }}</span>
        </span>
        {% elseif rates.best_eur %}
        <span class="work-rates-best-summary text-nowrap">
            <i class="bi bi-star-fill me-1"></i>{{ 'work.rates_best'|trans({'%bank%': rates.best_eur}, 'work') }}
        </span>
        {% endif %}
    </div>
</div>
{% endif %}

{# ── Stats del mes ── #}
<div class="row g-3 mb-4">
    <div class="col-sm-3">
        <div class="work-stat">
            <div class="work-stat-label">{{ 'work.stat_days_worked'|trans({'%month%': mes_label}, 'work') }}</div>
            <div class="work-stat-value">{{ dias_trabajados }}</div>
            <div class="work-stat-sub">{{ 'work.stat_days_worked_sub'|trans({}, 'work') }}</div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="work-stat">
            <div class="work-stat-label">{{ 'work.stat_bonus_days'|trans({'%month%': mes_label}, 'work') }}</div>
            <div class="work-stat-value bonus-yes">{{ dias_bonus }}</div>
            <div class="work-stat-sub">
                {{ 'work.client_before'|trans({'%time%': client.horaLimiteBonus}, 'work') }} · €{{ bonus_dia|number_format(2, '.', ',') }}
                {{ wf.work_fx_eur_sub(bonus_dia, salary_fx_rates, 'work-fx-eur-sub--sm') }}
                {% if dias_bonus > 0 %}
                <br><strong style="color:#22c55e;">{{ 'work.stat_total_bonus'|trans({'%amount%': (dias_bonus * bonus_dia)|number_format(2, '.', ',')}, 'work') }}</strong>
                {{ wf.work_fx_eur_sub(dias_bonus * bonus_dia, salary_fx_rates, 'work-fx-eur-sub--sm') }}
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="work-stat">
            <div class="work-stat-label">{{ 'work.stat_total_month'|trans({'%month%': mes_label}, 'work') }}</div>
            <div class="work-stat-value" style="color:#6366f1;">€{{ proyectado|number_format(2, '.', ',') }}</div>
            {{ wf.work_fx_eur_sub(proyectado, salary_fx_rates) }}
            <div class="work-stat-sub">
                €{{ salario_base|number_format(2, '.', ',') }} {{ 'work.stat_base'|trans({}, 'work') }}
                {% if dias_bonus > 0 %}+ €{{ (dias_bonus * bonus_dia)|number_format(2, '.', ',') }} bonus{% endif %}
            </div>
            {% if total_final_hnl > 0 %}
            <div class="total-sep">
                <div style="font-size:18px;font-weight:800;color:#f59e0b;">
                    L {{ total_final_hnl|number_format(2, '.', ',') }}
                </div>
                {% if salary_fx_rates.usd is defined and salary_fx_rates.usd > 0 %}
                <div style="font-size:12px;font-weight:700;color:#94a3b8;margin-top:3px;">≈ US$ {{ (total_final_hnl / salary_fx_rates.usd)|number_format(2, '.', ',') }}</div>
                {% endif %}
                <div style="font-size:10px;color:#64748b;line-height:1.5;margin-top:2px;">
                    €{{ proyectado|number_format(2) }} × {{ salary_fx_rates.eur }} = L {{ total_hnl|number_format(2, '.', ',') }}<br>
                    {% if recargo_hnl > 0 %}
                    − L {{ recargo_hnl|number_format(2, '.', ',') }} <span style="color:#94a3b8;">(≈ ${{ (recargo_hnl / salary_fx_rates.usd)|number_format(2, '.', ',') }} USD)</span> {{ 'work.stat_bank_commission'|trans({}, 'work') }}<br>
                    {% endif %}
                    <span style="color:#475569;">{{ salary_fx_rates.fecha }} · {{ salary_fx_rates.source }}</span>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
    <div class="col-sm-3">
        <div class="work-stat">
            <div class="work-stat-label">{{ 'work.stat_vacations'|trans({'%year%': year}, 'work') }}</div>
            <div class="work-stat-value">{{ vac_total }}<span style="font-size:14px;color:#64748b;">/15</span></div>
            <div class="work-stat-sub">S1: {{ vac_usado_s1 }}/5 · S2: {{ vac_usado_s2 }}/10</div>
            <div class="vac-bar"><div class="vac-bar-fill" style="width:{{ (vac_total / 15 * 100)|round }}%;"></div></div>
        </div>
    </div>
</div>

{# ── Filtro por mes ── #}
<form method="get" action="{{ path('grova_work_index', {_locale: app.request.locale}) }}"
      id="work-filter-form"
      style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;">
    <input type="hidden" name="holiday_year" value="{{ holiday_year }}">
    <select name="year" id="sel-year" class="form-select form-select-sm" style="width:auto;">
        {% for y in distinct_years %}
        <option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}</option>
        {% endfor %}
    </select>
    <select name="month" id="sel-month" class="form-select form-select-sm" style="width:auto;">
        {% for m in months_for_year %}
        <option value="{{ m.month }}" {{ m.month == month ? 'selected' : '' }}>
            {{ m.month_label }}
        </option>
        {% endfor %}
    </select>
    <div class="form-check form-check-inline mb-0" style="margin-left:.25rem;">
        <input class="form-check-input" type="checkbox" id="chk-show-all" name="show_all" value="1"
               {{ show_all ? 'checked' : '' }}>
        <label class="form-check-label" for="chk-show-all" style="font-size:12px;cursor:pointer;user-select:none;">
            {{ 'work.filter_show_all'|trans({}, 'work') }}
        </label>
    </div>
    <button type="submit" class="btn btn-sm btn-outline-secondary" style="padding:3px 8px;">
        <i class="bi bi-search" style="font-size:11px;"></i>
    </button>
</form>

<div class="row g-3">

    {# ── Tabla de días ── #}
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header">
                {% if show_all %}
                    {{ 'work.days_table_title_all'|trans({}, 'work') }}
                {% else %}
                    {{ 'work.days_table_title'|trans({'%month%': mes_label}, 'work') }}
                {% endif %}
                <div class="d-flex gap-2">
                    {% if not show_all %}
                    {% set is_paid_locked = work_recalc_month_is_paid|default(false) %}
                    {% set is_invoiced_locked = work_recalc_month_has_invoice|default(false) %}
                    {% set is_recalc_year_locked = year != vigente_year %}
                    {% set is_recalc_disabled = is_paid_locked or is_recalc_year_locked or not is_invoiced_locked %}
                    {% if is_paid_locked %}
                        {% set recalc_btn_title = 'work.locked_paid_invoice'|trans({}, 'work') %}
                    {% elseif is_recalc_year_locked %}
                        {% set recalc_btn_title = 'work.locked_recalc_not_vigente_year'|trans({}, 'work') %}
                    {% elseif not is_invoiced_locked %}
                        {% set recalc_btn_title = 'work.locked_recalc_no_invoice'|trans({}, 'work') %}
                    {% else %}
                        {% set recalc_btn_title = 'work.btn_recalculate'|trans({}, 'work') %}
                    {% endif %}
                    <form method="post" action="{{ path('grova_work_recalculate', {_locale: app.request.locale}) }}"
                          class="js-work-submit-loading"
                          data-work-loading-title="{{ 'work.swal_loading_recalculate'|trans({}, 'work') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('work_recalculate') }}">
                        <input type="hidden" name="year" value="{{ year }}">
                        <input type="hidden" name="month" value="{{ month }}">
                        <button type="submit"
                                class="btn btn-sm btn-outline-warning"
                                title="{{ recalc_btn_title }}"
                                {{ is_recalc_disabled ? 'disabled' : '' }}>
                            <i class="bi bi-arrow-clockwise me-1"></i>{{ 'work.btn_recalculate'|trans({}, 'work') }}
                        </button>
                    </form>
                    {% endif %}
                    {% set header_locked = (not show_all) and (work_recalc_month_has_invoice|default(false)) %}
                    <button type="button"
                            class="btn btn-sm btn-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#modal-nuevo-dia"
                            title="{{ header_locked ? 'work.locked_invoiced_month'|trans({}, 'work') : '' }}"
                            {{ header_locked ? 'disabled' : '' }}>
                        <i class="bi bi-plus-lg me-1"></i>{{ 'work.btn_log_day'|trans({}, 'work') }}
                    </button>
                </div>
            </div>
            <div class="content-card-body p-0">
                {% if days|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover work-days-table mb-0" style="color:inherit;">
                        <thead>
                            <tr>
                                <th class="col-day-ops text-nowrap" title="{{ 'work.col_operations_days_hint'|trans({}, 'work') }}">{{ 'work.col_operations'|trans({}, 'work') }}</th>
                                <th style="width:110px;">{{ 'work.col_date'|trans({}, 'work') }}</th>
                                <th style="width:90px;">{{ 'work.col_entry'|trans({}, 'work') }}</th>
                                <th>{{ 'work.col_type'|trans({}, 'work') }}</th>
                                <th>{{ 'work.col_notes'|trans({}, 'work') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for day in days %}
                            {% set day_key = day.fecha|date('Y-m') %}
                            {% set day_locked = invoiced_months[day_key] is defined %}
                            <tr>
                                <td class="col-day-ops">
                                    <div class="day-ops-row">
                                        <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            style="padding:2px 7px;font-size:11px;"
                                            data-bs-toggle="modal" data-bs-target="#modal-edit-day-{{ day.id }}"
                                            title="{{ day_locked ? ('work.locked_invoiced_month'|trans({}, 'work')) : ('work.tooltip_op_edit_day'|trans({}, 'work')) }}"
                                            {{ day_locked ? 'disabled' : '' }}>
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        {% if day_locked %}
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    style="padding:2px 7px;font-size:11px;"
                                                    title="{{ 'work.locked_invoiced_month'|trans({}, 'work') }}"
                                                    disabled>
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        {% else %}
                                            <form method="post" class="d-inline js-work-swal-confirm"
                                                  action="{{ path('grova_work_day_delete', {id: day.id, _locale: app.request.locale}) }}"
                                                  data-work-swal-title="{{ 'work.confirm_delete_day'|trans({}, 'work') }}"
                                                  data-work-swal-icon="warning"
                                                  data-work-swal-confirm-text="{{ 'work.confirm_yes_delete'|trans({}, 'work') }}"
                                                  data-work-swal-cancel-text="{{ 'work.confirm_cancel'|trans({}, 'work') }}"
                                                  data-work-loading-title="{{ 'work.swal_loading_delete'|trans({}, 'work') }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('work_day_delete_' ~ day.id) }}">
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm"
                                                        style="padding:2px 7px;font-size:11px;"
                                                        title="{{ 'work.tooltip_op_delete_day'|trans({}, 'work') }}">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                                <td style="font-size:12px;color:#64748b;">{{ day.fecha|date('d/m/Y') }}</td>
                                <td style="font-size:13px;font-weight:600;">
                                    {% if day.horaEntrada %}
                                        {{ day.horaEntrada }}
                                    {% else %}
                                        <span style="color:#475569;">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% set show_normal = day.horaEntrada and not day.esFeriado and not day.esVacacion and not day.bonusAplica %}
                                    {% set has_chip = day.esFeriado or day.esVacacion or day.bonusAplica or show_normal %}
                                    <div class="d-flex flex-wrap gap-1 align-items-center" style="max-width:260px;">
                                        {% if day.esFeriado %}
                                            <span class="tag-feriado">{{ 'work.tag_holiday'|trans({}, 'work') }}</span>
                                        {% endif %}
                                        {% if day.esVacacion %}
                                            <span class="tag-vacacion">{{ 'work.tag_vacation'|trans({}, 'work') }}</span>
                                        {% endif %}
                                        {% if day.bonusAplica %}
                                            <span class="tag-bonus"><i class="bi bi-star-fill me-1"></i>+€{{ bonus_dia }}</span>
                                        {% endif %}
                                        {% if show_normal %}
                                            <span class="tag-normal">{{ 'work.tag_normal'|trans({}, 'work') }}</span>
                                        {% endif %}
                                        {% if not has_chip %}
                                            <span class="text-muted">—</span>
                                        {% endif %}
                                    </div>
                                </td>
                                <td style="font-size:12px;color:#64748b;">{{ day.notas ?? '—' }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Modales editar día #}
                {% for day in days %}
                <div class="modal fade grova-modal--macos" id="modal-edit-day-{{ day.id }}" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <form method="post" action="{{ path('grova_work_day_edit', {id: day.id, _locale: app.request.locale}) }}"
                                  class="js-work-submit-loading"
                                  data-work-loading-title="{{ 'work.swal_loading_save'|trans({}, 'work') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('work_day_edit_' ~ day.id) }}">
                                <div class="modal-header">
                                    <h5 class="modal-title">{{ 'work.modal_edit_day'|trans({'%date%': day.fecha|date('d/m/Y')}, 'work') }}</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="row g-3">
                                        <div class="col-sm-6">
                                            <label class="form-label">{{ 'work.field_date'|trans({}, 'work') }}</label>
                                            <input type="date" class="form-control form-control-sm" name="fecha" value="{{ day.fecha|date('Y-m-d') }}" required>
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label">{{ 'work.field_entry_time'|trans({}, 'work') }}</label>
                                            <input type="time" class="form-control form-control-sm" name="hora_entrada" value="{{ day.horaEntrada }}">
                                            <div class="form-text">{{ 'work.field_bonus_hint'|trans({'%time%': client.horaLimiteBonus, '%amount%': bonus_dia}, 'work') }}</div>
                                        </div>
                                        <div class="col-12">
                                            <div class="d-flex gap-3">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="es_feriado" id="ef_{{ day.id }}" value="1" {{ day.esFeriado ? 'checked' : '' }}>
                                                    <label class="form-check-label" for="ef_{{ day.id }}">{{ 'work.field_is_holiday'|trans({}, 'work') }}</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="es_vacacion" id="ev_{{ day.id }}" value="1" {{ day.esVacacion ? 'checked' : '' }}>
                                                    <label class="form-check-label" for="ev_{{ day.id }}">{{ 'work.field_is_vacation'|trans({}, 'work') }}</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">{{ 'work.field_notes'|trans({}, 'work') }}</label>
                                            <input type="text" class="form-control form-control-sm" name="notas" value="{{ day.notas }}" maxlength="255">
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">{{ 'work.btn_cancel'|trans({}, 'work') }}</button>
                                    <button type="submit" class="btn btn-primary btn-sm">{{ 'work.btn_save'|trans({}, 'work') }}</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}

                {% else %}
                <div class="grova-empty-state">
                    <div class="grova-empty-icon"><i class="bi bi-briefcase"></i></div>
                    <div class="grova-empty-title">{{ 'work.empty_days_title'|trans({}, 'work') }}</div>
                    <div class="grova-empty-desc">{{ 'work.empty_days_desc'|trans({}, 'work') }}</div>
                    <div class="grova-empty-actions">
                        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modal-nuevo-dia">
                            <i class="bi bi-plus-lg me-1"></i>{{ 'work.btn_log_day'|trans({}, 'work') }}
                        </button>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        {# ── Bonos extra del mes (factura del mes visto) ── #}
        {% if client and not show_all %}
        <div class="content-card mt-3" id="work-card-extra-bonuses">
            <div class="content-card-header py-2 d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div>
                    <span class="fw-semibold">{{ 'work.card_extra_bonuses_month'|trans({'%month%': mes_label}, 'work') }}</span>
                    <div class="small text-muted mb-0">{{ 'work.card_extra_bonuses_intro'|trans({}, 'work') }}</div>
                </div>
                {% if invoice_for_view_month is not null %}
                    {% set iv_head = invoice_for_view_month %}
                    {% set iv_can_edit_bono_card = iv_head.anio == vigente_year and not iv_head.pagadaAt %}
                    {% if iv_can_edit_bono_card %}
                        <button type="button"
                                class="btn btn-sm btn-outline-warning"
                                data-bs-toggle="modal"
                                data-bs-target="#modal-work-inv-manual-bono"
                                data-inv-url="{{ path('grova_work_invoice_manual_bonus', {id: iv_head.id, _locale: app.request.locale}) }}"
                                data-csrf="{{ csrf_token('work_invoice_manual_bonus_' ~ iv_head.id) }}"
                                data-bonus-lines="{{ iv_head.extraBonusLinesPayload|json_encode(15)|e('html_attr') }}"
                                title="{{ 'work.invoice_manual_bonus_btn_title'|trans({}, 'work') }}">
                            <i class="bi bi-gift me-1"></i>{{ 'work.card_extra_bonuses_edit'|trans({}, 'work') }}
                        </button>
                    {% endif %}
                {% elseif year == vigente_year %}
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modal-generar-factura">
                        <i class="bi bi-plus-lg me-1"></i>{{ 'work.btn_generate_invoice_short'|trans({}, 'work') }}
                    </button>
                {% endif %}
            </div>
            <div class="content-card-body p-0">
                {% if invoice_for_view_month is null %}
                    <div class="px-3 py-3">
                        <p class="small text-muted mb-0">{{ 'work.card_extra_bonuses_no_invoice'|trans({}, 'work') }}</p>
                    </div>
                {% else %}
                    {% set iv = invoice_for_view_month %}
                    {% set iv_can_edit_bono_card = iv.anio == vigente_year and not iv.pagadaAt %}
                    {% if iv.bonusLines|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0" style="color:inherit;">
                                <thead>
                                    <tr>
                                        <th>{{ 'work.card_extra_bonuses_col_concept'|trans({}, 'work') }}</th>
                                        <th class="text-end" style="width:7.5rem;">{{ 'work.card_extra_bonuses_col_amount'|trans({}, 'work') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for line in iv.bonusLines %}
                                    <tr>
                                        <td style="font-size:13px;">{{ line.concepto ?: ('work.invoice_pdf_manual_bonus_default_concept'|trans({}, 'work')) }}</td>
                                        <td class="text-end fw-semibold" style="font-size:13px;">€{{ line.importeFloat|number_format(2, '.', ',') }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr class="table-light">
                                        <th class="small text-uppercase" style="letter-spacing:0.04em;font-size:11px;">{{ 'work.card_extra_bonuses_total'|trans({}, 'work') }}</th>
                                        <th class="text-end">€{{ iv.extraBonusSumFloat|number_format(2, '.', ',') }}</th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    {% else %}
                        <div class="px-3 py-3">
                            <p class="small text-muted mb-0">{{ 'work.card_extra_bonuses_empty'|trans({}, 'work') }}</p>
                        </div>
                    {% endif %}
                    {% if not iv_can_edit_bono_card %}
                        <div class="px-3 py-2 border-top" style="border-color: rgba(148,163,184,.25);">
                            <span class="badge text-bg-secondary text-wrap text-start">{{ 'work.card_extra_bonuses_hint_readonly'|trans({}, 'work') }}</span>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
        {% endif %}

    </div>

    {# ── Panel lateral ── #}
    <div class="col-lg-4">

        {# Mini calendario #}
        <div class="content-card mb-3 work-cal-card">
            <div class="content-card-header work-cal-card-header">
                <div class="work-cal-nav">
                    <a href="{{ path('grova_work_index', {_locale: app.request.locale}|merge(work_cal_prev_query)) }}"
                       class="btn btn-sm work-cal-nav-btn" aria-label="{{ 'work.cal_prev_month'|trans({}, 'work') }}">‹</a>
                    <span class="work-cal-title">
                        {{ mes_label }}
                        {% if is_current_month %}<span class="work-cal-today-badge">HOY</span>{% endif %}
                    </span>
                    <a href="{{ path('grova_work_index', {_locale: app.request.locale}|merge(work_cal_next_query)) }}"
                       class="btn btn-sm work-cal-nav-btn" aria-label="{{ 'work.cal_next_month'|trans({}, 'work') }}">›</a>
                </div>
                <div class="work-cal-legend-min">
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--n" aria-hidden="true"></span>{{ 'work.cal_legend_normal'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--b" aria-hidden="true"></span>{{ 'work.cal_legend_bonus'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--f" aria-hidden="true"></span>{{ 'work.cal_legend_holiday'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--v" aria-hidden="true"></span>{{ 'work.cal_legend_vacation'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--inv" aria-hidden="true"></span>{{ 'work.cal_legend_invoice_deadline'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--is" aria-hidden="true"></span>{{ 'work.cal_legend_inv_sent'|trans({}, 'work') }}</span>
                    <span><span class="work-cal-legend-dot work-cal-legend-dot--ip" aria-hidden="true"></span>{{ 'work.cal_legend_inv_paid'|trans({}, 'work') }}</span>
                </div>
                <p class="work-cal-hint-min mb-0">{{ 'work.cal_cell_stripes_hint'|trans({}, 'work') }}</p>
                <p class="work-cal-hint-min mb-0 mt-1">{{ 'work.cal_invoice_deadline_brief'|trans({}, 'work') }}</p>
                <p class="work-cal-hint-min mb-0 mt-1">{{ 'work.cal_inv_calendar_hint'|trans({}, 'work') }}</p>
            </div>
            <div class="content-card-body" style="padding:.75rem;">
                <table style="width:100%;border-collapse:collapse;table-layout:fixed;">
                    <thead>
                        <tr>
                            {% for label in ('work.cal_days'|trans({}, 'work'))|split(',') %}
                            <th class="work-cal-weekday">{{ label }}</th>
                            {% endfor %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for week in cal_weeks %}
                        <tr>
                            {% for dow, d_num in week %}
                                {% if d_num is null %}
                                    <td></td>
                                {% else %}
                                    {% set is_cal_today = is_current_month and (d_num == cal_today_dom) %}
                                    {% set is_invoice_deadline = invoice_deadline_dom is not null and d_num == invoice_deadline_dom %}
                                    {% set inv_st = invoice_sent_dom_details[d_num] %}
                                    {% set inv_py = invoice_paid_dom_details[d_num] %}
                                    {% set wd = cal_day_map[d_num] ?? null %}
                                    {% set cal_fer_name = holiday_days_in_month[d_num] ?? null %}
                                    {% if wd %}
                                        {% set fer_on = wd.esFeriado or cal_fer_name %}
                                        {% set vac_on = wd.esVacacion %}
                                        {% set bon_on = wd.bonusAplica %}
                                        {% set n_act = (fer_on ? 1 : 0) + (vac_on ? 1 : 0) + (bon_on ? 1 : 0) %}
                                        {% set tip = '' %}
                                        {% if wd.esFeriado %}{% set tip = tip ~ 'work.cal_mosaic_tip_fer'|trans({}, 'work') ~ '. ' %}{% elseif cal_fer_name %}{% set tip = tip ~ cal_fer_name ~ '. ' %}{% endif %}
                                        {% if wd.esVacacion %}{% set tip = tip ~ 'work.cal_mosaic_tip_vac'|trans({}, 'work') ~ '. ' %}{% endif %}
                                        {% if wd.bonusAplica %}{% set tip = tip ~ 'work.cal_mosaic_tip_bon'|trans({}, 'work') ~ '. ' %}{% endif %}
                                        {% if wd.horaEntrada %}{% set tip = tip ~ wd.horaEntrada %}{% endif %}
                                        {% if wd.notas %}{% set tip = tip ~ (wd.horaEntrada ? ' · ' : '') ~ wd.notas %}{% endif %}
                                        {% if is_cal_today %}{% set tip = (tip ~ ' · ' ~ 'work.cal_mosaic_tip_today'|trans({}, 'work'))|trim %}{% endif %}
                                        {% if is_invoice_deadline %}{% set tip = (tip ~ ' · ' ~ 'work.cal_mosaic_tip_invoice_deadline'|trans({}, 'work'))|trim %}{% endif %}
                                        {% if inv_st %}{% set tip = (tip ~ ' · ' ~ inv_st)|trim %}{% endif %}
                                        {% if inv_py %}{% set tip = (tip ~ ' · ' ~ inv_py)|trim %}{% endif %}
                                        <td class="work-cal-td">
                                            <div class="work-cal-mosaic{% if n_act >= 2 %} work-cal-mosaic--multi{% endif %}{% if is_cal_today %} work-cal-mosaic--today{% endif %}{% if is_invoice_deadline %} work-cal-mosaic--invoice-deadline{% endif %}"{% if is_cal_today %} aria-current="date"{% endif %} title="{{ tip|trim|e('html_attr') }}">
                                                <div class="work-cal-stripes" aria-hidden="true">
                                                    <div class="work-cal-stripe work-cal-stripe--fer{{ fer_on ? ' work-cal-stripe--on' : '' }}"></div>
                                                    <div class="work-cal-stripe work-cal-stripe--vac{{ vac_on ? ' work-cal-stripe--on' : '' }}"></div>
                                                    <div class="work-cal-stripe work-cal-stripe--bon{{ bon_on ? ' work-cal-stripe--on' : '' }}"></div>
                                                </div>
                                                <div class="work-cal-mosaic-num">{% if inv_st %}<span class="work-cal-inv-dot work-cal-inv-dot--sent" title="{{ inv_st|e('html_attr') }}"></span>{% endif %}{% if inv_py %}<span class="work-cal-inv-dot work-cal-inv-dot--paid" title="{{ inv_py|e('html_attr') }}"></span>{% endif %}{{ d_num }}</div>
                                            </div>
                                        </td>
                                    {% elseif cal_fer_name %}
                                        {% set tip = cal_fer_name %}
                                        {% if is_cal_today %}{% set tip = (tip ~ ' · ' ~ 'work.cal_mosaic_tip_today'|trans({}, 'work'))|trim %}{% endif %}
                                        {% if is_invoice_deadline %}{% set tip = (tip ~ ' · ' ~ 'work.cal_mosaic_tip_invoice_deadline'|trans({}, 'work'))|trim %}{% endif %}
                                        {% if inv_st %}{% set tip = (tip ~ ' · ' ~ inv_st)|trim %}{% endif %}
                                        {% if inv_py %}{% set tip = (tip ~ ' · ' ~ inv_py)|trim %}{% endif %}
                                        <td class="work-cal-td">
                                            <div class="work-cal-mosaic{% if is_cal_today %} work-cal-mosaic--today{% endif %}{% if is_invoice_deadline %} work-cal-mosaic--invoice-deadline{% endif %}"{% if is_cal_today %} aria-current="date"{% endif %} title="{{ tip|e('html_attr') }}">
                                                <div class="work-cal-stripes" aria-hidden="true">
                                                    <div class="work-cal-stripe work-cal-stripe--fer work-cal-stripe--on"></div>
                                                    <div class="work-cal-stripe work-cal-stripe--vac"></div>
                                                    <div class="work-cal-stripe work-cal-stripe--bon"></div>
                                                </div>
                                                <div class="work-cal-mosaic-num">{% if inv_st %}<span class="work-cal-inv-dot work-cal-inv-dot--sent" title="{{ inv_st|e('html_attr') }}"></span>{% endif %}{% if inv_py %}<span class="work-cal-inv-dot work-cal-inv-dot--paid" title="{{ inv_py|e('html_attr') }}"></span>{% endif %}{{ d_num }}</div>
                                            </div>
                                        </td>
                                    {% else %}
                                        {% set tip_empty = '' %}
                                        {% if is_invoice_deadline %}{% set tip_empty = 'work.cal_mosaic_tip_invoice_deadline'|trans({}, 'work') %}{% endif %}
                                        {% if is_cal_today %}{% set tip_empty = (tip_empty ~ (tip_empty ? ' · ' : '') ~ 'work.cal_mosaic_tip_today'|trans({}, 'work'))|trim %}{% endif %}
                                        {% if inv_st %}{% set tip_empty = (tip_empty ~ (tip_empty ? ' · ' : '') ~ inv_st)|trim %}{% endif %}
                                        {% if inv_py %}{% set tip_empty = (tip_empty ~ (tip_empty ? ' · ' : '') ~ inv_py)|trim %}{% endif %}
                                        <td class="work-cal-td">
                                            <div class="cal-empty-day cal-empty-day--minimal{% if is_cal_today %} work-cal-day--today{% endif %}{% if is_invoice_deadline %} work-cal-day--invoice-deadline{% endif %} {{ dow >= 5 ? 'weekend' : '' }}"{% if tip_empty %} title="{{ tip_empty|e('html_attr') }}"{% endif %}{% if is_cal_today %} aria-current="date"{% endif %}>{% if inv_st %}<span class="work-cal-inv-dot work-cal-inv-dot--sent" title="{{ inv_st|e('html_attr') }}"></span>{% endif %}{% if inv_py %}<span class="work-cal-inv-dot work-cal-inv-dot--paid" title="{{ inv_py|e('html_attr') }}"></span>{% endif %}{{ d_num }}</div>
                                        </td>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>

                {# Contador resumen #}
                <div class="cal-divider">
                    <div class="text-center">
                        <div class="work-cal-foot-line cal-num">
                            <span class="work-cal-foot-n">{{ dias_trabajados }}</span>
                            <span class="work-cal-foot-t">{{ 'work.cal_label_work'|trans({}, 'work') }}</span>
                        </div>
                    </div>
                    <div class="text-center">
                        <div class="work-cal-foot-line work-cal-foot-line--bonus">
                            <span class="work-cal-foot-n">{{ dias_bonus }}</span>
                            <span class="work-cal-foot-t">{{ 'work.cal_label_bonus'|trans({}, 'work') }}</span>
                        </div>
                    </div>
                    <div class="text-center">
                        <div class="work-cal-foot-line work-cal-foot-line--fer">
                            <span class="work-cal-foot-n">{{ dias_feriados }}</span>
                            <span class="work-cal-foot-t">{{ 'work.cal_label_holiday'|trans({}, 'work') }}</span>
                        </div>
                    </div>
                    <div class="text-center">
                        <div class="work-cal-foot-line work-cal-foot-line--vac">
                            <span class="work-cal-foot-n">{{ dias_vacaciones }}</span>
                            <span class="work-cal-foot-t">{{ 'work.cal_label_vac'|trans({}, 'work') }}</span>
                        </div>
                    </div>
                    <div class="text-center">
                        <div class="work-cal-foot-line work-cal-foot-line--eur">
                            <span class="work-cal-foot-n">€{{ proyectado|number_format(2, '.', ',') }}</span>
                        </div>
                        <div class="work-cal-foot-fx-mini">{{ wf.work_fx_eur_sub(proyectado, salary_fx_rates, 'work-fx-eur-sub--sm') }}</div>
                    </div>
                </div>
            </div>
        </div>

        {# Feriados: navegación solo por año (independiente del mes del calendario) #}
        <div class="content-card mb-3">
            <div class="content-card-header d-flex align-items-center justify-content-between gap-1 flex-wrap py-2">
                {% if holiday_nav_prev_query %}
                    <a href="{{ path('grova_work_index', {_locale: app.request.locale}|merge(holiday_nav_prev_query)) }}"
                       class="btn btn-sm btn-outline-secondary work-holiday-nav-btn px-2"
                       aria-label="{{ 'work.holidays_prev_year'|trans({}, 'work') }}"><i class="bi bi-chevron-left"></i></a>
                {% else %}
                    <span class="btn btn-sm btn-outline-secondary disabled opacity-50 work-holiday-nav-btn px-2" aria-hidden="true"><i class="bi bi-chevron-left"></i></span>
                {% endif %}
                <div class="d-flex align-items-center justify-content-center gap-1 flex-grow-1 px-1 flex-wrap">
                    <span class="small fw-semibold text-center">{{ 'work.holidays_title'|trans({'%year%': holiday_year}, 'work') }}</span>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary p-1 js-work-holidays-copy"
                            title="{{ 'work.holidays_copy_btn'|trans({}, 'work') }}"
                            aria-label="{{ 'work.holidays_copy_btn'|trans({}, 'work') }}">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
                {% if holiday_nav_next_query %}
                    <a href="{{ path('grova_work_index', {_locale: app.request.locale}|merge(holiday_nav_next_query)) }}"
                       class="btn btn-sm btn-outline-secondary work-holiday-nav-btn px-2"
                       aria-label="{{ 'work.holidays_next_year'|trans({}, 'work') }}"><i class="bi bi-chevron-right"></i></a>
                {% else %}
                    <span class="btn btn-sm btn-outline-secondary disabled opacity-50 work-holiday-nav-btn px-2" aria-hidden="true"><i class="bi bi-chevron-right"></i></span>
                {% endif %}
            </div>
            <div class="content-card-body p-0">
                <ul class="list-group list-group-flush" style="font-size:12px;">
                    {% for h in holidays_card %}
                    {% set esMesActual = h.fecha|date('n') == month and h.fecha|date('Y') == year %}
                    {% set esPasado    = h.fecha < date() %}
                    {% set esHoy       = h.fecha|date('Y-m-d') == 'now'|date('Y-m-d') %}
                    <li class="list-group-item list-li-dark d-flex justify-content-between align-items-center"
                        style="background:{{ esMesActual ? '#7c3aed18' : 'transparent' }};color:{{ esPasado and not esMesActual ? '#475569' : 'inherit' }};">
                        <span style="{{ esMesActual ? 'color:#a78bfa;font-weight:600;' : '' }}">
                            {% if esMesActual %}<i class="bi bi-circle-fill me-1" style="font-size:6px;color:#a78bfa;vertical-align:middle;"></i>{% endif %}
                            {% if esPasado %}
                                <i class="bi bi-check2-circle me-1" style="color:#22c55e;"></i>
                            {% elseif esHoy %}
                                <i class="bi bi-dot me-1" style="color:#f59e0b;"></i>
                            {% endif %}
                            {{ h.nombre }}
                        </span>
                        <span style="color:{{ esMesActual ? '#a78bfa' : '#64748b' }};font-weight:{{ esMesActual ? '700' : 'normal' }};">{{ h.fecha|date('d/m') }}</span>
                    </li>
                    {% endfor %}
                </ul>
                <textarea id="work-holidays-copy-src" class="visually-hidden" readonly tabindex="-1" aria-hidden="true">{{ holidays_clipboard_text|default('') }}</textarea>
            </div>
        </div>
        <div class="content-card">
            <div class="content-card-header">
                {{ 'work.vacations_title'|trans({'%year%': year}, 'work') }}
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modal-vacacion">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
            <div class="content-card-body p-0">
                {% if vacations|length > 0 %}
                <ul class="list-group list-group-flush" style="font-size:12px;">
                    {% for v in vacations %}
                    <li class="list-group-item list-li-dark d-flex justify-content-between align-items-center"
                        style="background:transparent;">
                        <span>
                            <span class="tag-vacacion me-1">S{{ v.semestre }}</span>
                            {{ v.fechaInicio|date('d/m') }} – {{ v.fechaFin|date('d/m') }}
                        </span>
                        <span style="color:#6366f1;font-weight:600;">{{ v.dias }}d</span>
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <div style="padding:1rem;font-size:12px;color:#475569;text-align:center;">{{ 'work.empty_vacations'|trans({}, 'work') }}</div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

