    border-color: rgba(165, 180, 252, 0.95);
    box-shadow: 0 0 0 2px rgba(129, 140, 248, 0.85), 0 0 14px rgba(99, 102, 241, 0.35);
}
.work-cal-mosaic.work-cal-mosaic--multi.work-cal-mosaic--today {
    box-shadow:
        0 0 0 2px rgba(165, 180, 252, 0.95),
        0 0 0 4px rgba(99, 102, 241, 0.45),
        0 0 16px rgba(129, 140, 248, 0.4);
}
body.light-mode .work-cal-mosaic.work-cal-mosaic--today {
    border-color: #4f46e5;
    box-shadow: 0 0 0 2px rgba(79, 70, 229, 0.45), 0 0 10px rgba(99, 102, 241, 0.15);
}
.work-cal-mosaic.work-cal-mosaic--today .work-cal-mosaic-num {
