body.light-mode .work-cal-legend-min { color: #475569; }
.work-cal-legend-min span { display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; }
.work-cal-legend-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.work-cal-legend-dot--n { background: #818cf8; }
.work-cal-legend-dot--b { background: #4ade80; }
.work-cal-legend-dot--f { background: #c4b5fd; }
.work-cal-legend-dot--v { background: #67e8f9; }
.work-cal-legend-dot--inv { background: #f59e0b; }
.work-cal-legend-dot--is { background: #14b8a6; }
.work-cal-legend-dot--ip { background: #fb7185; }
.work-cal-hint-min { font-size: 9px; color: #94a3b8; line-height: 1.35; margin-top: 6px; }
body.light-mode .work-cal-hint-min { color: #475569; }
.work-cal-td { text-align: center; padding: 2px 1px; vertical-align: middle; }
.work-cal-card .content-card-body { background: rgba(15, 23, 42, 0.35); }
body.light-mode .work-cal-card .content-card-body { background: #f8fafc; }
body.light-mode .work-cal-card > .content-card-header { border-bottom-color: #e2e8f0; }
.work-cal-card-header {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.5rem;
    font-size: 12px;
    padding: 0.65rem 0.85rem !important;
}
.work-cal-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    width: 100%;
}
.work-cal-nav-btn {
    padding: 2px 8px !important;
    font-size: 15px !important;
    line-height: 1 !important;
    color: #94a3b8 !important;
    border: none !important;
