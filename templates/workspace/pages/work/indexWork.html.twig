body.light-mode .cal-empty-day--minimal.work-cal-day--today {
    outline-color: #6366f1;
    color: #4338ca;
    background: rgba(199, 210, 254, 0.35);
}
.work-cal-mosaic.work-cal-mosaic--invoice-deadline .work-cal-mosaic-num {
    box-sizing: border-box;
    border-bottom: 3px solid #f59e0b;
}
.cal-empty-day--minimal.work-cal-day--invoice-deadline {
    box-sizing: border-box;
    border-bottom: 3px solid #f59e0b;
}
body.light-mode .work-cal-mosaic.work-cal-mosaic--invoice-deadline .work-cal-mosaic-num {
    border-bottom-color: #d97706;
}
body.light-mode .cal-empty-day--minimal.work-cal-day--invoice-deadline {
    border-bottom-color: #d97706;
}
.work-cal-mosaic-num {
    position: relative;
    flex-shrink: 0;
    min-height: 22px; display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; background: rgba(15, 23, 42, 0.55); color: #f8fafc;
    letter-spacing: -0.02em; padding: 2px 2px 4px;
