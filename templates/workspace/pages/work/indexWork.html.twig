{# ── Facturas: resumen (card aparte del listado) ── #}
<div class="content-card mt-4">
    <div class="content-card-header py-2 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <span class="small text-secondary fw-semibold text-uppercase" style="letter-spacing:0.06em;font-size:11px;">{{ 'work.invoices_summary_title'|trans({'%year%': invoice_year}, 'work') }}</span>
        {% if rates is defined and rates.eur is defined and rates.eur > 0 %}
        <div class="invoice-sum-header-rates d-flex flex-wrap align-items-center gap-2 ms-md-auto">
            {% set fx_hint = 'work.invoice_sum_fx_hint'|trans({'%fecha%': rates.fecha, '%banco%': rates.source}, 'work') %}
            <span class="text-nowrap" title="{{ fx_hint }}">
                <span class="fx-e">€</span> 1 = <span class="fx-l">L</span> {{ rates.eur|number_format(2, '.', ',') }}
            </span>
            {% if rates.usd is defined and rates.usd > 0 %}
            {% set eur_usd = (rates.eur / rates.usd)|number_format(4, '.', ',') %}
            <span class="text-nowrap d-none d-sm-inline" style="opacity:0.45;">|</span>
            <span class="text-nowrap" title="{{ fx_hint }}"><span class="fx-d">US$</span> 1 = <span class="fx-l">L</span> {{ rates.usd|number_format(2, '.', ',') }}</span>
            <span class="text-nowrap d-none d-sm-inline" style="opacity:0.45;">|</span>
            <span class="text-nowrap" title="{{ 'work.invoice_sum_fx_cross_title'|trans({}, 'work') }}">{{ 'work.invoice_sum_fx_cross'|trans({'%rate%': eur_usd}, 'work') }}</span>
            {% endif %}
        </div>
        {% endif %}
    </div>
    <div class="content-card-body p-3">
        <div class="invoice-sum-panel">
            <div class="text-muted small mb-2" style="font-size:11px;">{{ 'work.invoice_sum_intro'|trans({'%year%': invoice_year}, 'work') }}</div>
            {% if rates is defined and rates.eur is defined and rates.eur > 0 %}
            <div class="text-muted small mb-2" style="font-size:10px;line-height:1.35;">{{ 'work.invoice_sum_fx_hint'|trans({'%fecha%': rates.fecha, '%banco%': rates.source}, 'work') }}</div>
            {% endif %}
            <div class="row g-2 row-cols-1 row-cols-md-2 row-cols-xl-4">
                <div class="col">
                    <div class="invoice-sum-card">
                        <div class="invoice-sum-label">{{ 'work.invoice_sum_invoiced_paid'|trans({}, 'work') }}</div>
                        <div class="invoice-sum-value invoice-sum-val-total">€{{ invoice_summary.received_eur|number_format(2, '.', ',') }}</div>
                        <div class="invoice-sum-sub">{{ 'work.invoice_sum_paid_count'|trans({'%n%': invoice_summary.paid_count}, 'work') }}</div>
                        <div class="invoice-sum-sub" style="font-size:10px;opacity:0.9;">{{ 'work.invoice_sum_invoiced_paid_hint'|trans({}, 'work') }}</div>
                        {% if rates is defined and rates.eur is defined and rates.eur > 0 %}
                        {% if rates.usd is defined and rates.usd > 0 %}
                        <div class="invoice-sum-sub" style="color:#94a3b8;">US$ {{ (invoice_summary.received_eur * rates.eur / rates.usd)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                        <div class="invoice-sum-sub" style="color:#f59e0b;">L {{ (invoice_summary.received_eur * rates.eur)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                    </div>
                </div>
                <div class="col">
                    <div class="invoice-sum-card">
                        <div class="invoice-sum-label"><i class="bi bi-bank2 me-1"></i>{{ 'work.invoice_sum_received'|trans({}, 'work') }}</div>
                        {% if rates is defined and rates.eur is defined and rates.eur > 0 and invoice_summary.received_eur_net is not null %}
                        <div class="invoice-sum-value invoice-sum-val-received">€{{ invoice_summary.received_eur_net|number_format(2, '.', ',') }}</div>
                        {% if rates.usd is defined and rates.usd > 0 %}
                        <div class="invoice-sum-sub" style="color:#94a3b8;">US$ {{ (invoice_summary.received_eur_net * rates.eur / rates.usd)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                        <div class="invoice-sum-sub" style="color:#f59e0b;">L {{ invoice_summary.received_l_net|number_format(2, '.', ',') }}</div>
                        <div class="invoice-sum-sub" style="font-size:10px;opacity:0.9;">{{ 'work.invoice_sum_received_hint'|trans({}, 'work') }}</div>
                        {% else %}
                        <div class="invoice-sum-value invoice-sum-val-received">€{{ invoice_summary.received_eur|number_format(2, '.', ',') }}</div>
                        <div class="invoice-sum-sub text-muted small">{{ 'work.invoice_sum_received_no_rate'|trans({}, 'work') }}</div>
                        {% endif %}
                    </div>
                </div>
                <div class="col">
                    <div class="invoice-sum-card">
                        <div class="invoice-sum-label"><i class="bi bi-percent me-1"></i>{{ 'work.invoice_sum_commission_total'|trans({}, 'work') }}</div>
                        {% if rates is defined and rates.eur is defined and rates.eur > 0 and invoice_summary.paid_count > 0 %}
                        <div class="invoice-sum-value" style="color:#fb923c;">≈ €{{ (invoice_summary.commission_hnl_paid_sum / rates.eur)|number_format(2, '.', ',') }}</div>
                        {% if rates.usd is defined and rates.usd > 0 %}
                        <div class="invoice-sum-sub" style="color:#94a3b8;">≈ US$ {{ (invoice_summary.commission_hnl_paid_sum / rates.usd)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                        <div class="invoice-sum-sub" style="color:#f59e0b;font-weight:700;">L {{ invoice_summary.commission_hnl_paid_sum|number_format(2, '.', ',') }}</div>
                        {% else %}
                        <div class="invoice-sum-value" style="color:#fb923c;">L {{ invoice_summary.commission_hnl_paid_sum|number_format(2, '.', ',') }}</div>
                        {% endif %}
                        <div class="invoice-sum-sub">{{ 'work.invoice_sum_commission_sub'|trans({'%n%': invoice_summary.paid_count, '%each%': invoice_summary.recargo_hnl_per_payment|number_format(2, '.', ',')}, 'work') }}</div>
                    </div>
                </div>
                <div class="col">
                    <div class="invoice-sum-card">
                        <div class="invoice-sum-label"><i class="bi bi-hourglass-split me-1"></i>{{ 'work.invoice_sum_pending'|trans({}, 'work') }}</div>
                        <div class="invoice-sum-value invoice-sum-val-pending">€{{ invoice_summary.pending_payment_eur|number_format(2, '.', ',') }}</div>
                        <div class="invoice-sum-sub">{{ 'work.invoice_sum_pending_count'|trans({'%n%': invoice_summary.pending_payment_count}, 'work') }}</div>
                        {% if rates is defined and rates.eur is defined and rates.eur > 0 %}
                        {% if rates.usd is defined and rates.usd > 0 %}
                        <div class="invoice-sum-sub" style="color:#94a3b8;">US$ {{ (invoice_summary.pending_payment_eur * rates.eur / rates.usd)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                        <div class="invoice-sum-sub" style="color:#f59e0b;">L {{ (invoice_summary.pending_payment_eur * rates.eur)|number_format(2, '.', ',') }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% if invoice_summary.count > 0 %}
            <div class="text-muted small mt-2 mb-0" style="font-size:10px;line-height:1.35;">{{ 'work.invoice_sum_emitido_foot'|trans({'%eur%': invoice_summary.total_eur|number_format(2, '.', ','), '%n%': invoice_summary.count, '%draft%': invoice_summary.draft_count, '%sent%': invoice_summary.sent_count}, 'work') }}</div>
            {% endif %}
            {% if rates is defined and rates.eur is defined and rates.eur > 0 and invoice_summary.received_l_gross is not null %}
            <div class="border-top mt-2 pt-2 mt-md-3 pt-md-3" style="font-size:11px;line-height:1.5;color:#94a3b8;">
                <div class="fw-semibold mb-1" style="color:#cbd5e1;">{{ 'work.invoice_commission_block_title'|trans({}, 'work') }}</div>
                <div class="mb-1">{{ 'work.invoice_commission_per_payment'|trans({'%l%': invoice_summary.recargo_hnl_per_payment|number_format(2, '.', ',')}, 'work') }}</div>
                {% if invoice_summary.pending_payment_count > 0 %}
                <div class="mb-1">
                    <span class="text-nowrap">{{ 'work.invoice_pending_l_gross'|trans({'%l%': invoice_summary.pending_l_gross|number_format(2, '.', ',')}, 'work') }}</span>
                    <span class="text-nowrap"> · {{ 'work.invoice_pending_commission_est'|trans({'%sum%': invoice_summary.commission_hnl_pending_est|number_format(2, '.', ','), '%n%': invoice_summary.pending_payment_count}, 'work') }}</span>
                    <span class="text-nowrap"> · <strong style="color:#e2e8f0;">{{ 'work.invoice_pending_l_net'|trans({'%l%': invoice_summary.pending_l_net_est|number_format(2, '.', ',')}, 'work') }}</strong></span>
                </div>
                {% endif %}
                {% if invoice_summary.count > 0 %}
                <div class="mb-0 small" style="font-size:10px;opacity:0.95;">
                    {{ 'work.invoice_emitido_l_gross'|trans({'%l%': invoice_summary.total_l_gross|number_format(2, '.', ',')}, 'work') }}
                    {% if invoice_summary.count > 0 and invoice_summary.recargo_hnl_per_payment > 0 %}
                    · {{ 'work.invoice_emitido_commission_if_all_paid'|trans({'%sum%': invoice_summary.commission_hnl_if_all_invoices_paid|number_format(2, '.', ','), '%n%': invoice_summary.count}, 'work') }}
                    · {{ 'work.invoice_emitido_l_net_if_all_paid'|trans({'%l%': invoice_summary.total_l_net_if_all_paid|number_format(2, '.', ',')}, 'work') }}
                    {% endif %}
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="content-card mt-3 work-invoices-card">
    <div class="content-card-header d-flex flex-wrap align-items-center gap-2">
        <span class="me-auto"><i class="bi bi-receipt me-2"></i>{{ 'work.invoices_title'|trans({}, 'work') }}</span>
        <form method="get" action="{{ path('grova_work_index', {_locale: app.request.locale}) }}" class="d-flex align-items-center gap-2 flex-wrap">
            <input type="hidden" name="year" value="{{ year }}">
            <input type="hidden" name="month" value="{{ month }}">
            <input type="hidden" name="holiday_year" value="{{ holiday_year }}">
            {% if show_all %}<input type="hidden" name="show_all" value="1">{% endif %}
            <label for="invoice-year-filter" class="mb-0 small text-secondary" style="white-space:nowrap;">{{ 'work.invoice_filter_year'|trans({}, 'work') }}</label>
            <select id="invoice-year-filter" name="invoice_year" class="form-select form-select-sm" style="width:auto;min-width:5.5rem;" onchange="this.form.submit()">
                {% for y in invoice_years %}
                <option value="{{ y }}" {{ y == invoice_year ? 'selected' : '' }}>{{ y }}</option>
                {% endfor %}
            </select>
        </form>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modal-generar-factura">
            <i class="bi bi-plus-lg me-1"></i>{{ 'work.btn_generate_invoice'|trans({}, 'work') }}
        </button>
    </div>
    <div class="content-card-body p-0">
        {% if invoices|length > 0 %}
        <div class="work-invoice-dt-scroll-wrap px-3 pt-3" data-grova-dual-scroll>
            <table class="table table-hover work-invoice-table mb-0" id="work-inv-table" style="color:inherit;">
                <thead>
                    <tr>
                        <th class="col-inv-ops text-nowrap" title="{{ 'work.col_operations_hint'|trans({}, 'work') }}">{{ 'work.col_operations'|trans({}, 'work') }}</th>
                        <th class="col-inv-hash text-nowrap text-end" title="{{ 'work.col_invoice_number'|trans({}, 'work') }}">{{ 'work.col_invoice_number'|trans({}, 'work') }}</th>
                        <th class="col-inv-period text-nowrap" title="{{ 'work.invoice_period_col_hint'|trans({}, 'work') }}">{{ 'work.col_period'|trans({}, 'work') }}</th>
                        <th class="col-inv-compact text-nowrap">{{ 'work.col_days'|trans({}, 'work') }}</th>
                        <th class="col-inv-compact text-nowrap">{{ 'work.col_bonus'|trans({}, 'work') }}</th>
                        <th class="col-inv-eur text-end text-nowrap" title="{{ 'work.invoice_paid_fx_label'|trans({}, 'work') }}">{{ 'work.col_total_eur'|trans({}, 'work') }}</th>
                        <th class="col-inv-l text-end text-nowrap" title="{{ 'work.invoice_paid_fx_label'|trans({}, 'work') }}">{{ 'work.col_equiv_l'|trans({}, 'work') }}</th>
                        <th class="col-inv-usd text-end text-nowrap" title="{{ 'work.invoice_paid_fx_label'|trans({}, 'work') }}">{{ 'work.col_equiv_usd'|trans({}, 'work') }}</th>
                        <th class="col-inv-tasas text-end text-nowrap" title="{{ 'work.col_inv_tasas_hint'|trans({}, 'work') }}">{{ 'work.col_inv_tasas'|trans({}, 'work') }}</th>
                        <th class="col-inv-estado text-nowrap">{{ 'work.col_status'|trans({}, 'work') }}</th>
                        <th class="col-inv-paid text-nowrap">{{ 'work.col_paid'|trans({}, 'work') }}</th>
                        <th class="col-inv-proof text-nowrap" title="{{ 'work.col_payment_proof_hint'|trans({}, 'work') }}">{{ 'work.col_payment_proof'|trans({}, 'work') }}</th>
                        <th class="col-inv-commission text-nowrap">{{ 'work.col_commission_cobro'|trans({}, 'work') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for inv in invoices %}
                    {% set inv_fx = rates %}
                    {% if inv.tasaPagoEurL is not null and inv.tasaPagoEurLFloat > 0 %}
                        {% set inv_fx = rates|merge({'eur': inv.tasaPagoEurLFloat, 'usd': inv.tasaPagoUsdLFloat > 0 ? inv.tasaPagoUsdLFloat : (rates.usd ?? 0)}) %}
                    {% elseif inv.tasaEmisionEurL is not null and inv.tasaEmisionEurLFloat > 0 %}
                        {% set inv_fx = rates|merge({'eur': inv.tasaEmisionEurLFloat, 'usd': inv.tasaEmisionUsdLFloat > 0 ? inv.tasaEmisionUsdLFloat : (rates.usd ?? 0)}) %}
                    {% endif %}
                    {% set inv_comm_l = inv.comisionBancoHnl is not null ? inv.comisionBancoHnlFloat : recargo_hnl %}
                    {% set inv_can_toggle_paid = inv.anio == vigente_year %}
                    {% set inv_t_eur = null %}
                    {% set inv_t_usd = null %}
                    {% if inv.tasaPagoEurL is not null and inv.tasaPagoEurLFloat > 0 %}
                        {% set inv_t_eur = inv.tasaPagoEurLFloat %}
                        {% set inv_t_usd = inv.tasaPagoUsdLFloat > 0 ? inv.tasaPagoUsdLFloat : null %}
                    {% elseif inv.tasaEmisionEurL is not null and inv.tasaEmisionEurLFloat > 0 %}
                        {% set inv_t_eur = inv.tasaEmisionEurLFloat %}
                        {% set inv_t_usd = inv.tasaEmisionUsdLFloat > 0 ? inv.tasaEmisionUsdLFloat : null %}
                    {% endif %}
                    {% set inv_can_edit_bono = inv.anio == vigente_year and not inv.pagadaAt %}
                    <tr>
                        <td class="col-inv-ops">
                            <div class="inv-ops-row">
                                {% if inv_can_edit_bono %}
                                <button type="button"
                                        class="btn btn-outline-warning btn-sm"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modal-work-inv-manual-bono"
                                        data-inv-url="{{ path('grova_work_invoice_manual_bonus', {id: inv.id, _locale: app.request.locale}) }}"
                                        data-csrf="{{ csrf_token('work_invoice_manual_bonus_' ~ inv.id) }}"
                                        data-bonus-lines="{{ inv.extraBonusLinesPayload|json_encode(15)|e('html_attr') }}"
                                        title="{{ 'work.invoice_manual_bonus_btn_title'|trans({}, 'work') }}">
                                    <i class="bi bi-gift"></i>
                                </button>
                                {% endif %}
                                <a href="{{ path('grova_work_invoice_pdf', {id: inv.id, _locale: app.request.locale}) }}"
                                   class="btn btn-outline-secondary btn-sm"
                                   title="{{ 'work.invoice_pdf_internal'|trans({}, 'work') }}" target="_blank"><i class="bi bi-filetype-pdf"></i></a>
                                <a href="{{ path('grova_work_invoice_pdf_external', {id: inv.id, _locale: app.request.locale}) }}"
                                   class="btn btn-outline-primary btn-sm"
                                   title="{{ 'work.invoice_pdf_client'|trans({}, 'work') }}" target="_blank"><i class="bi bi-receipt"></i></a>
                                {% if inv.estado == 'borrador' %}
                                <form method="post" action="{{ path('grova_work_invoice_send', {id: inv.id, _locale: app.request.locale}) }}"
                                      class="d-inline js-work-swal-confirm"
                                      data-work-swal-title="{{ 'work.confirm_send_invoice'|trans({}, 'work') }}"
                                      data-work-swal-icon="question"
                                      data-work-swal-confirm-text="{{ 'work.confirm_yes_send'|trans({}, 'work') }}"
                                      data-work-swal-cancel-text="{{ 'work.confirm_cancel'|trans({}, 'work') }}"
                                      data-work-swal-confirm-color="#2563eb"
                                      data-work-loading-title="{{ 'work.swal_loading_send'|trans({}, 'work') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('work_invoice_send_' ~ inv.id) }}">
                                    <button type="submit"
                                            class="btn btn-outline-primary btn-sm"
                                            title="{{ inv.pagadaAt ? ('work.locked_paid_invoice'|trans({}, 'work')) : ('work.tooltip_op_send_invoice'|trans({}, 'work')) }}"
                                            {{ inv.pagadaAt ? 'disabled' : '' }}>
                                        <i class="bi bi-send"></i>
                                    </button>
                                </form>
                                {% endif %}
                                {% set inv_past_year = inv.anio < vigente_year %}
                                {% if inv_past_year or inv.pagadaAt %}
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            title="{{ inv_past_year ? 'work.locked_delete_past_year'|trans({}, 'work') : ('work.locked_paid_invoice'|trans({}, 'work')) }}"
                                            disabled>
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                {% else %}
                                    <form method="post" action="{{ path('grova_work_invoice_delete', {id: inv.id, _locale: app.request.locale}) }}"
                                          class="d-inline js-work-swal-confirm"
                                          data-work-swal-title="{{ 'work.confirm_delete_invoice'|trans({}, 'work') }}"
                                          data-work-swal-icon="warning"
                                          data-work-swal-confirm-text="{{ 'work.confirm_yes_delete'|trans({}, 'work') }}"
                                          data-work-swal-cancel-text="{{ 'work.confirm_cancel'|trans({}, 'work') }}"
                                          data-work-loading-title="{{ 'work.swal_loading_delete'|trans({}, 'work') }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('work_invoice_delete_' ~ inv.id) }}">
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                title="{{ 'work.tooltip_op_delete_invoice'|trans({}, 'work') }}">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                        <td class="col-inv-hash" data-order="{{ inv.numero ?? inv.id }}">
                            <span class="inv-num">N.º {{ inv.numero ?? inv.id }}</span>
                        </td>
                        <td class="col-inv-period" data-order="{{ inv.anio * 100 + inv.mes }}">
                            <span class="inv-period-short">{{ work_month_year(inv.anio, inv.mes) }}</span>
                        </td>
                        <td class="col-inv-compact">{{ inv.diasTrabajados }}d</td>
                        <td class="col-inv-compact">
                            {% if inv.diasBonus > 0 %}
                                <span style="color:#22c55e;">+{{ inv.diasBonus }}d</span>
                            {% else %}
                                <span style="color:#475569;">—</span>
                            {% endif %}
                            {% if inv.extraBonusSumFloat > 0 %}
                                <div class="small text-warning text-nowrap mt-1" style="font-size:10px;line-height:1.2;"
                                     title="{{ 'work.invoice_bonus_lines_tooltip'|trans({'%n%': inv.bonusLines|length}, 'work') }}">
                                    +€{{ inv.extraBonusSumFloat|number_format(2, '.', ',') }}{% if inv.bonusLines|length > 1 %} <span class="text-muted">({{ inv.bonusLines|length }})</span>{% endif %}
                                </div>
                            {% endif %}
                        </td>
                        <td class="col-inv-eur"><span class="inv-eur-cell">€{{ inv.totalFloat|number_format(2, '.', ',') }}</span></td>
                        <td class="col-inv-l">
                            {% if inv.lempirasRecibidos is not null and inv.lempirasRecibidosFloat > 0 %}
                            <span class="inv-fx-cell" style="color:#22c55e;" title="Lempiras reales recibidos">{{ inv.lempirasRecibidosFloat|number_format(2, '.', ',') }}</span>
                            {% elseif inv_fx is defined and inv_fx.eur is defined and inv_fx.eur > 0 %}
                            <span class="inv-fx-cell">{{ (inv.totalFloat * inv_fx.eur)|number_format(2, '.', ',') }}</span>
                            {% else %}
                            <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="col-inv-usd">
                            {% if inv_fx is defined and inv_fx.eur is defined and inv_fx.eur > 0 and inv_fx.usd is defined and inv_fx.usd > 0 %}
                            <span class="inv-fx-cell">{{ (inv.totalFloat * inv_fx.eur / inv_fx.usd)|number_format(2, '.', ',') }}</span>
                            {% else %}
                            <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="col-inv-tasas">
                            {% if inv_t_eur is not null and inv_t_eur > 0 %}
                                <span class="inv-tasa-inline">
                                    <span>€{{ inv_t_eur|number_format(2, '.', ',') }}</span>
                                    {% if inv_t_usd is not null and inv_t_usd > 0 %}
                                    <span class="inv-tasa-sep" aria-hidden="true">·</span>
                                    <span>${{ inv_t_usd|number_format(2, '.', ',') }}</span>
                                    {% endif %}
                                </span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="col-inv-estado">
                            {% if inv.estado == 'enviada' %}
                                <span class="inv-estado-inline">
                                    <span class="inv-status-sent">
                                        <i class="bi bi-check-circle me-1"></i>{{ 'work.status_sent'|trans({}, 'work') }}
                                    </span>
                                    {% if inv.enviadaAt %}
                                        <span class="inv-paid-at text-nowrap" title="{{ 'work.invoice_sent_at_tooltip'|trans({'%fecha%': inv.enviadaAt|date('d/m/Y')}, 'work') }}">{{ inv.enviadaAt|date('d/m/y') }}</span>
                                    {% endif %}
                                </span>
                            {% else %}
                                <span class="badge-borrador">{{ 'work.status_draft'|trans({}, 'work') }}</span>
                            {% endif %}
                        </td>
                        <td class="col-inv-paid">
                            {% if inv_can_toggle_paid %}
                                {% if inv.pagadaAt %}
                                    <form method="post"
                                          action="{{ path('grova_work_invoice_paid', {id: inv.id, _locale: app.request.locale}) }}"
                                          class="js-work-invoice-unpaid-confirm mb-0"
                                          data-confirm-title="{{ 'work.paid_mark_as_unpaid'|trans({}, 'work') }}"
                                          data-confirm-text="{{ 'work.confirm_mark_unpaid'|trans({}, 'work') }}">
                                        <input type="hidden" name="invoice_year" value="{{ invoice_year }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('work_invoice_paid_' ~ inv.id) }}">
                                        {% if inv_fx is defined and inv_fx.eur is defined and inv_fx.eur > 0 %}
                                            {% set inv_fx_tip = 'L ' ~ (inv.totalFloat * inv_fx.eur)|number_format(2, '.', ',') %}
                                            {% if inv_fx.usd is defined and inv_fx.usd > 0 %}
                                                {% set inv_fx_tip = inv_fx_tip ~ ' · US$ ' ~ (inv.totalFloat * inv_fx.eur / inv_fx.usd)|number_format(2, '.', ',') %}
                                            {% endif %}
                                            {% set inv_btn_title = ('work.invoice_paid_fx_label'|trans({}, 'work')) ~ ': ' ~ inv_fx_tip ~ ' — ' ~ ('work.paid_mark_as_unpaid'|trans({}, 'work')) %}
                                        {% else %}
                                            {% set inv_btn_title = 'work.paid_mark_as_unpaid'|trans({}, 'work') %}
                                        {% endif %}
                                        <div class="inv-paid-row">
                                            <button type="submit"
                                                    class="btn btn-outline-success btn-sm inv-paid-mark-pill"
                                                    title="{{ inv_btn_title|e('html_attr') }}">
                                                <i class="bi bi-bank2 me-1"></i>{{ 'work.paid'|trans({}, 'work') }}
                                            </button>
                                            <span class="inv-paid-at text-nowrap" title="{{ 'work.invoice_paid_at_tooltip'|trans({'%fecha%': inv.pagadaAt|date('d/m/Y')}, 'work') }}">{{ inv.pagadaAt|date('d/m/y') }}</span>
                                        </div>
                                    </form>
                                {% else %}
                                    <span class="text-muted small" title="{{ 'work.invoice_paid_column_pending_hint'|trans({}, 'work') }}">—</span>
                                {% endif %}
                            {% else %}
                            {% set inv_lock_year_hint = 'work.locked_paid_toggle_not_vigente_year'|trans({}, 'work') %}
                            {% if inv.pagadaAt %}
                                {% if inv_fx is defined and inv_fx.eur is defined and inv_fx.eur > 0 %}
                                    {% set inv_fx_tip2 = 'L ' ~ (inv.totalFloat * inv_fx.eur)|number_format(2, '.', ',') %}
                                    {% if inv_fx.usd is defined and inv_fx.usd > 0 %}
                                        {% set inv_fx_tip2 = inv_fx_tip2 ~ ' · US$ ' ~ (inv.totalFloat * inv_fx.eur / inv_fx.usd)|number_format(2, '.', ',') %}
                                    {% endif %}
                                    {% set inv_lock_title = ('work.invoice_paid_fx_label'|trans({}, 'work')) ~ ': ' ~ inv_fx_tip2 %}
                                {% else %}
                                    {% set inv_lock_title = '' %}
                                {% endif %}
                                {% set inv_paid_row_title = inv_lock_year_hint ~ (inv_lock_title ? ' — ' ~ inv_lock_title : '') %}
                                <div class="inv-paid-row" title="{{ inv_paid_row_title|e('html_attr') }}">
                                    <span class="btn btn-outline-success btn-sm disabled inv-paid-mark-pill" style="pointer-events:none;opacity:.85;">
                                        <i class="bi bi-bank2 me-1"></i>{{ 'work.paid'|trans({}, 'work') }}
                                    </span>
                                    <span class="inv-paid-at text-nowrap" title="{{ 'work.invoice_paid_at_tooltip'|trans({'%fecha%': inv.pagadaAt|date('d/m/Y')}, 'work') }}">{{ inv.pagadaAt|date('d/m/y') }}</span>
                                </div>
                            {% else %}
                                <div class="inv-paid-row" title="{{ inv_lock_year_hint|e('html_attr') }}">
                                    <span class="btn btn-outline-secondary btn-sm disabled" style="pointer-events:none;opacity:.85;">
                                        <i class="bi bi-hourglass-split me-1"></i>{{ 'work.unpaid'|trans({}, 'work') }}
                                    </span>
                                </div>
                            {% endif %}
                            {% endif %}
                        </td>
                        <td class="col-inv-proof">
                            <div id="work-inv-proof-cell-{{ inv.id }}" class="work-inv-proof-cell">
                                {% include 'workspace/pages/work/_invoice_proof_cell.html.twig' with {
                                    invoice: inv,
                                    invoice_year: invoice_year,
                                    locale: app.request.locale,
                                    vigente_year: vigente_year
                                } only %}
                            </div>
                        </td>
                        <td class="col-inv-commission">
                            {% if inv_can_toggle_paid %}
                                {% if inv.pagadaAt %}
                                    <div class="small text-muted mt-0 inv-commission-paid-line" title="{{ 'work.invoice_row_commission_title'|trans({}, 'work') }}">
                                        −L {{ inv_comm_l|number_format(2, '.', ',') }}{% if inv.comisionBancoHnl is null %} <span class="text-muted">({{ 'work.commission_estimated_suffix'|trans({}, 'work') }})</span>{% endif %}
                                    </div>
                                {% else %}
                                    <form method="post"
                                          action="{{ path('grova_work_invoice_paid', {id: inv.id, _locale: app.request.locale}) }}"
                                          class="mb-0 js-work-submit-loading"
                                          data-work-loading-title="{{ 'work.swal_loading_save'|trans({}, 'work') }}"
                                          title="{{ 'work.invoice_unpaid_form_flow_hint'|trans({}, 'work')|e('html_attr') }}">
                                        <input type="hidden" name="invoice_year" value="{{ invoice_year }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('work_invoice_paid_' ~ inv.id) }}">
                                        <div class="inv-pay-row-pendiente">
                                            <label for="fecha-pay-{{ inv.id }}" class="visually-hidden">{{ 'work.invoice_paid_date_label'|trans({}, 'work') }}</label>
                                            <input id="fecha-pay-{{ inv.id }}" type="date" name="fecha_cobro" value="{{ 'now'|date('Y-m-d') }}" max="{{ 'now'|date('Y-m-d') }}" class="form-control form-control-sm inv-fecha-input" required title="{{ 'work.invoice_paid_date_hint'|trans({}, 'work') }}">
                                            <label for="lempiras-pay-{{ inv.id }}" class="visually-hidden">{{ 'work.invoice_paid_lempiras_label'|trans({}, 'work') }}</label>
                                            <input id="lempiras-pay-{{ inv.id }}" type="number" step="0.01" min="0" name="lempiras_recibidos" value="" class="form-control form-control-sm inv-lempiras-input" placeholder="{{ 'work.invoice_paid_lempiras_ph'|trans({}, 'work') }}" title="{{ 'work.invoice_paid_lempiras_hint'|trans({}, 'work') }}">
                                            <label for="comision-pay-{{ inv.id }}" class="visually-hidden">{{ 'work.invoice_paid_bank_commission_label'|trans({}, 'work') }}</label>
                                            <input id="comision-pay-{{ inv.id }}" type="number" step="0.01" min="0" name="comision_banco_hnl" value="{{ recargo_hnl|number_format(2, '.', '') }}" class="form-control form-control-sm inv-comision-input" title="{{ 'work.invoice_paid_bank_commission_hint'|trans({}, 'work') }}">
                                            <label for="recibo-pay-{{ inv.id }}" class="visually-hidden">{{ 'work.field_recibo_swift'|trans({}, 'work') }}</label>
                                            <input id="recibo-pay-{{ inv.id }}" type="number" min="1" step="1" name="recibo_swift" value="" class="form-control form-control-sm inv-recibo-input" placeholder="{{ 'work.field_recibo_swift_ph'|trans({}, 'work') }}" title="{{ 'work.field_recibo_swift_hint'|trans({}, 'work') }}">
                                            <button type="submit"
                                                    class="btn btn-outline-secondary btn-sm"
                                                    title="{{ 'work.paid_mark_as_paid'|trans({}, 'work') }}">
                                                <i class="bi bi-hourglass-split me-1"></i>{{ 'work.unpaid'|trans({}, 'work') }}
                                            </button>
                                        </div>
                                    </form>
                                {% endif %}
                            {% else %}
                                {% if inv.pagadaAt %}
                                    <div class="small text-muted mt-0 inv-commission-paid-line">
                                        {% if inv.lempirasRecibidos is not null and inv.lempirasRecibidosFloat > 0 %}
                                            <span title="Lempiras recibidos del banco">L {{ inv.lempirasRecibidosFloat|number_format(2, '.', ',') }}</span>
                                            <span class="text-muted mx-1">·</span>
                                        {% endif %}
                                        −L {{ inv_comm_l|number_format(2, '.', ',') }}{% if inv.comisionBancoHnl is null %} <span class="text-muted">({{ 'work.commission_estimated_suffix'|trans({}, 'work') }})</span>{% endif %}
                                    </div>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="grova-empty-state">
            <div class="grova-empty-icon"><i class="bi bi-receipt"></i></div>
            <div class="grova-empty-title">{{ 'work.empty_invoices_year'|trans({'%year%': invoice_year}, 'work') }}</div>
            <div class="grova-empty-desc">{{ 'work.empty_invoices_desc'|trans({}, 'work') }}</div>
        </div>
        {% endif %}
    </div>
</div>

