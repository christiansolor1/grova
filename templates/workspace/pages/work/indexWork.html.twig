}
.work-cal-nav-btn:hover { color: #e2e8f0 !important; }
body.light-mode .work-cal-nav-btn { color: #64748b !important; }
body.light-mode .work-cal-nav-btn:hover { color: #0f172a !important; }
.work-cal-title {
    font-weight: 800;
    font-size: 13px;
    min-width: 7.5rem;
    text-align: center;
    color: #f8fafc;
    letter-spacing: -0.02em;
}
body.light-mode .work-cal-title { color: #0f172a; }
.work-cal-today-badge { font-size: 9px; color: #818cf8; font-weight: 700; margin-left: 4px; vertical-align: middle; }
.work-cal-card-header .work-cal-legend-min {
