{% block app_page_scripts %}
<script>
(function () {
    var WORK_PAGE_FLASHES = {{ work_swal_flashes|default([])|json_encode|raw }};
    var WORK_HOLIDAYS_COPY = {
        ok: {{ 'work.holidays_copy_ok'|trans({}, 'work')|json_encode|raw }},
        fail: {{ 'work.holidays_copy_fail'|trans({}, 'work')|json_encode|raw }},
        empty: {{ 'work.holidays_copy_empty'|trans({}, 'work')|json_encode|raw }}
    };

    function workHasSwal() {
        return typeof window.Swal !== 'undefined' && window.Swal && typeof window.Swal.fire === 'function';
    }

    function workSwalBlockingLoad(title) {
        if (!workHasSwal()) return;
        window.Swal.fire({
            title: title || '',
            allowOutsideClick: false,
            allowEscapeKey: false,
            showConfirmButton: false,
            didOpen: function () { window.Swal.showLoading(); }
        });
    }

    function showWorkPageFlashToasts() {
        if (!workHasSwal() || !WORK_PAGE_FLASHES || !WORK_PAGE_FLASHES.length) return;
        var delay = 0;
        WORK_PAGE_FLASHES.forEach(function (row) {
            var icon = row.type === 'success' ? 'success' : (row.type === 'danger' ? 'error' : (row.type === 'warning' ? 'warning' : 'info'));
            (function (d, r) {
                setTimeout(function () {
                    window.Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: icon,
                        title: r.message,
                        showConfirmButton: false,
                        timer: r.type === 'danger' ? 9000 : 6000,
                        timerProgressBar: true
                    });
                }, d);
            })(delay, row);
            delay += 420;
        });
    }

    function bindWorkSwalConfirmForms() {
        document.querySelectorAll('form.js-work-swal-confirm').forEach(function (form) {
            if (form.dataset.workSwalBound === '1') return;
            form.dataset.workSwalBound = '1';
            form.addEventListener('submit', async function (e) {
                if (!workHasSwal()) return;
                e.preventDefault();
                var title = form.getAttribute('data-work-swal-title') || '';
                var text = form.getAttribute('data-work-swal-text') || '';
                var icon = form.getAttribute('data-work-swal-icon') || 'warning';
                var confirmTxt = form.getAttribute('data-work-swal-confirm-text') || 'OK';
                var cancelTxt = form.getAttribute('data-work-swal-cancel-text') || {{ 'work.confirm_cancel'|trans({}, 'work')|json_encode|raw }};
                var loadTitle = form.getAttribute('data-work-loading-title') || {{ 'work.swal_loading_default'|trans({}, 'work')|json_encode|raw }};
                var confirmColor = form.getAttribute('data-work-swal-confirm-color') || '#dc3545';
                var res = await window.Swal.fire({
                    title: title,
                    text: text || undefined,
                    icon: icon,
                    showCancelButton: true,
                    confirmButtonText: confirmTxt,
                    cancelButtonText: cancelTxt,
                    confirmButtonColor: confirmColor,
                    focusCancel: true
                });
                if (!res.isConfirmed) return;
                workSwalBlockingLoad(loadTitle);
                form.submit();
            });
        });
    }

    function bindWorkSubmitLoading() {
        document.querySelectorAll('form.js-work-submit-loading').forEach(function (form) {
            if (form.dataset.workLoadingBound === '1') return;
            if (form.classList.contains('js-work-swal-confirm')) return;
            if (form.classList.contains('js-work-invoice-unpaid-confirm')) return;
            if (form.classList.contains('js-work-proof-delete')) return;
            if (form.classList.contains('js-work-proof-upload-form')) return;
            form.dataset.workLoadingBound = '1';
            form.addEventListener('submit', function () {
                if (!workHasSwal()) return;
                var t = form.getAttribute('data-work-loading-title') || {{ 'work.swal_loading_default'|trans({}, 'work')|json_encode|raw }};
                workSwalBlockingLoad(t);
            });
        });
    }

    function bindWorkInvoiceUnpaidConfirm() {
        document.querySelectorAll('form.js-work-invoice-unpaid-confirm').forEach(function (form) {
            if (form.dataset.bound === '1') return;
            form.dataset.bound = '1';

            form.addEventListener('submit', async function (e) {
                if (!workHasSwal()) {
                    return;
                }

                e.preventDefault();

                var title = form.getAttribute('data-confirm-title') || {{ 'work.confirm_dialog_default_title'|trans({}, 'work')|json_encode|raw }};
                var text = form.getAttribute('data-confirm-text') || '';

                var res = await window.Swal.fire({
                    title: title,
                    text: text,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: {{ 'work.confirm_yes_revert'|trans({}, 'work')|json_encode|raw }},
                    cancelButtonText: {{ 'work.confirm_cancel'|trans({}, 'work')|json_encode|raw }},
                    confirmButtonColor: '#dc3545',
                });

                if (res.isConfirmed) {
                    workSwalBlockingLoad({{ 'work.swal_loading_save'|trans({}, 'work')|json_encode|raw }});
                    form.submit();
                }
            });
        });
    }

    function workProofToast(icon, title) {
        if (!workHasSwal()) return;
        window.Swal.fire({
            toast: true,
            position: 'top-end',
            icon: icon,
            title: title,
            showConfirmButton: false,
            timer: icon === 'error' ? 9000 : 6000,
            timerProgressBar: true
        });
    }

    function workProofApplyCellHtml(invoiceId, html) {
        var wrap = document.getElementById('work-inv-proof-cell-' + invoiceId);
        if (wrap && typeof html === 'string') {
            wrap.innerHTML = html;
        }
    }

    async function workProofParseJsonResponse(res) {
        var txt = await res.text();
        try {
            return JSON.parse(txt);
        } catch (e) {
            return { success: false, message: txt || ('HTTP ' + res.status) };
        }
    }

    function bindWorkProofDeleteConfirm() {
        document.querySelectorAll('form.js-work-proof-delete').forEach(function (form) {
            if (form.dataset.bound === '1') return;
            form.dataset.bound = '1';

            form.addEventListener('submit', async function (e) {
                if (!workHasSwal()) {
                    return;
                }

                e.preventDefault();

                var title = form.getAttribute('data-confirm-title') || '';
                var text = form.getAttribute('data-confirm-text') || '';

                var res = await window.Swal.fire({
                    title: title,
                    text: text,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: {{ 'work.payment_proof_delete_confirm_yes'|trans({}, 'work')|json_encode|raw }},
                    cancelButtonText: {{ 'work.confirm_cancel'|trans({}, 'work')|json_encode|raw }},
                    confirmButtonColor: '#dc3545',
                });

                if (!res.isConfirmed) return;

                workSwalBlockingLoad({{ 'work.swal_loading_delete'|trans({}, 'work')|json_encode|raw }});

                var fd = new FormData(form);
                var action = form.getAttribute('action') || '';
                var invId = parseInt(form.getAttribute('data-invoice-id') || '0', 10) || 0;

                try {
                    var xhr = await fetch(action, {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin',
                        headers: {
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    var json = await workProofParseJsonResponse(xhr);
                    if (typeof window.Swal.close === 'function') window.Swal.close();

                    if (xhr.ok && json && json.success) {
                        workProofToast('success', json.message || '');
                        if (json.cellHtml && invId) {
                            workProofApplyCellHtml(invId, json.cellHtml);
                            bindWorkProofDeleteConfirm();
                        }
                    } else {
                        workProofToast('error', (json && json.message) ? json.message : ('HTTP ' + xhr.status));
                    }
                } catch (err) {
                    if (typeof window.Swal.close === 'function') window.Swal.close();
                    workProofToast('error', {{ 'work.flash_network_error'|trans({}, 'work')|json_encode|raw }});
                }
            });
        });
    }

    function bindWorkProofUploadAjax() {
        var form = document.getElementById('form-work-payment-proof-upload');
        if (!form || form.dataset.workProofAjaxBound === '1') return;
        form.dataset.workProofAjaxBound = '1';

        form.addEventListener('submit', async function (e) {
            if (!workHasSwal()) {
                return;
            }

            e.preventDefault();

            var action = form.getAttribute('action') || '';
            if (!action || action === '#') {
                workProofToast('warning', {{ 'work.flash_payment_proof_missing_file'|trans({}, 'work')|json_encode|raw }});
                return;
            }

            var invId = parseInt(form.dataset.proofInvoiceId || '0', 10) || 0;
            var fileInput = document.getElementById('work-proof-upload-file');
            if (!fileInput || !fileInput.files || !fileInput.files.length) {
                workProofToast('warning', {{ 'work.flash_payment_proof_missing_file'|trans({}, 'work')|json_encode|raw }});
                return;
            }

            workSwalBlockingLoad({{ 'work.swal_loading_upload'|trans({}, 'work')|json_encode|raw }});

            var fd = new FormData(form);
            try {
                var xhr = await fetch(action, {
                    method: 'POST',
                    body: fd,
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                var json = await workProofParseJsonResponse(xhr);
                if (typeof window.Swal.close === 'function') window.Swal.close();

                if (xhr.ok && json && json.success) {
                    workProofToast('success', json.message || '');
                    var modalEl = document.getElementById('modal-work-payment-proof');
                    if (modalEl && window.bootstrap && window.bootstrap.Modal) {
                        var inst = window.bootstrap.Modal.getInstance(modalEl);
                        if (inst) inst.hide();
                    }
                    if (json.cellHtml && (json.invoiceId || invId)) {
                        workProofApplyCellHtml(json.invoiceId || invId, json.cellHtml);
                        bindWorkProofDeleteConfirm();
                    }
                    if (fileInput) fileInput.value = '';
                } else {
                    workProofToast('error', (json && json.message) ? json.message : ('HTTP ' + xhr.status));
                }
            } catch (err) {
                if (typeof window.Swal.close === 'function') window.Swal.close();
                workProofToast('error', {{ 'work.flash_network_error'|trans({}, 'work')|json_encode|raw }});
            }
        });
    }

    function bindWorkProofUploadModal() {
        var modal = document.getElementById('modal-work-payment-proof');
        var form = document.getElementById('form-work-payment-proof-upload');
        var fileInput = document.getElementById('work-proof-upload-file');
        var tokenEl = document.getElementById('work-proof-upload-csrf');
        var periodEl = document.getElementById('modal-work-payment-proof-period');
        if (!modal || !form || !fileInput || !tokenEl) return;

        modal.addEventListener('show.bs.modal', function (ev) {
            var btn = ev.relatedTarget;
            if (!btn || !btn.classList || !btn.classList.contains('js-work-proof-upload-open')) return;
            var action = btn.getAttribute('data-proof-action') || '#';
            var token = btn.getAttribute('data-proof-token') || '';
            var month = btn.getAttribute('data-proof-period-text') || '';
            var invId = btn.getAttribute('data-invoice-id') || '';
            form.setAttribute('action', action);
            form.dataset.proofInvoiceId = invId;
            tokenEl.value = token;
            if (periodEl) {
                periodEl.textContent = month;
            }
            fileInput.value = '';
        });
    }

    function relayoutWorkInvoiceDualScroll() {
        var table = document.getElementById('work-inv-table');
        if (window.GrovaDataTableDualScroll && table) {
            window.GrovaDataTableDualScroll.relayout(table);
        }
    }

    function initWorkInvoiceDataTable() {
        var el = document.getElementById('work-inv-table');
        if (!el || typeof DataTable === 'undefined') {
            return null;
        }
        if (el.tBodies.length === 0 || el.tBodies[0].rows.length < 1) {
            return null;
        }
        if (el.dataset.workInvDtInit === '1') {
            return null;
        }
        el.dataset.workInvDtInit = '1';

        var locale = {{ app.request.locale|json_encode|raw }};
        var dtLang = locale === 'en'
            ? 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/en-GB.json'
            : 'https://cdn.datatables.net/plug-ins/2.1.8/i18n/es-ES.json';
        var searchPh = {{ 'work.datatable_search_placeholder'|trans({}, 'work')|json_encode|raw }};

        try {
            var initDt = (window.GrovaDataTable && window.GrovaDataTable.init) ? window.GrovaDataTable.init : function (t, o) { return new DataTable(t, o); };
            var dt = initDt(el, {
                language: { url: dtLang },
                buttons: ['excel', 'pdf', 'colvis'],
                pageLength: 12,
                order: [[2, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [0, 10, 11, 12] }
                ],
                layout: {
                    topStart: {
                        pageLength: {
                            menu: [6, 12, 24, 50, -1]
                        }
                    },
                    topEnd: {
                        search: {
                            placeholder: searchPh
                        }
                    }
                },
                initComplete: function () {
                    relayoutWorkInvoiceDualScroll();
                },
                drawCallback: function () {
                    bindWorkSwalConfirmForms();
                    bindWorkSubmitLoading();
                    bindWorkInvoiceUnpaidConfirm();
                    bindWorkProofDeleteConfirm();
                    relayoutWorkInvoiceDualScroll();
                }
            });
            return dt;
        } catch (e) {
            console.error('DataTable facturas:', e);
            return null;
        }
    }

    function bindWorkHolidaysCopy() {
        var btn = document.querySelector('.js-work-holidays-copy');
        var ta = document.getElementById('work-holidays-copy-src');
        if (!btn || !ta) return;
        if (btn.dataset.workHolidaysCopyBound === '1') return;
        btn.dataset.workHolidaysCopyBound = '1';
        btn.addEventListener('click', function () {
            var text = (ta.value || '').trim();
            if (!text) {
                if (workHasSwal()) {
                    window.Swal.fire({
                        toast: true,
                        position: 'top-end',
                        icon: 'info',
                        title: WORK_HOLIDAYS_COPY.empty,
                        showConfirmButton: false,
                        timer: 3500,
                        timerProgressBar: true
                    });
                }
                return;
            }
            function showOk() {
                if (!workHasSwal()) return;
                window.Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: WORK_HOLIDAYS_COPY.ok,
                    showConfirmButton: false,
                    timer: 3200,
                    timerProgressBar: true
                });
            }
            function showFail() {
                if (!workHasSwal()) return;
                window.Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'error',
                    title: WORK_HOLIDAYS_COPY.fail,
                    showConfirmButton: false,
                    timer: 7000,
                    timerProgressBar: true
                });
            }
            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                navigator.clipboard.writeText(text).then(showOk).catch(function () {
                    try {
                        ta.style.position = 'fixed';
                        ta.style.left = '-10000px';
                        ta.style.top = '0';
                        ta.style.opacity = '0';
                        ta.classList.remove('visually-hidden');
                        ta.removeAttribute('aria-hidden');
                        ta.focus();
                        ta.select();
                        var ok = document.execCommand('copy');
                        ta.blur();
                        ta.classList.add('visually-hidden');
                        ta.setAttribute('aria-hidden', 'true');
                        ta.style.position = '';
                        ta.style.left = '';
                        ta.style.top = '';
                        ta.style.opacity = '';
                        if (ok) showOk(); else showFail();
                    } catch (e) {
                        showFail();
                    }
                });
                return;
            }
            try {
                ta.style.position = 'fixed';
                ta.style.left = '-10000px';
                ta.classList.remove('visually-hidden');
                ta.focus();
                ta.select();
                var ok2 = document.execCommand('copy');
                ta.blur();
                ta.classList.add('visually-hidden');
                ta.style.position = '';
                ta.style.left = '';
                if (ok2) showOk(); else showFail();
            } catch (e2) {
                showFail();
            }
        });
    }

    function bindWorkInvoiceManualBonusModal() {
        var modalEl = document.getElementById('modal-work-inv-manual-bono');
        var tpl = document.getElementById('tpl-work-inv-bono-line');
        var container = document.getElementById('work-inv-bono-lines');
        var btnAdd = document.getElementById('work-inv-bono-add-row');
        if (!modalEl || !tpl || !container || modalEl.dataset.workManualBonoBound === '1') return;
        modalEl.dataset.workManualBonoBound = '1';

        function parseBonusLinesAttr(raw) {
            if (!raw) return [];
            try {
                var j = JSON.parse(raw);
                return Array.isArray(j) ? j : [];
            } catch (e) {
                return [];
            }
        }

        function appendBonoRow(data) {
            var node = tpl.content.cloneNode(true);
            var root = node.querySelector('.js-work-bono-line');
            if (!root) return;
            var eur = root.querySelector('.js-bono-eur');
            var con = root.querySelector('.js-bono-concepto');
            if (eur && data && Object.prototype.hasOwnProperty.call(data, 'eur')) {
                var ve = data.eur;
                if (ve !== '' && ve !== null && typeof ve !== 'undefined') {
                    eur.value = String(ve);
                }
            }
            if (con && data && Object.prototype.hasOwnProperty.call(data, 'concepto')) con.value = data.concepto || '';
            var rm = root.querySelector('.js-work-bono-remove-line');
            if (rm) {
                rm.addEventListener('click', function () {
                    var rows = container.querySelectorAll('.js-work-bono-line');
                    if (rows.length <= 1) {
                        if (eur) eur.value = '';
                        if (con) con.value = '';
                        return;
                    }
                    root.remove();
                });
            }
            container.appendChild(node);
        }

        modalEl.addEventListener('show.bs.modal', function (ev) {
            var btn = ev.relatedTarget;
            if (!btn || !btn.getAttribute('data-inv-url')) return;
            var form = document.getElementById('form-work-inv-manual-bono');
            if (!form) return;
            form.setAttribute('action', btn.getAttribute('data-inv-url'));
            var tok = form.querySelector('input[name="_token"]');
            if (tok) tok.value = btn.getAttribute('data-csrf') || '';
            container.innerHTML = '';
            var lines = parseBonusLinesAttr(btn.getAttribute('data-bonus-lines'));
            if (!lines.length) {
                appendBonoRow({ eur: '', concepto: '' });
            } else {
                lines.forEach(function (row) {
                    appendBonoRow({ eur: row.eur, concepto: row.concepto || '' });
                });
            }
        });

        if (btnAdd) {
            btnAdd.addEventListener('click', function () {
                if (container.querySelectorAll('.js-work-bono-line').length >= 40) return;
                appendBonoRow({ eur: '', concepto: '' });
            });
        }
    }

    function initWorkInvoicePageUi() {
        bindWorkSwalConfirmForms();
        bindWorkSubmitLoading();
        bindWorkInvoiceUnpaidConfirm();
        bindWorkProofDeleteConfirm();
        bindWorkProofUploadModal();
        bindWorkProofUploadAjax();
        bindWorkHolidaysCopy();
        bindWorkInvoiceManualBonusModal();
        initWorkInvoiceDataTable();
        showWorkPageFlashToasts();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWorkInvoicePageUi);
    } else {
        initWorkInvoicePageUi();
    }
})();
</script>
{% endblock %}
