/* Franjas apiladas: arriba feriado, centro vacación, abajo bonus */
.work-cal-stripes {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    flex: 1 1 auto;
    padding: 6px 5px 4px;
