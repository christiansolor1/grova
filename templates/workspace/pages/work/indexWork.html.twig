{% extends 'workspace/app_layout.html.twig' %}
{# Equiv. L / US$ desde importe EUR (misma fórmula que facturas). #}
{% macro work_fx_eur_sub(eur, rates, extra_class = '') %}
{% if rates is defined and rates.eur is defined and rates.eur > 0 %}
<div class="work-fx-eur-sub{{ extra_class ? ' ' ~ extra_class : '' }}">
    <span class="work-fx-eur-sub-l">L {{ (eur * rates.eur)|number_format(2, '.', ',') }}</span>
    {% if rates.usd is defined and rates.usd > 0 %}
    <span class="work-fx-eur-sub-usd"> · US$ {{ (eur * rates.eur / rates.usd)|number_format(2, '.', ',') }}</span>
    {% endif %}
</div>
{% endif %}
{% endmacro %}
{% block page_title %}{{ 'work.page_title'|trans({}, 'work') }}{% endblock %}
{% block app_page_subtitle %}
    {% if client %}{{ 'work.subtitle_client'|trans({'%client%': client.nombre}, 'work') }}{% else %}{{ 'work.subtitle_no_client'|trans({}, 'work') }}{% endif %}
{% endblock %}

{% block page_styles %}
<style>
/* Tarjeta «Facturas»: cabecera más clara */
