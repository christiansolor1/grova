body.light-mode .invoice-sum-val-received { color: #16a34a; }
body.light-mode .invoice-sum-val-pending { color: #d97706; }
/* Tabla «Días registrados»: columna de acciones a la izquierda (misma idea que facturas) */
.work-days-table .col-day-ops { width: 5.5rem; min-width: 5rem; vertical-align: middle; }
.work-days-table .col-day-ops .day-ops-row { display: flex; flex-wrap: wrap; gap: 4px; justify-content: flex-start; align-items: center; }
.work-days-table thead th.col-day-ops {
  white-space: nowrap;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #94a3b8;
  font-weight: 600;
}
body.light-mode .work-days-table thead th.col-day-ops { color: #64748b; }
/* Tabla Facturas: auto + min-width → la tabla puede ser más ancha que la tarjeta y activar scroll horizontal */
.work-invoice-table.table {
  table-layout: auto;
  width: 100%;
  min-width: 1280px;
  font-size: inherit;
  border-collapse: separate;
  border-spacing: 0;
}
.work-invoice-table.table > :not(caption) > * > * {
  padding: 0.65rem 1rem;
  vertical-align: middle;
  line-height: 1.45;
  border-bottom: 1px solid rgba(51, 65, 85, 0.45);
}
body.light-mode .work-invoice-table.table > :not(caption) > * > * {
  border-bottom-color: #e2e8f0;
}
.work-invoice-table.table thead th {
  border-bottom: 1px solid rgba(71, 85, 105, 0.75);
  background: rgba(15, 23, 42, 0.92);
  font-weight: 600;
}
body.light-mode .work-invoice-table.table thead th {
  background: #f1f5f9;
  border-bottom-color: #cbd5e1;
}
.work-invoice-table.table > tbody > tr:nth-child(even) > * {
  background-color: rgba(30, 41, 59, 0.28);
}
.work-invoice-table.table > tbody > tr:hover > * {
  background-color: rgba(51, 65, 85, 0.42) !important;
}
body.light-mode .work-invoice-table.table > tbody > tr:nth-child(even) > * {
  background-color: #f8fafc;
}
body.light-mode .work-invoice-table.table > tbody > tr:hover > * {
  background-color: #f1f5f9 !important;
}
/* Doble scroll: piel global en _grova_datatables2_skin.css.twig */
.work-invoice-dt-scroll-wrap {
  position: relative;
  min-width: 0;
}
.work-invoice-table .inv-eur-cell {
  font-weight: 600;
  color: #a5b4fc;
  font-size: 13px;
  line-height: 1.35;
  white-space: nowrap;
