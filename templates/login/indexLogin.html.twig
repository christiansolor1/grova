{% extends 'base.html.twig' %}

{% block title %}{{ 'app.name' | trans }} – {{ 'auth.login.title' | trans }}{% endblock %}

{% block stylesheets %}
<style>
    body {
        background-color: #0f172a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        padding-top: 56px;
    }
    .login-toolbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        padding: 10px 14px;
        pointer-events: none;
    }
    .login-toolbar > * {
        pointer-events: auto;
    }
    .login-toolbar-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid #334155;
        background: #1e293b;
        color: #94a3b8;
        cursor: pointer;
        transition: background .15s, border-color .15s, color .15s;
    }
    .login-toolbar-btn:hover {
        background: #0f172a;
        border-color: #475569;
        color: #e2e8f0;
    }
    .lang-combo--login .lang-combo-trigger {
        background: #1e293b;
        border-color: #334155;
        color: #94a3b8;
    }
    .lang-combo--login .lang-combo-list {
        z-index: 200;
    }
    body.light-mode .login-toolbar-btn {
        background: #fff;
        border-color: #e2e8f0;
        color: #64748b;
    }
    body.light-mode .login-toolbar-btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #1e293b;
    }
    body.light-mode .lang-combo--login .lang-combo-trigger {
        background: #fff;
        border-color: #e2e8f0;
        color: #64748b;
    }
    .lang-combo { position: relative; }
    .lang-combo-trigger {
        display: flex; align-items: center; gap: 6px;
        padding: 5px 10px; border-radius: 7px; border: 1px solid #334155;
        background: #0f172a; color: #94a3b8;
        font-size: 12px; font-weight: 500; cursor: pointer;
        transition: border-color .15s, color .15s; white-space: nowrap;
    }
    .lang-combo-trigger:hover { border-color: #475569; color: #e2e8f0; }
    .lang-combo-trigger .lc-flag { font-size: 15px; line-height: 1; }
    .lang-combo-trigger .lc-code { font-size: 11px; letter-spacing: .4px; }
    .lang-combo-trigger .lc-chevron { color: #475569; transition: transform .2s; }
    .lang-combo.open .lc-chevron { transform: rotate(180deg); }
    body.light-mode .lang-combo-trigger { background: #f8fafc; border-color: #e2e8f0; color: #64748b; }
    body.light-mode .lang-combo-trigger:hover { border-color: #94a3b8; color: #1e293b; }
    .lang-combo-list {
        position: absolute; top: calc(100% + 6px); right: 0;
        min-width: 130px; background: #1e293b; border: 1px solid #334155;
        border-radius: 8px; box-shadow: 0 8px 20px rgba(0,0,0,.4);
        z-index: 300; overflow: hidden; display: none;
    }
    .lang-combo.open .lang-combo-list { display: block; }
    body.light-mode .lang-combo-list { background: #fff; border-color: #e2e8f0; box-shadow: 0 8px 20px rgba(0,0,0,.1); }
    .lang-combo-option {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 12px; text-decoration: none;
        font-size: 12px; font-weight: 500; color: #94a3b8;
        transition: background .12s, color .12s;
    }
    .lang-combo-option:hover { background: #0f172a; color: #e2e8f0; }
    .lang-combo-option.active { color: #60a5fa; }
    .lang-combo-option .lc-check { margin-left: auto; color: #3b82f6; }
    body.light-mode .lang-combo-option { color: #64748b; }
    body.light-mode .lang-combo-option:hover { background: #f8fafc; color: #1e293b; }
    body.light-mode .lang-combo-option.active { color: #2563eb; }
    body.light-mode .lang-combo-option .lc-check { color: #2563eb; }
    .login-card {
        width: 100%;
        max-width: 560px;
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
    }
    .login-logo-box {
        width: 40px; height: 40px;
        background: #2563eb;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: #fff; font-size: 1.1rem;
    }
    .login-title { color: #f1f5f9; font-weight: 700; font-size: 1.65rem; letter-spacing: -0.5px; }
    .login-subtitle { color: #94a3b8; font-size: .95rem; }
    .form-label { color: #cbd5e1; font-size: .9rem; font-weight: 600; margin-bottom: .45rem; }
    .form-control, .input-group-text {
        background: #0f172a;
        border-color: #334155;
        color: #f1f5f9;
    }
    .form-control:focus {
        background: #0f172a;
        border-color: #2563eb;
        color: #f1f5f9;
        box-shadow: 0 0 0 3px rgba(37,99,235,.2);
    }
    .form-control::placeholder { color: #475569; }
    .input-group-text { color: #64748b; }
    .btn-grova {
        background: #2563eb;
        border: none;
        font-weight: 600;
        padding: .78rem;
        font-size: .98rem;
        transition: background .2s;
    }
    .btn-grova:hover { background: #1d4ed8; }
    .btn-grova:disabled { background: #1e40af; opacity: .7; cursor: not-allowed; }
    .alert-dark-error {
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.3);
        color: #fca5a5;
        border-radius: 8px;
        font-size: .85rem;
    }
    .remember-label { color: #94a3b8; font-size: .8rem; cursor: pointer; }
    .attempts-warning { color: #fbbf24; font-size: .78rem; }
    .login-wrapper {
        width: 100%;
        max-width: 560px;
    }
    .login-footer {
        margin-top: 18px;
        border: 1px solid #334155;
        border-radius: 12px;
        overflow: hidden;
        background: #1e293b;
    }
    .login-footer-main {
        padding: 12px 14px;
        border-bottom: 1px solid #334155;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }
    .login-footer-title {
        color: #e2e8f0;
        font-size: .78rem;
        font-weight: 600;
    }
    .login-footer-links {
        display: flex;
        gap: 10px;
    }
    .login-footer-links a {
        color: #93c5fd;
        text-decoration: none;
        font-size: .72rem;
    }
    .login-footer-copy {
        padding: 10px 12px;
        text-align: center;
        color: #64748b;
        font-size: .72rem;
    }
    .login-footer-copy a {
        color: #93c5fd;
        text-decoration: none;
        font-weight: 500;
    }
    .login-footer-copy a:hover {
        text-decoration: underline;
    }
    .login-footer-form {
        padding: 12px 14px 6px;
    }
    .login-footer-form .form-label {
        color: #94a3b8;
        font-size: .68rem;
        margin-bottom: 3px;
    }
    .login-footer-form .form-control {
        background: #0f172a;
        border-color: #334155;
        color: #f1f5f9;
        font-size: .72rem;
    }
    .login-footer-form .form-control::placeholder {
        color: #64748b;
    }
    @media (max-width: 768px) {
        .login-card { max-width: 100%; }
        .login-title { font-size: 1.45rem; }
        .login-subtitle { font-size: .9rem; }
        .card.login-card { padding: 18px !important; }
    }
    @media (max-width: 480px) {
        body { padding: 10px; }
        .login-wrapper { max-width: 100%; }
        .card.login-card { padding: 14px !important; }
        .login-title { font-size: 1.32rem; }
        .login-footer-main {
            flex-direction: column;
            align-items: flex-start;
        }
        .login-footer-links { gap: 8px; }
        .login-footer-form .row > [class*="col-"] {
            width: 100%;
        }
    }

    /* Minimal theme overrides */
    body {
        background: #0b1020;
    }
    .login-card,
    .login-footer {
        background: #111827;
        border-color: #1f2937;
        box-shadow: none !important;
    }
    .login-title {
        font-size: 1.55rem;
        letter-spacing: -0.3px;
    }
    .login-subtitle {
        color: #9ca3af;
    }
    .form-control,
    .input-group-text {
        background: #0f172a;
        border-color: #1f2937;
        border-radius: 8px;
    }
    .btn-grova {
        background: #2563eb;
        border-radius: 8px;
    }
    .btn-grova:hover {
        background: #1e40af;
    }
    .login-footer-form .form-control {
        border-radius: 8px;
    }
    body.light-mode {
        background: #f8fafc;
    }
    body.light-mode .login-card,
    body.light-mode .login-footer {
        background: #ffffff;
        border-color: #e5e7eb;
    }
    body.light-mode .login-title {
        color: #111827;
    }
    body.light-mode .login-subtitle {
        color: #6b7280;
    }
    body.light-mode .form-label {
        color: #475569;
    }
    body.light-mode .form-control,
    body.light-mode .input-group-text {
        background: #ffffff;
        border-color: #d1d5db;
        color: #111827;
    }
    body.light-mode .form-control::placeholder {
        color: #9ca3af;
    }
    body.light-mode .input-group-text {
        color: #64748b;
    }
    body.light-mode .remember-label {
        color: #64748b;
    }
    body.light-mode .login-footer-title {
        color: #1f2937;
    }
    body.light-mode .login-footer-main {
        border-bottom-color: #e5e7eb;
    }
    body.light-mode .login-footer-links a {
        color: #2563eb;
    }
    body.light-mode .login-footer-form .form-label {
        color: #64748b;
    }
    body.light-mode .login-footer-form .form-control {
        background: #ffffff;
        border-color: #d1d5db;
        color: #111827;
    }
    body.light-mode .login-footer-copy {
        color: #6b7280;
    }
    body.light-mode .login-footer-copy a {
        color: #2563eb;
    }
    body.light-mode #webauthn-section .login-webauthn-divider {
        color: #94a3b8;
    }
    body.light-mode #webauthn-section .login-webauthn-divider::before,
    body.light-mode #webauthn-section .login-webauthn-divider::after {
        background: #e5e7eb;
    }
    body.light-mode #btn-webauthn {
        background: #f8fafc;
        border-color: #d1d5db;
        color: #1e293b;
    }
    body.light-mode #btn-webauthn:hover {
        background: #f1f5f9;
    }
    #webauthn-section .login-webauthn-divider {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: .85rem;
        font-size: .78rem;
        color: #475569;
    }
    #webauthn-section .login-webauthn-divider::before,
    #webauthn-section .login-webauthn-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #1f2937;
    }
</style>
{% endblock %}

{% block body %}
{% include 'login/partials/_login_toolbar.html.twig' %}
<div class="login-wrapper">
    <div class="card login-card p-4 shadow-lg">
        <div class="card-body px-2">

        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="login-logo-box">G</div>
            <div>
                <div class="login-title">{{ 'app.name' | trans }}</div>
                <div class="login-subtitle">{{ 'auth.login.subtitle' | trans }}</div>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert {{ label == 'success' ? 'alert-success' : 'alert-dark-error' }} mb-3 px-3 py-2" style="{{ label == 'success' ? 'background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);color:#86efac;' : '' }}">
                    <i class="bi {{ label == 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle' }} me-2"></i>{{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Error de autenticación #}
        {% if error %}
            <div class="alert alert-dark-error mb-3 px-3 py-2">
                <i class="bi bi-exclamation-triangle me-2"></i>
                {{ error.messageKey | trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Bloqueo por rate limiting #}
        {% if retry_after %}
            <div class="alert alert-dark-error mb-3 px-3 py-2">
                <i class="bi bi-shield-lock me-2"></i>
                {{ 'auth.login.error.too_many_attempts' | trans }}
            </div>
        {% endif %}

        {# Advertencia de intentos restantes #}
        {% if attempts_left is defined and attempts_left <= 2 and attempts_left > 0 and not retry_after %}
            <div class="attempts-warning mb-3">
                <i class="bi bi-exclamation-circle me-1"></i>
                {{ 'auth.login.error.attempts_left' | trans({'%count%': attempts_left}) }}
            </div>
        {% endif %}

        {# ── Google OAuth ── #}
        <div style="margin-bottom:1rem;">
            <a href="{{ path('connect_google') }}"
               style="display:flex;align-items:center;justify-content:center;gap:.6rem;width:100%;padding:.7rem;background:#1e293b;border:1px solid #334155;color:#f1f5f9;border-radius:8px;font-size:.95rem;font-weight:600;text-decoration:none;transition:background .2s,border-color .2s;"
               onmouseover="this.style.background='#0f172a';this.style.borderColor='#475569'"
               onmouseout="this.style.background='#1e293b';this.style.borderColor='#334155'">
                <svg width="20" height="20" viewBox="0 0 48 48" style="flex-shrink:0;"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59A14.5 14.5 0 0 1 9.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 0 0 0 24c0 3.77.87 7.35 2.56 10.56l7.97-5.97z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.97C6.51 42.62 14.62 48 24 48z"/></svg>
                Continuar con Google
            </a>
        </div>

        {# ── Divisor ── #}
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;">
            <div style="flex:1;height:1px;background:#1f2937;"></div>
            <span style="color:#475569;font-size:.78rem;white-space:nowrap;">{{ 'auth.login.or' | trans | default('O inicia con email') }}</span>
            <div style="flex:1;height:1px;background:#1f2937;"></div>
        </div>

        <form method="post" action="{{ path('login_check', {'_locale': app.request.locale}) }}" id="login-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            {% if post_login_path is defined %}
            <input type="hidden" name="_target_path" value="{{ post_login_path }}">
            {% endif %}

            <div class="mb-3">
                <label for="username" class="form-label">{{ 'auth.login.username' | trans }}</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input type="text"
                           class="form-control"
                           id="username"
                           name="username"
                           value="{{ last_username ?: app.request.query.get('_username', '') }}"
                           placeholder="Email o nombre de workspace"
                           required
                           autofocus
                           autocomplete="username"
                           {% if retry_after %}disabled{% endif %}>
                </div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">{{ 'auth.login.password' | trans }}</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input type="password"
                           class="form-control"
                           id="password"
                           name="password"
                           placeholder="{{ 'auth.login.password_placeholder' | trans }}"
                           required
                           autocomplete="current-password"
                           {% if retry_after %}disabled{% endif %}>
                </div>
            </div>

            <div class="mb-4 d-flex align-items-center">
                <input class="form-check-input me-2" type="checkbox" name="_remember_me" id="remember_me">
                <label class="remember-label" for="remember_me">{{ 'auth.login.remember_me' | trans }}</label>
            </div>

            <button type="submit" class="btn btn-grova btn-primary w-100" id="btn-submit" {% if retry_after %}disabled{% endif %}>
                <span id="btn-text">{{ 'auth.login.submit' | trans }}</span>
                <span id="btn-spinner" class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
            </button>

            <div class="text-end mt-2">
                <a href="{{ path('recuperar_contrasena') }}"
                   style="color:#64748b;font-size:.8rem;text-decoration:none;">
                    ¿Olvidaste tu contraseña?
                </a>
            </div>
        </form>

        {# ── Crear cuenta ── #}
        <div class="text-center mt-3" style="font-size:.85rem;color:#64748b;">
            ¿No tienes cuenta?
            <a href="{{ path('registro') }}" style="color:#93c5fd;text-decoration:none;font-weight:500;">Pruébalo gratis 30 días</a>
        </div>

        {# ── Biométrico ── #}
        <div id="webauthn-section" style="display:none;margin-top:1.25rem;">
            <div class="login-webauthn-divider">
                <span style="white-space:nowrap;">{{ 'auth.login.webauthn_or'|trans }}</span>
            </div>
            <button type="button" id="btn-webauthn" style="width:100%;padding:.78rem;background:#1e293b;border:1px solid #334155;color:#f1f5f9;border-radius:8px;font-size:.95rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.6rem;transition:background .2s,border-color .2s;">
                <i class="bi bi-fingerprint" style="font-size:22px;color:#6366f1;"></i>
                <span id="webauthn-label">Entrar con huella / Face ID</span>
            </button>
        </div>

        </div>
    </div>
    <footer class="login-footer">
        <div class="login-footer-main">
            <span class="login-footer-title">{{ 'app.name' | trans }}</span>
            <div class="login-footer-links">
                <a href="#">{{ 'auth.login.footer.privacy' | trans }}</a>
                <a href="#">{{ 'auth.login.footer.support' | trans }}</a>
            </div>
        </div>
        <div class="login-footer-form">
            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label" for="login-footer-email">{{ 'auth.login.footer.email_demo' | trans }}</label>
                    <input id="login-footer-email" type="email" class="form-control form-control-sm" placeholder="{{ 'auth.login.footer.email_placeholder' | trans }}">
                </div>
                <div class="col-6">
                    <label class="form-label" for="login-footer-phone">{{ 'auth.login.footer.phone_demo' | trans }}</label>
                    <input id="login-footer-phone" type="text" class="form-control form-control-sm" placeholder="{{ 'auth.login.footer.phone_placeholder' | trans }}">
                </div>
            </div>
        </div>
        <div class="login-footer-copy">
            &copy; {{ "now"|date("Y") }} {{ 'app.name' | trans }}. {{ 'auth.login.footer.rights' | trans }} ·
            v{{ build_info.display_version|default(build_info.version) }} ·
            {% if is_granted('ROLE_DEVELOPER') and build_info.commit_url %}
                <a href="{{ build_info.commit_url }}" target="_blank" rel="noopener noreferrer">{{ build_info.git_sha }}</a>
            {% else %}
                {{ build_info.git_sha }}
            {% endif %}
        </div>
    </footer>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    function getCookie(name) {
        return document.cookie.split('; ').reduce(function (acc, c) {
            var p = c.split('=');
            return p[0] === name ? decodeURIComponent(p[1] || '') : acc;
        }, null);
    }
    window.setCookie = function (name, value, days) {
        var expires = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + expires + ';path=/;SameSite=Lax';
    };
    window.toggleLangCombo = function (id, e) {
        if (e) e.stopPropagation();
        var combo = document.getElementById('lang-combo-' + id);
        if (!combo) return;
        var isOpen = combo.classList.contains('open');
        document.querySelectorAll('.lang-combo.open').forEach(function (el) { el.classList.remove('open'); });
        if (!isOpen) combo.classList.add('open');
    };

    var cookieTheme = getCookie('grova_theme');
    var darkMode = cookieTheme
        ? cookieTheme !== 'light'
        : !document.body.classList.contains('light-mode');

    function applyTheme() {
        var sun = document.getElementById('login-icon-sun');
        var moon = document.getElementById('login-icon-moon');
        if (darkMode) {
            document.body.classList.remove('light-mode');
            document.body.setAttribute('data-bs-theme', 'dark');
            if (sun) sun.style.display = 'block';
            if (moon) moon.style.display = 'none';
        } else {
            document.body.classList.add('light-mode');
            document.body.setAttribute('data-bs-theme', 'light');
            if (sun) sun.style.display = 'none';
            if (moon) moon.style.display = 'block';
        }
    }

    applyTheme();

    var themeBtn = document.getElementById('login-theme-toggle');
    if (themeBtn) {
        themeBtn.addEventListener('click', function () {
            darkMode = !darkMode;
            setCookie('grova_theme', darkMode ? 'dark' : 'light', 365);
            applyTheme();
        });
    }

    document.addEventListener('click', function () {
        document.querySelectorAll('.lang-combo.open').forEach(function (el) { el.classList.remove('open'); });
    });
})();

document.getElementById('login-form').addEventListener('submit', function() {
    const btn    = document.getElementById('btn-submit');
    const text   = document.getElementById('btn-text');
    const spinner = document.getElementById('btn-spinner');
    btn.disabled = true;
    text.textContent = {{ 'auth.login.submitting' | trans | json_encode | raw }};
    spinner.classList.remove('d-none');
});

// ── WebAuthn login ──────────────────────────────────────────────────────────
const locale = '{{ app.request.locale }}';

function b64url(buf) {
    return btoa(String.fromCharCode(...new Uint8Array(buf)))
        .replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');
}
function fromB64(s) {
    s = s.replace(/-/g,'+').replace(/_/g,'/');
    while (s.length % 4) s += '=';
    return Uint8Array.from(atob(s), c => c.charCodeAt(0));
}

// Mostrar botón solo si el navegador soporta WebAuthn
if (window.PublicKeyCredential) {
    PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable().then(available => {
        if (available) {
            document.getElementById('webauthn-section').style.display = 'block';
        }
    }).catch(() => {});
}

async function loginWithBiometric() {
    const btn   = document.getElementById('btn-webauthn');
    const label = document.getElementById('webauthn-label');
    btn.disabled = true;
    label.textContent = 'Verificando…';

    try {
        const res  = await fetch(`/${locale}/lock/login-webauthn/challenge`);
        const args = await res.json();
        if (args.error) throw new Error(args.error);

        args.publicKey.challenge = fromB64(args.publicKey.challenge);
        if (args.publicKey.allowCredentials) {
            args.publicKey.allowCredentials = args.publicKey.allowCredentials.map(c => ({
                ...c, id: fromB64(c.id)
            }));
        }

        const credential = await navigator.credentials.get({ publicKey: args.publicKey });

        const payload = {
            id:                b64url(credential.rawId),
            clientDataJSON:    b64url(credential.response.clientDataJSON),
            authenticatorData: b64url(credential.response.authenticatorData),
            signature:         b64url(credential.response.signature),
        };

        const verRes  = await fetch(`/${locale}/lock/login-webauthn/verify`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        const verData = await verRes.json();

        if (verData.ok) {
            label.textContent = '¡Acceso concedido!';
            btn.style.borderColor = '#16a34a';
            btn.style.color = '#4ade80';
            setTimeout(() => { window.location.href = verData.redirect; }, 300);
        } else {
            throw new Error(verData.error || 'Verificación fallida');
        }
    } catch (e) {
        btn.style.borderColor = '#dc2626';
        btn.style.color = '#fca5a5';
        label.textContent = e.name === 'NotAllowedError' ? 'Cancelado' : 'Error — intenta con contraseña';
        btn.disabled = false;
        setTimeout(() => {
            btn.style.borderColor = '#334155';
            btn.style.color = '#f1f5f9';
            label.textContent = 'Reintentar huella / Face ID';
        }, 3000);
    }
}

document.getElementById('btn-webauthn')?.addEventListener('click', loginWithBiometric);

</script>
{% endblock %}
