{% extends 'workspace/app_layout.html.twig' %}

{% block page_title %}{{ 'admin.errores.titulo'|trans }} #{{ error.id }}{% endblock %}

{% block page_styles %}
<style>
    .detail-section { margin-bottom: 20px; }
    .detail-label { font-size: 11px; text-transform: uppercase; color: #64748b; font-weight: 600; letter-spacing: .5px; margin-bottom: 4px; }
    .detail-value { background: #1e293b; border: 1px solid #334155; border-radius: 6px; padding: 10px 14px; font-family: "SFMono-Regular", Consolas, monospace; font-size: 13px; white-space: pre-wrap; word-break: break-all; color: #e2e8f0; }
    .detail-value.trace { font-size: 11px; max-height: 500px; overflow-y: auto; }
    .detail-value.json { font-size: 11px; max-height: 300px; overflow-y: auto; }
    .detail-meta { color: #94a3b8; font-size: 12px; }
    .back-link { color: #94a3b8; text-decoration: none; font-size: 13px; }
    .back-link:hover { color: #e2e8f0; }
</style>
{% endblock %}

{% block app_main %}
{{ parent() }}
<div class="mb-3">
    <a href="{{ path('grova_admin_errores_index') }}" class="back-link">
        <i class="bi bi-arrow-left me-1"></i>{{ 'admin.errores.volver'|trans }}
    </a>
</div>

<div class="admin-content-card">
    <div class="admin-content-header d-flex align-items-center justify-content-between">
        <div>
            <i class="bi bi-bug me-2"></i>{{ 'admin.errores.titulo'|trans }} #{{ error.id }}
            <span class="ms-2" style="font-size:12px; color:#64748b;">{{ error.createdAt|date('Y-m-d H:i:s T') }}</span>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="text-secondary" style="font-size:12px;">{{ 'admin.errores.col.estado'|trans }}:</span>
            <form method="post" action="{{ path('grova_admin_errores_cambiar_estado', {id: error.id}) }}" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="_token" value="{{ csrf_token('error_estado_' ~ error.id) }}">
                <select name="estado" class="form-select form-select-sm" style="background:#0f172a; border-color:#334155; color:#e2e8f0; width:auto;">
                    <option value="new" {{ error.status == 'new' ? 'selected' : '' }}>{{ 'admin.errores.estado.nuevo'|trans }}</option>
                    <option value="in_progress" {{ error.status == 'in_progress' ? 'selected' : '' }}>{{ 'admin.errores.estado.en_progreso'|trans }}</option>
                    <option value="resolved" {{ error.status == 'resolved' ? 'selected' : '' }}>{{ 'admin.errores.estado.resuelto'|trans }}</option>
                    <option value="ignored" {{ error.status == 'ignored' ? 'selected' : '' }}>{{ 'admin.errores.estado.ignorado'|trans }}</option>
                </select>
                <button type="submit" class="btn btn-sm btn-admin-outline">{{ 'admin.errores.actualizar_estado'|trans }}</button>
            </form>
        </div>
    </div>
    <div class="admin-content-body">

        {# ── Nivel y mensaje ── #}
        <div class="detail-section">
            <div class="detail-label">{{ 'admin.errores.col.nivel'|trans }}</div>
            <div class="detail-value" style="padding:6px 14px;">
                <strong>{{ error.levelLabel }}</strong>
                <span style="color:#64748b; margin-left:8px;">{{ error.channel }}</span>
            </div>
        </div>

        <div class="detail-section">
            <div class="detail-label">{{ 'admin.errores.col.mensaje'|trans }}</div>
            <div class="detail-value">{{ error.message }}</div>
        </div>

        {# ── Excepción ── #}
        {% if error.exceptionClass %}
        <div class="detail-section">
            <div class="detail-label">{{ 'admin.errores.tipo_excepcion'|trans }}</div>
            <div class="detail-value">{{ error.exceptionClass }}</div>
        </div>
        {% endif %}

        {% if error.file %}
        <div class="detail-section">
            <div class="detail-label">{{ 'admin.errores.archivo'|trans }}</div>
            <div class="detail-value" style="color:#64748b; font-size:12px;">
                {{ error.file }}{{ error.line is not null ? ':' ~ error.line : '' }}
            </div>
        </div>
        {% endif %}

        {# ── Trace ── #}
        {% if error.trace %}
        <div class="detail-section">
            <div class="detail-label">Trace</div>
            <div class="detail-value trace">{{ error.trace }}</div>
        </div>
        {% endif %}

        {# ── Contexto ── #}
        {% if error.context %}
        <div class="detail-section">
            <div class="detail-label">Context</div>
            <div class="detail-value json">{{ error.context|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</div>
        </div>
        {% endif %}

        {# ── Extra ── #}
        {% if error.extra %}
        <div class="detail-section">
            <div class="detail-label">Extra</div>
            <div class="detail-value json">{{ error.extra|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_SLASHES')) }}</div>
        </div>
        {% endif %}

        {# ── Metadata ── #}
        <div class="detail-section">
            <div class="detail-label">{{ 'admin.errores.metadata'|trans }}</div>
            <div class="detail-value" style="font-size:12px; color:#94a3b8;">
                <div><strong>ID:</strong> {{ error.id }}</div>
                {% if error.tenantId %}<div><strong>Tenant ID:</strong> {{ error.tenantId }}</div>{% endif %}
                {% if error.userId %}<div><strong>User ID:</strong> {{ error.userId }}</div>{% endif %}
                {% if error.url %}<div><strong>URL:</strong> {{ error.url }}</div>{% endif %}
                <div><strong>Created:</strong> {{ error.createdAt|date('Y-m-d H:i:s T') }}</div>
                {% if error.updatedAt %}<div><strong>Updated:</strong> {{ error.updatedAt|date('Y-m-d H:i:s T') }}</div>{% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
