{% extends 'admin/layout.html.twig' %}

{% block title %}Licencias – {{ inquilino.nombre }} – {{ 'app.name'|trans }}{% endblock %}

{% block admin_styles %}
<style>
    .licencia-clave {
        font-family: monospace;
        font-size: 11px;
        color: #94a3b8;
        word-break: break-all;
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 6px;
        padding: 8px 10px;
        margin-top: 4px;
        max-height: 60px;
        overflow: hidden;
        position: relative;
    }
    .btn-copy {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 5px;
        border: 1px solid #334155;
        background: #1e293b;
        color: #94a3b8;
        cursor: pointer;
    }
    .btn-copy:hover { background: #0f172a; color: #f1f5f9; }
    .badge-activa  { background: rgba(34,197,94,.15); border: 1px solid rgba(34,197,94,.3); color: #86efac; font-size:11px; padding: 2px 8px; border-radius:20px; }
    .badge-revocada { background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.3); color: #fca5a5; font-size:11px; padding: 2px 8px; border-radius:20px; }
    .badge-vencida-l { background: rgba(234,179,8,.15); border: 1px solid rgba(234,179,8,.3); color: #fde047; font-size:11px; padding: 2px 8px; border-radius:20px; }
    .form-licencia input[type=number],
    .form-licencia input[type=text],
    .form-licencia textarea {
        background: #0f172a;
        border: 1px solid #334155;
        color: #e2e8f0;
        border-radius: 6px;
        font-size: 13px;
    }
    .form-licencia input:focus,
    .form-licencia textarea:focus {
        background: #0f172a;
        border-color: #2563eb;
        color: #f1f5f9;
        box-shadow: none;
    }
    .modulo-check label { color: #94a3b8; font-size: 13px; cursor: pointer; }
    .modulo-check input { accent-color: #2563eb; }
</style>
{% endblock %}

{% block admin_main %}
{# Breadcrumb #}
<div class="d-flex align-items-center gap-2 mb-3" style="font-size:13px; color:#64748b;">
    <a href="{{ path('grova_admin_empresas') }}" style="color:#64748b; text-decoration:none;">
        <i class="bi bi-building me-1"></i>Empresas
    </a>
    <i class="bi bi-chevron-right" style="font-size:10px;"></i>
    <span style="color:#cbd5e1;">{{ inquilino.nombre }}</span>
    <i class="bi bi-chevron-right" style="font-size:10px;"></i>
    <span>Licencias</span>
</div>

{# Flashes #}
{% for etiqueta, mensajes in app.flashes %}
    {% for mensaje in mensajes %}
        <div class="alert mb-3 px-3 py-2 {{ etiqueta == 'success' ? 'admin-flash-success' : 'admin-flash-error' }}">
            <i class="bi {{ etiqueta == 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle' }} me-2"></i>{{ mensaje }}
        </div>
    {% endfor %}
{% endfor %}

<div class="row g-3">
    {# ── Generar nueva licencia ─────────────────────────────────────────── #}
    <div class="col-lg-4">
        <div class="admin-content-card">
            <div class="admin-content-header">
                <i class="bi bi-key me-2"></i>Nueva licencia
            </div>
            <div class="admin-content-body form-licencia">
                <form method="post" action="{{ path('grova_admin_licencias_generar', {id: inquilino.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('generar_licencia_' ~ inquilino.id) }}">

                    <div class="mb-3">
                        <label class="form-label" style="color:#94a3b8; font-size:12px;">Duración (días)</label>
                        <input type="number" name="duracion_dias" class="form-control form-control-sm"
                               value="365" min="1" max="3650">
                        <div style="font-size:11px; color:#475569; margin-top:4px;">365 = 1 año · 730 = 2 años</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color:#94a3b8; font-size:12px;">Módulos incluidos</label>
                        <div class="d-flex flex-column gap-1 modulo-check">
                            {% set modulosDisponibles = ['construccion','legal','pos','restaurante','clinica','financiera','facturacion','inventario','rrhh','agenda','wallet','work','pesca','habitos'] %}
                            {% for modulo in modulosDisponibles %}
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="modulos[]"
                                           id="mod_{{ modulo }}" value="{{ modulo }}">
                                    <label class="form-check-label" for="mod_{{ modulo }}">{{ modulo }}</label>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="color:#94a3b8; font-size:12px;">Notas internas (opcional)</label>
                        <textarea name="notas" class="form-control form-control-sm" rows="2"
                                  placeholder="ej. Renovación anual 2026"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-shield-lock me-1"></i>Generar licencia
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Licencias existentes ────────────────────────────────────────────── #}
    <div class="col-lg-8">
        <div class="admin-content-card">
            <div class="admin-content-header">
                <i class="bi bi-list-ul me-2"></i>Licencias de {{ inquilino.nombre }}
                <span class="text-secondary fw-normal ms-2" style="font-size:.8rem;">({{ licencias|length }})</span>
            </div>
            <div class="admin-content-body">
                {% if licencias is empty %}
                    <p class="text-secondary mb-0" style="font-size:13px;">Aún no hay licencias generadas para esta empresa.</p>
                {% else %}
                    <div class="d-flex flex-column gap-3">
                        {% for licencia in licencias %}
                        <div style="border:1px solid #1f2937; border-radius:8px; padding:12px 14px;">
                            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                <div>
                                    {% if licencia.isActiva and licencia.estaVigente %}
                                        <span class="badge-activa">Activa</span>
                                    {% elseif licencia.isActiva and not licencia.estaVigente %}
                                        <span class="badge-vencida-l">Vencida</span>
                                    {% else %}
                                        <span class="badge-revocada">Revocada</span>
                                    {% endif %}

                                    <span style="font-size:11px; color:#64748b; margin-left:8px;">
                                        Emitida {{ licencia.fechaEmision|date('d/m/Y H:i') }}
                                        · Vence {{ licencia.fechaVencimiento|date('d/m/Y') }}
                                        · {{ licencia.duracionDias }} días
                                    </span>
                                </div>

                                {% if licencia.isActiva %}
                                <form method="post"
                                      action="{{ path('grova_admin_licencias_revocar', {id: inquilino.id, licenciaId: licencia.id}) }}"
                                      data-swal-confirm="¿Revocar esta licencia? El cliente perderá acceso.">
                                    <input type="hidden" name="_token" value="{{ csrf_token('revocar_licencia_' ~ licencia.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            style="font-size:11px; padding:2px 8px;">
                                        <i class="bi bi-shield-x me-1"></i>Revocar
                                    </button>
                                </form>
                                {% endif %}
                            </div>

                            {% if licencia.modulos is not empty %}
                            <div class="mb-2">
                                {% for modulo in licencia.modulos %}
                                    <span class="badge text-bg-secondary me-1" style="font-size:10px;">{{ modulo }}</span>
                                {% endfor %}
                            </div>
                            {% endif %}

                            {% if licencia.notas %}
                            <div style="font-size:11px; color:#64748b; margin-bottom:6px;">
                                <i class="bi bi-chat-left-text me-1"></i>{{ licencia.notas }}
                            </div>
                            {% endif %}

                            <div class="d-flex align-items-center gap-2">
                                <div class="licencia-clave flex-grow-1" id="clave_{{ licencia.id }}">{{ licencia.clave }}</div>
                                <button class="btn-copy"
                                        onclick="navigator.clipboard.writeText(document.getElementById('clave_{{ licencia.id }}').innerText).then(() => this.textContent = '✓ Copiado').catch(() => {}); setTimeout(() => this.textContent = 'Copiar', 2000)">
                                    Copiar
                                </button>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
