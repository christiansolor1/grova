# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
#
# Generar APP_SECRET:   openssl rand -hex 32
# Generar JWT_PASSPHRASE: openssl rand -hex 32
# Generar MERCURE_JWT_SECRET: openssl rand -hex 32

###> symfony/framework-bundle ###
APP_ENV=dev                        # prod en servidor
APP_DEBUG=1                        # 0 en prod
APP_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
APP_SHARE_DIR=var/share
APP_VERSION=0.1.0
APP_GIT_SHA=local
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost        # https://tudominio.com en prod
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://usuario:password@127.0.0.1:3306/grova_core?serverVersion=mariadb-10.11.16&charset=utf8mb4"
DATABASE_CORE_URL="mysql://usuario:password@127.0.0.1:3306/grova_core?serverVersion=mariadb-10.11.16&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=REPLACE_WITH_OPENSSL_RAND_HEX_32
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# Dev: permitir localhost. Prod: solo tu dominio.
# Prod example: '^https://tudominio\.com$'
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# APIs externas
STORMGLASS_API_KEY=REPLACE_WITH_REAL_KEY

###> symfony/mailer ###
MAILER_DSN=null://null             # smtp://user:pass@host:587 en prod
###< symfony/mailer ###
MAILER_FROM_EMAIL=noreply@tudominio.com

###> symfony/mercure-bundle ###
MERCURE_URL=https://tudominio.com/.well-known/mercure
MERCURE_PUBLIC_URL=https://tudominio.com/.well-known/mercure
MERCURE_JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
###< symfony/mercure-bundle ###
